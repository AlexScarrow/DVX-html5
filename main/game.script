-- =============================================================================
-- UPDATE FUNCTION
-- =============================================================================

function update(self, dt)
    if self.mp_transport and self.mp_transport.update then
        self.mp_transport.update(dt)
    end
    if self.sfx_state and self.sfx_state.boot_deferred ~= true then
        self.sfx_state.boot_deferred = true
        refresh_ambient_sfx_state(self)
    end
    if self.realtime_client_settle_timer and self.realtime_client_settle_timer > 0 then
        self.realtime_client_settle_timer = math.max(0, self.realtime_client_settle_timer - dt)
    end
    if self.mp_state and self.mp_state.enabled and self.mp_state.local_player_id == self.mp_state.host_player_id then
        if realtime_mp_host_can_simulate(self) then
            local snapshot_interval_s = math.max(0.05, tonumber(REALTIME_MP_SNAPSHOT_INTERVAL_S or 0.2) or 0.2)
            self.mp_state.realtime_snapshot_accum_s = (tonumber(self.mp_state.realtime_snapshot_accum_s or 0) or 0) + dt
            while self.mp_state.realtime_snapshot_accum_s >= snapshot_interval_s do
                self.mp_state.realtime_snapshot_accum_s = self.mp_state.realtime_snapshot_accum_s - snapshot_interval_s
                local snapshot = multiplayer_build_snapshot_state(self)
                self.mp_state.realtime_snapshot_seq = (tonumber(self.mp_state.realtime_snapshot_seq or 0) or 0) + 1
                multiplayer_transport_broadcast_event(self, "realtime_state_snapshot", {
                    seq = self.mp_state.realtime_snapshot_seq,
                    turn_id = self.mp_state.turn_id or 1,
                    snapshot = snapshot
                })
            end
        else
            self.mp_state.realtime_snapshot_accum_s = 0
            self.mp_state.realtime_snapshot_heartbeat_accum_s = 0
        end
        if self.realtime_rules_enabled ~= true then
            local turn_snapshot_interval_s = math.max(0.5, tonumber(TURN_BASED_MP_SNAPSHOT_INTERVAL_S or 2.5) or 2.5)
            self.mp_state.turn_based_snapshot_accum_s = (tonumber(self.mp_state.turn_based_snapshot_accum_s or 0) or 0) + dt
            if self.mp_state.turn_based_snapshot_accum_s >= turn_snapshot_interval_s then
                self.mp_state.turn_based_snapshot_accum_s = 0
                multiplayer_transport_broadcast_event(self, "turn_state_heartbeat", {
                    turn_id = self.mp_state.turn_id or 1,
                    checksum = multiplayer_compute_turn_checksum(self)
                })
            end
        else
            self.mp_state.turn_based_snapshot_accum_s = 0
            self.mp_state.turn_based_heartbeat_mismatch_streak = 0
            self.mp_state.turn_based_heartbeat_last_request_turn_id = 0
        end
        if LOOT_RUNTIME and LOOT_RUNTIME.build_workshop_sync_state then
            local sync_interval_s = 0.2
            self.mp_state.workshop_state_sync_accum_s = (tonumber(self.mp_state.workshop_state_sync_accum_s or 0) or 0) + dt
            if self.mp_state.workshop_state_sync_accum_s >= sync_interval_s then
                self.mp_state.workshop_state_sync_accum_s = 0
                local workshop_state = LOOT_RUNTIME.build_workshop_sync_state(self)
                local signature = workshop_state_signature(workshop_state)
                if signature ~= tostring(self.mp_state.workshop_state_sync_signature or "") then
                    self.mp_state.workshop_state_sync_signature = signature
                    multiplayer_transport_broadcast_event(self, "workshop_state_changed", {
                        workshop_state = workshop_state,
                        turn_id = self.mp_state.turn_id or 1
                    })
                end
            end
        end
        if LOOT_RUNTIME and LOOT_RUNTIME.build_factory_sync_state then
            local sync_interval_s = 0.2
            self.mp_state.factory_state_sync_accum_s = (tonumber(self.mp_state.factory_state_sync_accum_s or 0) or 0) + dt
            if self.mp_state.factory_state_sync_accum_s >= sync_interval_s then
                self.mp_state.factory_state_sync_accum_s = 0
                local factory_state = LOOT_RUNTIME.build_factory_sync_state(self)
                local signature = factory_state_signature(factory_state)
                if signature ~= tostring(self.mp_state.factory_state_sync_signature or "") then
                    self.mp_state.factory_state_sync_signature = signature
                    multiplayer_transport_broadcast_event(self, "factory_state_changed", {
                        factory_state = factory_state,
                        turn_id = self.mp_state.turn_id or 1
                    })
                end
            end
        end
    end
    if self.mp_state and self.mp_state.enabled and self.mp_state.local_player_id == self.mp_state.host_player_id then
        local pending_turn_state_turn_id = tonumber(self.mp_state.pending_turn_state_snapshot_turn_id or 0) or 0
        if pending_turn_state_turn_id > 0 then
            local alien_cycle_active = self.alien_turn_active
                or self.pending_spitter_attack_phase
                or self.pending_melee_attack_phase
                or any_alien_is_moving(self)
            if (not alien_cycle_active) and (tonumber(self.mp_state.turn_id or 0) or 0) >= pending_turn_state_turn_id then
                local last_sent_turn = tonumber(self.mp_state.last_turn_state_snapshot_broadcast_turn_id or 0) or 0
                if pending_turn_state_turn_id > last_sent_turn then
                    multiplayer_transport_broadcast_event(self, "turn_state_snapshot", {
                        turn_id = pending_turn_state_turn_id,
                        snapshot = multiplayer_build_snapshot_state(self)
                    })
                    self.mp_state.last_turn_state_snapshot_broadcast_turn_id = pending_turn_state_turn_id
                    print(string.format("MP TURNSTATE | host_broadcast | turn_id=%d", pending_turn_state_turn_id))
                end
                self.mp_state.pending_turn_state_snapshot_turn_id = 0
            end
        end
    end
    if self.mp_state and self.mp_state.enabled and self.mp_state.local_player_id ~= self.mp_state.host_player_id then
        local wait_timeout = tonumber(self.mp_state.awaiting_snapshot_timeout_s or 0) or 0
        if self.mp_state.awaiting_snapshot and self.mp_state.snapshot_blocking == true and wait_timeout > 0 then
            wait_timeout = math.max(0, wait_timeout - dt)
            self.mp_state.awaiting_snapshot_timeout_s = wait_timeout
            if wait_timeout <= 0 then
                -- Avoid permanent input freeze if a snapshot is delayed/lost.
                self.mp_state.awaiting_snapshot = false
                self.mp_state.snapshot_blocking = false
                print("MP SNAPSHOT | timeout_unblocked")
            end
        end
        local delay = tonumber(self.mp_state.post_turn_snapshot_delay_s or 0) or 0
        if delay > 0 then
            delay = math.max(0, delay - dt)
            self.mp_state.post_turn_snapshot_delay_s = delay
            if delay <= 0 and not self.mp_state.awaiting_snapshot then
                self.mp_state.awaiting_snapshot = true
                self.mp_state.snapshot_blocking = false
                multiplayer_transport_send_command(self, "request_snapshot", {
                    turn_id = self.mp_state.turn_id or 1
                }, self.mp_state.local_player_id)
                print("MP SNAPSHOT | requested_post_turn_settle")
            end
        end
    end
    if self.zoom_block_timer and self.zoom_block_timer > 0 then
        self.zoom_block_timer = math.max(0, self.zoom_block_timer - dt)
    end
    if not IS_HTML5 then
        enforce_fixed_window_size(self, dt, false)
    end
    update_smooth_zoom(self, dt)
    local nightvision_reveal_enabled, nightvision_tile_instance_id = get_nightvision_reveal_context(self, dt)
    if self.world_grid and self.tile_light_layers then
        self.tile_light_display_power_state = self.tile_light_display_power_state or {}
        for tile_instance_id, light_go in pairs(self.tile_light_layers) do
            local light_anim_cfg = self.tile_light_anim_ids and self.tile_light_anim_ids[tile_instance_id] or nil
            if light_anim_cfg and light_anim_cfg.on and light_anim_cfg.off then
                local light_anim_on = light_anim_cfg.on
                local light_anim_off = light_anim_cfg.off
                local tile_powered = false
                for _, cell in ipairs(self.world_grid) do
                    if cell.tileInstanceId == tile_instance_id and cell.isPowered then
                        tile_powered = true
                        break
                    end
                end

                local nightvision_reveal_for_tile = nightvision_reveal_enabled
                    and tonumber(tile_instance_id or 0) == tonumber(nightvision_tile_instance_id or 0)
                local display_powered = tile_powered or nightvision_reveal_for_tile

                local was_display_powered = self.tile_light_display_power_state[tile_instance_id]
                if was_display_powered == nil or was_display_powered ~= display_powered then
                    if display_powered then
                        if self.tile_light_is_workshop and self.tile_light_is_workshop[tile_instance_id] then
                            -- Workshop keeps its own smooth emissive profile without startup stutter.
                            self.tile_light_flicker_state[tile_instance_id] = nil
                            msg.post(msg.url(nil, light_go, "sprite"), "play_animation", { id = light_anim_on })
                        elseif self.tile_light_is_lab and self.tile_light_is_lab[tile_instance_id] then
                            -- Lab stays stable at full emissive; no startup flicker.
                            self.tile_light_flicker_state[tile_instance_id] = nil
                            msg.post(msg.url(nil, light_go, "sprite"), "play_animation", { id = light_anim_on })
                        elseif nightvision_reveal_for_tile and not tile_powered then
                            -- Nightvision reveal should show ON art instantly, not OFF flicker.
                            self.tile_light_flicker_state[tile_instance_id] = nil
                            msg.post(msg.url(nil, light_go, "sprite"), "play_animation", { id = light_anim_on })
                            -- Prevent one-frame pop: swap ON art at zero tint, then let NV tint fade drive visibility.
                            go.set(msg.url(nil, light_go, "sprite"), "tint", vmath.vector4(0, 0, 0, 0))
                        else
                            -- Fluorescent-style startup flicker: OFF/ON pulses before stabilizing ON.
                            self.tile_light_flicker_state[tile_instance_id] = {
                                active = true,
                                timer = 0.06,
                                step = 1
                            }
                            msg.post(msg.url(nil, light_go, "sprite"), "play_animation", { id = light_anim_off })
                        end
                    else
                        self.tile_light_flicker_state[tile_instance_id] = nil
                        msg.post(msg.url(nil, light_go, "sprite"), "play_animation", { id = light_anim_off })
                    end
                    self.tile_light_display_power_state[tile_instance_id] = display_powered
                end
                self.tile_light_power_state[tile_instance_id] = tile_powered

                local flicker = self.tile_light_flicker_state[tile_instance_id]
                if flicker and flicker.active then
                    flicker.timer = flicker.timer - dt
                    if flicker.timer <= 0 then
                        if flicker.step == 1 then
                            msg.post(msg.url(nil, light_go, "sprite"), "play_animation", { id = light_anim_on })
                            flicker.timer = 0.05
                        elseif flicker.step == 2 then
                            msg.post(msg.url(nil, light_go, "sprite"), "play_animation", { id = light_anim_off })
                            flicker.timer = 0.06
                        elseif flicker.step == 3 then
                            msg.post(msg.url(nil, light_go, "sprite"), "play_animation", { id = light_anim_on })
                            flicker.timer = 0.05
                        elseif flicker.step == 4 then
                            msg.post(msg.url(nil, light_go, "sprite"), "play_animation", { id = light_anim_off })
                            flicker.timer = 0.04
                        else
                            msg.post(msg.url(nil, light_go, "sprite"), "play_animation", { id = light_anim_on })
                            flicker.active = false
                            flicker.timer = 0
                        end
                        flicker.step = flicker.step + 1
                    end
                end
            end
        end
    end

    if self.world_grid and self.tile_alpha_layers then
        for tile_instance_id, alpha_go in pairs(self.tile_alpha_layers) do
            local tile_powered = false
            local always_visible = false
            local selected_level = self.level_library and self.level_library[self.current_level_index or 1] or nil
            local placement = selected_level and selected_level[tile_instance_id] or nil
            local tile_def = placement and self.tile_library and self.tile_library[placement.tile] or nil
            if tile_def and tile_def.alphaOverlayAlwaysVisible == true then
                always_visible = true
            else
                for _, cell in ipairs(self.world_grid) do
                    if cell.tileInstanceId == tile_instance_id and cell.isPowered then
                        tile_powered = true
                        break
                    end
                end
            end
            local was_powered = self.tile_alpha_power_state[tile_instance_id]
            local now_on = always_visible or tile_powered
            if was_powered == nil or was_powered ~= now_on then
                if now_on then
                    go.set(msg.url(nil, alpha_go, "sprite"), "tint", vmath.vector4(1, 1, 1, 1))
                else
                    go.set(msg.url(nil, alpha_go, "sprite"), "tint", vmath.vector4(1, 1, 1, 0))
                end
                self.tile_alpha_power_state[tile_instance_id] = now_on
            end
        end
    end
    apply_computer_emissive_accents(self, dt)

    update_human_movement(self, dt)
    update_civilian_movement(self, dt)
    refresh_civilian_visuals(self)
    update_alien_movement(self, dt)
    local obstacle_shudder_active = false
    local door_shudder_active = false
    if self.world_grid then
        for _, cell in ipairs(self.world_grid) do
            if cell and (cell.obstacleShudderTimer or 0) > 0 then
                cell.obstacleShudderTimer = math.max(0, (cell.obstacleShudderTimer or 0) - dt)
                cell.obstacleShudderPhase = (cell.obstacleShudderPhase or 0) + (dt * 48)
                if cell.obstacleShudderTimer > 0 then
                    obstacle_shudder_active = true
                else
                    cell.obstacleShudderTimer = nil
                    cell.obstacleShudderPhase = nil
                end
            end
            if cell then
                if cell.obstacleNudgeEventClock ~= nil then
                    cell.obstacleNudgeEventClock = (cell.obstacleNudgeEventClock or 0) + dt
                end
                local current_by_index = cell.obstacleNudgeCurrentByIndex
                local target_by_index = cell.obstacleNudgeTargetByIndex
                local lag_by_index = cell.obstacleNudgeLagByIndex
                if current_by_index and target_by_index then
                    local has_active_nudge = false
                    local clock = cell.obstacleNudgeEventClock or 0
                    local blend = math.min(1, dt * 6.8)
                    local decay = math.max(0, 1 - (dt * 0.175))
                    local max_idx = #current_by_index
                    if #target_by_index > max_idx then
                        max_idx = #target_by_index
                    end
                    for i = 1, max_idx do
                        local current_x = current_by_index[i] or 0
                        local target_x = target_by_index[i] or 0
                        local lag_s = (lag_by_index and lag_by_index[i]) or 0
                        if clock >= lag_s then
                            current_x = current_x + ((target_x - current_x) * blend)
                            target_x = target_x * decay
                        end
                        if math.abs(current_x) < 0.02 then
                            current_x = 0
                        end
                        if math.abs(target_x) < 0.02 then
                            target_x = 0
                        end
                        current_by_index[i] = current_x
                        target_by_index[i] = target_x
                        if math.abs(current_x) > 0.01 or math.abs(target_x) > 0.01 then
                            has_active_nudge = true
                        end
                    end
                    if has_active_nudge then
                        obstacle_shudder_active = true
                    else
                        cell.obstacleNudgeEventClock = nil
                    end
                end
            end
            if cell and (cell.barricade_scale_pulse_timer or 0) > 0 then
                cell.barricade_scale_pulse_timer = math.max(0, (cell.barricade_scale_pulse_timer or 0) - dt)
                if cell.barricade_scale_pulse_timer > 0 then
                    obstacle_shudder_active = true
                    cell.barricade_scale_pulse = 0.1 * (cell.barricade_scale_pulse_timer / 0.22)
                else
                    cell.barricade_scale_pulse_timer = nil
                    cell.barricade_scale_pulse = nil
                end
            end
            if cell then
                local door_objs = { cell.object1, cell.object2, cell.object3 }
                for _, obj in ipairs(door_objs) do
                    if obj and obj.name == hash("door") and (obj.door_shudder_timer or 0) > 0 then
                        obj.door_shudder_timer = math.max(0, (obj.door_shudder_timer or 0) - dt)
                        obj.door_shudder_phase = (obj.door_shudder_phase or 0) + (dt * 48)
                        if obj.door_shudder_timer > 0 then
                            door_shudder_active = true
                        else
                            obj.door_shudder_timer = nil
                            obj.door_shudder_phase = nil
                        end
                    end
                end
            end
        end
    end
    if obstacle_shudder_active or door_shudder_active then
        self.obstacle_shudder_refresh_timer = (self.obstacle_shudder_refresh_timer or 0) - dt
        if self.obstacle_shudder_refresh_timer <= 0 then
            self.obstacle_shudder_refresh_timer = 0.016
            if LOOT_RUNTIME and LOOT_RUNTIME.refresh_fix_markers then
                LOOT_RUNTIME.refresh_fix_markers(self)
            end
            if LOOT_RUNTIME and LOOT_RUNTIME.refresh_door_markers then
                LOOT_RUNTIME.refresh_door_markers(self)
            end
        end
    else
        self.obstacle_shudder_refresh_timer = 0
    end
    if LOOT_RUNTIME.update_exit_boarding then
        LOOT_RUNTIME.update_exit_boarding(self)
    end
    if self.aliens then
        local world_shadow_alpha = get_world_shadow_alpha(self)
        local profile = get_aesthetic_profile(self)
        local counter_move_enabled = profile and profile.counter_token_move_enabled == true
        local shadow_origin = vmath.vector3(30, -30, -0.01)
        for _, alien in ipairs(self.aliens) do
            if alien and (alien.melee_pose_lock_timer or 0) > 0 then
                alien.melee_pose_lock_timer = math.max(0, (alien.melee_pose_lock_timer or 0) - dt)
            end
            apply_brute_alpha_pulse(self, alien, dt)
            if alien
                and (not alien.is_dead)
                and (alien.type == ALIEN_TYPE_CANNON or alien.type == ALIEN_TYPE_SPITTER or alien.type == ALIEN_TYPE_SPEEDY or alien.type == ALIEN_TYPE_BRUTE)
                and alien.go_id then
                local shadow_pos = shadow_origin
                if counter_move_enabled then
                    shadow_pos = alien.counter_shadow_offset or get_counter_shadow_offset(profile, 0)
                end
                local use_proxy_shadow = counter_move_enabled and (alien.is_moving or alien.shadow_proxy_pending_clear)
                if use_proxy_shadow then
                    local proxy_id = ensure_counter_shadow_proxy(
                        alien,
                        get_counter_shadow_anim_for_alien(alien.type),
                        vmath.vector4(1, 1, 1, 0.5)
                    )
                    if proxy_id then
                        local apos = go.get_position(alien.go_id)
                        go.set_position(vmath.vector3(apos.x + shadow_pos.x, apos.y + shadow_pos.y, apos.z - 0.01), proxy_id)
                    end
                    pcall(go.set, msg.url(nil, alien.go_id, "shadow"), "tint", vmath.vector4(1, 1, 1, 0))
                    if counter_move_enabled and (not alien.is_moving) and alien.shadow_proxy_id then
                        schedule_counter_shadow_proxy_clear(alien, 0.08)
                    end
                else
                    clear_counter_shadow_proxy(alien)
                    pcall(go.set, msg.url(nil, alien.go_id, "shadow"), "tint", vmath.vector4(1, 1, 1, world_shadow_alpha))
                    pcall(go.set, msg.url(nil, alien.go_id, "shadow"), "position", shadow_pos)
                end
                if not alien.is_moving then
                    alien.counter_shadow_offset = nil
                end
            end
            if alien
                and (not alien.is_dead)
                and (alien.type == ALIEN_TYPE_CANNON or alien.type == ALIEN_TYPE_SPEEDY or alien.type == ALIEN_TYPE_BRUTE)
                and (not alien.is_moving)
                and alien.go_id then
                alien.spitter_anim_phase = (alien.spitter_anim_phase or 0) + (dt * 2.2 * math.pi * 2)
                local pulse = math.sin(alien.spitter_anim_phase)
                local base_scale = 0.33333334
                if alien.type == ALIEN_TYPE_CANNON then
                    base_scale = 0.22
                elseif alien.type == ALIEN_TYPE_SPITTER or alien.type == ALIEN_TYPE_SPEEDY then
                    base_scale = base_scale * 0.75
                elseif alien.type == ALIEN_TYPE_BRUTE then
                    pcall(go.set_rotation, vmath.quat_rotation_z(0), alien.go_id)
                    if (alien.melee_pose_lock_timer or 0) <= 0 then
                        local front_anim = get_alien_anim_for_aesthetic(self, alien.type)
                        if front_anim and alien.current_aesthetic_anim ~= front_anim then
                            pcall(msg.post, msg.url(nil, alien.go_id, "sprite"), "play_animation", { id = front_anim })
                            alien.current_aesthetic_anim = front_anim
                        end
                        sprite.set_hflip(msg.url(nil, alien.go_id, "sprite"), false)
                        sprite.set_hflip(msg.url(nil, alien.go_id, "shadow"), false)
                    end
                    base_scale = (0.22 * 1.5 * 1.25 * 1.2 * 1.1) * ((self.aesthetic_mode == AESTHETIC_MODE_COMPUTER) and 1.2 or 1.0)
                end
                local sx = base_scale * (1 - (0.045 * pulse))
                local sy = base_scale * (1 + (0.0675 * pulse))
                go.set_scale(vmath.vector3(sx, sy, 1), alien.go_id)
            end
        end
    end
    MELEE_RUNTIME.update_human_hit_flash(self, dt)
    MELEE_RUNTIME.update_swipe_fx(self, dt)
    MELEE_RUNTIME.update_phase(self, dt)
    update_spitter_projectiles(self, dt)
    update_turret_projectiles(self, dt)
    update_spitter_attack_phase(self, dt)
    if self.alien_turn_ap_debug
        and (not self.alien_turn_ap_debug_flushed)
        and (not self.alien_turn_active)
        and (not self.pending_spitter_attack_phase)
        and (not self.pending_melee_attack_phase)
        and (not any_alien_is_moving(self))
    then
        flush_alien_turn_ap_debug(self)
    end
    tick_human_reactive_fire_cooldowns(self, dt)
    process_turret_reactive_fire(self, dt)
    if self.pending_manual_shot_alien_id then
        if self.ranged_hit_preview_fading_out == true then
            local fade_s = math.max(0.001, tonumber(RANGED_HIT_PREVIEW_FADE_SECONDS or 0.22) or 0.22)
            self.ranged_hit_preview_fade_alpha = math.max(0, (self.ranged_hit_preview_fade_alpha or 0) - (dt / fade_s))
            if (self.ranged_hit_preview_fade_alpha or 0) <= 0 then
                clear_ranged_hit_preview(self)
            end
        else
            self.ranged_hit_preview_fade_alpha = 1
        end
    end
    if self.civilian_turn_waiting_for_alien
        and self.realtime_rules_enabled ~= true
        and (not any_civilian_is_moving(self))
        and (not self.alien_turn_active)
        and (not self.pending_spitter_attack_phase)
        and (not self.pending_melee_attack_phase)
        and (not any_alien_is_moving(self))
    then
        self.civilian_turn_waiting_for_alien = false
        process_alien_turn(self)
    end
    if self.alien_turn_active and (not self.alien_turn_waiting_for_advance) and (not any_alien_is_moving(self)) and (not self.pending_spitter_attack_phase) and (not self.pending_melee_attack_phase) then
        process_alien_turn(self)
    end
    local in_outro_flow = (self.game_flow_state or FLOW_STATE_GAME) == FLOW_STATE_OUTRO
    LOOT_RUNTIME.update_loot_pickup_blips(self, dt)
    if LOOT_RUNTIME.update_impact_rings then
        LOOT_RUNTIME.update_impact_rings(self, dt)
    end
    LOOT_RUNTIME.update_derple_feedback_bubbles(self, dt)
    LOOT_RUNTIME.update_power_node_flicker(self, dt)
    enforce_tutorial_infinite_ap(self)
    enforce_realtime_ap_regen(self, dt)
    process_realtime_world_ticks(self, dt)
    if (not in_outro_flow) and LOOT_RUNTIME.update_hazard_fx_visibility then
        LOOT_RUNTIME.update_hazard_fx_visibility(self)
    end
    if LOOT_RUNTIME.update_dna_mission_markers then
        LOOT_RUNTIME.update_dna_mission_markers(self)
    end
    if (not in_outro_flow) and LOOT_RUNTIME.update_factory_conveyor_tokens then
        LOOT_RUNTIME.update_factory_conveyor_tokens(self, dt)
    end
    if (not in_outro_flow) and LOOT_RUNTIME.update_factory_underlay_animations then
        LOOT_RUNTIME.update_factory_underlay_animations(self, dt)
    end
    if (not in_outro_flow) and LOOT_RUNTIME.update_workshop_underlay_animations then
        LOOT_RUNTIME.update_workshop_underlay_animations(self, dt)
    end
    update_human_visual_state(self)
    update_derple_feedback_triggers(self, dt)
    update_purge_runtime(self)
    update_all_humans_dead_loss(self)
    if not in_outro_flow then
        update_exit_green_smoke_fx(self)
    end
    update_ladder_tints(self)
    update_selected_unit_pulse(self, dt)
    update_selected_unit_ui(self)
    update_flow_ui(self, dt)
    refresh_ambient_sfx_state(self)
    update_outro_slideshow_runtime(self, dt)
    update_tutorial_overlay_ui(self)
    LOOT_RUNTIME.update_drag_visual(self)
    update_human_ap_debug_label(self)
    if self.world_backdrop or (self.world_backdrop_tiles and #self.world_backdrop_tiles > 0) then
        local profile = get_aesthetic_profile(self)
        local pan_speed_x = (profile and profile.backdrop_pan_speed_x) or 0
        local pan_speed_y = (profile and profile.backdrop_pan_speed_y) or 0
        local parallax_factor = (profile and profile.backdrop_parallax_factor) or 1
        local follow_camera = not (profile and profile.backdrop_follow_camera == false)
        self.world_backdrop_pan_x = (self.world_backdrop_pan_x or 0) + (pan_speed_x * dt)
        self.world_backdrop_pan_y = (self.world_backdrop_pan_y or 0) + (pan_speed_y * dt)
        if follow_camera then
            if self.world_backdrop_prev_camera_x == nil or self.world_backdrop_prev_camera_y == nil then
                self.world_backdrop_prev_camera_x = self.camera_pos.x
                self.world_backdrop_prev_camera_y = self.camera_pos.y
                self.world_backdrop_parallax_x = self.camera_pos.x
                self.world_backdrop_parallax_y = self.camera_pos.y
            else
                local camera_dx = self.camera_pos.x - self.world_backdrop_prev_camera_x
                local camera_dy = self.camera_pos.y - self.world_backdrop_prev_camera_y
                self.world_backdrop_parallax_x = (self.world_backdrop_parallax_x or self.camera_pos.x) + (camera_dx * parallax_factor)
                self.world_backdrop_parallax_y = (self.world_backdrop_parallax_y or self.camera_pos.y) + (camera_dy * parallax_factor)
                self.world_backdrop_prev_camera_x = self.camera_pos.x
                self.world_backdrop_prev_camera_y = self.camera_pos.y
            end
        else
            if self.world_backdrop_anchor_world_x == nil or self.world_backdrop_anchor_world_y == nil then
                self.world_backdrop_anchor_world_x = self.camera_pos.x
                self.world_backdrop_anchor_world_y = self.camera_pos.y
            end
            self.world_backdrop_prev_camera_x = nil
            self.world_backdrop_prev_camera_y = nil
            self.world_backdrop_parallax_x = nil
            self.world_backdrop_parallax_y = nil
        end
        local backdrop_cam_x = nil
        local backdrop_cam_y = nil
        if follow_camera then
            backdrop_cam_x = (parallax_factor == 1) and self.camera_pos.x or (self.world_backdrop_parallax_x or self.camera_pos.x)
            backdrop_cam_y = (parallax_factor == 1) and self.camera_pos.y or (self.world_backdrop_parallax_y or self.camera_pos.y)
        else
            backdrop_cam_x = self.world_backdrop_anchor_world_x or self.camera_pos.x
            backdrop_cam_y = self.world_backdrop_anchor_world_y or self.camera_pos.y
        end
        local bx = backdrop_cam_x + (self.world_backdrop_base_offset_x or 0) + (self.world_backdrop_pan_x or 0)
        local by = backdrop_cam_y + (self.world_backdrop_base_offset_y or 0) + (self.world_backdrop_pan_y or 0)
        if self.world_backdrop then
            local backdrop_scale = (profile and profile.backdrop_scale) or 1
            local sx = (SCREEN_WIDTH / (self.world_backdrop_art_w or 256)) * backdrop_scale
            local sy = (SCREEN_HEIGHT / (self.world_backdrop_art_h or 256)) * backdrop_scale
            local final_by = by
            local align_bottom_world_y = profile and profile.backdrop_align_bottom_world_y
            if align_bottom_world_y == nil and profile and profile.backdrop_align_to_lowest_tile_floor == true and self.world_grid then
                local lowest_y_cell = nil
                for _, cell in ipairs(self.world_grid) do
                    if cell and cell.tileID and cell.tileID ~= hash("empty") then
                        local y_cell = cell.yCell or 1
                        if lowest_y_cell == nil or y_cell < lowest_y_cell then
                            lowest_y_cell = y_cell
                        end
                    end
                end
                if lowest_y_cell ~= nil then
                    local _, lowest_row_center_y = coords_to_world_pos(1, lowest_y_cell)
                    align_bottom_world_y = lowest_row_center_y - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM + ((profile.backdrop_floor_align_offset_y) or 0)
                end
            end
            if align_bottom_world_y ~= nil then
                if self.world_backdrop_anchor_camera_y == nil then
                    self.world_backdrop_anchor_camera_y = backdrop_cam_y
                end
                local parallax_delta_y = backdrop_cam_y - self.world_backdrop_anchor_camera_y
                local backdrop_height = (self.world_backdrop_art_h or 256) * sy
                final_by = align_bottom_world_y + (backdrop_height * 0.5) + parallax_delta_y + (self.world_backdrop_pan_y or 0)
            end
            go.set_position(vmath.vector3(bx, final_by, self.world_backdrop_z or -0.2), self.world_backdrop)
            go.set_scale(vmath.vector3(sx, sy, 1), self.world_backdrop)
            apply_backdrop_emissive_tint(self, dt, profile)
        end
        if self.world_backdrop_tiles and #self.world_backdrop_tiles > 0 then
            local cols = (profile and profile.backdrop_tile_cols) or 5
            local rows = (profile and profile.backdrop_tile_rows) or 5
            local tile_art_w = (profile and profile.backdrop_tile_art_w) or 256
            local tile_art_h = (profile and profile.backdrop_tile_art_h) or 256
            local tile_scale_base = (profile and profile.backdrop_tile_scale) or 1
            local tile_scale_x = tile_scale_base
            local tile_scale_y = tile_scale_base
            local tile_span_x = tile_art_w * tile_scale_x
            local tile_span_y = tile_art_h * tile_scale_y
            local x0 = bx - (((cols - 1) * tile_span_x) * 0.5)
            local y0 = by - (((rows - 1) * tile_span_y) * 0.5)
            local tile_i = 1
            for row = 1, rows do
                for col = 1, cols do
                    local tile_id = self.world_backdrop_tiles[tile_i]
                    if tile_id then
                        local px = x0 + ((col - 1) * tile_span_x)
                        local py = y0 + ((row - 1) * tile_span_y)
                        go.set_position(vmath.vector3(px, py, self.world_backdrop_z or -0.2), tile_id)
                        go.set_scale(vmath.vector3(tile_scale_x, tile_scale_y, 1), tile_id)
                    end
                    tile_i = tile_i + 1
                end
            end
        end
    end
    update_backdrop_cloud_fx(self)
    if self.table_sweep_shadow_overlay then
        local profile = get_aesthetic_profile(self)
        local pan_speed_x = (profile and profile.table_sweep_shadow_pan_speed_x) or 0
        local pan_speed_y = (profile and profile.table_sweep_shadow_pan_speed_y) or 0
        -- Treat sweep offsets/speed as screen-space so motion feels identical across zoom levels.
        local start_x = (-SCREEN_WIDTH * 0.6) - 1000
        local end_x = (SCREEN_WIDTH * 0.6) + 1000
        local pan_x = self.table_sweep_shadow_pan_x
        local pause_timer = self.table_sweep_shadow_pause_timer or 0
        if pan_x == nil then
            pan_x = start_x
        elseif pause_timer > 0 then
            pause_timer = math.max(0, pause_timer - dt)
        else
            pan_x = pan_x + (pan_speed_x * dt)
            if pan_x > end_x then
                pan_x = start_x
                pause_timer = 10 + (math.random() * 10)
            end
        end
        local pan_y = (self.table_sweep_shadow_pan_y or 0) + (pan_speed_y * dt)
        self.table_sweep_shadow_pan_x = pan_x
        self.table_sweep_shadow_pan_y = pan_y
        self.table_sweep_shadow_pause_timer = pause_timer
        local sx = ((SCREEN_WIDTH / self.camera_zoom) / (self.table_sweep_shadow_art_w or 256)) * (self.table_sweep_shadow_scale_x or 1)
        local sy = ((SCREEN_HEIGHT / self.camera_zoom) / (self.table_sweep_shadow_art_h or 256)) * (self.table_sweep_shadow_scale_y or 1)
        local ox = ((self.table_sweep_shadow_base_offset_x or 0) + pan_x) / self.camera_zoom
        local oy = ((self.table_sweep_shadow_base_offset_y or 0) + pan_y) / self.camera_zoom
        go.set_position(vmath.vector3(self.camera_pos.x + ox, self.camera_pos.y + oy, self.table_sweep_shadow_z or 0.74), self.table_sweep_shadow_overlay)
        go.set_scale(vmath.vector3(sx, sy, 1), self.table_sweep_shadow_overlay)
    end
    if self.sheen_overlay then
        local sx = (SCREEN_WIDTH / self.camera_zoom) / (self.sheen_art_w or 768)
        local sy = (SCREEN_HEIGHT / self.camera_zoom) / (self.sheen_art_h or 576)
        local ox = self.sheen_offset_x or 0
        local oy = self.sheen_offset_y or 0
        go.set_position(vmath.vector3(self.camera_pos.x + ox, self.camera_pos.y + oy, self.sheen_z or 0.4), self.sheen_overlay)
        go.set_scale(vmath.vector3(sx, sy, 1), self.sheen_overlay)
    end

    if not self.is_panning then
        local speed = math.sqrt(self.pan_velocity_x * self.pan_velocity_x + self.pan_velocity_y * self.pan_velocity_y)
        if speed > self.pan_inertia_min_speed then
            self.camera_pos.x = self.camera_pos.x + self.pan_velocity_x * dt
            self.camera_pos.y = self.camera_pos.y + self.pan_velocity_y * dt

            local decay = math.exp(-self.pan_inertia_damping * dt)
            self.pan_velocity_x = self.pan_velocity_x * decay
            self.pan_velocity_y = self.pan_velocity_y * decay

            apply_camera_transform(self)
        else
            self.pan_velocity_x = 0
            self.pan_velocity_y = 0
        end
    end
end

-- =============================================================================
-- INPUT FUNCTION
-- =============================================================================

function on_input(self, action_id, action)
    if action_id == hash("touch") then
        local input_x, input_y, inside_view = map_window_input_to_logical(action.x, action.y, action.screen_x, action.screen_y)
        if (self.game_flow_state or FLOW_STATE_GAME) ~= FLOW_STATE_GAME then
            if action.released and inside_view and input_x and input_y then
                handle_flow_touch(self, input_x, input_y)
            end
            return true
        end
        if self.drag_resource and self.drag_resource.active then
            if input_x and input_y then
                LOOT_RUNTIME.update_resource_drag(self, input_x, input_y)
            end
            if action.released then
                if self.mp_state and self.mp_state.enabled then
                    local world_x, world_y = screen_to_world(input_x, input_y, self.camera_pos, self.camera_zoom)
                    multiplayer_transport_send_command(self, "resource_drag_end", {
                        turn_id = self.mp_state.turn_id or 1,
                        screen_x = input_x,
                        screen_y = input_y,
                        world_x = world_x,
                        world_y = world_y,
                        drag = multiplayer_clone_flat_table(self.drag_resource)
                    }, multiplayer_get_active_player_id_for_commands(self))
                    self.drag_resource = { active = false }
                else
                    LOOT_RUNTIME.end_resource_drag(self, input_x, input_y)
                end
            end
            return true
        end

        if action.pressed then
            self.zoom_input_armed = true
            if not inside_view then
                return true
            end
            if get_selected_unit(self) and is_point_in_ui_panel(input_x, input_y) then
                if LOOT_RUNTIME.begin_command_drag(self, input_x, input_y) then
                    self.is_panning = false
                    self.did_drag = true
                    return true
                end
                if LOOT_RUNTIME.begin_resource_drag(self, input_x, input_y) then
                    self.is_panning = false
                    self.did_drag = true
                    return true
                end
            end

            self.is_panning = true
            self.did_drag = false
            self.drag_start_screen_x = input_x
            self.drag_start_screen_y = input_y
            self.drag_start_camera_pos = vmath.vector3(self.camera_pos)
            self.last_pan_screen_x = input_x
            self.last_pan_screen_y = input_y
            self.pan_velocity_x = 0
            self.pan_velocity_y = 0
        elseif action.released then
            if not inside_view then
                self.is_panning = false
                self.pan_velocity_x = 0
                self.pan_velocity_y = 0
                return true
            end
            if not self.did_drag then
                if tutorial_try_advance_from_click(self, input_x, input_y) then
                    dismiss_ranged_hit_preview(self)
                    return true
                end
                if try_multiplayer_debug_player_buttons(self, input_x, input_y) then
                    dismiss_ranged_hit_preview(self)
                    return true
                end
                if try_multiplayer_ready_buttons(self, input_x, input_y) then
                    dismiss_ranged_hit_preview(self)
                    return true
                end
                if try_next_turn_button(self, input_x, input_y) then
                    dismiss_ranged_hit_preview(self)
                    return true
                end
                if try_launch_button(self, input_x, input_y) then
                    dismiss_ranged_hit_preview(self)
                    return true
                end
                if try_toggle_realtime_button(self, input_x, input_y) then
                    dismiss_ranged_hit_preview(self)
                    return true
                end
                if try_toggle_objective_button(self, input_x, input_y) then
                    dismiss_ranged_hit_preview(self)
                    return true
                end
                if try_toggle_aesthetic_ui_button(self, input_x, input_y) then
                    dismiss_ranged_hit_preview(self)
                    return true
                end
                if try_zoom_in_button(self, input_x, input_y) then
                    dismiss_ranged_hit_preview(self)
                    return true
                end
                if try_zoom_out_button(self, input_x, input_y) then
                    dismiss_ranged_hit_preview(self)
                    return true
                end
                if try_toggle_reactive_combat(self, input_x, input_y) then
                    dismiss_ranged_hit_preview(self)
                    return true
                end
                if try_select_level_button(self, input_x, input_y) then
                    dismiss_ranged_hit_preview(self)
                    return true
                end
                if try_advance_reactive_alien_turn(self, input_x, input_y) then
                    dismiss_ranged_hit_preview(self)
                    return true
                end
                if try_toggle_comms_panel(self, input_x, input_y) then
                    dismiss_ranged_hit_preview(self)
                    return true
                end
                if try_activate_comms_slot(self, input_x, input_y) then
                    dismiss_ranged_hit_preview(self)
                    return true
                end
                if get_selected_unit(self) and is_point_in_ui_panel(input_x, input_y) then
                    if try_close_selected_unit_ui(self, input_x, input_y) then
                        dismiss_ranged_hit_preview(self)
                        return
                    end
                    dismiss_ranged_hit_preview(self)
                    return
                end
                local mapped_action = { x = input_x, y = input_y }
                local world_x, world_y = screen_to_world(input_x, input_y, self.camera_pos, self.camera_zoom)
                local clicked_cell_id = handle_cell_click(mapped_action, self.camera_pos, self.camera_zoom)
                if clicked_cell_id then
                    if LOOT_RUNTIME.handle_world_click_selected_unit(self, input_x, input_y, clicked_cell_id) then
                        return true
                    end
                    local handled_by_human = handle_human_click_flow(self, clicked_cell_id, world_x, world_y)
                    if not handled_by_human then
                        process_cell_selection(self, clicked_cell_id)
                    end
                end
            end
            self.is_panning = false
            self.pan_velocity_x = 0
            self.pan_velocity_y = 0
        elseif self.is_panning and input_x and input_y and inside_view then
            local dx = input_x - self.drag_start_screen_x
            local dy = input_y - self.drag_start_screen_y
            local drag_distance = math.sqrt(dx * dx + dy * dy)

            if drag_distance >= self.drag_threshold_px then
                self.did_drag = true
            end

            if self.did_drag then
                -- Convert screen drag to world offset (zoom-aware).
                local old_cam_x = self.camera_pos.x
                local old_cam_y = self.camera_pos.y
                self.camera_pos.x = self.drag_start_camera_pos.x - (dx / self.camera_zoom)
                self.camera_pos.y = self.drag_start_camera_pos.y - (dy / self.camera_zoom)
                apply_camera_transform(self)

                -- Approximate world-space pan velocity for release inertia.
                local frame_dx = input_x - self.last_pan_screen_x
                local frame_dy = input_y - self.last_pan_screen_y
                self.pan_velocity_x = -(frame_dx / self.camera_zoom) * 60
                self.pan_velocity_y = -(frame_dy / self.camera_zoom) * 60
                self.last_pan_screen_x = input_x
                self.last_pan_screen_y = input_y

                -- If clamped by bounds, don't keep adding outward velocity.
                if self.camera_pos.x == old_cam_x then
                    self.pan_velocity_x = 0
                end
                if self.camera_pos.y == old_cam_y then
                    self.pan_velocity_y = 0
                end
            end
        end
    elseif action_id == hash("zoom_in") then
        if (self.game_flow_state or FLOW_STATE_GAME) ~= FLOW_STATE_GAME then
            return true
        end
        if self.zoom_block_timer and self.zoom_block_timer > 0 then
            return true
        end
        if not ((action.value and action.value ~= 0) or action.pressed or action.repeated) then
            return true
        end
        local focus_x, focus_y, inside_view = map_window_input_to_logical(action.x, action.y, action.screen_x, action.screen_y)
        if not inside_view then
            focus_x = SCREEN_WIDTH * 0.5
            focus_y = SCREEN_HEIGHT * 0.5
        end
        focus_x = focus_x or (SCREEN_WIDTH * 0.5)
        focus_y = focus_y or (SCREEN_HEIGHT * 0.5)
        request_zoom_delta(self, 0.12, focus_x, focus_y)
    elseif action_id == hash("zoom_out") then
        if (self.game_flow_state or FLOW_STATE_GAME) ~= FLOW_STATE_GAME then
            return true
        end
        if self.zoom_block_timer and self.zoom_block_timer > 0 then
            return true
        end
        if not ((action.value and action.value ~= 0) or action.pressed or action.repeated) then
            return true
        end
        local focus_x, focus_y, inside_view = map_window_input_to_logical(action.x, action.y, action.screen_x, action.screen_y)
        if not inside_view then
            focus_x = SCREEN_WIDTH * 0.5
            focus_y = SCREEN_HEIGHT * 0.5
        end
        focus_x = focus_x or (SCREEN_WIDTH * 0.5)
        focus_y = focus_y or (SCREEN_HEIGHT * 0.5)
        request_zoom_delta(self, -0.12, focus_x, focus_y)
    elseif action_id == hash("toggle_aesthetic_mode") and action.pressed then
        if (self.game_flow_state or FLOW_STATE_GAME) ~= FLOW_STATE_GAME then
            return true
        end
        toggle_aesthetic_mode(self)
        return true
    elseif action_id == hash("next_turn") and action.pressed then
        if (self.game_flow_state or FLOW_STATE_GAME) ~= FLOW_STATE_GAME then
            return true
        end
        if self.realtime_rules_enabled == true then
            return true
        end
        if tutorial_rules_locked and tutorial_rules_locked(self) then
            return true
        end
        if self.alien_turn_active
            or self.pending_spitter_attack_phase
            or self.pending_melee_attack_phase
            or any_alien_is_moving(self)
            or any_civilian_is_moving(self)
        then
            return true
        end
        if not can_advance_next_turn(self, true) then
            return true
        end
        if self.mp_state and self.mp_state.enabled then
            multiplayer_transport_send_command(self, "new_turn_request", {
                turn_id = self.mp_state and self.mp_state.turn_id or 1
            }, self.mp_state and self.mp_state.host_player_id or "p1")
        else
            next_turn_reset_human_ap(self)
            if LOOT_RUNTIME.process_factory_turn then
                LOOT_RUNTIME.process_factory_turn(self)
            end
            process_civilian_turn(self)
            if any_civilian_is_moving(self) then
                self.civilian_turn_waiting_for_alien = true
            else
                process_alien_turn(self)
            end
        end
    elseif action.pressed and self.realtime_rules_enabled == true and (self.game_flow_state or FLOW_STATE_GAME) == FLOW_STATE_GAME then
        if action_id == hash("rt_tune_spawn_slower") then
            self.realtime_blip_spawn_interval_s = math.min(20.0, (tonumber(self.realtime_blip_spawn_interval_s or 2.0) or 2.0) + 0.25)
            log_realtime_tuning(self)
            return true
        elseif action_id == hash("rt_tune_spawn_faster") then
            self.realtime_blip_spawn_interval_s = math.max(0.25, (tonumber(self.realtime_blip_spawn_interval_s or 2.0) or 2.0) - 0.25)
            log_realtime_tuning(self)
            return true
        elseif action_id == hash("rt_tune_blip_slower") then
            self.realtime_blip_move_speed_multiplier = math.max(0.05, (tonumber(self.realtime_blip_move_speed_multiplier or 0.25) or 0.25) - 0.05)
            log_realtime_tuning(self)
            return true
        elseif action_id == hash("rt_tune_blip_faster") then
            self.realtime_blip_move_speed_multiplier = math.min(1.5, (tonumber(self.realtime_blip_move_speed_multiplier or 0.25) or 0.25) + 0.05)
            log_realtime_tuning(self)
            return true
        elseif action_id == hash("rt_tune_aliens_slower") then
            self.realtime_alien_move_speed_multiplier = math.max(0.2, (tonumber(self.realtime_alien_move_speed_multiplier or 0.75) or 0.75) - 0.05)
            log_realtime_tuning(self)
            return true
        elseif action_id == hash("rt_tune_aliens_faster") then
            self.realtime_alien_move_speed_multiplier = math.min(1.5, (tonumber(self.realtime_alien_move_speed_multiplier or 0.75) or 0.75) + 0.05)
            log_realtime_tuning(self)
            return true
        elseif action_id == hash("rt_tune_step_slower") then
            self.realtime_alien_step_hz = math.max(0.25, (tonumber(self.realtime_alien_step_hz or 1.2) or 1.2) - 0.1)
            log_realtime_tuning(self)
            return true
        elseif action_id == hash("rt_tune_step_faster") then
            self.realtime_alien_step_hz = math.min(10.0, (tonumber(self.realtime_alien_step_hz or 1.2) or 1.2) + 0.1)
            log_realtime_tuning(self)
            return true
        end
    end
end

-- =============================================================================
-- MESSAGE HANDLER
-- =============================================================================

function on_message(self, message_id, message, sender)
    if message_id == hash("next_turn") then
        if (self.game_flow_state or FLOW_STATE_GAME) ~= FLOW_STATE_GAME then
            return
        end
        if self.realtime_rules_enabled == true then
            return
        end
        if tutorial_rules_locked and tutorial_rules_locked(self) then
            return
        end
        if self.alien_turn_active
            or self.pending_spitter_attack_phase
            or self.pending_melee_attack_phase
            or any_alien_is_moving(self)
            or any_civilian_is_moving(self)
        then
            return
        end
        local is_network_authoritative_turn = message and message.from_mp_turn_advanced == true
        if (not is_network_authoritative_turn) and (not can_advance_next_turn(self, true)) then
            return
        end
        next_turn_reset_human_ap(self)
        local skip_authoritative_sim = message and message.skip_authoritative_sim == true
        if skip_authoritative_sim then
            print("MP TURN | non_host_skip_local_alien_factory_sim")
            return
        end
        if LOOT_RUNTIME.process_factory_turn then
            LOOT_RUNTIME.process_factory_turn(self)
        end
        process_civilian_turn(self)
        if any_civilian_is_moving(self) then
            self.civilian_turn_waiting_for_alien = true
        else
            process_alien_turn(self)
        end
    end
end

function final(self)
    if self and self.sfx_state then
        self.sfx_state.vertical_active_by_unit = {}
        self.sfx_state.vertical_active_count = 0
        self.sfx_state.horizontal_active_by_actor = {}
        self.sfx_state.horizontal_active_count = 0
        self.sfx_state.speedy_active_count = 0
        set_sound_loop_state(self, "human_vertical", false)
        set_sound_loop_state(self, "human_horizontal", false)
        stop_speedy_move_sfx(self)
        set_sound_loop_state(self, "planet", false)
        set_sound_loop_state(self, "title", false)
    end
end

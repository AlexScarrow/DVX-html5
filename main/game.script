end
do
    local preview_cfg = sys.get_config and sys.get_config("debug.outro_preview") or nil
    DEBUG_OUTRO_PREVIEW_ENABLED = (preview_cfg == "1" or preview_cfg == "true" or preview_cfg == "on")
    DEBUG_OUTRO_PREVIEW_SEQUENCE = tostring((sys.get_config and sys.get_config("debug.outro_preview_sequence")) or "")
    local preview_result = tostring((sys.get_config and sys.get_config("debug.outro_preview_result")) or "win")
    if preview_result ~= "win" and preview_result ~= "lose" then
        preview_result = "win"
    end
    DEBUG_OUTRO_PREVIEW_RESULT = preview_result
end

local function read_debug_outro_preview_settings()
    local preview_cfg = sys.get_config and sys.get_config("debug.outro_preview") or nil
    local enabled = (preview_cfg == "1" or preview_cfg == "true" or preview_cfg == "on")
    local sequence = tostring((sys.get_config and sys.get_config("debug.outro_preview_sequence")) or "")
    local result = tostring((sys.get_config and sys.get_config("debug.outro_preview_result")) or "win")
    if result ~= "win" and result ~= "lose" then
        result = "win"
    end
    return enabled, sequence, result
end

is_directional_move_sfx_allowed = function(self)
    return self and self.aesthetic_mode == AESTHETIC_MODE_COMPUTER
end

trigger_unit_tile_bump_sfx = function(self, unit_kind)
    if not self or not self.sfx_state then
        return
    end
    if self.aesthetic_mode ~= AESTHETIC_MODE_BOARDGAME then
        return
    end
    if unit_kind == "blip" then
        return
    end
    play_sfx_one_shot(self, "unit_tile_bump")
end

refresh_ambient_sfx_state = function(self)
    if not self or not self.sfx_state then
        return
    end
    local state = self.game_flow_state or FLOW_STATE_GAME
    if self.sfx_state.last_flow_state == state then
        return
    end
    self.sfx_state.last_flow_state = state
    local in_gameplay = state == FLOW_STATE_GAME
    local directional_move_sfx_allowed = is_directional_move_sfx_allowed(self)
    local is_title_outro = (state == FLOW_STATE_OUTRO) and tostring(self.end_outro_sequence_id or "") == "title"
    local in_title_like = (state == FLOW_STATE_TITLE)
        or (state == FLOW_STATE_SOLO_SETUP)
        or (state == FLOW_STATE_MP_SETUP)
        or (state == FLOW_STATE_SCORE)
        or is_title_outro
    set_sound_loop_state(self, "planet", in_gameplay)
    set_sound_loop_state(self, "title", in_title_like)
    if (not in_gameplay) or (not directional_move_sfx_allowed) then
        self.sfx_state.vertical_active_by_unit = {}
        self.sfx_state.vertical_active_count = 0
        set_sound_loop_state(self, "human_vertical", false)
        self.sfx_state.horizontal_active_by_actor = {}
        self.sfx_state.horizontal_active_count = 0
        set_sound_loop_state(self, "human_horizontal", false)
        self.sfx_state.speedy_active_count = 0
        stop_speedy_move_sfx(self)
    end
end

update_vertical_move_sfx_for_unit = function(self, unit, is_vertical_now)
    if not (self and self.sfx_state and unit and unit.id) then
        return
    end
    local actor_key = tostring(unit.id)
    local by_unit = self.sfx_state.vertical_active_by_unit
    if not is_directional_move_sfx_allowed(self) then
        if by_unit[actor_key] == true then
            by_unit[actor_key] = nil
            self.sfx_state.vertical_active_count = math.max(0, (self.sfx_state.vertical_active_count or 0) - 1)
        end
        if (self.sfx_state.vertical_active_count or 0) <= 0 then
            self.sfx_state.vertical_active_count = 0
            set_sound_loop_state(self, "human_vertical", false)
        end
        return
    end
    local was_active = by_unit[actor_key] == true
    local now_active = is_vertical_now == true
    if was_active == now_active then
        return
    end
    if now_active then
        by_unit[actor_key] = true
        self.sfx_state.vertical_active_count = (self.sfx_state.vertical_active_count or 0) + 1
    else
        by_unit[actor_key] = nil
        self.sfx_state.vertical_active_count = math.max(0, (self.sfx_state.vertical_active_count or 0) - 1)
    end
    set_sound_loop_state(self, "human_vertical", (self.sfx_state.vertical_active_count or 0) > 0)
end

update_vertical_move_sfx_for_actor = function(self, actor_key, is_vertical_now)
    if not (self and self.sfx_state and actor_key) then
        return
    end
    local by_unit = self.sfx_state.vertical_active_by_unit
    if not is_directional_move_sfx_allowed(self) then
        if by_unit[actor_key] == true then

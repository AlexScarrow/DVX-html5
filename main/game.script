-- =============================================================================
-- CELL PROTOTYPE STRUCTURE
-- =============================================================================
--[[
    Each cell in the worldGrid contains:
    - idNumber: Unique cell ID (1-225 for 15x15 grid)
    - xCell, yCell: Grid coordinates (1-15)
    - tileID: Hash of tile name this cell belongs to (hash("empty") if not part of a tile)
    - lightValue: Light level (1-5)
    - moveValue: Movement cost (1-5)
    - coverValue: Cover protection (1-5)
    - accessRight: Boolean - can move through right border
    - accessDown: Boolean - can move through bottom border
    - isPowered: Boolean - is this cell powered
    - isOccupied: Hash of occupant ("empty", "sarge", "medic", "alien", etc)
    - object1/2/3: Objects in cell (hash names: "switch", "door", "machine", "wire")
    - isFixed: Boolean - has the object itself been repaired
    - isDependentOn: List of other objects needed for this to function
]]

function create_cell_prototype(id_number, x_cell, y_cell)
    return {
        idNumber = id_number,
        xCell = x_cell,
        yCell = y_cell,
        tileID = hash("empty"),
        lightValue = 1,
        moveValue = 1,
        coverValue = 1,
        accessRight = true,
        accessDown = true,
        isPowered = false,
        tileInstanceId = 0,
        isOccupied = hash("empty"),
        hasLoot = false,
        lootOffsetX = -32,
        lootOffsetY = -32,
        object1 = { name = hash("empty"), isFixed = false, isWelded = false, isOpen = false, dependsOn = 0, isDependentOn = {}, objectId = 0, offsetX = 0, offsetY = 0, fxOffsetX = 0, fxOffsetY = 0, fxRotation = 0, hitW = 32, hitH = 32, requiredComponent = nil },
        object2 = { name = hash("empty"), isFixed = false, isWelded = false, isOpen = false, dependsOn = 0, isDependentOn = {}, objectId = 0, offsetX = 0, offsetY = 0, fxOffsetX = 0, fxOffsetY = 0, fxRotation = 0, hitW = 32, hitH = 32, requiredComponent = nil },
        object3 = { name = hash("empty"), isFixed = false, isWelded = false, isOpen = false, dependsOn = 0, isDependentOn = {}, objectId = 0, offsetX = 0, offsetY = 0, fxOffsetX = 0, fxOffsetY = 0, fxRotation = 0, hitW = 32, hitH = 32, requiredComponent = nil }
    }
end

-- =============================================================================
-- TILE PROTOTYPE STRUCTURE
-- =============================================================================
--[[
    A tile is a 3x3 grid of cells that defines a room/area
    Structure:
    - tileID: Hash identifier for the tile type
    - cells: 3x3 array of cell data (indexed 1-9)
    Each tile cell contains the same properties as a world cell
]]

function create_tile_prototype(tile_id)
    local tile = {
        tileID = hash(tile_id),
        cells = {}
    }

    -- Create 9 cells for the 3x3 tile (numbered 1-9)
    -- Layout: 7 8 9
    --         4 5 6
    --         1 2 3
    for i = 1, 9 do
        tile.cells[i] = {
            lightValue = 3,
            moveValue = 1,
            coverValue = 1,
            accessRight = true,
            accessDown = true,
            isPowered = false,
            tileInstanceId = 0,
            isOccupied = hash("empty"),
            hasLoot = false,
            lootOffsetX = -32,
            lootOffsetY = -32,
            object1 = { name = hash("empty"), isFixed = false, isWelded = false, isOpen = false, dependsOn = 0, isDependentOn = {}, objectId = 0, offsetX = 0, offsetY = 0, fxOffsetX = 0, fxOffsetY = 0, fxRotation = 0, hitW = 32, hitH = 32, requiredComponent = nil },
            object2 = { name = hash("empty"), isFixed = false, isWelded = false, isOpen = false, dependsOn = 0, isDependentOn = {}, objectId = 0, offsetX = 0, offsetY = 0, fxOffsetX = 0, fxOffsetY = 0, fxRotation = 0, hitW = 32, hitH = 32, requiredComponent = nil },
            object3 = { name = hash("empty"), isFixed = false, isWelded = false, isOpen = false, dependsOn = 0, isDependentOn = {}, objectId = 0, offsetX = 0, offsetY = 0, fxOffsetX = 0, fxOffsetY = 0, fxRotation = 0, hitW = 32, hitH = 32, requiredComponent = nil }
        }
    end

    return tile
end

-- =============================================================================
-- WORLDGRID CREATION
-- =============================================================================
--[[
    Creates the worldGrid as a flat sequential table
    - Total cells: GRID_COLS * GRID_ROWS (15x15 = 225)
    - Numbering starts at 1 (bottom-left) and goes sequentially
    - Cell 1 = (1,1), Cell 2 = (2,1), Cell 16 = (1,2), etc.
    - To get cell ID from coords: ID = x + (y-1) * GRID_COLS
    - To get coords from ID: x = ((ID-1) % GRID_COLS) + 1, y = floor((ID-1) / GRID_COLS) + 1
]]

function create_world_grid()
    local world_grid = {}

    for cell_id = 1, (GRID_COLS * GRID_ROWS) do
        -- Calculate x and y coordinates from cell ID
        local x_cell = ((cell_id - 1) % GRID_COLS) + 1
        local y_cell = math.floor((cell_id - 1) / GRID_COLS) + 1

        -- Create cell with prototype
        world_grid[cell_id] = create_cell_prototype(cell_id, x_cell, y_cell)
    end

    return world_grid
end

-- =============================================================================
-- COORDINATE CONVERSION HELPERS
-- =============================================================================

-- Convert grid coordinates (xCell, yCell) to cell ID
function coords_to_id(x_cell, y_cell)
    if x_cell < 1 or x_cell > GRID_COLS or y_cell < 1 or y_cell > GRID_ROWS then
        return nil  -- Out of bounds
    end
    return x_cell + (y_cell - 1) * GRID_COLS
end

-- Convert cell ID to grid coordinates
function id_to_coords(cell_id)
    if cell_id < 1 or cell_id > (GRID_COLS * GRID_ROWS) then
        return nil, nil
    end
    local x_cell = ((cell_id - 1) % GRID_COLS) + 1
    local y_cell = math.floor((cell_id - 1) / GRID_COLS) + 1
    return x_cell, y_cell
end

-- Convert grid coordinates to world position (center of cell)

function coords_to_world_pos(x_cell, y_cell)
    local x_pos = (x_cell - 1) * CELL_WIDTH + (CELL_WIDTH * 0.5)
    local y_pos = (y_cell - 1) * CELL_HEIGHT + (CELL_HEIGHT * 0.5)
    return x_pos, y_pos
end

function clamp_world_x_to_cell(cell, world_x)
    if not cell then
        return world_x
    end
    local center_x, _ = coords_to_world_pos(cell.xCell, cell.yCell)
    local min_x = center_x - (CELL_WIDTH * 0.5) + 8
    local max_x = center_x + (CELL_WIDTH * 0.5) - 8
    if world_x < min_x then
        return min_x
    end
    if world_x > max_x then
        return max_x
    end
    return world_x
end

function world_pos_to_coords(x_pos, y_pos)
    local x_cell = math.floor(x_pos / CELL_WIDTH) + 1
    local y_cell = math.floor(y_pos / CELL_HEIGHT) + 1
    return x_cell, y_cell
end

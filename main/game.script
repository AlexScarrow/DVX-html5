        set_ui_square_transform(self, self.ui.flow_solo_setup_panel, SOLO_SETUP_PANEL_X, SOLO_SETUP_PANEL_Y, SOLO_SETUP_PANEL_Z, vmath.vector4(1, 1, 1, 1), SOLO_SETUP_PANEL_SCALE, SOLO_SETUP_PANEL_SCALE)
        set_ui_square_transform(

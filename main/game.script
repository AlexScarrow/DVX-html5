                set_ui_square_transform(self, row_id, -9999, -9999, FLOW_UI_PANEL_Z, hidden, 300, 28)
            end
        end
        return
    end
    if state == FLOW_STATE_SOLO_SETUP then
        local mission_type = multiplayer_normalize_mission_type(self.solo_setup and self.solo_setup.mission_type or MISSION_TYPE_ESCAPE)
        local selected_idx = 1
        for i, m in ipairs(MP_SETUP_MISSION_TYPES) do

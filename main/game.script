local function update_human_ap_debug_label(self)
    local unit = get_controlled_unit(self)
    if not unit then
        return
    end

    self.last_debug_ap_by_unit = self.last_debug_ap_by_unit or {}
    if self.last_debug_ap_by_unit[unit.id] ~= unit.current_ap then
        print(string.format("UI DEBUG | %s AP: %d/%d", unit.display_name, unit.current_ap, unit.max_ap))
        self.last_debug_ap_by_unit[unit.id] = unit.current_ap
    end
end

local function next_turn_reset_human_ap(self)
    score_record_turn_started(self)
    if not self.squad_units then
        return
    end

    for _, unit in pairs(self.squad_units) do
        if unit and (unit.current_health or 0) > 0 then
            unit.current_ap = unit.max_ap
        else
            unit.current_ap = 0
            unit.is_moving = false
            unit.move_path = nil
            unit.move_path_index = 0
        end
        clear_counter_shadow_proxy(unit)
        unit.is_selected = false
    end

    -- Future hook: Sarge command points increase by 1/turn (max 10).
    local sarge = self.squad_units.sarge
    if sarge then
        sarge.command_points = math.min(sarge.max_command_points, (sarge.command_points or 0) + 1)
        print("UI DEBUG | Sarge Command Points: " .. sarge.command_points)
    end

    tick_turret_arming_timers(self)
    multiplayer_on_turn_advanced(self)
    if self.mp_state and self.mp_state.enabled then
        self.mp_state.debug_active_player_id = self.mp_state.local_player_id or self.mp_state.host_player_id
        multiplayer_enforce_controlled_unit(self, true)
        print(string.format("MP DEBUG | acting_as=%s", tostring(self.mp_state.debug_active_player_id or "p1")))
    end
    update_human_visual_state(self)
    update_human_ap_debug_label(self)
    print("Next turn: squad AP restored")
end

local function get_human_world_pos_for_cell(cell)
    local x, y = coords_to_world_pos(cell.xCell, cell.yCell)
    -- Keep feet near the floor: 10px above each cell's bottom boundary.
    y = y - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM
    return x, y
end

local function get_unit_world_pos_in_cell(self, unit, cell_id)
    local cell = self.world_grid[cell_id]
    local base_x, base_y = get_human_world_pos_for_cell(cell)
    local slot_index = ensure_cell_slot_assignment(self, unit, cell_id)
    local slot_offset = CELL_SLOT_OFFSETS_X[slot_index] or 0
    local x = base_x + (slot_offset * HUMAN_STACK_SPACING_X)
    x = clamp_world_x_to_cell(cell, x)
    return x, base_y
end

local function refresh_unit_positions_in_cell(self, cell_id)
    if not cell_id then
        return
    end
    local units_in_cell = get_units_on_cell(self, cell_id)
    sort_units_by_spawn_order(units_in_cell)
    for _, unit in ipairs(units_in_cell) do
        if unit.go_path then
            local x, y = get_unit_world_pos_in_cell(self, unit, cell_id)
            go.set_position(vmath.vector3(x, y, 0.5), unit.go_path)
        end
    end
end

local function move_human_to_cell(self, unit, cell_id)
    if not unit then
        return
    end

    local old_cell_id = unit.cell_id
    clear_cell_slot_assignment(self, unit, old_cell_id)
    if old_cell_id and self.world_grid[old_cell_id] and not cell_has_any_unit_except(self, old_cell_id, unit.id) then
        self.world_grid[old_cell_id].isOccupied = hash("empty")
    end

    unit.cell_id = cell_id
    self.world_grid[cell_id].isOccupied = unit.occupancy_hash
    ensure_cell_slot_assignment(self, unit, cell_id)
    if unit.forced_slot_index and self.cell_slot_assignments and self.cell_slot_assignments[cell_id] then
        self.cell_slot_assignments[cell_id][unit.id] = unit.forced_slot_index
        unit.forced_slot_index = nil
    end

    refresh_unit_positions_in_cell(self, old_cell_id)
    refresh_unit_positions_in_cell(self, cell_id)
end

function spawn_human_unit(self)
    if not self.squad_units then
        print("No squad units available for spawn.")
        return
    end

    local spawn_cells = {}
    local selected_level = self.level_library and self.level_library[self.current_level_index or 1] or nil
    local leftmost_tile = nil
    local entry_tile = nil
    if selected_level then
        for _, placement in ipairs(selected_level) do
            if (not entry_tile) and placement.tile == "entry" then
                entry_tile = placement
            end
            if (not leftmost_tile)
                or placement.x < leftmost_tile.x
                or (placement.x == leftmost_tile.x and placement.y < leftmost_tile.y)
            then
                leftmost_tile = placement
            end
        end
    end

    local entry_spawn_cell_id = nil
    if entry_tile then
        entry_spawn_cell_id = coords_to_id(entry_tile.x + 1, entry_tile.y)
    end
    local leftmost_spawn_cell_id = nil
    if leftmost_tile then
        leftmost_spawn_cell_id = coords_to_id(leftmost_tile.x, leftmost_tile.y)
    end
    if entry_spawn_cell_id and self.world_grid[entry_spawn_cell_id] and self.world_grid[entry_spawn_cell_id].tileID ~= hash("empty") then
        for i = 1, 4 do
            spawn_cells[i] = entry_spawn_cell_id
        end
    elseif leftmost_spawn_cell_id and self.world_grid[leftmost_spawn_cell_id] and self.world_grid[leftmost_spawn_cell_id].tileID ~= hash("empty") then
        for i = 1, 4 do
            spawn_cells[i] = leftmost_spawn_cell_id
        end
    else
        for cell_id, cell in ipairs(self.world_grid) do
            if cell.tileID ~= hash("empty") then
                table.insert(spawn_cells, cell_id)
            end
        end
        if #spawn_cells < 4 then
            print("Not enough walkable cells to spawn the full squad.")
            return
        end
    end

    self.cell_slot_assignments = {}

    local spawn_order = get_spawn_order_unit_id_list()
    for i, unit_id in ipairs(spawn_order) do
        local unit = self.squad_units[unit_id]
        if unit then
            unit.cell_id = nil
            unit.is_selected = false
            unit.is_moving = false
            unit.move_path = nil
            unit.move_path_index = 0
            unit.anim_phase = 0
            unit.shadow_motion_offset = nil
            unit.current_ap = unit.max_ap
            if unit.class_id == UNIT_CLASS_TECHIE then
                unit.backpack_items = { "power" }
                unit.backpack_used = 1
            else
                unit.backpack_items = {}
                unit.backpack_used = 0
            end

            move_human_to_cell(self, unit, spawn_cells[i])
            set_unit_scale(unit, HUMAN_VISUAL_SCALE, HUMAN_VISUAL_SCALE)
            if unit.shadow_path then
                go.set(unit.shadow_path, "tint", vmath.vector4(1, 1, 1, 0.5))
            end
            print(unit.display_name .. " spawned on cell: " .. spawn_cells[i])
        end
    end

    update_human_visual_state(self)
    apply_human_aesthetic_animations(self)
    update_human_ap_debug_label(self)
end

local function begin_human_path_move(self, path, destination_cell_id, destination_slot_index)
    local unit = get_controlled_unit(self)
    if not unit then
        return
    end
    if not (unit and (unit.current_health or 0) > 0) then
        print(unit.display_name .. " is dead and cannot move.")
        return
    end

    if not path or #path < 2 then
        unit.is_moving = false
        unit.move_path = nil
        unit.move_path_index = 0
        unit.desired_destination_cell_id = nil
        unit.desired_destination_slot_index = nil
        return
    end

    unit.is_moving = true
    unit.move_path = path
    unit.move_path_index = 2 -- first element is current cell
    unit.anim_phase = 0
    unit.shadow_motion_offset = nil
    unit.micro_target_x = nil
    unit.micro_target_y = nil
    unit.micro_move_kind = nil
    unit.vertical_prep_done_for_index = nil
    unit.entry_slot_for_index = nil
    unit.entry_slot_index = nil
    unit.last_completed_step_vertical = false
    unit.counter_move_total_dist = nil
    unit.desired_destination_cell_id = destination_cell_id or path[#path]
    unit.desired_destination_slot_index = destination_slot_index
end

begin_human_path_move_for_unit = function(self, unit, path, destination_cell_id, destination_slot_index)
    if not unit then
        return
    end
    local previous_controlled = self.controlled_unit_id
    self.controlled_unit_id = unit.id
    begin_human_path_move(self, path, destination_cell_id, destination_slot_index)
    self.controlled_unit_id = previous_controlled
end

local function update_single_unit_movement(self, unit, dt)
    if not unit or not unit.is_moving or not unit.move_path then
        return
    end
    if not (unit and (unit.current_health or 0) > 0) then
        unit.is_moving = false
        unit.move_path = nil
        unit.move_path_index = 0
        unit.desired_destination_cell_id = nil
        unit.desired_destination_slot_index = nil
        unit.micro_target_x = nil
        unit.micro_target_y = nil
        unit.micro_move_kind = nil
        unit.vertical_prep_done_for_index = nil
        unit.entry_slot_for_index = nil
        unit.entry_slot_index = nil
        unit.last_completed_step_vertical = false
        unit.shadow_motion_offset = nil
        set_unit_scale(unit, HUMAN_VISUAL_SCALE, HUMAN_VISUAL_SCALE)
        return
    end

    if unit.micro_target_x and unit.micro_target_y then
        local current_pos = go.get_position(unit.go_path)
        local dx = unit.micro_target_x - current_pos.x
        local dy = unit.micro_target_y - current_pos.y
        local distance = math.sqrt(dx * dx + dy * dy)
        local step = HUMAN_MOVE_SPEED * dt
        unit.anim_phase = (unit.anim_phase or 0) + (dt * HUMAN_PINGPONG_SPEED * math.pi * 2)
        local ping = math.sin(unit.anim_phase)
        local scale_x = HUMAN_VISUAL_SCALE
        local scale_y = HUMAN_VISUAL_SCALE
        local profile = get_aesthetic_profile(self)
        local move_z = 0.5
        if profile and profile.counter_token_move_enabled == true then
            move_z = profile.counter_human_move_z or 0.64
        end
        if profile and profile.counter_token_move_enabled == true then
            if not unit.counter_move_total_dist or unit.counter_move_total_dist <= 0 then
                unit.counter_move_total_dist = math.max(distance, 1)
            end
            local progress = 1 - math.max(0, math.min(1, distance / unit.counter_move_total_dist))
            local lift = math.sin(progress * math.pi)
            local move_arc = 4 * progress * (1 - progress)
            local wobble = math.sin((unit.anim_phase or 0) * 2.0 + ((dx < 0) and 1.4 or 0))
            local lift_scale = profile.counter_lift_scale or 0.16
            local wobble_scale = profile.counter_wobble_scale or 0.04
            scale_x = HUMAN_VISUAL_SCALE * (1 + (lift * lift_scale) + (wobble * wobble_scale))
            scale_y = HUMAN_VISUAL_SCALE * (1 + (lift * lift_scale) - (wobble * wobble_scale * 0.6))
            unit.shadow_motion_offset = get_counter_shadow_offset(profile, move_arc)
        else
            unit.shadow_motion_offset = nil
            if math.abs(dx) >= math.abs(dy) then
                scale_x = HUMAN_VISUAL_SCALE * (1 + HUMAN_PINGPONG_AMPLITUDE * ping)
            else
                scale_y = HUMAN_VISUAL_SCALE * (1 + HUMAN_PINGPONG_AMPLITUDE * ping)
            end
        end
        set_unit_scale(unit, scale_x, scale_y)
        if distance <= step then
            local snap_z = (unit.micro_move_kind == "settle_end") and 0.5 or move_z
            go.set_position(vmath.vector3(unit.micro_target_x, unit.micro_target_y, snap_z), unit.go_path)
            if unit.micro_move_kind == "settle_end" then
                unit.is_moving = false
                unit.move_path = nil
                unit.move_path_index = 0
                unit.desired_destination_cell_id = nil
                unit.desired_destination_slot_index = nil
                unit.micro_target_x = nil
                unit.micro_target_y = nil
                unit.micro_move_kind = nil
                unit.shadow_motion_offset = nil
                unit.counter_move_total_dist = nil
                set_unit_scale(unit, HUMAN_VISUAL_SCALE, HUMAN_VISUAL_SCALE)
                print(unit.display_name .. " move complete on cell: " .. unit.cell_id)
                update_human_visual_state(self)
                return
            end
            unit.micro_target_x = nil
            unit.micro_target_y = nil
            unit.micro_move_kind = nil
            unit.counter_move_total_dist = nil
            return
        end
        local nx = current_pos.x + (dx / distance) * step
        local ny = current_pos.y + (dy / distance) * step
        go.set_position(vmath.vector3(nx, ny, move_z), unit.go_path)
        return
    end

    local target_cell_id = unit.move_path[unit.move_path_index]
    if not target_cell_id then
        unit.is_moving = false
        unit.move_path = nil
        unit.move_path_index = 0
        unit.desired_destination_cell_id = nil
        unit.desired_destination_slot_index = nil
        unit.vertical_prep_done_for_index = nil
        unit.entry_slot_for_index = nil
        unit.entry_slot_index = nil
        unit.last_completed_step_vertical = false
        unit.shadow_motion_offset = nil
        set_unit_scale(unit, HUMAN_VISUAL_SCALE, HUMAN_VISUAL_SCALE)
        return
    end

    local from_x, from_y = id_to_coords(unit.cell_id)
    local to_x, to_y = id_to_coords(target_cell_id)
    local is_vertical_step = (from_x == to_x) and (from_y ~= to_y)
    local move_profile = get_aesthetic_profile(self)
    local counter_move_enabled = move_profile and move_profile.counter_token_move_enabled == true
    if (not counter_move_enabled) and is_vertical_step and unit.vertical_prep_done_for_index ~= unit.move_path_index then
        if self.cell_slot_assignments and self.cell_slot_assignments[unit.cell_id] then
            local assignment = self.cell_slot_assignments[unit.cell_id]
            local right_slot = 1
            for i = 1, #CELL_SLOT_OFFSETS_X do
                local slot_offset = CELL_SLOT_OFFSETS_X[i] or 0
                local best_offset = CELL_SLOT_OFFSETS_X[right_slot] or 0
                if slot_offset > best_offset then
                    right_slot = i
                end
            end
            assignment[unit.id] = right_slot
        end
        local prep_x, prep_y = get_unit_world_pos_in_cell(self, unit, unit.cell_id)
        unit.micro_target_x = prep_x
        unit.micro_target_y = prep_y
        unit.micro_move_kind = "prep_vertical"
        unit.vertical_prep_done_for_index = unit.move_path_index
        return
    end

    if unit.entry_slot_for_index ~= unit.move_path_index then
        local selected_slot = math.random(1, #CELL_SLOT_OFFSETS_X)
        local is_final_step = unit.move_path and (unit.move_path_index >= #unit.move_path)
        local prefer_clicked_slot = is_final_step
            and unit.desired_destination_slot_index
            and (target_cell_id == unit.desired_destination_cell_id)
        local allow_clicked_slot_for_entry = prefer_clicked_slot and (counter_move_enabled or (not is_vertical_step))
        if is_vertical_step and (not counter_move_enabled) then
            local right_slot = 1
            for i = 1, #CELL_SLOT_OFFSETS_X do
                local slot_offset = CELL_SLOT_OFFSETS_X[i] or 0
                local best_offset = CELL_SLOT_OFFSETS_X[right_slot] or 0
                if slot_offset > best_offset then
                    right_slot = i
                end
            end
            selected_slot = right_slot
        end
        if self.cell_slot_assignments and self.cell_slot_assignments[target_cell_id] then
            local assignment = self.cell_slot_assignments[target_cell_id]
            local free_slots = {}
            local used = {}
            for unit_id, slot_index in pairs(assignment) do
                if unit_id ~= unit.id then
                    used[slot_index] = true
                end
            end
            for i = 1, #CELL_SLOT_OFFSETS_X do
                if not used[i] then
                    table.insert(free_slots, i)
                end
            end
            if allow_clicked_slot_for_entry then
                local desired_slot = math.max(1, math.min(#CELL_SLOT_OFFSETS_X, unit.desired_destination_slot_index))
                if not used[desired_slot] then
                    selected_slot = desired_slot
                elseif #free_slots > 0 then
                    local desired_offset = CELL_SLOT_OFFSETS_X[desired_slot] or 0
                    local best_slot = free_slots[1]
                    local best_dist = math.abs((CELL_SLOT_OFFSETS_X[best_slot] or 0) - desired_offset)
                    for _, free_slot in ipairs(free_slots) do
                        local dist = math.abs((CELL_SLOT_OFFSETS_X[free_slot] or 0) - desired_offset)
                        if dist < best_dist then
                            best_dist = dist
                            best_slot = free_slot
                        end
                    end
                    selected_slot = best_slot
                end
            elseif #free_slots > 0 and (counter_move_enabled or (not is_vertical_step)) then
                selected_slot = free_slots[math.random(1, #free_slots)]
            end
        elseif allow_clicked_slot_for_entry then
            selected_slot = math.max(1, math.min(#CELL_SLOT_OFFSETS_X, unit.desired_destination_slot_index))
        end
        unit.entry_slot_for_index = unit.move_path_index
        unit.entry_slot_index = selected_slot
    end
    local target_cell = self.world_grid[target_cell_id]
    local target_x, target_y = get_human_world_pos_for_cell(target_cell)
    target_x = target_x + ((CELL_SLOT_OFFSETS_X[unit.entry_slot_index] or 0) * HUMAN_STACK_SPACING_X)
    target_x = clamp_world_x_to_cell(target_cell, target_x)
    local target_cost = get_step_move_cost(self.world_grid, unit.cell_id, target_cell_id)
    if target_cost > unit.current_ap then
        unit.is_moving = false
        unit.move_path = nil
        unit.move_path_index = 0
        unit.desired_destination_cell_id = nil
        unit.desired_destination_slot_index = nil
        unit.micro_target_x = nil
        unit.micro_target_y = nil
        unit.micro_move_kind = nil
        unit.vertical_prep_done_for_index = nil
        unit.entry_slot_for_index = nil
        unit.entry_slot_index = nil
        unit.last_completed_step_vertical = false
        unit.shadow_motion_offset = nil
        set_unit_scale(unit, HUMAN_VISUAL_SCALE, HUMAN_VISUAL_SCALE)
        if LOOT_RUNTIME and LOOT_RUNTIME.emit_derple_feedback and unit.id then
            LOOT_RUNTIME.emit_derple_feedback(self, unit.id, "NOT_ENOUGH_AP")
        end
        print(unit.display_name .. " stopped before cell " .. target_cell_id .. " (cost " .. target_cost .. ", AP " .. unit.current_ap .. ")")
        update_human_visual_state(self)
        update_human_ap_debug_label(self)
        return
    end

    local current_pos = go.get_position(unit.go_path)
    local dx = target_x - current_pos.x
    local dy = target_y - current_pos.y
    local distance = math.sqrt(dx * dx + dy * dy)
    local move_speed_mul = get_obstacle_move_speed_multiplier(target_cost)
    local step = (HUMAN_MOVE_SPEED * move_speed_mul) * dt

    unit.anim_phase = (unit.anim_phase or 0) + (dt * HUMAN_PINGPONG_SPEED * math.pi * 2)
    local ping = math.sin(unit.anim_phase)
    local scale_x = HUMAN_VISUAL_SCALE
    local scale_y = HUMAN_VISUAL_SCALE
    local profile = get_aesthetic_profile(self)
    local move_z = 0.5
    if profile and profile.counter_token_move_enabled == true then
        move_z = profile.counter_human_move_z or 0.64
    end
    if profile and profile.counter_token_move_enabled == true then
        if not unit.counter_move_total_dist or unit.counter_move_total_dist <= 0 then
            unit.counter_move_total_dist = math.max(distance, 1)
        end
        local progress = 1 - math.max(0, math.min(1, distance / unit.counter_move_total_dist))
        local lift = math.sin(progress * math.pi)
        local move_arc = 4 * progress * (1 - progress)
        local wobble = math.sin((unit.anim_phase or 0) * 2.0 + ((dx < 0) and 1.4 or 0))
        local lift_scale = profile.counter_lift_scale or 0.16
        local wobble_scale = profile.counter_wobble_scale or 0.04
        scale_x = HUMAN_VISUAL_SCALE * (1 + (lift * lift_scale) + (wobble * wobble_scale))
        scale_y = HUMAN_VISUAL_SCALE * (1 + (lift * lift_scale) - (wobble * wobble_scale * 0.6))
        unit.shadow_motion_offset = get_counter_shadow_offset(profile, move_arc)
    else
        unit.shadow_motion_offset = nil
        if math.abs(dx) >= math.abs(dy) then
            scale_x = HUMAN_VISUAL_SCALE * (1 + HUMAN_PINGPONG_AMPLITUDE * ping)
        else
            scale_y = HUMAN_VISUAL_SCALE * (1 + HUMAN_PINGPONG_AMPLITUDE * ping)
        end
    end
    set_unit_scale(unit, scale_x, scale_y)

    if distance <= step then
        go.set_position(vmath.vector3(target_x, target_y, 0.5), unit.go_path)
        unit.current_ap = unit.current_ap - target_cost
        unit.forced_slot_index = unit.entry_slot_index
        local from_cell_id = unit.cell_id
        move_human_to_cell(self, unit, target_cell_id)
        trigger_obstacle_pass_nudge(self, target_cell_id, from_cell_id)
        unit.entry_slot_for_index = nil
        unit.entry_slot_index = nil
        unit.vertical_prep_done_for_index = nil
        unit.last_completed_step_vertical = (not counter_move_enabled) and is_vertical_step
        unit.counter_move_total_dist = nil
        update_human_ap_debug_label(self)
        unit.move_path_index = unit.move_path_index + 1

        if unit.move_path_index > #unit.move_path then
            local final_desired_slot_index = unit.desired_destination_slot_index
            unit.desired_destination_cell_id = nil
            unit.desired_destination_slot_index = nil
            if (not counter_move_enabled) and unit.last_completed_step_vertical and self.cell_slot_assignments and self.cell_slot_assignments[unit.cell_id] then
                local assignment = self.cell_slot_assignments[unit.cell_id]
                local current_slot = assignment[unit.id] or 1
                local spare_slots = {}
                local used = {}
                for unit_id, slot_index in pairs(assignment) do
                    if unit_id ~= unit.id then
                        used[slot_index] = true
                    end
                end
                for i = 1, #CELL_SLOT_OFFSETS_X do
                    if i ~= current_slot and not used[i] then
                        table.insert(spare_slots, i)
                    end
                end
                local settle_slot = nil
                if final_desired_slot_index then
                    local desired_slot = math.max(1, math.min(#CELL_SLOT_OFFSETS_X, final_desired_slot_index))
                    if desired_slot ~= current_slot then
                        if not used[desired_slot] then
                            settle_slot = desired_slot
                        elseif #spare_slots > 0 then
                            local desired_offset = CELL_SLOT_OFFSETS_X[desired_slot] or 0
                            settle_slot = spare_slots[1]
                            local best_dist = math.abs((CELL_SLOT_OFFSETS_X[settle_slot] or 0) - desired_offset)
                            for _, free_slot in ipairs(spare_slots) do
                                local dist = math.abs((CELL_SLOT_OFFSETS_X[free_slot] or 0) - desired_offset)
                                if dist < best_dist then
                                    best_dist = dist
                                    settle_slot = free_slot
                                end
                            end
                        end
                    end
                elseif #spare_slots > 0 then
                    settle_slot = spare_slots[math.random(1, #spare_slots)]
                end
                if settle_slot then
                    assignment[unit.id] = settle_slot
                    local settle_x, settle_y = get_unit_world_pos_in_cell(self, unit, unit.cell_id)
                    unit.micro_target_x = settle_x
                    unit.micro_target_y = settle_y
                    unit.micro_move_kind = "settle_end"
                    return
                end
            end
            unit.is_moving = false
            unit.move_path = nil
            unit.move_path_index = 0
            unit.last_completed_step_vertical = false
            unit.shadow_motion_offset = nil
            unit.counter_move_total_dist = nil
            set_unit_scale(unit, HUMAN_VISUAL_SCALE, HUMAN_VISUAL_SCALE)
            print(unit.display_name .. " move complete on cell: " .. unit.cell_id)
            update_human_visual_state(self)
        end
    else
        local nx = current_pos.x + (dx / distance) * step
        local ny = current_pos.y + (dy / distance) * step
        go.set_position(vmath.vector3(nx, ny, move_z), unit.go_path)
    end
end

local function update_human_movement(self, dt)
    if not self.squad_units then
        return
    end
    for _, unit in pairs(self.squad_units) do
        update_single_unit_movement(self, unit, dt)
    end
end

local function get_clicked_unit_in_cell(self, cell_id, world_x, world_y)
    local units_in_cell = get_units_on_cell(self, cell_id)
    if #units_in_cell == 0 then
        return nil
    end

    local best_unit = nil
    local best_dist = math.huge
    for _, unit in ipairs(units_in_cell) do
        if unit.go_path and (unit.current_health or 0) > 0 then
            local pos = go.get_position(unit.go_path)
            local dx = pos.x - world_x
            local dy = pos.y - world_y
            local dist = math.sqrt(dx * dx + dy * dy)
            if dist < best_dist then
                best_dist = dist
                best_unit = unit
            end
        end
    end

    if best_dist <= UNIT_CLICK_SELECT_RADIUS then
        return best_unit
    end
    return nil
end

local function get_clicked_alien_in_cell(self, cell_id, world_x, world_y)
    if not self.aliens then
        return nil
    end

    local best_alien = nil
    local best_dist = math.huge
    for _, alien in ipairs(self.aliens) do
        if (not alien.is_dead) and alien.cell_id == cell_id then
            if alien.go_id then
                local pos = go.get_position(alien.go_id)
                local dx = pos.x - world_x
                local dy = pos.y - world_y
                local dist = math.sqrt(dx * dx + dy * dy)
                if dist < best_dist then
                    best_dist = dist
                    best_alien = alien
                end
            elseif not best_alien then
                best_alien = alien
            end
        end
    end

    if best_dist <= UNIT_CLICK_SELECT_RADIUS then
        return best_alien
    end
    return nil
end

multiplayer_attempt_manual_shot_on_target = function(self, unit, alien)
    if not unit then
        return false
    end
    if not (unit and (unit.current_health or 0) > 0) then
        print("Unable to fire: selected unit is dead.")
        return true
    end
    if not alien or alien.is_dead then
        return false
    end

    -- Keep this command on the human side of the turn boundary.
    if (any_alien_is_moving(self) or self.pending_spitter_attack_phase or self.pending_melee_attack_phase) and (not self.alien_turn_waiting_for_advance) then
        print("Unable to fire: alien turn in progress.")
        return true
    end

    if MELEE_RUNTIME.try_manual_human_melee(self, unit, alien) then
        update_human_visual_state(self)
        update_human_ap_debug_label(self)
        return true
    end

    local alien_cell = self.world_grid[alien.cell_id]
    if not alien_cell or alien_cell.tileID == hash("empty") then
        print("Unable to fire: target is in VOID.")
        return false
    end

    if not has_unobstructed_los(self.world_grid, unit.cell_id, alien.cell_id) then
        print("Unable to fire: no line of sight.")
        return false
    end

    local shooter_cell = self.world_grid[unit.cell_id]
    local target_cell = self.world_grid[alien.cell_id]
    if shooter_cell and target_cell then
        local is_vertical_lane = (shooter_cell.xCell == target_cell.xCell) and (shooter_cell.yCell ~= target_cell.yCell)
        if is_vertical_lane then
            local shooter_center_x = coords_to_world_pos(shooter_cell.xCell, shooter_cell.yCell)
            local target_center_x = coords_to_world_pos(target_cell.xCell, target_cell.yCell)
            local shooter_pos = unit.go_path and go.get_position(unit.go_path) or nil
            local target_pos = alien.go_id and go.get_position(alien.go_id) or nil
            local shooter_x = shooter_pos and shooter_pos.x or shooter_center_x
            local target_x = target_pos and target_pos.x or target_center_x
            local right_threshold = CELL_WIDTH * 0.15
            local shooter_in_right_lane = shooter_x >= (shooter_center_x + right_threshold)
            local target_in_right_lane = target_x >= (target_center_x + right_threshold)
            if (not shooter_in_right_lane) or (not target_in_right_lane) then
                print("Unable to fire: vertical shot requires both shooter and target in right lane.")
                return false
            end
        end
    end

    local shot_ap_cost = get_ap_cost_value("manual_ranged_shot", 1)
    if unit.current_ap < shot_ap_cost or unit.current_ammo <= 0 then
        print("unable to fire no ammo/ap")
        return false
    end

    unit.current_ap = unit.current_ap - shot_ap_cost
    unit.current_ammo = unit.current_ammo - 1
    local active_light = (alien_cell.isPowered and math.max(0, math.min(3, alien_cell.lightValue or 0))) or 0
    local ranged_model = require("main.config").RANGED_HIT_MODEL
    local base_hit_chance = ranged_model.base_hit_chance + (active_light * ranged_model.per_light_level_bonus)
    local range_cells = manhattan_distance_by_id(unit.cell_id, alien.cell_id)
    local range_penalty = math.max(0, (range_cells - 1) * 10)
    local role = CLASS_ROLE_HOOKS[unit.class_id]
    local class_bonus = (role and role.ranged_hit_bonus) or 0
    local hit_chance = math.max(ranged_model.min_hit_chance, math.min(ranged_model.max_hit_chance, base_hit_chance + class_bonus - range_penalty))
    print(string.format(
        "RANGED DEBUG | manual | shooter=%s targetAlien=%d range=%d penalty=%d light=%d classBonus=%d chance=%d",
        unit.display_name or "unit",
        alien.id or 0,
        range_cells or 0,
        range_penalty or 0,
        active_light or 0,
        class_bonus or 0,
        hit_chance or 0
    ))
    local roll = math.random(1, 100)
    spawn_human_reaction_projectile(self, unit, alien, roll <= hit_chance, active_light, hit_chance, roll)

    update_human_visual_state(self)
    update_human_ap_debug_label(self)
    return true
end

multiplayer_resolve_destination_slot = function(self, unit, destination_cell_id, requested_slot_index)
    local destination_cell = self.world_grid and self.world_grid[destination_cell_id] or nil
    if not destination_cell then
        return nil
    end
    local assignment = self.cell_slot_assignments and self.cell_slot_assignments[destination_cell_id] or nil
    local used = {}
    if assignment then
        for unit_id, slot_index in pairs(assignment) do
            if unit_id ~= unit.id then
                used[slot_index] = true
            end
        end
    end
    local slot_count = #CELL_SLOT_OFFSETS_X
    local requested_slot = math.max(1, math.min(slot_count, math.floor(tonumber(requested_slot_index) or 1)))
    if not used[requested_slot] then
        return requested_slot
    end
    local desired_offset = CELL_SLOT_OFFSETS_X[requested_slot] or 0
    local best_slot = nil
    local best_dist = math.huge
    for i = 1, slot_count do
        if not used[i] then
            local dist = math.abs((CELL_SLOT_OFFSETS_X[i] or 0) - desired_offset)
            if dist < best_dist then
                best_dist = dist
                best_slot = i
            end
        end
    end
    return best_slot or requested_slot
end

multiplayer_apply_move_unit_event = function(self, payload)
    if not payload then
        return false
    end
    local unit = self.squad_units and self.squad_units[payload.unit_id] or nil
    if not unit or unit.is_moving then
        return false
    end
    if (unit.current_health or 0) <= 0 then
        return false
    end
    local destination_cell_id = tonumber(payload.destination_cell_id)
    if not destination_cell_id then
        return false
    end
    if unit.cell_id == destination_cell_id then
        return false
    end
    if not is_walkable_cell(self.world_grid, destination_cell_id) then
        return false
    end
    local ap_before = tonumber(payload.ap_before)
    if ap_before then
        local max_ap = tonumber(unit.max_ap or HUMAN_MAX_ACTION_POINTS) or HUMAN_MAX_ACTION_POINTS
        unit.current_ap = math.max(0, math.min(max_ap, math.floor(ap_before + 0.5)))
    end
    local path = nil
    local total_cost = nil
    if type(payload.path) == "table" and #payload.path >= 2 then
        path = multiplayer_clone_simple_table(payload.path)
        if path and path[1] ~= unit.cell_id then
            path = nil
        end
    end
    if not path then
        path, total_cost = find_path(self.world_grid, unit.cell_id, destination_cell_id, nil, MOVEMENT_PROFILE_HUMAN, nil)
    end
    if not path then
        return false
    end
    if not total_cost then
        total_cost = tonumber(payload.ap_cost)
    end
    local resolved_slot = multiplayer_resolve_destination_slot(self, unit, destination_cell_id, payload.destination_slot_index)
    print(unit.display_name .. " route selected (network event):")
    if total_cost then
        print_path_debug(path, total_cost)
    end
    highlight_path(self, path)
    begin_human_path_move_for_unit(self, unit, path, destination_cell_id, resolved_slot)
    return true
end

multiplayer_apply_manual_shot_event = function(self, payload)
    if not payload then
        return false
    end
    local unit = self.squad_units and self.squad_units[payload.unit_id] or nil
    local alien = find_alien_by_id(self, tonumber(payload.alien_id))
    if not unit or not alien then
        return false
    end
    return multiplayer_attempt_manual_shot_on_target(self, unit, alien)
end

multiplayer_clone_flat_table = function(src)
    local out = {}
    if type(src) ~= "table" then
        return out
    end
    for k, v in pairs(src) do
        if type(v) ~= "table" then
            out[k] = v
        else
            local nested = {}
            for nk, nv in pairs(v) do
                if type(nv) ~= "table" then
                    nested[nk] = nv
                end
            end
            out[k] = nested
        end
    end
    return out
end

multiplayer_clone_simple_table = function(src, depth)
    if type(src) ~= "table" then
        return nil
    end
    local max_depth = 5
    local level = depth or 1
    if level > max_depth then
        return {}
    end
    local out = {}
    for k, v in pairs(src) do
        local key_type = type(k)
        if key_type == "string" or key_type == "number" then
            local value_type = type(v)
            if value_type == "table" then
                out[k] = multiplayer_clone_simple_table(v, level + 1)
            elseif value_type == "string" or value_type == "number" or value_type == "boolean" then
                out[k] = v
            end
        end
    end
    return out
end

multiplayer_clone_with_string_keys = function(src, depth)
    if type(src) ~= "table" then
        return nil
    end
    local max_depth = 5
    local level = depth or 1
    if level > max_depth then
        return {}
    end
    local out = {}
    for k, v in pairs(src) do
        local out_key = (type(k) == "number") and tostring(k) or k
        local value_type = type(v)
        if value_type == "table" then
            out[out_key] = multiplayer_clone_with_string_keys(v, level + 1)
        elseif value_type == "string" or value_type == "number" or value_type == "boolean" then
            out[out_key] = v
        end
    end
    return out
end

multiplayer_restore_numeric_top_keys = function(src)
    if type(src) ~= "table" then
        return {}
    end
    local out = {}
    for k, v in pairs(src) do
        local numeric_key = tonumber(k)
        if numeric_key ~= nil then
            out[numeric_key] = v
        else
            out[k] = v
        end
    end
    return out
end

multiplayer_build_snapshot_state = function(self)
    local snapshot = {
        version = 1,
        level_index = self.current_level_index or 1,
        turn_id = (self.mp_state and self.mp_state.turn_id) or 1,
        player_count = (self.mp_state and self.mp_state.player_count) or 4,
        seat_assignments = multiplayer_clone_simple_table(self.mp_state and self.mp_state.seat_assignments or {}),
        required_ready_player_ids = multiplayer_clone_simple_table(self.mp_state and self.mp_state.required_ready_player_ids or {}),
        ready_by_player_id = multiplayer_clone_simple_table(self.mp_state and self.mp_state.ready_by_player_id or {}),
        controlled_unit_id = self.controlled_unit_id,
        cell_slot_assignments = multiplayer_clone_with_string_keys(self.cell_slot_assignments or {}),
        units = {},
        aliens = {},
        next_alien_id = self.next_alien_id or 0,
        world_cells = {},
        world_item_instances = multiplayer_clone_simple_table(self.world_item_instances or {}),
        next_world_item_id = self.next_world_item_id or 0,
        workshop_states = multiplayer_clone_with_string_keys(self.workshop_states or {}),
        medbay_states = multiplayer_clone_with_string_keys(self.medbay_states or {}),
        exit_objective_state = multiplayer_clone_with_string_keys(self.exit_objective_state or {}),
        score_turn_counter = tonumber(self.score_turn_counter or 0) or 0,
        score_state = multiplayer_clone_with_string_keys(self.score_state or {})
    }
    for unit_id, unit in pairs(self.squad_units or {}) do
        snapshot.units[unit_id] = {
            id = unit.id,
            cell_id = unit.cell_id,
            current_ap = unit.current_ap,
            current_ammo = unit.current_ammo,
            current_health = unit.current_health,
            command_points = unit.command_points,
            backpack_items = multiplayer_clone_simple_table(unit.backpack_items or {}),
            backpack_used = unit.backpack_used,
            carrying_corpse_id = unit.carrying_corpse_id
        }
    end
    for _, alien in ipairs(self.aliens or {}) do
        if alien and (not alien.is_dead) then
            table.insert(snapshot.aliens, {
                id = alien.id,
                type = alien.type,
                cell_id = alien.cell_id,
                hp_current = alien.hp_current,
                hidden_reveal_type = alien.hidden_reveal_type
            })
        end
    end
    for _, cell in ipairs(self.world_grid or {}) do
        if cell and cell.idNumber then
            local object_states = {}
            local objects = { cell.object1, cell.object2, cell.object3 }
            for slot_idx, obj in ipairs(objects) do
                if obj and obj.name and obj.name ~= hash("empty") then
                    object_states[tostring(slot_idx)] = {
                        isFixed = obj.isFixed == true,
                        isWelded = obj.isWelded == true
                    }
                end
            end
            snapshot.world_cells[tostring(cell.idNumber)] = {
                isPowered = cell.isPowered == true,
                lightValue = tonumber(cell.lightValue or 0) or 0,
                has_barricade = cell.has_barricade == true,
                barricade_hp = tonumber(cell.barricade_hp or 0) or 0,
                barricade_anchor_x = tonumber(cell.barricade_anchor_x or 0) or 0,
                barricade_anchor_y = tonumber(cell.barricade_anchor_y or 0) or 0,
                barricade_slot_index = tonumber(cell.barricade_slot_index or 0) or 0,
                object_states = object_states
            }
        end
    end
    return snapshot
end

multiplayer_apply_snapshot_state = function(self, snapshot)
    if type(snapshot) ~= "table" then
        return false
    end
    local target_level = tonumber(snapshot.level_index or self.current_level_index or 1) or 1
    if self.current_level_index ~= target_level then
        local ok = reset_and_load_level(self, target_level)
        if not ok then
            return false
        end
    end
    if not (self.world_grid and self.squad_units) then
        return false
    end

    if self.aliens then
        for _, alien in ipairs(self.aliens) do
            if alien and alien.go_id then
                pcall(go.delete, alien.go_id)
            end
        end
    end
    self.aliens = {}
    self.next_alien_id = 0

    for _, cell in ipairs(self.world_grid) do
        if cell then
            cell.isOccupied = hash("empty")
        end
    end

    for unit_id, unit in pairs(self.squad_units) do
        local unit_snapshot = snapshot.units and snapshot.units[unit_id] or nil
        unit.is_selected = false
        unit.is_moving = false
        unit.move_path = nil
        unit.move_path_index = 0
        if unit_snapshot then
            unit.current_ap = tonumber(unit_snapshot.current_ap or unit.current_ap or unit.max_ap) or unit.max_ap
            unit.current_ammo = tonumber(unit_snapshot.current_ammo or unit.current_ammo or unit.max_ammo) or unit.max_ammo
            unit.current_health = tonumber(unit_snapshot.current_health or unit.current_health or unit.max_health) or unit.max_health
            unit.command_points = tonumber(unit_snapshot.command_points or unit.command_points or 0) or 0
            unit.backpack_items = multiplayer_clone_simple_table(unit_snapshot.backpack_items or {}) or {}
            unit.backpack_used = tonumber(unit_snapshot.backpack_used or #unit.backpack_items) or #unit.backpack_items
            unit.carrying_corpse_id = unit_snapshot.carrying_corpse_id
            unit.cell_id = tonumber(unit_snapshot.cell_id)
        end
    end

    self.cell_slot_assignments = multiplayer_restore_numeric_top_keys(
        multiplayer_clone_simple_table(snapshot.cell_slot_assignments or {}) or {}
    )
    for _, unit in pairs(self.squad_units) do
        if unit and unit.cell_id and self.world_grid[unit.cell_id] then
            self.world_grid[unit.cell_id].isOccupied = unit.occupancy_hash
            refresh_unit_positions_in_cell(self, unit.cell_id)
        end
    end

    local world_cells = snapshot.world_cells or {}
    for cell_id_key, cell_state in pairs(world_cells) do
        local cell_id = tonumber(cell_id_key)
        local cell = cell_id and self.world_grid[cell_id] or nil
        if cell and type(cell_state) == "table" then
            cell.isPowered = (cell_state.isPowered == true)
            cell.lightValue = tonumber(cell_state.lightValue or cell.lightValue or 0) or 0
            cell.has_barricade = (cell_state.has_barricade == true)
            cell.barricade_hp = tonumber(cell_state.barricade_hp or 0) or 0
            cell.barricade_anchor_x = tonumber(cell_state.barricade_anchor_x or 0) or 0
            cell.barricade_anchor_y = tonumber(cell_state.barricade_anchor_y or 0) or 0
            cell.barricade_slot_index = tonumber(cell_state.barricade_slot_index or 0) or 0
            local object_states = cell_state.object_states or {}
            local objects = { cell.object1, cell.object2, cell.object3 }
            for slot_idx, obj in ipairs(objects) do
                local obj_state = object_states[slot_idx] or object_states[tostring(slot_idx)]
                if obj and obj.name and obj.name ~= hash("empty") and type(obj_state) == "table" then
                    obj.isFixed = (obj_state.isFixed == true)
                    obj.isWelded = (obj_state.isWelded == true)
                end
            end
        end
    end

    local aliens_snapshot = snapshot.aliens or {}
    for _, alien_snapshot in ipairs(aliens_snapshot) do
        local alien_type = alien_snapshot.type or ALIEN_TYPE_BLIP
        local cfg = ALIEN_TYPE_CONFIG[alien_type] or ALIEN_TYPE_CONFIG[ALIEN_TYPE_BLIP]
        local alien = {
            id = tonumber(alien_snapshot.id or 0) or 0,
            type = alien_type,
            cell_id = tonumber(alien_snapshot.cell_id),
            ap_max = cfg.ap_per_turn,
            hp_max = cfg.hp,
            hp_current = tonumber(alien_snapshot.hp_current or cfg.hp) or cfg.hp,
            can_traverse_void = cfg.can_traverse_void == true,
            has_ranged = cfg.has_ranged == true,
            ranged_cells = cfg.ranged_cells or 0,
            go_id = nil,
            is_moving = false,
            move_path = nil,
            move_path_index = 0,
            spitter_anim_phase = math.random() * math.pi * 2,
            spitter_flip = false,
            hidden_reveal_type = alien_snapshot.hidden_reveal_type
        }
        table.insert(self.aliens, alien)
        if alien.id > (self.next_alien_id or 0) then
            self.next_alien_id = alien.id
        end
        ensure_alien_visual(self, alien)
        refresh_alien_visual(self, alien)
    end
    self.next_alien_id = math.max(tonumber(snapshot.next_alien_id or 0) or 0, self.next_alien_id or 0)

    self.world_item_instances = multiplayer_clone_simple_table(snapshot.world_item_instances or {}) or {}
    self.next_world_item_id = tonumber(snapshot.next_world_item_id or 0) or 0
    self.workshop_states = multiplayer_restore_numeric_top_keys(
        multiplayer_clone_simple_table(snapshot.workshop_states or {}) or {}
    )
    self.medbay_states = multiplayer_restore_numeric_top_keys(
        multiplayer_clone_simple_table(snapshot.medbay_states or {}) or {}
    )
    self.exit_objective_state = multiplayer_restore_numeric_top_keys(
        multiplayer_clone_simple_table(snapshot.exit_objective_state or {}) or {}
    )
    self.score_turn_counter = tonumber(snapshot.score_turn_counter or self.score_turn_counter or 0) or 0
    self.score_state = multiplayer_clone_simple_table(snapshot.score_state or self.score_state or {}) or SCORE_RUNTIME.create_state("escape_pod")
    self.score_state = SCORE_RUNTIME.set_mission_type(self.score_state, "escape_pod")

    if self.mp_state then
        self.mp_state.turn_id = tonumber(snapshot.turn_id or self.mp_state.turn_id or 1) or 1
        self.mp_state.player_count = tonumber(snapshot.player_count or self.mp_state.player_count or 4) or 4
        self.mp_state.seat_assignments = multiplayer_clone_simple_table(snapshot.seat_assignments or self.mp_state.seat_assignments or {}) or {}
        self.mp_state.required_ready_player_ids = multiplayer_clone_simple_table(snapshot.required_ready_player_ids or self.mp_state.required_ready_player_ids or {}) or {}
        self.mp_state.ready_by_player_id = multiplayer_clone_simple_table(snapshot.ready_by_player_id or self.mp_state.ready_by_player_id or {}) or {}
    end

    local snapshot_controlled_unit_id = snapshot.controlled_unit_id
    if self.mp_state and self.mp_state.enabled then
        if snapshot_controlled_unit_id and multiplayer_can_control_unit(self, snapshot_controlled_unit_id) then
            self.controlled_unit_id = snapshot_controlled_unit_id
        else
            self.controlled_unit_id = nil
        end
    else
        self.controlled_unit_id = snapshot_controlled_unit_id or self.controlled_unit_id
    end
    deselect_all_units(self)
    if self.controlled_unit_id and self.squad_units[self.controlled_unit_id] and (self.squad_units[self.controlled_unit_id].current_health or 0) > 0 then
        self.squad_units[self.controlled_unit_id].is_selected = true
    else
        multiplayer_enforce_controlled_unit(self, true)
    end

    if LOOT_RUNTIME.refresh_world_item_visuals then LOOT_RUNTIME.refresh_world_item_visuals(self) end
    if LOOT_RUNTIME.refresh_loot_markers then LOOT_RUNTIME.refresh_loot_markers(self) end
    if LOOT_RUNTIME.refresh_machine_markers then LOOT_RUNTIME.refresh_machine_markers(self) end
    if LOOT_RUNTIME.refresh_turret_markers then LOOT_RUNTIME.refresh_turret_markers(self) end
    if LOOT_RUNTIME.refresh_fix_markers then LOOT_RUNTIME.refresh_fix_markers(self) end
    if LOOT_RUNTIME.refresh_power_node_markers then LOOT_RUNTIME.refresh_power_node_markers(self) end
    if LOOT_RUNTIME.refresh_door_markers then LOOT_RUNTIME.refresh_door_markers(self) end
    if LOOT_RUNTIME.refresh_wiregap_markers then LOOT_RUNTIME.refresh_wiregap_markers(self) end
    if LOOT_RUNTIME.refresh_vent_markers then LOOT_RUNTIME.refresh_vent_markers(self) end
    if LOOT_RUNTIME.refresh_light_value_markers then LOOT_RUNTIME.refresh_light_value_markers(self) end
    if LOOT_RUNTIME.refresh_factory_underlay_visuals then LOOT_RUNTIME.refresh_factory_underlay_visuals(self) end
    if LOOT_RUNTIME.refresh_exit_objective_state then LOOT_RUNTIME.refresh_exit_objective_state(self) end
    update_human_visual_state(self)
    update_score_hud(self, true)
    update_selected_unit_ui(self)
    return true
end

multiplayer_force_select_unit = function(self, unit_id)
    if not (self and self.squad_units and unit_id) then
        return false
    end
    local unit = self.squad_units[unit_id]
    if not unit then
        return false
    end
    self.controlled_unit_id = unit_id
    deselect_all_units(self)
    unit.is_selected = true
    return true
end

multiplayer_apply_resource_drag_event = function(self, payload)
    if not payload or type(payload) ~= "table" then
        return false
    end
    if not (payload.drag and type(payload.drag) == "table") then
        return false
    end
    local source_unit_id = payload.drag.source_unit_id
    if not (source_unit_id and self.squad_units and self.squad_units[source_unit_id]) then
        return false
    end
    local drag = multiplayer_clone_flat_table(payload.drag)
    drag.world_x = tonumber(payload.world_x)
    drag.world_y = tonumber(payload.world_y)
    drag.active = true
    self.drag_resource = drag
    local screen_x = tonumber(payload.screen_x)
    local screen_y = tonumber(payload.screen_y)
    if not (screen_x and screen_y) then
        self.drag_resource = { active = false }
        return false
    end
    return LOOT_RUNTIME.end_resource_drag(self, screen_x, screen_y) == true
end


    end
    set_ui_square_transform(self, self.ui.flow_overlay, SCREEN_WIDTH * 0.5, SCREEN_HEIGHT * 0.5, FLOW_UI_OVERLAY_Z, vmath.vector4(0.03, 0.03, 0.06, 1), FLOW_UI_SCREEN_W, FLOW_UI_SCREEN_H)
    if state == FLOW_STATE_TITLE then

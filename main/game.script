                set_ui_square_transform(self, row_id, -9999, -9999, FLOW_UI_PANEL_Z, hidden, 300, 28)
            end
        end
        return
    end
    if state == FLOW_STATE_MP_SETUP then
        local valid = multiplayer_setup_is_valid(self)
        if self.mp_state and self.mp_state.enabled then
            set_ui_square_transform(
                self,
                self.ui.transport_status_dot,

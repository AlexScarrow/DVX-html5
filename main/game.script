function is_point_in_screen_rect(screen_x, screen_y, cx, cy, w, h)
    local half_w = w * 0.5
    local half_h = h * 0.5
    return screen_x >= (cx - half_w)
        and screen_x <= (cx + half_w)
        and screen_y >= (cy - half_h)
        and screen_y <= (cy + half_h)
end

function ensure_score_state(self)
    if not self.score_state then
        self.score_state = SCORE_RUNTIME.create_state("escape_pod")
    end
    return self.score_state
end

function get_current_score_total(self)
    local state = ensure_score_state(self)
    local result = SCORE_RUNTIME.compute_score(state)
    local total = math.max(0, math.floor((result and result.total) or 0))
    self.score_display_total = math.max(self.score_display_total or 0, total)
    return self.score_display_total
end

function update_score_hud(self, visible)
    if not self.ui or not self.ui.score_digit_icons then
        return
    end
    local hidden = vmath.vector4(0, 0, 0, 0)
    if visible ~= true then
        for _, digit_id in ipairs(self.ui.score_digit_icons) do
            set_ui_square_transform(self, digit_id, -9999, -9999, SCORE_HUD_Z, hidden, SCORE_HUD_DIGIT_DRAW_W * 0.021, SCORE_HUD_DIGIT_DRAW_H * 0.021)
        end
        return
    end

    local score_text = tostring(get_current_score_total(self))
    if #score_text > SCORE_HUD_MAX_DIGITS then
        score_text = string.sub(score_text, #score_text - SCORE_HUD_MAX_DIGITS + 1)
    end
    local count = #score_text
    local start_x = SCORE_HUD_CENTER_X - ((count - 1) * SCORE_HUD_DIGIT_SPACING_PX * 0.5)
    for idx, digit_id in ipairs(self.ui.score_digit_icons) do
        if idx <= count then
            local ch = string.sub(score_text, idx, idx)
            msg.post(msg.url(nil, digit_id, "sprite"), "play_animation", { id = hash("score_" .. ch) })
            local dx = start_x + ((idx - 1) * SCORE_HUD_DIGIT_SPACING_PX)
            set_ui_square_transform(
                self,
                digit_id,
                dx,
                SCORE_HUD_Y,
                SCORE_HUD_Z,
                vmath.vector4(1, 1, 1, 1),
                SCORE_HUD_DIGIT_DRAW_W * 0.021,
                SCORE_HUD_DIGIT_DRAW_H * 0.021
            )
        else
            set_ui_square_transform(self, digit_id, -9999, -9999, SCORE_HUD_Z, hidden, SCORE_HUD_DIGIT_DRAW_W * 0.021, SCORE_HUD_DIGIT_DRAW_H * 0.021)
        end
    end
end

function score_log_snapshot(self, label)
    local state = ensure_score_state(self)
    local result = SCORE_RUNTIME.compute_score(state)
    local b = result.breakdown or {}
    local m = result.metrics or {}
    print(string.format(
        "SCORE TRACE [%s] total=%d | kills=%d tiles=%d escaped=%d turns=%d eff=%d win=%d",
        tostring(label or "event"),
        result.total or 0,
        b.aliens_killed_points or 0,
        b.tiles_powered_points or 0,
        b.humans_escaped_points or 0,
        m.turns_elapsed or 0,
        b.efficiency_points or 0,
        b.win_bonus_points or 0
    ))
    print(string.format(
        "UI DEBUG | SCORE [%s] total=%d turns=%d kills=%d tiles=%d escaped=%d",
        tostring(label or "event"),
        result.total or 0,
        m.turns_elapsed or 0,
        m.aliens_killed_total or 0,
        m.tiles_powered_first_time or 0,
        m.humans_escaped_on_launch or 0
    ))
end

function score_record_turn_started(self)
    self.score_turn_counter = (self.score_turn_counter or 0) + 1
    SCORE_RUNTIME.record_turn_started(ensure_score_state(self), self.score_turn_counter)
    score_log_snapshot(self, "turn_started")
end

function score_record_alien_kill(self, alien_type)
    SCORE_RUNTIME.record_alien_killed(ensure_score_state(self), alien_type)
    score_log_snapshot(self, "alien_killed")
end

function score_record_tile_powered_first_time(self, tile_instance_id)
    SCORE_RUNTIME.record_tile_powered(ensure_score_state(self), tile_instance_id)
    score_log_snapshot(self, "tile_powered")
end

function score_record_launch_success(self, escaped_humans_alive_count)
    local state = ensure_score_state(self)
    SCORE_RUNTIME.record_launch_success(state, escaped_humans_alive_count or 0)
    local alive = 0
    if self.squad_units then
        for _, unit in pairs(self.squad_units) do
            if unit and (unit.current_health or 0) > 0 then
                alive = alive + 1
            end
        end
    end
    SCORE_RUNTIME.record_humans_alive_at_end(state, alive)
    SCORE_RUNTIME.record_mission_complete(state)
    score_log_snapshot(self, "launch_success")
end

function compute_placeholder_score_breakdown(self)
    local state = ensure_score_state(self)
    local result = SCORE_RUNTIME.compute_score(state)
    local m = result.metrics or {}
    local b = result.breakdown or {}
    local status = (LOOT_RUNTIME.get_launch_status and LOOT_RUNTIME.get_launch_status(self)) or {}
    local total_units = 0
    if self.squad_units then
        for _, _ in pairs(self.squad_units) do
            total_units = total_units + 1
        end
    end
    local objectives = 0
    if status.nav_ready then
        objectives = objectives + 1
    end
    if status.supplies_ready then
        objectives = objectives + 1
    end
    local seated = m.humans_escaped_on_launch or 0
    local survivors = math.max(seated, m.humans_alive_at_end or 0)
    local dead = math.max(0, total_units - (m.humans_alive_at_end or 0))
    return {
        survivors = survivors,
        seated = seated,
        dead = dead,
        power_units = status.power_loaded or 0,
        objectives = objectives,
        total = result.total or 0,
        score_breakdown = b,
        score_metrics = m
    }
end

function enter_flow_state(self, next_state)
    self.game_flow_state = next_state or FLOW_STATE_GAME
    self.flow_overlay_phase = 0
    self.flow_submit_done = false
end

local function spawn_exit_test_stash(self)
    if EXIT_TEST_STASH_ENABLED ~= true then
        return
    end
    if not (self.world_grid and self.level_library and self.current_level_index and LOOT_RUNTIME and LOOT_RUNTIME.create_world_item_instance) then
        return
    end
    local selected_level = self.level_library[self.current_level_index]
    if not selected_level then
        return
    end
    local cell5_id = nil
    for _, placement in ipairs(selected_level) do
        if placement and placement.tile == "exit" then
            cell5_id = coords_to_id(placement.x, placement.y)
            break
        end
    end
    if not (cell5_id and self.world_grid[cell5_id] and self.world_grid[cell5_id].tileID ~= hash("empty")) then
        return
    end
    -- for _ = 1, 9 do
    --     LOOT_RUNTIME.create_world_item_instance(self, "power", cell5_id, nil, { test_stash = true })
    -- end
    if LOOT_RUNTIME.refresh_world_item_visuals then
        LOOT_RUNTIME.refresh_world_item_visuals(self)
    end
    print("TEST STASH | Spawned exit cell-5 items (9x power).")
end

function start_solo_game_flow(self)
    self.multiplayer_mode_active = false
    if self.mp_state then
        self.mp_state.enabled = false
    end
    local selected = self.solo_setup and self.solo_setup.mission_type or self.selected_mission_type or MISSION_TYPE_ESCAPE
    self.selected_mission_type = multiplayer_normalize_mission_type(selected)
    self.controlled_unit_id = "sarge"
    local level_index = select_level_index_for_mission(self, self.selected_mission_type)
    reset_and_load_level(self, level_index)
    reset_derple_feedback_runtime(self)
    apply_aesthetic_mode(self)
    enter_flow_state(self, FLOW_STATE_GAME)
    self.game_won = false
end

solo_setup_init_runtime = function(self)
    self.solo_setup = self.solo_setup or {}
    self.solo_setup.mission_type = multiplayer_normalize_mission_type(self.solo_setup.mission_type or MISSION_TYPE_ESCAPE)
end

function start_multiplayer_game_flow(self, session_config)
    self.multiplayer_mode_active = true
    self.selected_mission_type = multiplayer_normalize_mission_type(session_config and session_config.mission_type or self.selected_mission_type or MISSION_TYPE_ESCAPE)
    if self.mp_state then
        self.mp_state.enabled = true
        self.mp_state.session_id = "local_session_" .. tostring(os.time())
        self.mp_state.mission_type = self.selected_mission_type
        local session_player_count = session_config and session_config.player_count or self.mp_state.player_count or 4
        self.mp_state.player_count = math.max(2, math.min(4, session_player_count))
        if session_config and session_config.seat_assignments then
            self.mp_state.seat_assignments = multiplayer_clone_seat_assignments(session_config.seat_assignments, self.mp_state.player_count)
        elseif not self.mp_state.seat_assignments then
            self.mp_state.seat_assignments = multiplayer_get_default_seat_assignments(self.mp_state.player_count)
        end
        self.mp_state.required_ready_player_ids = multiplayer_get_required_ready_player_ids_for_count(self.mp_state.player_count)
    end
    multiplayer_reset_ready_gate(self)
    if self.mp_state then
        self.mp_state.debug_active_player_id = self.mp_state.local_player_id or self.mp_state.host_player_id
    end
    local level_index = tonumber(session_config and session_config.level_index or 0) or 0
    if level_index < 1 or not (self.level_library and self.level_library[level_index]) then
        level_index = select_level_index_for_mission(self, self.selected_mission_type)
    end
    reset_and_load_level(self, level_index)
    multiplayer_enforce_controlled_unit(self, true)
    reset_derple_feedback_runtime(self)
    apply_aesthetic_mode(self)
    enter_flow_state(self, FLOW_STATE_GAME)
    self.game_won = false
end

multiplayer_setup_init_runtime = function(self)
    self.mp_setup = self.mp_setup or {}
    self.mp_setup.player_count = self.mp_setup.player_count or 2
    self.mp_setup.mission_type = multiplayer_normalize_mission_type(self.mp_setup.mission_type or MISSION_TYPE_ESCAPE)
    self.mp_setup.selected_unit_id = self.mp_setup.selected_unit_id or "techie"
    self.mp_setup.seat_slots = self.mp_setup.seat_slots or {}
    local defaults = multiplayer_get_default_seat_assignments(self.mp_setup.player_count)
    for _, player_id in ipairs(MP_SETUP_PLAYER_IDS) do
        local slot_count = multiplayer_get_slot_count_for_player(self.mp_setup.player_count, player_id)
        self.mp_setup.seat_slots[player_id] = {}
        for slot_index = 1, slot_count do
            self.mp_setup.seat_slots[player_id][slot_index] = false
        end
    end
    for player_id, units in pairs(defaults) do
        if self.mp_setup.seat_slots[player_id] then
            for slot_index, unit_id in ipairs(units) do
                if self.mp_setup.seat_slots[player_id][slot_index] ~= nil then
                    self.mp_setup.seat_slots[player_id][slot_index] = unit_id
                end
            end
        end
    end
end

multiplayer_setup_set_player_count = function(self, player_count)
    self.mp_setup = self.mp_setup or {}
    self.mp_setup.player_count = math.max(2, math.min(4, player_count or 2))
    self.mp_setup.mission_type = multiplayer_normalize_mission_type(self.mp_setup.mission_type or MISSION_TYPE_ESCAPE)
    self.mp_setup.selected_unit_id = "techie"
    self.mp_setup.seat_slots = {}
    local defaults = multiplayer_get_default_seat_assignments(self.mp_setup.player_count)
    for _, player_id in ipairs(MP_SETUP_PLAYER_IDS) do
        local slot_count = multiplayer_get_slot_count_for_player(self.mp_setup.player_count, player_id)
        self.mp_setup.seat_slots[player_id] = {}
        for slot_index = 1, slot_count do
            self.mp_setup.seat_slots[player_id][slot_index] = false
        end
    end
    for player_id, units in pairs(defaults) do
        for slot_index, unit_id in ipairs(units) do
            if self.mp_setup.seat_slots[player_id] and self.mp_setup.seat_slots[player_id][slot_index] ~= nil then
                self.mp_setup.seat_slots[player_id][slot_index] = unit_id
            end
        end
    end
end

multiplayer_setup_remove_unit_from_slots = function(self, unit_id)
    if not (self.mp_setup and self.mp_setup.seat_slots) then
        return
    end
    for _, player_id in ipairs(MP_SETUP_PLAYER_IDS) do
        local slots = self.mp_setup.seat_slots[player_id]
        if slots then
            for slot_index = 1, #slots do
                if slots[slot_index] == unit_id then
                    slots[slot_index] = false
                end
            end
        end
    end
end

multiplayer_setup_unit_assigned = function(self, unit_id)
    if not (self.mp_setup and self.mp_setup.seat_slots) then
        return false
    end
    for _, player_id in ipairs(MP_SETUP_PLAYER_IDS) do
        local slots = self.mp_setup.seat_slots[player_id]
        if slots then
            for slot_index = 1, #slots do
                if slots[slot_index] == unit_id then
                    return true
                end
            end
        end
    end
    return false
end

multiplayer_setup_is_valid = function(self)
    if not (self.mp_setup and self.mp_setup.seat_slots) then
        return false
    end
    local used = {}
    local total_assigned = 0
    local assigned_per_player = {}
    local count = self.mp_setup.player_count or 2
    for i = 1, count do
        local player_id = "p" .. tostring(i)
        local slot_count = multiplayer_get_slot_count_for_player(count, player_id)
        local slots = self.mp_setup.seat_slots[player_id] or {}
        local player_assigned = 0
        for slot_index = 1, slot_count do
            local unit_id = slots[slot_index]
            if unit_id and unit_id ~= false then
                if used[unit_id] then
                    return false
                end
                used[unit_id] = true
                total_assigned = total_assigned + 1
                player_assigned = player_assigned + 1
            end
        end
        assigned_per_player[player_id] = player_assigned
    end
    if total_assigned ~= #MP_SETUP_UNIT_IDS then
        return false
    end
    if multiplayer_get_player_for_unit(self.mp_setup.seat_slots, count, "sarge") ~= "p1" then
        return false
    end
    if count == 2 then
        if assigned_per_player.p1 ~= 2 or assigned_per_player.p2 ~= 2 then
            return false
        end
    elseif count == 3 then
        local p1 = assigned_per_player.p1 or 0
        local p2 = assigned_per_player.p2 or 0
        local p3 = assigned_per_player.p3 or 0
        if p1 < 1 or p1 > 2 or p2 < 1 or p2 > 2 or p3 < 1 or p3 > 2 then
            return false
        end
        local two_count = 0
        if p1 == 2 then two_count = two_count + 1 end
        if p2 == 2 then two_count = two_count + 1 end
        if p3 == 2 then two_count = two_count + 1 end
        if two_count ~= 1 then
            return false
        end
    elseif count == 4 then
        if (assigned_per_player.p1 or 0) ~= 1
            or (assigned_per_player.p2 or 0) ~= 1
            or (assigned_per_player.p3 or 0) ~= 1
            or (assigned_per_player.p4 or 0) ~= 1 then
            return false
        end
    end
    return true
end

multiplayer_setup_build_session_config = function(self)
    local count = self.mp_setup and self.mp_setup.player_count or 2
    local mission_type = multiplayer_normalize_mission_type(self.mp_setup and self.mp_setup.mission_type or MISSION_TYPE_ESCAPE)
    local compact = {}
    for i = 1, count do
        local player_id = "p" .. tostring(i)
        compact[player_id] = {}
        local slots = self.mp_setup and self.mp_setup.seat_slots and self.mp_setup.seat_slots[player_id] or {}
        local slot_count = multiplayer_get_slot_count_for_player(count, player_id)
        for slot_index = 1, slot_count do
            local unit_id = slots and slots[slot_index] or nil
            if unit_id and unit_id ~= false then
                table.insert(compact[player_id], unit_id)
            end
        end
    end
    return {
        player_count = count,
        seat_assignments = compact,
        mission_type = mission_type
    }
end

multiplayer_setup_apply_session_config = function(self, session_config)
    if type(session_config) ~= "table" then
        return
    end
    local player_count = math.max(2, math.min(4, tonumber(session_config.player_count or 2) or 2))
    multiplayer_setup_set_player_count(self, player_count)
    self.mp_setup.mission_type = multiplayer_normalize_mission_type(session_config.mission_type or self.mp_setup.mission_type or MISSION_TYPE_ESCAPE)
    local assignments = multiplayer_clone_seat_assignments(session_config.seat_assignments or {}, player_count)
    for _, player_id in ipairs(MP_SETUP_PLAYER_IDS) do
        local slot_count = multiplayer_get_slot_count_for_player(player_count, player_id)
        self.mp_setup.seat_slots[player_id] = self.mp_setup.seat_slots[player_id] or {}
        for slot_index = 1, slot_count do
            self.mp_setup.seat_slots[player_id][slot_index] = false
        end
        local units = assignments[player_id] or {}
        for slot_index = 1, math.min(slot_count, #units) do
            self.mp_setup.seat_slots[player_id][slot_index] = units[slot_index]
        end
    end
end

multiplayer_setup_push_state = function(self)
    if not (self.mp_state and self.mp_state.enabled) then
        return
    end
    if self.mp_state.local_player_id ~= self.mp_state.host_player_id then
        return
    end
    multiplayer_transport_send_command(self, "push_setup_state", {
        session_config = multiplayer_setup_build_session_config(self)
    }, self.mp_state.local_player_id)
end

function enter_outro_flow_from_launch(self)
    self.flow_score_breakdown = compute_placeholder_score_breakdown(self)
    self.flow_outro_timer = 0
    self.flow_submit_done = false
    self.drag_resource = { active = false }
    self.is_panning = false
    self.did_drag = false
    enter_flow_state(self, FLOW_STATE_OUTRO)
    print("FLOW | launch -> outro")
end

function enter_score_flow(self)
    if not self.flow_score_breakdown then
        self.flow_score_breakdown = compute_placeholder_score_breakdown(self)
    end
    enter_flow_state(self, FLOW_STATE_SCORE)
    local s = self.flow_score_breakdown
    print(string.format(
        "SCORE | total=%d survivors=%d seated=%d power=%d objectives=%d dead=%d",
        s.total or 0,
        s.survivors or 0,
        s.seated or 0,
        s.power_units or 0,
        s.objectives or 0,
        s.dead or 0
    ))
end


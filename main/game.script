--[[
    Pre-defined tiles that can be placed in level designs
    Each tile defines a 3x3 area with specific properties
]]

function create_tile_library()
    local library = {}

    local function assign_random_loot_cell(tile)
        for i = 1, 9 do
            tile.cells[i].hasLoot = false
        end
        local idx = math.random(1, 9)
        tile.cells[idx].hasLoot = true
    end

------ Example Tile 1: "corridor" - simple passage--------------------------------------------------
    local corridor = create_tile_prototype("corridor")
    -- Set all cells to be passable corridors
    for i = 1, 9 do
        corridor.cells[i].lightValue = 2
        corridor.cells[i].moveValue = 1
        corridor.cells[i].coverValue = 1
    end

    -- Add walls to specific cells (example: create a corridor pattern)
    --     -- Cell layout: 7 8 9
    --     --              4 5 6
    --     --              1 2 3
    corridor.cells[1].accessDown = false 
    corridor.cells[2].accessDown = false
    --corridor.cells[2].moveValue = 3 -- NOTE ROOMS WITH LADDERS DONT NEED a move value of 3, just 1. (hardcoded - vert moves always cost 3 AP)
    corridor.cells[3].accessDown = false
    corridor.cells[3].accessRight = false 
    corridor.cells[4].accessDown = false
    corridor.cells[6].accessDown = false
    corridor.cells[7].accessDown = false
    corridor.cells[8].accessDown = false 
    corridor.cells[9].accessRight = false 
    --corridor.cells[4].accessRight = false  -- Wall on right of cell 4
    --corridor.cells[6].accessRight = false  -- Wall on right of cell 6

    corridor.cells[5].object1 = {
        name = hash("power_node"),
        isFixed = true,
        dependsOn = 0,
        isDependentOn = {},
        objectId = 0,
        offsetX = 0,
        offsetY = 0,
        hitW = 32,
        hitH = 32,
        requiredComponent = nil
    }

    assign_random_loot_cell(corridor)
    library["corridor"] = corridor


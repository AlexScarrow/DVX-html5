        if not multiplayer_player_owns_unit(self, sender, unit_id) then
            table.insert(events, multiplayer_transport_emit_event(self, "command_rejected", {
                command_type = "toggle_door",
                reason = "unit_not_owned_by_sender"
            }))
            return events
        end
        local unit = self.squad_units and self.squad_units[unit_id] or nil
        local owner_cell, door_obj = get_door_by_object_id(self.world_grid, object_id)
        if not unit or not owner_cell or not door_obj then
            table.insert(events, multiplayer_transport_emit_event(self, "command_rejected", {
                command_type = "toggle_door",
                reason = "invalid_door_target"
            }))
            return events
        end
        if not can_unit_reach_door_toggle(unit, owner_cell.idNumber) then
            table.insert(events, multiplayer_transport_emit_event(self, "command_rejected", {
                command_type = "toggle_door",
                reason = "too_far_away"
            }))

function is_point_in_screen_rect(screen_x, screen_y, cx, cy, w, h)
    local half_w = w * 0.5
    local half_h = h * 0.5
    return screen_x >= (cx - half_w)
        and screen_x <= (cx + half_w)
        and screen_y >= (cy - half_h)
        and screen_y <= (cy + half_h)
end

function ensure_score_state(self)
    local mission_type = get_current_mission_type(self)
    local score_profile_id = "escape_pod"
    if mission_type == MISSION_TYPE_RESCUE then
        score_profile_id = "escort"
    elseif mission_type == MISSION_TYPE_PURGE then
        score_profile_id = "purge_and_power"
    elseif mission_type == MISSION_TYPE_DNA_SAMPLE then
        score_profile_id = "holdout"
    end
    if not self.score_state then
        self.score_state = SCORE_RUNTIME.create_state(score_profile_id)
    else
        self.score_state = SCORE_RUNTIME.set_mission_type(self.score_state, score_profile_id)
    end
    return self.score_state
end

function get_current_score_total(self)
    local state = ensure_score_state(self)
    local result = SCORE_RUNTIME.compute_score(state)
    local total = math.max(0, math.floor((result and result.total) or 0))
    self.score_display_total = math.max(self.score_display_total or 0, total)
    return self.score_display_total
end

function update_score_hud(self, visible)
    if not self.ui or not self.ui.score_digit_icons then
        return
    end
    local hidden = vmath.vector4(0, 0, 0, 0)
    if visible ~= true then
        for _, digit_id in ipairs(self.ui.score_digit_icons) do
            set_ui_square_transform(self, digit_id, -9999, -9999, SCORE_HUD_Z, hidden, SCORE_HUD_DIGIT_DRAW_W * 0.021, SCORE_HUD_DIGIT_DRAW_H * 0.021)
        end
        update_ranged_hit_preview_hud(self, false)
        return
    end

    local score_text = tostring(get_current_score_total(self))
    if #score_text > SCORE_HUD_MAX_DIGITS then
        score_text = string.sub(score_text, #score_text - SCORE_HUD_MAX_DIGITS + 1)
    end
    local count = #score_text
    local start_x = SCORE_HUD_CENTER_X - ((count - 1) * SCORE_HUD_DIGIT_SPACING_PX * 0.5)
    for idx, digit_id in ipairs(self.ui.score_digit_icons) do
        if idx <= count then
            local ch = string.sub(score_text, idx, idx)
            msg.post(msg.url(nil, digit_id, "sprite"), "play_animation", { id = hash("score_" .. ch) })
            local dx = start_x + ((idx - 1) * SCORE_HUD_DIGIT_SPACING_PX)
            set_ui_square_transform(
                self,
                digit_id,
                dx,
                SCORE_HUD_Y,
                SCORE_HUD_Z,
                vmath.vector4(1, 1, 1, 1),
                SCORE_HUD_DIGIT_DRAW_W * 0.021,
                SCORE_HUD_DIGIT_DRAW_H * 0.021
            )
        else
            set_ui_square_transform(self, digit_id, -9999, -9999, SCORE_HUD_Z, hidden, SCORE_HUD_DIGIT_DRAW_W * 0.021, SCORE_HUD_DIGIT_DRAW_H * 0.021)
        end
    end
    update_ranged_hit_preview_hud(self, true)
end

local function get_purge_timer_display_text(self)
    local status = get_purge_mission_status(self)
    if status.timer_started ~= true then
        return "0500"
    end
    local total_seconds = math.max(0, tonumber(status.remaining_s or 0) or 0)
    local mins = math.floor(total_seconds / 60)
    local secs = total_seconds % 60
    return string.format("%02d%02d", mins, secs)
end

local function update_purge_timer_hud(self, visible)
    if not self.ui or not self.ui.purge_timer_digit_icons then
        return
    end
    local hidden = vmath.vector4(0, 0, 0, 0)
    local status = get_purge_mission_status(self)
    if visible ~= true or not purge_is_active_mission(self) or status.timer_started ~= true then
        for _, digit_id in ipairs(self.ui.purge_timer_digit_icons) do
            set_ui_square_transform(
                self,
                digit_id,
                -9999,
                -9999,
                PURGE_TIMER_HUD_Z,
                hidden,
                PURGE_TIMER_HUD_DIGIT_DRAW_W * 0.021,
                PURGE_TIMER_HUD_DIGIT_DRAW_H * 0.021
            )
        end
        return
    end
    local text = get_purge_timer_display_text(self)
    local count = #text
    local start_x = PURGE_TIMER_HUD_CENTER_X - ((count - 1) * PURGE_TIMER_HUD_DIGIT_SPACING_PX * 0.5)
    local tint = vmath.vector4(1, 1, 1, 1)
    if status.remaining_s <= 60 then
        tint = vmath.vector4(1, 0.5, 0.4, 1)
    end
    for i, digit_id in ipairs(self.ui.purge_timer_digit_icons) do
        local ch = string.sub(text, i, i)
        msg.post(msg.url(nil, digit_id, "sprite"), "play_animation", { id = hash("score_" .. ch) })
        local dx = start_x + ((i - 1) * PURGE_TIMER_HUD_DIGIT_SPACING_PX)
        set_ui_square_transform(
            self,
            digit_id,
            dx,
            PURGE_TIMER_HUD_Y,
            PURGE_TIMER_HUD_Z,
            tint,
            PURGE_TIMER_HUD_DIGIT_DRAW_W * 0.021,
            PURGE_TIMER_HUD_DIGIT_DRAW_H * 0.021
        )
    end
end

local function get_objective_reminder_anim_id(self)
    local mission_type = multiplayer_normalize_mission_type(get_current_mission_type(self))
    if mission_type == MISSION_TYPE_RESCUE then
        return hash("objective_rescue")
    elseif mission_type == MISSION_TYPE_PURGE then
        return hash("objective_purge")
    elseif mission_type == MISSION_TYPE_DNA_SAMPLE then
        return hash("objective_dna")
    end
    return hash("objective_escape")
end

local function update_objective_ui(self, visible)
    if not self.ui then
        return
    end
    local hidden = vmath.vector4(0, 0, 0, 0)
    if visible ~= true then
        set_ui_square_transform(self, self.ui.objective_button, -9999, -9999, OBJECTIVE_BUTTON_Z, hidden, 1, 1)
        set_ui_square_transform(self, self.ui.objective_reminder, -9999, -9999, OBJECTIVE_REMINDER_Z, hidden, 1, 1)
        return
    end
    set_ui_square_transform(
        self,
        self.ui.objective_button,
        OBJECTIVE_BUTTON_X,
        OBJECTIVE_BUTTON_Y,
        OBJECTIVE_BUTTON_Z,
        vmath.vector4(1, 1, 1, 1),
        1,
        1
    )
    if self.objective_reminder_visible == true then
        msg.post(msg.url(nil, self.ui.objective_reminder, "sprite"), "play_animation", { id = get_objective_reminder_anim_id(self) })
        set_ui_square_transform(
            self,
            self.ui.objective_reminder,
            OBJECTIVE_REMINDER_X,
            OBJECTIVE_REMINDER_Y,
            OBJECTIVE_REMINDER_Z,
            vmath.vector4(1, 1, 1, 1),
            1,
            1
        )
    else
        set_ui_square_transform(self, self.ui.objective_reminder, -9999, -9999, OBJECTIVE_REMINDER_Z, hidden, 1, 1)
    end
end

function score_log_snapshot(self, label)
    local state = ensure_score_state(self)
    local result = SCORE_RUNTIME.compute_score(state)
    local b = result.breakdown or {}
    local m = result.metrics or {}
    print(string.format(
        "SCORE TRACE [%s] total=%d | kills=%d tiles=%d escaped=%d turns=%d eff=%d win=%d",
        tostring(label or "event"),
        result.total or 0,
        b.aliens_killed_points or 0,
        b.tiles_powered_points or 0,
        b.humans_escaped_points or 0,
        m.turns_elapsed or 0,
        b.efficiency_points or 0,
        b.win_bonus_points or 0
    ))
    print(string.format(
        "UI DEBUG | SCORE [%s] total=%d turns=%d kills=%d tiles=%d escaped=%d",
        tostring(label or "event"),
        result.total or 0,
        m.turns_elapsed or 0,
        m.aliens_killed_total or 0,
        m.tiles_powered_first_time or 0,
        m.humans_escaped_on_launch or 0
    ))
end

function score_record_turn_started(self)
    self.score_turn_counter = (self.score_turn_counter or 0) + 1
    SCORE_RUNTIME.record_turn_started(ensure_score_state(self), self.score_turn_counter)
    score_log_snapshot(self, "turn_started")
end

function score_record_alien_kill(self, alien_type)
    SCORE_RUNTIME.record_alien_killed(ensure_score_state(self), alien_type)
    score_log_snapshot(self, "alien_killed")
end

function score_record_tile_powered_first_time(self, tile_instance_id)
    SCORE_RUNTIME.record_tile_powered(ensure_score_state(self), tile_instance_id)
    score_log_snapshot(self, "tile_powered")
end

function score_record_launch_success(self, escaped_humans_alive_count)
    local state = ensure_score_state(self)
    SCORE_RUNTIME.record_launch_success(state, escaped_humans_alive_count or 0)
    local alive = 0
    if self.squad_units then
        for _, unit in pairs(self.squad_units) do
            if unit and (unit.current_health or 0) > 0 then
                alive = alive + 1
            end
        end
    end
    SCORE_RUNTIME.record_humans_alive_at_end(state, alive)
    SCORE_RUNTIME.record_mission_complete(state)
    score_log_snapshot(self, "launch_success")
end

function score_record_civilian_escorted(self, civilian_id)
    local state = ensure_score_state(self)
    SCORE_RUNTIME.record_civilian_escorted(state, civilian_id)
    score_log_snapshot(self, "civilian_escorted")
end

function compute_placeholder_score_breakdown(self)
    local state = ensure_score_state(self)
    local result = SCORE_RUNTIME.compute_score(state)
    local m = result.metrics or {}
    local b = result.breakdown or {}
    local status = (LOOT_RUNTIME.get_launch_status and LOOT_RUNTIME.get_launch_status(self)) or {}
    local total_units = 0
    if self.squad_units then
        for _, _ in pairs(self.squad_units) do
            total_units = total_units + 1
        end
    end
    local objectives = 0
    if status.nav_ready then
        objectives = objectives + 1
    end
    if status.supplies_ready then
        objectives = objectives + 1
    end
    local seated = m.humans_escaped_on_launch or 0
    local survivors = math.max(seated, m.humans_alive_at_end or 0)
    local dead = math.max(0, total_units - (m.humans_alive_at_end or 0))
    return {
        survivors = survivors,
        seated = seated,
        dead = dead,
        power_units = status.power_loaded or 0,
        objectives = objectives,
        total = result.total or 0,
        score_breakdown = b,
        score_metrics = m
    }
end

function enter_flow_state(self, next_state)
    self.game_flow_state = next_state or FLOW_STATE_GAME
    self.flow_overlay_phase = 0
    self.flow_submit_done = false
end

set_sound_loop_state = function(self, key, should_play)
    if not self or not self.sfx_state then
        return
    end
    if self.sfx_state.loops ~= true then
        return
    end
    if self.sfx_state.enabled_by_key and self.sfx_state.enabled_by_key[key] ~= true then
        return
    end
    local entry = self.sfx_state[key]
    if not entry or not entry.url then
        return
    end
    if should_play and not entry.playing then
        entry.playing = true
        print(string.format("SFX TRACE | play %s", tostring(key)))
        pcall(msg.post, entry.url, "play_sound")
    elseif (not should_play) and entry.playing then
        entry.playing = false
        print(string.format("SFX TRACE | stop %s", tostring(key)))
        pcall(msg.post, entry.url, "stop_sound")
    end
end

play_sfx_one_shot = function(self, key)
    if not self or not self.sfx_state then
        return
    end
    if self.sfx_state.loops ~= true then
        return
    end
    if self.sfx_state.enabled_by_key and self.sfx_state.enabled_by_key[key] ~= true then
        return
    end
    local entry = self.sfx_state[key]
    if not entry or not entry.url then
        return
    end
    print(string.format("SFX TRACE | oneshot %s", tostring(key)))
    pcall(msg.post, entry.url, "play_sound")
end


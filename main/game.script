--[[
    DERPLES VS XENOS - Main Game Script
    This script manages the core game systems including:
    - Cell and Tile data structures
    - WorldGrid management (15x15 cells)
    - Level design and "baking down" process
    - Pathfinding for characters
    - Input handling for cell selection
    - Camera scrolling and zooming
]]

-- =============================================================================
-- CONSTANTS
-- =============================================================================
-- luacheck: globals DERPLE_FEEDBACK_LOW_HP_RATIO DERPLE_FEEDBACK_LOS_SCAN_INTERVAL
-- luacheck: globals LEVEL_BUTTON_Y LEVEL_BUTTON_W LEVEL_BUTTON_H LEVEL1_BUTTON_X LEVEL_BUTTON_GAP LEVEL_BUTTON_Z
-- luacheck: globals UI_COLOR_AP UI_COLOR_HP UI_COLOR_AMMO UI_COLOR_SLOT UI_COLOR_SLOT_ACTIVE
-- luacheck: globals NEW_TURN_BUTTON_X NEW_TURN_BUTTON_Y NEW_TURN_BUTTON_W NEW_TURN_BUTTON_H NEW_TURN_BUTTON_Z
-- luacheck: globals LAUNCH_BUTTON_X LAUNCH_BUTTON_Y LAUNCH_BUTTON_W LAUNCH_BUTTON_H LAUNCH_BUTTON_Z
-- luacheck: globals FLOW_UI_OVERLAY_Z FLOW_UI_PANEL_Z FLOW_UI_BUTTON_Z FLOW_UI_SCREEN_W FLOW_UI_SCREEN_H
-- luacheck: globals FLOW_STATE_TITLE FLOW_STATE_GAME FLOW_STATE_OUTRO FLOW_STATE_SCORE FLOW_STATE_MP_SETUP EXIT_TEST_STASH_ENABLED
-- luacheck: globals AESTHETIC_BUTTON_X AESTHETIC_BUTTON_Y AESTHETIC_BUTTON_W AESTHETIC_BUTTON_H AESTHETIC_BUTTON_Z
-- luacheck: globals ZOOM_IN_BUTTON_X ZOOM_IN_BUTTON_Y ZOOM_IN_BUTTON_W ZOOM_IN_BUTTON_H ZOOM_IN_BUTTON_Z
-- luacheck: globals ZOOM_OUT_BUTTON_X ZOOM_OUT_BUTTON_Y ZOOM_OUT_BUTTON_W ZOOM_OUT_BUTTON_H ZOOM_OUT_BUTTON_Z
-- luacheck: globals ENTRY_FIRE_OFFSET_X ENTRY_FIRE_OFFSET_Y ENTRY_FIRE_Z ENTRY_FIRE_ROTATION_DEG
-- luacheck: globals EXIT_GREEN_SMOKE_Z EXIT_GREEN_SMOKE_CELL3_BOTTOM_OFFSET_X EXIT_GREEN_SMOKE_CELL3_BOTTOM_OFFSET_Y
-- luacheck: globals MELEE_RUNTIME TURRET_REACTIVE_FIRE_INTERVAL_SECONDS TURRET_PROJECTILE_SPEED
-- luacheck: globals TURRET_BURST_PROJECTILE_COUNT TURRET_BURST_PROJECTILE_DELAY TURRET_BURST_SPREAD_PIXELS
-- luacheck: globals HUMAN_REACTIVE_FIRE_INTERVAL_SECONDS
-- luacheck: globals AESTHETIC_MODE_COMPUTER AESTHETIC_MODE_BOARDGAME AESTHETIC_PROFILES
-- luacheck: globals get_vent_neighbors_for_path get_blip_fallback_staging_target get_blip_cell_offset apply_blip_pulse_scale
-- luacheck: globals get_fixed_viewport_rect map_window_input_to_logical enforce_fixed_window_size
-- luacheck: globals request_zoom_to request_zoom_delta update_smooth_zoom
-- luacheck: globals get_counter_shadow_offset get_counter_shadow_anim_for_alien get_alien_anim_for_aesthetic
-- luacheck: globals get_counter_shadow_anim_for_human ensure_counter_shadow_proxy clear_counter_shadow_proxy
-- luacheck: globals schedule_counter_shadow_proxy_clear PANEL_ART_ANIM_BY_CLASS_ID get_unit_panel_anim
-- luacheck: globals get_ui_panel_close_button_center get_ui_panel_reactive_button_center count_non_nil_entries
-- luacheck: globals collect_runtime_reference_counts log_runtime_reference_audit
-- luacheck: globals get_aesthetic_profile get_world_shadow_alpha get_ui_panel_shadow_alpha get_human_anim_for_aesthetic
-- luacheck: globals apply_human_aesthetic_animations apply_alien_aesthetic_animations apply_computer_emissive_accents
-- luacheck: globals apply_aesthetic_mode apply_backdrop_emissive_tint update_backdrop_cloud_fx
-- luacheck: globals set_aesthetic_mode toggle_aesthetic_mode
-- luacheck: globals apply_brute_alpha_pulse
-- luacheck: globals get_obstacle_move_speed_multiplier


                MP_NET_STATUS_DOT_H
            )
        end
        set_ui_square_transform(self, self.ui.flow_panel, -9999, -9999, FLOW_UI_PANEL_Z, hidden, FLOW_UI_SCREEN_W, FLOW_UI_SCREEN_H)
        set_ui_square_transform(self, self.ui.flow_title_tutorial_button, -9999, -9999, FLOW_UI_BUTTON_Z, hidden, 280, 70)
        set_ui_square_transform(self, self.ui.flow_title_solo_button, -9999, -9999, FLOW_UI_BUTTON_Z, hidden, 280, 70)
        set_ui_square_transform(self, self.ui.flow_title_multiplayer_button, -9999, -9999, FLOW_UI_BUTTON_Z, hidden, 280, 70)
        set_ui_square_transform(self, self.ui.flow_outro_slide, -9999, -9999, FLOW_UI_PANEL_Z + 0.001, hidden, OUTRO_SLIDE_DEFAULT_W * 0.021, OUTRO_SLIDE_DEFAULT_H * 0.021)
        set_ui_square_transform(self, self.ui.flow_outro_ship, -9999, -9999, FLOW_UI_PANEL_Z, hidden, 280, 120)
        set_ui_square_transform(self, self.ui.flow_outro_skip_button, -9999, -9999, FLOW_UI_BUTTON_Z, hidden, 170, 52)
        set_ui_square_transform(self, self.ui.flow_score_submit_button, -9999, -9999, FLOW_UI_BUTTON_Z, hidden, 250, 56)
        set_ui_square_transform(self, self.ui.flow_score_title_button, -9999, -9999, FLOW_UI_BUTTON_Z, hidden, 250, 56)
        set_ui_square_transform(self, self.ui.flow_mp_setup_panel, MP_SETUP_PANEL_X, MP_SETUP_PANEL_Y, MP_SETUP_PANEL_Z, vmath.vector4(1, 1, 1, 1), MP_SETUP_PANEL_W * 0.021, MP_SETUP_PANEL_H * 0.021)
        if self.ui.flow_mp_mission_buttons then
            local selected_mission = multiplayer_normalize_mission_type(self.mp_setup and self.mp_setup.mission_type or MISSION_TYPE_ESCAPE)
            for i, btn in ipairs(self.ui.flow_mp_mission_buttons) do
                local mission_type = MP_SETUP_MISSION_TYPES[i] or MISSION_TYPE_ESCAPE
                local is_active = (mission_type == selected_mission)
                local tint = is_active and vmath.vector4(1, 1, 1, 1) or vmath.vector4(0.72, 0.72, 0.72, 1)
                set_ui_square_transform(
                    self,
                    btn,
                    MP_SETUP_MISSION_BTN_X[i],
                    MP_SETUP_MISSION_BTN_Y,
                    MP_SETUP_UI_Z,
                    tint,
                    MP_SETUP_MISSION_BTN_W * 0.021,
                    MP_SETUP_MISSION_BTN_H * 0.021
                )
            end
        end
        local count_x = { MP_SETUP_BTN_2P_X, MP_SETUP_BTN_3P_X, MP_SETUP_BTN_4P_X }
        if self.ui.flow_mp_count_buttons then
            for i, btn in ipairs(self.ui.flow_mp_count_buttons) do
                local is_active = (i + 1) == (self.mp_setup and self.mp_setup.player_count or 2)
                local tint = is_active and vmath.vector4(1, 1, 1, 1) or vmath.vector4(0.65, 0.65, 0.65, 1)
                set_ui_square_transform(self, btn, count_x[i], MP_SETUP_COUNT_BTN_Y, MP_SETUP_UI_Z, tint, MP_SETUP_COUNT_BTN_W * 0.021, MP_SETUP_COUNT_BTN_H * 0.021)
            end
        end
        local active_idx = math.max(1, math.min(3, (self.mp_setup and self.mp_setup.player_count or 2) - 1))
        set_ui_square_transform(self, self.ui.flow_mp_count_active_ring, count_x[active_idx] + 4, MP_SETUP_COUNT_BTN_Y, MP_SETUP_UI_Z, vmath.vector4(1, 1, 1, 1), MP_SETUP_COUNT_ACTIVE_RING_W * 0.021, MP_SETUP_COUNT_ACTIVE_RING_H * 0.021)
        set_ui_square_transform(self, self.ui.flow_mp_back_button, MP_SETUP_BACK_BTN_X, MP_SETUP_BACK_BTN_Y, MP_SETUP_UI_Z, vmath.vector4(1, 1, 1, 1), MP_SETUP_ACTION_BTN_W * 0.021, MP_SETUP_ACTION_BTN_H * 0.021)
        set_ui_square_transform(self, self.ui.flow_mp_start_button, MP_SETUP_START_BTN_X, MP_SETUP_START_BTN_Y, MP_SETUP_UI_Z, valid and vmath.vector4(1, 1, 1, 1) or vmath.vector4(0.65, 0.65, 0.65, 1), MP_SETUP_ACTION_BTN_W * 0.021, MP_SETUP_ACTION_BTN_H * 0.021)
        set_ui_square_transform(self, self.ui.flow_mp_start_enabled_glow, MP_SETUP_START_BTN_X, MP_SETUP_START_BTN_Y, MP_SETUP_UI_Z - 0.001, valid and vmath.vector4(1, 1, 1, 0.95) or hidden, MP_SETUP_START_GLOW_W * 0.021, MP_SETUP_START_GLOW_H * 0.021)
        set_ui_square_transform(self, self.ui.flow_mp_start_disabled_overlay, MP_SETUP_START_BTN_X, MP_SETUP_START_BTN_Y, MP_SETUP_UI_Z + 0.001, valid and hidden or vmath.vector4(1, 1, 1, 0.92), MP_SETUP_ACTION_BTN_W * 0.021, MP_SETUP_ACTION_BTN_H * 0.021)
        if self.ui.flow_mp_unit_buttons then
            local pulse = 1 + (0.06 * math.sin((self.flow_overlay_phase or 0) * 8))
            for i, btn in ipairs(self.ui.flow_mp_unit_buttons) do
                local unit_id = MP_SETUP_UNIT_IDS[i]
                local selected = self.mp_setup and self.mp_setup.selected_unit_id == unit_id
                local assigned = multiplayer_setup_unit_assigned(self, unit_id)
                local tint = nil
                if unit_id == "sarge" then
                    tint = vmath.vector4(0.45, 0.45, 0.45, 1)
                else
                    tint = selected and vmath.vector4(0.2, 1, 1, 1) or (assigned and vmath.vector4(0.75, 0.75, 0.75, 1) or vmath.vector4(1, 1, 1, 1))
                end
                local chip_scale = selected and pulse or 1
                local unit_pool_y = MP_SETUP_UNIT_POOL_Y_BY_INDEX[i] or MP_SETUP_UNIT_POOL_Y_BY_INDEX[1] or 114
                set_ui_square_transform(self, btn, MP_SETUP_UNIT_POOL_X[i], unit_pool_y, MP_SETUP_UI_Z, tint, (MP_SETUP_UNIT_POOL_W * 0.021) * chip_scale, (MP_SETUP_UNIT_POOL_H * 0.021) * chip_scale)
            end
        end
        if self.ui.flow_mp_slot_icons then
            for seat_index, player_id in ipairs(MP_SETUP_PLAYER_IDS) do
                local slot_count = multiplayer_get_slot_count_for_player(self.mp_setup and self.mp_setup.player_count or 2, player_id)
                local slot_x = MP_SETUP_SEAT_X[seat_index] + MP_SETUP_SLOT_X_OFFSET
                for slot_index, slot_icon in ipairs(self.ui.flow_mp_slot_icons[player_id] or {}) do
                    if slot_index <= slot_count then
                        local unit_id = self.mp_setup and self.mp_setup.seat_slots and self.mp_setup.seat_slots[player_id] and self.mp_setup.seat_slots[player_id][slot_index] or false
                        if unit_id and unit_id ~= false then
                            msg.post(msg.url(nil, slot_icon, "sprite"), "play_animation", { id = multiplayer_get_unit_anim_id(unit_id) })
                            set_ui_square_transform(self, slot_icon, slot_x, MP_SETUP_SLOT_Y[slot_index], MP_SETUP_UI_Z + 0.002, vmath.vector4(1, 1, 1, 1), MP_SETUP_SLOT_W * 0.021, MP_SETUP_SLOT_H * 0.021)
                        else
                            set_ui_square_transform(self, slot_icon, slot_x, MP_SETUP_SLOT_Y[slot_index], MP_SETUP_UI_Z + 0.002, hidden, MP_SETUP_SLOT_W * 0.021, MP_SETUP_SLOT_H * 0.021)
                        end
                    else
                        set_ui_square_transform(self, slot_icon, -9999, -9999, MP_SETUP_UI_Z + 0.002, hidden, MP_SETUP_SLOT_W * 0.021, MP_SETUP_SLOT_H * 0.021)
                    end
                end
            end
        end
        if self.ui.flow_score_rows then
            for _, row_id in ipairs(self.ui.flow_score_rows) do
                set_ui_square_transform(self, row_id, -9999, -9999, FLOW_UI_PANEL_Z, hidden, 300, 28)
            end
        end
        return
    end
    if state == FLOW_STATE_OUTRO then
        local wobble = math.sin((self.flow_overlay_phase or 0) * 2.4) * 12
        set_ui_square_transform(self, self.ui.flow_panel, SCREEN_WIDTH * 0.5, SCREEN_HEIGHT * 0.5, FLOW_UI_PANEL_Z, vmath.vector4(0.12, 0.12, 0.18, 1), FLOW_UI_SCREEN_W, FLOW_UI_SCREEN_H)
        set_ui_square_transform(self, self.ui.flow_outro_slide, SCREEN_WIDTH * 0.5, SCREEN_HEIGHT * 0.56, FLOW_UI_PANEL_Z + 0.001, vmath.vector4(1, 1, 1, 1), OUTRO_SLIDE_DEFAULT_W * 0.021, OUTRO_SLIDE_DEFAULT_H * 0.021)
        if self.outro_slideshow_state then
            set_ui_square_transform(self, self.ui.flow_outro_ship, -9999, -9999, FLOW_UI_PANEL_Z, hidden, 280, 120)
        else
            set_ui_square_transform(self, self.ui.flow_outro_ship, (SCREEN_WIDTH * 0.5) + wobble, SCREEN_HEIGHT * 0.56, FLOW_UI_PANEL_Z, vmath.vector4(0.78, 0.82, 0.95, 0.97), 280, 120)
        end
        set_ui_square_transform(self, self.ui.flow_outro_skip_button, SCREEN_WIDTH - 110, 54, FLOW_UI_BUTTON_Z, vmath.vector4(0.82, 0.36, 0.2, 0.98), 170, 52)
        set_ui_square_transform(self, self.ui.flow_title_tutorial_button, -9999, -9999, FLOW_UI_BUTTON_Z, hidden, 280, 70)
        set_ui_square_transform(self, self.ui.flow_title_solo_button, -9999, -9999, FLOW_UI_BUTTON_Z, hidden, 280, 70)
        set_ui_square_transform(self, self.ui.flow_title_multiplayer_button, -9999, -9999, FLOW_UI_BUTTON_Z, hidden, 280, 70)
        set_ui_square_transform(self, self.ui.flow_mp_setup_panel, -9999, -9999, MP_SETUP_PANEL_Z, hidden, MP_SETUP_PANEL_W * 0.021, MP_SETUP_PANEL_H * 0.021)
        if self.ui.flow_mp_mission_buttons then
            for _, btn in ipairs(self.ui.flow_mp_mission_buttons) do
                set_ui_square_transform(self, btn, -9999, -9999, MP_SETUP_UI_Z, hidden, MP_SETUP_MISSION_BTN_W * 0.021, MP_SETUP_MISSION_BTN_H * 0.021)
            end
        end
        if self.ui.flow_mp_count_buttons then
            for _, btn in ipairs(self.ui.flow_mp_count_buttons) do
                set_ui_square_transform(self, btn, -9999, -9999, MP_SETUP_UI_Z, hidden, MP_SETUP_COUNT_BTN_W * 0.021, MP_SETUP_COUNT_BTN_H * 0.021)
            end
        end
        set_ui_square_transform(self, self.ui.flow_mp_count_active_ring, -9999, -9999, MP_SETUP_UI_Z, hidden, MP_SETUP_COUNT_ACTIVE_RING_W * 0.021, MP_SETUP_COUNT_ACTIVE_RING_H * 0.021)
        set_ui_square_transform(self, self.ui.flow_mp_back_button, -9999, -9999, MP_SETUP_UI_Z, hidden, MP_SETUP_ACTION_BTN_W * 0.021, MP_SETUP_ACTION_BTN_H * 0.021)
        set_ui_square_transform(self, self.ui.flow_mp_start_button, -9999, -9999, MP_SETUP_UI_Z, hidden, MP_SETUP_ACTION_BTN_W * 0.021, MP_SETUP_ACTION_BTN_H * 0.021)
        set_ui_square_transform(self, self.ui.flow_mp_start_disabled_overlay, -9999, -9999, MP_SETUP_UI_Z + 0.001, hidden, MP_SETUP_ACTION_BTN_W * 0.021, MP_SETUP_ACTION_BTN_H * 0.021)
        set_ui_square_transform(self, self.ui.flow_mp_start_enabled_glow, -9999, -9999, MP_SETUP_UI_Z - 0.001, hidden, MP_SETUP_START_GLOW_W * 0.021, MP_SETUP_START_GLOW_H * 0.021)
        if self.ui.flow_mp_unit_buttons then
            for _, btn in ipairs(self.ui.flow_mp_unit_buttons) do
                set_ui_square_transform(self, btn, -9999, -9999, MP_SETUP_UI_Z, hidden, MP_SETUP_UNIT_POOL_W * 0.021, MP_SETUP_UNIT_POOL_H * 0.021)
            end
        end
        if self.ui.flow_mp_slot_icons then
            for _, slot_icons in pairs(self.ui.flow_mp_slot_icons) do
                for _, slot_icon in ipairs(slot_icons) do
                    set_ui_square_transform(self, slot_icon, -9999, -9999, MP_SETUP_UI_Z + 0.002, hidden, MP_SETUP_SLOT_W * 0.021, MP_SETUP_SLOT_H * 0.021)
                end
            end
        end
        set_ui_square_transform(self, self.ui.flow_score_submit_button, -9999, -9999, FLOW_UI_BUTTON_Z, hidden, 250, 56)
        set_ui_square_transform(self, self.ui.flow_score_title_button, -9999, -9999, FLOW_UI_BUTTON_Z, hidden, 250, 56)
        if self.ui.flow_score_rows then
            for _, row_id in ipairs(self.ui.flow_score_rows) do
                set_ui_square_transform(self, row_id, -9999, -9999, FLOW_UI_PANEL_Z, hidden, 300, 28)
            end
        end
        return
    end
    local s = self.flow_score_breakdown or { survivors = 0, seated = 0, power_units = 0, objectives = 0, total = 0 }
    set_ui_square_transform(self, self.ui.flow_panel, SCREEN_WIDTH * 0.5, SCREEN_HEIGHT * 0.5, FLOW_UI_PANEL_Z, vmath.vector4(0.07, 0.13, 0.09, 1), FLOW_UI_SCREEN_W, FLOW_UI_SCREEN_H)
    set_ui_square_transform(self, self.ui.flow_score_submit_button, SCREEN_WIDTH * 0.5, SCREEN_HEIGHT * 0.28, FLOW_UI_BUTTON_Z, self.flow_submit_done and vmath.vector4(0.2, 0.65, 0.22, 0.95) or vmath.vector4(0.2, 0.45, 0.75, 0.95), 250, 56)
    set_ui_square_transform(self, self.ui.flow_score_title_button, SCREEN_WIDTH * 0.5, SCREEN_HEIGHT * 0.17, FLOW_UI_BUTTON_Z, vmath.vector4(0.72, 0.24, 0.24, 0.95), 250, 56)
    set_ui_square_transform(self, self.ui.flow_title_tutorial_button, -9999, -9999, FLOW_UI_BUTTON_Z, hidden, 280, 70)
    set_ui_square_transform(self, self.ui.flow_title_solo_button, -9999, -9999, FLOW_UI_BUTTON_Z, hidden, 280, 70)
    set_ui_square_transform(self, self.ui.flow_title_multiplayer_button, -9999, -9999, FLOW_UI_BUTTON_Z, hidden, 280, 70)
    set_ui_square_transform(self, self.ui.flow_mp_setup_panel, -9999, -9999, MP_SETUP_PANEL_Z, hidden, MP_SETUP_PANEL_W * 0.021, MP_SETUP_PANEL_H * 0.021)
    if self.ui.flow_mp_mission_buttons then
        for _, btn in ipairs(self.ui.flow_mp_mission_buttons) do
            set_ui_square_transform(self, btn, -9999, -9999, MP_SETUP_UI_Z, hidden, MP_SETUP_MISSION_BTN_W * 0.021, MP_SETUP_MISSION_BTN_H * 0.021)
        end
    end
    if self.ui.flow_mp_count_buttons then
        for _, btn in ipairs(self.ui.flow_mp_count_buttons) do
            set_ui_square_transform(self, btn, -9999, -9999, MP_SETUP_UI_Z, hidden, MP_SETUP_COUNT_BTN_W * 0.021, MP_SETUP_COUNT_BTN_H * 0.021)
        end
    end
    set_ui_square_transform(self, self.ui.flow_mp_count_active_ring, -9999, -9999, MP_SETUP_UI_Z, hidden, MP_SETUP_COUNT_ACTIVE_RING_W * 0.021, MP_SETUP_COUNT_ACTIVE_RING_H * 0.021)
    set_ui_square_transform(self, self.ui.flow_mp_back_button, -9999, -9999, MP_SETUP_UI_Z, hidden, MP_SETUP_ACTION_BTN_W * 0.021, MP_SETUP_ACTION_BTN_H * 0.021)
    set_ui_square_transform(self, self.ui.flow_mp_start_button, -9999, -9999, MP_SETUP_UI_Z, hidden, MP_SETUP_ACTION_BTN_W * 0.021, MP_SETUP_ACTION_BTN_H * 0.021)
    set_ui_square_transform(self, self.ui.flow_mp_start_disabled_overlay, -9999, -9999, MP_SETUP_UI_Z + 0.001, hidden, MP_SETUP_ACTION_BTN_W * 0.021, MP_SETUP_ACTION_BTN_H * 0.021)
    set_ui_square_transform(self, self.ui.flow_mp_start_enabled_glow, -9999, -9999, MP_SETUP_UI_Z - 0.001, hidden, MP_SETUP_START_GLOW_W * 0.021, MP_SETUP_START_GLOW_H * 0.021)
    if self.ui.flow_mp_unit_buttons then
        for _, btn in ipairs(self.ui.flow_mp_unit_buttons) do
            set_ui_square_transform(self, btn, -9999, -9999, MP_SETUP_UI_Z, hidden, MP_SETUP_UNIT_POOL_W * 0.021, MP_SETUP_UNIT_POOL_H * 0.021)
        end
    end
    if self.ui.flow_mp_slot_icons then
        for _, slot_icons in pairs(self.ui.flow_mp_slot_icons) do
            for _, slot_icon in ipairs(slot_icons) do
                set_ui_square_transform(self, slot_icon, -9999, -9999, MP_SETUP_UI_Z + 0.002, hidden, MP_SETUP_SLOT_W * 0.021, MP_SETUP_SLOT_H * 0.021)
            end
        end
    end
    set_ui_square_transform(self, self.ui.flow_outro_slide, -9999, -9999, FLOW_UI_PANEL_Z + 0.001, hidden, OUTRO_SLIDE_DEFAULT_W * 0.021, OUTRO_SLIDE_DEFAULT_H * 0.021)
    set_ui_square_transform(self, self.ui.flow_outro_ship, -9999, -9999, FLOW_UI_PANEL_Z, hidden, 280, 120)
    set_ui_square_transform(self, self.ui.flow_outro_skip_button, -9999, -9999, FLOW_UI_BUTTON_Z, hidden, 170, 52)
    if self.ui.flow_score_rows then
        local vals = {
            math.max(0, s.survivors or 0) * 28,
            math.max(0, s.seated or 0) * 28,
            math.max(0, s.power_units or 0) * 12,
            math.max(0, s.objectives or 0) * 70
        }
        local cols = {
            vmath.vector4(0.24, 0.78, 0.34, 0.95),
            vmath.vector4(0.35, 0.75, 0.9, 0.95),
            vmath.vector4(0.95, 0.85, 0.24, 0.95),
            vmath.vector4(0.9, 0.48, 0.92, 0.95)
        }
        local y = SCREEN_HEIGHT * 0.67
        for i, row_id in ipairs(self.ui.flow_score_rows) do
            local w = math.min(300, math.max(90, vals[i] or 90))
            set_ui_square_transform(self, row_id, SCREEN_WIDTH * 0.5, y - ((i - 1) * 52), FLOW_UI_PANEL_Z, cols[i] or vmath.vector4(0.7, 0.7, 0.7, 0.9), w, 28)
        end
    end
end

multiplayer_setup_handle_touch = function(self, input_x, input_y)
    if self.mp_state and self.mp_state.local_player_id ~= self.mp_state.host_player_id then
        print("MP SETUP | only host may edit setup.")
        return true
    end
    for i, mission_type in ipairs(MP_SETUP_MISSION_TYPES) do
        if is_point_in_screen_rect(
            input_x,
            input_y,
            MP_SETUP_MISSION_BTN_X[i],
            MP_SETUP_MISSION_BTN_Y,
            MP_SETUP_MISSION_BTN_W,
            MP_SETUP_MISSION_BTN_H
        ) then
            self.mp_setup.mission_type = multiplayer_normalize_mission_type(mission_type)
            multiplayer_setup_push_state(self)
            return true
        end
    end
    local count_buttons = {
        { x = MP_SETUP_BTN_2P_X, count = 2 },
        { x = MP_SETUP_BTN_3P_X, count = 3 },
        { x = MP_SETUP_BTN_4P_X, count = 4 }
    }
    for _, btn in ipairs(count_buttons) do
        if is_point_in_screen_rect(input_x, input_y, btn.x, MP_SETUP_COUNT_BTN_Y, MP_SETUP_COUNT_BTN_W, MP_SETUP_COUNT_BTN_H) then
            multiplayer_setup_set_player_count(self, btn.count)
            multiplayer_setup_push_state(self)
            return true
        end
    end
    if is_point_in_screen_rect(input_x, input_y, MP_SETUP_BACK_BTN_X, MP_SETUP_BACK_BTN_Y, MP_SETUP_ACTION_BTN_W, MP_SETUP_ACTION_BTN_H) then
        if self.mp_state then
            self.mp_state.enabled = false
        end
        self.multiplayer_mode_active = false
        enter_flow_state(self, FLOW_STATE_TITLE)
        return true
    end
    if is_point_in_screen_rect(input_x, input_y, MP_SETUP_START_BTN_X, MP_SETUP_START_BTN_Y, MP_SETUP_ACTION_BTN_W, MP_SETUP_ACTION_BTN_H) then
        if multiplayer_setup_is_valid(self) then
            multiplayer_transport_send_command(self, "start_match_request", {
                session_config = multiplayer_setup_build_session_config(self)
            }, self.mp_state and self.mp_state.local_player_id or "p1")
        else
            print("MP SETUP | invalid assignment: each active seat must be filled, unique units, and Sarge must stay on p1.")
        end
        return true
    end
    for i, unit_id in ipairs(MP_SETUP_UNIT_IDS) do
        local unit_pool_y = MP_SETUP_UNIT_POOL_Y_BY_INDEX[i] or MP_SETUP_UNIT_POOL_Y_BY_INDEX[1] or 114
        if is_point_in_screen_rect(input_x, input_y, MP_SETUP_UNIT_POOL_X[i], unit_pool_y, MP_SETUP_UNIT_POOL_W, MP_SETUP_UNIT_POOL_H) then
            if unit_id == "sarge" then
                print("MP SETUP | Sarge is host-locked to p1.")
                return true
            end
            self.mp_setup.selected_unit_id = unit_id
            multiplayer_setup_push_state(self)
            return true
        end
    end
    local player_count = self.mp_setup and self.mp_setup.player_count or 2
    for seat_index, player_id in ipairs(MP_SETUP_PLAYER_IDS) do
        local slot_count = multiplayer_get_slot_count_for_player(player_count, player_id)
        local slot_x = MP_SETUP_SEAT_X[seat_index] + MP_SETUP_SLOT_X_OFFSET
        for slot_index = 1, slot_count do
            if is_point_in_screen_rect(input_x, input_y, slot_x, MP_SETUP_SLOT_Y[slot_index], MP_SETUP_SLOT_W, MP_SETUP_SLOT_H) then
                local selected_unit_id = self.mp_setup and self.mp_setup.selected_unit_id or nil
                local current_unit_id = self.mp_setup and self.mp_setup.seat_slots and self.mp_setup.seat_slots[player_id] and self.mp_setup.seat_slots[player_id][slot_index] or false
                if selected_unit_id and selected_unit_id ~= false then
                    if selected_unit_id == "sarge" and player_id ~= "p1" then
                        print("MP SETUP | blocked: Sarge must stay on p1.")
                        return true
                    end
                    if current_unit_id == "sarge" then
                        print("MP SETUP | blocked: Sarge must stay on p1.")
                        return true
                    end
                    if current_unit_id == selected_unit_id then
                        return true
                    end
                    multiplayer_setup_remove_unit_from_slots(self, selected_unit_id)
                    if current_unit_id and current_unit_id ~= false then
                        if current_unit_id ~= "sarge" then
                            self.mp_setup.selected_unit_id = current_unit_id
                        end
                    end
                    self.mp_setup.seat_slots[player_id][slot_index] = selected_unit_id
                elseif current_unit_id and current_unit_id ~= false then
                    if current_unit_id == "sarge" and player_id == "p1" then
                        print("MP SETUP | blocked: Sarge must stay on p1.")
                        return true
                    end
                    self.mp_setup.seat_slots[player_id][slot_index] = false
                    self.mp_setup.selected_unit_id = current_unit_id
                end
                multiplayer_setup_push_state(self)
                return true
            end
        end
    end
    return true
end

solo_setup_handle_touch = function(self, input_x, input_y)
    for i, mission_type in ipairs(MP_SETUP_MISSION_TYPES) do
        if is_point_in_screen_rect(
            input_x,
            input_y,
            SOLO_SETUP_EXPLAINER_X[i],
            SOLO_SETUP_EXPLAINER_Y,
            SOLO_SETUP_EXPLAINER_W,
            SOLO_SETUP_EXPLAINER_H
        ) then
            solo_setup_init_runtime(self)
            self.solo_setup.mission_type = multiplayer_normalize_mission_type(mission_type)
            return true
        end
    end
    if is_point_in_screen_rect(input_x, input_y, MP_SETUP_BACK_BTN_X, MP_SETUP_BACK_BTN_Y, MP_SETUP_ACTION_BTN_W, MP_SETUP_ACTION_BTN_H) then
        enter_flow_state(self, FLOW_STATE_TITLE)
        return true
    end
    if is_point_in_screen_rect(input_x, input_y, MP_SETUP_START_BTN_X, MP_SETUP_START_BTN_Y, MP_SETUP_ACTION_BTN_W, MP_SETUP_ACTION_BTN_H) then
        start_solo_game_flow(self)
        return true
    end
    return true
end

function handle_flow_touch(self, input_x, input_y)
    local state = self.game_flow_state or FLOW_STATE_GAME
    if state == FLOW_STATE_TITLE then
        if is_point_in_screen_rect(input_x, input_y, TITLE_TUTORIAL_BUTTON_X, TITLE_TUTORIAL_BUTTON_Y, 280, 70) then
            start_tutorial_game_flow(self)
            return true
        end
        if is_point_in_screen_rect(input_x, input_y, TITLE_SOLO_BUTTON_X, TITLE_SOLO_BUTTON_Y, 280, 70) then
            solo_setup_init_runtime(self)
            enter_flow_state(self, FLOW_STATE_SOLO_SETUP)
            return true
        end
        if is_point_in_screen_rect(input_x, input_y, TITLE_MULTIPLAYER_BUTTON_X, TITLE_MULTIPLAYER_BUTTON_Y, 280, 70) then
            self.multiplayer_mode_active = true
            if self.mp_state then
                self.mp_state.enabled = true
                self.mp_state.debug_active_player_id = self.mp_state.local_player_id
            end
            multiplayer_setup_init_runtime(self)
            enter_flow_state(self, FLOW_STATE_MP_SETUP)
            if self.mp_state and self.mp_state.local_player_id == self.mp_state.host_player_id then
                multiplayer_setup_push_state(self)
            elseif self.mp_state and self.mp_state.local_player_id ~= self.mp_state.host_player_id then
                multiplayer_transport_send_command(self, "request_setup_state", {}, self.mp_state.local_player_id)
            end
            return true
        end
        return true
    end
    if state == FLOW_STATE_MP_SETUP then
        return multiplayer_setup_handle_touch(self, input_x, input_y)
    end
    if state == FLOW_STATE_SOLO_SETUP then
        return solo_setup_handle_touch(self, input_x, input_y)
    end
    if state == FLOW_STATE_OUTRO then
        if is_point_in_screen_rect(input_x, input_y, SCREEN_WIDTH - 110, 54, 170, 52) then
            if self.outro_slideshow_state then
                OUTRO_SLIDESHOW.skip(self.outro_slideshow_state)
            else
                enter_score_flow(self)
            end
            return true
        end
        return true
    end
    if state == FLOW_STATE_SCORE then
        if is_point_in_screen_rect(input_x, input_y, SCREEN_WIDTH * 0.5, SCREEN_HEIGHT * 0.28, 250, 56) then
            self.flow_submit_done = true
            print("SCORE | leaderboard submit hook (placeholder)")
            return true
        end
        if is_point_in_screen_rect(input_x, input_y, SCREEN_WIDTH * 0.5, SCREEN_HEIGHT * 0.17, 250, 56) then
            enter_flow_state(self, FLOW_STATE_TITLE)
            self.game_won = false
            return true
        end
        return true
    end
    return false
end

local function get_selected_unit(self)
    if not self.squad_units then
        return nil
    end
    for _, unit in pairs(self.squad_units) do
        if unit.is_selected then
            return unit
        end
    end
    return nil
end

function reset_and_load_level(self, level_index)
    if not self.level_library or not self.level_library[level_index] then
        print("Level index not found: " .. tostring(level_index))
        return false
    end

    self.current_level_index = level_index
    local level_def = self.level_library and self.level_library[level_index] or nil
    local level_mission = get_level_mission_type(level_def)
    self.current_mission_type = multiplayer_normalize_mission_type(
        self.selected_mission_type or (self.mp_state and self.mp_state.mission_type) or level_mission
    )
    if self and self.sfx_state then
        self.sfx_state.vertical_active_by_unit = {}
        self.sfx_state.vertical_active_count = 0
        self.sfx_state.horizontal_active_by_actor = {}
        self.sfx_state.horizontal_active_count = 0
        self.sfx_state.speedy_active_count = 0
        set_sound_loop_state(self, "human_vertical", false)
        set_sound_loop_state(self, "human_horizontal", false)
        stop_speedy_move_sfx(self)
    end
    if self.mp_state and self.mp_state.enabled then
        self.mp_state.mission_type = self.current_mission_type
    end
    log_runtime_reference_audit(self, "pre_clear")
    clear_path_visuals(self)
    self.selected_start_cell = nil
    self.path_highlight_cells = {}
    self.ui_close_on_next_non_unit_click = false
    self.awaiting_slot_shuffle_click = false
    clear_ranged_hit_preview(self)

    local function safe_delete(go_id)
        if go_id then
            pcall(go.delete, go_id)
        end
    end
    local function safe_delete_map(map_table)
        if not map_table then
            return
        end
        for key, go_id in pairs(map_table) do
            safe_delete(go_id)
            map_table[key] = nil
        end
    end
    local function safe_delete_array(list_table)
        if not list_table then
            return
        end
        for i, go_id in ipairs(list_table) do
            safe_delete(go_id)
            list_table[i] = nil
        end
    end

    if self.sheen_overlay then
        go.delete(self.sheen_overlay)
        self.sheen_overlay = nil
    end
    if self.table_sweep_shadow_overlay then
        go.delete(self.table_sweep_shadow_overlay)
        self.table_sweep_shadow_overlay = nil
        self.table_sweep_shadow_anim = nil
    end
    if self.world_backdrop then
        go.delete(self.world_backdrop)
        self.world_backdrop = nil
        self.world_backdrop_anim = nil
    end
    if self.backdrop_cloud_fx then
        go.delete(self.backdrop_cloud_fx)
        self.backdrop_cloud_fx = nil
    end
    if self.world_backdrop_tiles then
        safe_delete_array(self.world_backdrop_tiles)
        self.world_backdrop_anim = nil
    end
    self.tile_base_objects = nil
    safe_delete_array(tile_objects)
    safe_delete_map(self.tile_room_shadows)
    safe_delete_map(self.entry_fire_fx_objects)
    safe_delete_map(self.exit_green_smoke_fx_objects)
    safe_delete_map(cell_objects)
    safe_delete_map(loot_objects)
    safe_delete_map(self.loot_shadow_objects)
    safe_delete_map(machine_objects)
    safe_delete_map(self.tile_light_layers)
    safe_delete_map(self.tile_alpha_layers)
    safe_delete_map(self.fix_objects)
    safe_delete_map(self.power_node_objects)
    safe_delete_map(self.vent_objects)
    safe_delete_map(self.door_objects)
    safe_delete_map(self.civilian_visuals)
    safe_delete_map(self.civilian_shadow_visuals)
    safe_delete_map(self.civilian_hp_bar_bg_visuals)
    safe_delete_map(self.civilian_hp_bar_fill_visuals)
    safe_delete_map(self.machine_shadow_objects)
    safe_delete_map(self.turret_shadow_objects)
    safe_delete_map(self.power_node_shadow_objects)
    safe_delete_array(self.escape_pod_power_slot_markers)
    safe_delete_map(self.vent_shadow_objects)
    safe_delete_map(self.door_shadow_objects)
    safe_delete_map(self.turret_tripod_objects)
    safe_delete_map(self.turret_gun_objects)
    safe_delete_array(self.wiregap_objects)
    safe_delete_array(self.wiregap_shadow_objects)
    safe_delete_array(self.wiregap_fx_objects)
    safe_delete_array(self.light_value_objects)
    safe_delete_array(self.dna_lab_progress_markers)
    safe_delete_map(self.ladder_markers)
    safe_delete_array(self.workshop_conveyor_tokens)
    safe_delete_map(self.workshop_underlay_visuals)
    self.workshop_states = {}
    if self.aliens then
        for _, alien in ipairs(self.aliens) do
            safe_delete(alien and alien.go_id)
        end
    end
    if self.spitter_projectiles then
        for _, p in ipairs(self.spitter_projectiles) do
            if p and p.go_id then
                go.delete(p.go_id)
            end
        end
    end
    if self.turret_projectiles then
        for _, p in ipairs(self.turret_projectiles) do
            if p and p.go_id then
                go.delete(p.go_id)
            end
        end
    end

    if self.world_item_visuals then
        for _, go_id in pairs(self.world_item_visuals) do
            if go_id then
                go.delete(go_id)
            end
        end
    end
    if self.world_item_shadow_visuals then
        for _, go_id in pairs(self.world_item_shadow_visuals) do
            if go_id then
                go.delete(go_id)
            end
        end
    end
    if self.power_node_loop_fx then
        for _, fx_id in pairs(self.power_node_loop_fx) do
            if fx_id then
                go.delete(fx_id)
            end
        end
    end
    if self.melee_swipe_fx then
        for _, fx in pairs(self.melee_swipe_fx) do
            if fx and fx.go_id then
                go.delete(fx.go_id)
            end
        end
    end

    self.tile_library = require("main.tile_defs").create_tile_library(COMPONENT_UI)
    self.level_library = require("main.level_defs").create_level_library()
    self.world_grid = create_world_grid()
    self.world_grid = bake_level_to_world_grid(self.world_grid, self.level_library[level_index], self.tile_library)

    self.alien_turn_active = false
    self.alien_turn_waiting_for_advance = false
    self.alien_turn_manual_pause = false
    self.pending_spitter_attack_phase = false
    self.spitter_attack_started = false
    self.spitter_attack_timer = 0
    self.spitter_attack_queue = {}
    self.spitter_projectiles = {}
    self.pending_melee_attack_phase = false
    self.melee_attack_started = false
    self.melee_attack_timer = 0
    self.melee_action_queue = {}
    self.melee_ap_left_by_alien_id = {}
    self.turret_projectiles = {}
    self.turret_pending_shots = {}
    self.next_turret_shot_id = 0
    self.turret_last_human_cell_by_id = {}
    self.turret_last_alien_cell_by_id = {}
    self.turret_fire_cooldown_by_object_id = {}
    self.turret_fired_this_alien_turn_by_object_id = {}
    self.human_reactive_fire_cooldown_by_unit_id = {}
    self.human_reactive_pending_delay_by_unit_id = {}
    self.loot_pickup_blips = {}
    self.world_item_instances = {}
    self.world_item_visuals = {}
    self.world_item_shadow_visuals = {}
    self.loot_shadow_objects = {}
    self.machine_shadow_objects = {}
    self.turret_shadow_objects = {}
    self.power_node_shadow_objects = {}
    self.vent_shadow_objects = {}
    self.door_shadow_objects = {}
    self.entry_fire_fx_objects = {}
    self.exit_green_smoke_fx_objects = {}
    self.exit_green_smoke_fx_power_state = {}
    self.wiregap_shadow_objects = {}
    self.next_world_item_id = 0
    self.drag_resource = { active = false }
    self.civilian_turn_waiting_for_alien = false
    self.exit_objective_state = nil
    self.dna_analysis_progress = 0
    self.dna_analysis_complete = false
    self.dna_sample_spawned = false
    self.dna_sample_returned = false
    self.purge_bomb_planted = false
    self.purge_timer_started = false
    self.purge_launch_pressed = false
    self.purge_time_expired = false
    self.purge_result_locked = false
    self.purge_deadline_epoch_ms = 0
    self.end_result = ""
    self.end_mission_type = ""
    self.end_outro_sequence_id = ""
    self.end_reason = ""
    self.end_session_origin = ""
    self.outro_slideshow_state = nil
    self.outro_fx_instances = {}
    self.outro_slide_anim_id = nil
    self.tutorial_mode = false
    self.tutorial_completed = false
    self.tutorial_overlay_active = false
    self.tutorial_step_index = nil
    self.tutorial_anchor_world_x = nil
    self.tutorial_anchor_world_y = nil
    self.tutorial_panel_screen_x = nil
    self.tutorial_panel_screen_y = nil
    self.nightvision_reveal_unit_id = nil
    self.nightvision_reveal_tile_id = 0
    self.nightvision_reveal_hold_timer = 0
    self.nightvision_reveal_alpha = 0
    self.launch_fx_timer = 0
    self.game_won = false
    self.score_turn_counter = 0
    self.score_state = nil
    ensure_score_state(self)
    self.score_display_total = 0
    self.power_node_loop_fx = {}
    self.melee_swipe_fx = {}
    self.melee_swipe_next_id = 0
    log_runtime_reference_audit(self, "post_clear")

    self.squad_units = create_squad_units()
    self.controlled_unit_id = "sarge"
    self.aliens = {}
    self.next_alien_id = 0
    clear_civilian_visuals(self)
    self.civilians = {}
    self.next_civilian_id = 0
    self.civilians = {}
    self.next_civilian_id = 0
    self.civilian_visuals = {}
    self.civilian_shadow_visuals = {}
    self.civilian_hp_bar_bg_visuals = {}
    self.civilian_hp_bar_fill_visuals = {}
    self.civilian_hp_bar_bg_visuals = {}
    self.civilian_hp_bar_fill_visuals = {}

    spawn_visuals(self)
    apply_aesthetic_mode(self)
    if self.spawn_human_unit_fn then
        self.spawn_human_unit_fn(self)
    else
        spawn_human_unit(self)
    end
    spawn_initial_blips(self, INITIAL_BLIP_COUNT)
    spawn_civilians_for_current_mission(self)
    refresh_civilian_visuals(self)
    print("SCORE TRACE READY | scoring runtime initialized")
    score_log_snapshot(self, "level_reset")
    spawn_exit_test_stash(self)
    LOOT_RUNTIME.refresh_exit_objective_state(self)
    refresh_dna_marker_runtime(self)
    update_human_visual_state(self)
    update_selected_unit_ui(self)
    if self.mp_state and self.mp_state.enabled then
        multiplayer_enforce_controlled_unit(self, true)
    end
    log_runtime_reference_audit(self, "post_load")
    print("Loaded level " .. tostring(level_index))
    return true
end

local function get_level_button_screen_x(level_index)
    return LEVEL1_BUTTON_X + ((level_index - 1) * (LEVEL_BUTTON_W + LEVEL_BUTTON_GAP))
end

function update_global_ui_buttons(self)
    if (self.game_flow_state or FLOW_STATE_GAME) ~= FLOW_STATE_GAME then
        local hidden = vmath.vector4(0, 0, 0, 0)
        set_ui_square_transform(self, self.ui.new_turn_button, -9999, -9999, NEW_TURN_BUTTON_Z, hidden, NEW_TURN_BUTTON_W, NEW_TURN_BUTTON_H)
        if self.ui.ready_buttons then
            for _, btn in ipairs(self.ui.ready_buttons) do
                set_ui_square_transform(self, btn, -9999, -9999, MULTIPLAYER_READY_BUTTON_Z, hidden, MULTIPLAYER_READY_ICON_DRAW_SIZE * 0.021, MULTIPLAYER_READY_ICON_DRAW_SIZE * 0.021)
            end
        end
        if self.ui.mp_debug_player_buttons then
            for _, btn in ipairs(self.ui.mp_debug_player_buttons) do
                set_ui_square_transform(self, btn, -9999, -9999, MULTIPLAYER_DEBUG_BUTTON_Z, hidden, MULTIPLAYER_DEBUG_BUTTON_DRAW_SIZE * 0.021, MULTIPLAYER_DEBUG_BUTTON_DRAW_SIZE * 0.021)
            end
        end
        set_ui_square_transform(self, self.ui.launch_button, -9999, -9999, LAUNCH_BUTTON_Z, hidden, LAUNCH_BUTTON_W, LAUNCH_BUTTON_H)
        set_ui_square_transform(self, self.ui.realtime_toggle_button, -9999, -9999, LAUNCH_BUTTON_Z, hidden, REALTIME_TOGGLE_BUTTON_DRAW_W * 0.021, REALTIME_TOGGLE_BUTTON_DRAW_H * 0.021)
        set_ui_square_transform(self, self.ui.aesthetic_toggle_button, -9999, -9999, AESTHETIC_BUTTON_Z, hidden, AESTHETIC_BUTTON_W, AESTHETIC_BUTTON_H)
        set_ui_square_transform(self, self.ui.zoom_in_button, -9999, -9999, ZOOM_IN_BUTTON_Z, hidden, ZOOM_IN_BUTTON_W, ZOOM_IN_BUTTON_H)
        set_ui_square_transform(self, self.ui.zoom_out_button, -9999, -9999, ZOOM_OUT_BUTTON_Z, hidden, ZOOM_OUT_BUTTON_W, ZOOM_OUT_BUTTON_H)
        set_ui_square_transform(self, self.ui.transport_status_dot, -9999, -9999, MP_NET_STATUS_DOT_Z, hidden, MP_NET_STATUS_DOT_W, MP_NET_STATUS_DOT_H)
        update_objective_ui(self, false)
        update_score_hud(self, false)
        return
    end
    local tutorial_locked = tutorial_rules_locked and tutorial_rules_locked(self)
    local alien_cycle_active = self.alien_turn_active
        or self.pending_spitter_attack_phase
        or self.pending_melee_attack_phase
        or any_alien_is_moving(self)
    if self.realtime_rules_enabled == true then
        set_ui_square_transform(
            self,
            self.ui.new_turn_button,
            -9999,
            -9999,
            NEW_TURN_BUTTON_Z,
            vmath.vector4(0, 0, 0, 0),
            NEW_TURN_BUTTON_W,
            NEW_TURN_BUTTON_H
        )
        update_multiplayer_new_turn_button_visual(self)
    elseif tutorial_locked then
        set_ui_square_transform(
            self,
            self.ui.new_turn_button,
            NEW_TURN_BUTTON_X,
            NEW_TURN_BUTTON_Y,
            NEW_TURN_BUTTON_Z,
            vmath.vector4(0.85, 0.2, 0.2, 0.95),
            NEW_TURN_BUTTON_VISUAL_SCALE,
            NEW_TURN_BUTTON_VISUAL_SCALE
        )
        update_multiplayer_new_turn_button_visual(self)
    elseif alien_cycle_active then
        set_ui_square_transform(
            self,
            self.ui.new_turn_button,
            -9999,
            -9999,
            NEW_TURN_BUTTON_Z,
            vmath.vector4(0, 0, 0, 0),
            NEW_TURN_BUTTON_W,
            NEW_TURN_BUTTON_H
        )
        update_multiplayer_new_turn_button_visual(self)
    else
        local new_turn_button_w = NEW_TURN_BUTTON_VISUAL_SCALE
        local new_turn_button_h = NEW_TURN_BUTTON_VISUAL_SCALE
        if self.mp_state and self.mp_state.enabled and self.mp_state.local_player_id ~= self.mp_state.host_player_id then
            new_turn_button_w = 1.0
            new_turn_button_h = 0.8
        end
        set_ui_square_transform(
            self,
            self.ui.new_turn_button,
            NEW_TURN_BUTTON_X,
            NEW_TURN_BUTTON_Y,
            NEW_TURN_BUTTON_Z,
            vmath.vector4(1, 1, 1, 1),
            new_turn_button_w,
            new_turn_button_h
        )
        update_multiplayer_new_turn_button_visual(self)
    end
    if self.ui.ready_buttons then
        local hidden = vmath.vector4(0, 0, 0, 0)
        if self.mp_state and self.mp_state.enabled and self.mp_state.local_player_id == self.mp_state.host_player_id and self.mp_state.required_ready_player_ids then
            for i, btn in ipairs(self.ui.ready_buttons) do
                local player_id = self.mp_state.required_ready_player_ids[i]
                if player_id then
                    local ready_on = self.mp_state.ready_by_player_id[player_id] == true
                    local color = ready_on and vmath.vector4(0.2, 0.8, 0.3, 0.95) or vmath.vector4(0.75, 0.2, 0.2, 0.95)
                    local bx = get_multiplayer_ready_button_x(i)
                    set_ui_square_transform(self, btn, bx, MULTIPLAYER_READY_BUTTON_Y, MULTIPLAYER_READY_BUTTON_Z, color, MULTIPLAYER_READY_ICON_DRAW_SIZE * 0.021, MULTIPLAYER_READY_ICON_DRAW_SIZE * 0.021)
                else
                    set_ui_square_transform(self, btn, -9999, -9999, MULTIPLAYER_READY_BUTTON_Z, hidden, MULTIPLAYER_READY_ICON_DRAW_SIZE * 0.021, MULTIPLAYER_READY_ICON_DRAW_SIZE * 0.021)
                end
            end
        else
            for _, btn in ipairs(self.ui.ready_buttons) do
                set_ui_square_transform(self, btn, -9999, -9999, MULTIPLAYER_READY_BUTTON_Z, hidden, MULTIPLAYER_READY_ICON_DRAW_SIZE * 0.021, MULTIPLAYER_READY_ICON_DRAW_SIZE * 0.021)
            end
        end
    end
    if self.ui.mp_debug_player_buttons then
        local hidden = vmath.vector4(0, 0, 0, 0)
        local can_show_debug_switch = self.mp_state
            and self.mp_state.enabled
            and self.mp_state.local_player_id == self.mp_state.host_player_id
        if can_show_debug_switch and self.mp_state.required_ready_player_ids then
            for i, btn in ipairs(self.ui.mp_debug_player_buttons) do
                local by = MULTIPLAYER_DEBUG_BUTTON_START_Y - ((i - 1) * MULTIPLAYER_DEBUG_BUTTON_Y_GAP)
                local player_id = self.mp_state.required_ready_player_ids[i]
                if player_id then
                    local remote_connected = (player_id ~= self.mp_state.host_player_id)
                        and self.mp_state.connected_players
                        and self.mp_state.connected_players[player_id] == true
                    local active = self.mp_state.debug_active_player_id == player_id
                    local tint = nil
                    if remote_connected then
                        tint = vmath.vector4(0.4, 0.4, 0.4, 0.7)
                    else
                        tint = active and vmath.vector4(0.2, 0.95, 1, 0.95) or vmath.vector4(1, 1, 1, 0.9)
                    end
                    set_ui_square_transform(self, btn, MULTIPLAYER_DEBUG_BUTTON_X, by, MULTIPLAYER_DEBUG_BUTTON_Z, tint, MULTIPLAYER_DEBUG_BUTTON_DRAW_SIZE * 0.021, MULTIPLAYER_DEBUG_BUTTON_DRAW_SIZE * 0.021)
                    msg.post(msg.url(nil, btn, "sprite"), "play_animation", { id = hash("score_" .. tostring(i + 1)) })
                else
                    set_ui_square_transform(self, btn, -9999, -9999, MULTIPLAYER_DEBUG_BUTTON_Z, hidden, MULTIPLAYER_DEBUG_BUTTON_DRAW_SIZE * 0.021, MULTIPLAYER_DEBUG_BUTTON_DRAW_SIZE * 0.021)
                end
            end
        else
            for _, btn in ipairs(self.ui.mp_debug_player_buttons) do
                set_ui_square_transform(self, btn, -9999, -9999, MULTIPLAYER_DEBUG_BUTTON_Z, hidden, MULTIPLAYER_DEBUG_BUTTON_DRAW_SIZE * 0.021, MULTIPLAYER_DEBUG_BUTTON_DRAW_SIZE * 0.021)
            end
        end
    end
    local launch_status = LOOT_RUNTIME.get_launch_status and LOOT_RUNTIME.get_launch_status(self) or nil
    local launch_color = vmath.vector4(0.72, 0.2, 0.2, 0.95)
    if self.game_won then
        launch_color = vmath.vector4(0.95, 0.9, 0.2, 0.98)
    elseif launch_status and launch_status.can_launch then
        launch_color = vmath.vector4(0.2, 0.78, 0.3, 0.95)
    end
    if self.mp_state and self.mp_state.enabled and self.mp_state.local_player_id ~= self.mp_state.host_player_id then
        launch_color = vmath.vector4(0.35, 0.35, 0.35, 0.95)
    end
    local realtime_btn_color = vmath.vector4(1, 1, 1, 1)
    update_realtime_toggle_button_visual(self)
    set_ui_square_transform(
        self,
        self.ui.launch_button,
        LAUNCH_BUTTON_X,
        LAUNCH_BUTTON_Y,
        LAUNCH_BUTTON_Z,
        launch_color,
        LAUNCH_BUTTON_W,
        LAUNCH_BUTTON_H
    )
    set_ui_square_transform(
        self,
        self.ui.realtime_toggle_button,
        REALTIME_TOGGLE_BUTTON_X,
        REALTIME_TOGGLE_BUTTON_Y,
        LAUNCH_BUTTON_Z,
        realtime_btn_color,
        REALTIME_TOGGLE_BUTTON_DRAW_W * 0.021,
        REALTIME_TOGGLE_BUTTON_DRAW_H * 0.021
    )
    local aesthetic_color = self.aesthetic_mode == AESTHETIC_MODE_BOARDGAME
        and vmath.vector4(0.45, 0.35, 0.75, 0.95)
        or vmath.vector4(0.2, 0.55, 0.9, 0.95)
    set_ui_square_transform(
        self,
        self.ui.aesthetic_toggle_button,
        AESTHETIC_BUTTON_X,
        AESTHETIC_BUTTON_Y,
        AESTHETIC_BUTTON_Z,
        aesthetic_color,
        AESTHETIC_BUTTON_W,
        AESTHETIC_BUTTON_H
    )
    set_ui_square_transform(
        self,
        self.ui.zoom_in_button,
        ZOOM_IN_BUTTON_X,
        ZOOM_IN_BUTTON_Y,
        ZOOM_IN_BUTTON_Z,
        vmath.vector4(0.2, 0.55, 0.95, 0.95),
        ZOOM_IN_BUTTON_W,
        ZOOM_IN_BUTTON_H
    )
    set_ui_square_transform(
        self,
        self.ui.zoom_out_button,
        ZOOM_OUT_BUTTON_X,
        ZOOM_OUT_BUTTON_Y,
        ZOOM_OUT_BUTTON_Z,
        vmath.vector4(0.2, 0.55, 0.95, 0.95),
        ZOOM_OUT_BUTTON_W,
        ZOOM_OUT_BUTTON_H
    )
    if self.mp_state and self.mp_state.enabled then
        set_ui_square_transform(
            self,
            self.ui.transport_status_dot,
            MP_NET_STATUS_DOT_X,
            MP_NET_STATUS_DOT_Y,
            MP_NET_STATUS_DOT_Z,
            get_multiplayer_transport_status_tint(self),
            MP_NET_STATUS_DOT_W,
            MP_NET_STATUS_DOT_H
        )
    else
        set_ui_square_transform(self, self.ui.transport_status_dot, -9999, -9999, MP_NET_STATUS_DOT_Z, vmath.vector4(0, 0, 0, 0), MP_NET_STATUS_DOT_W, MP_NET_STATUS_DOT_H)
    end
    update_objective_ui(self, true)
    update_score_hud(self, true)
    update_purge_timer_hud(self, true)
end

local function update_tutorial_overlay_ui(self)
    if not (self and self.ui and self.ui.tutorial_panel) then
        return
    end
    local hidden = vmath.vector4(0, 0, 0, 0)
    if self.tutorial_mode == true and self.tutorial_overlay_active == true and self.tutorial_panel_screen_x and self.tutorial_panel_screen_y then
        local world_x, world_y = nil, nil
        if self.tutorial_anchor_world_x and self.tutorial_anchor_world_y then
            local sx, sy = tutorial_world_to_screen(self, self.tutorial_anchor_world_x, self.tutorial_anchor_world_y)
            self.tutorial_panel_screen_x = sx
            self.tutorial_panel_screen_y = sy
            world_x = self.tutorial_anchor_world_x
            world_y = self.tutorial_anchor_world_y
        else
            world_x, world_y = screen_to_world(self.tutorial_panel_screen_x, self.tutorial_panel_screen_y, self.camera_pos, self.camera_zoom)
        end
        go.set_position(vmath.vector3(world_x, world_y, TUTORIAL_PANEL_Z), self.ui.tutorial_panel)
        go.set_scale(vmath.vector3(TUTORIAL_PANEL_DRAW_SCALE, TUTORIAL_PANEL_DRAW_SCALE, 1), self.ui.tutorial_panel)
        go.set(msg.url(nil, self.ui.tutorial_panel, "sprite"), "tint", vmath.vector4(1, 1, 1, 1))
    else
        go.set_position(vmath.vector3(-9999, -9999, TUTORIAL_PANEL_Z), self.ui.tutorial_panel)
        go.set_scale(vmath.vector3(TUTORIAL_PANEL_DRAW_SCALE, TUTORIAL_PANEL_DRAW_SCALE, 1), self.ui.tutorial_panel)
        go.set(msg.url(nil, self.ui.tutorial_panel, "sprite"), "tint", hidden)
    end
end

get_aesthetic_profile = function(self)
    local mode = self.aesthetic_mode or AESTHETIC_MODE_BOARDGAME
    return AESTHETIC_PROFILES[mode] or AESTHETIC_PROFILES[AESTHETIC_MODE_BOARDGAME]
end

get_world_shadow_alpha = function(self)
    local profile = get_aesthetic_profile(self)
    if not profile or profile.world_drop_shadows_enabled ~= true then
        return 0
    end
    return profile.world_shadow_alpha or 0.5
end

get_ui_panel_shadow_alpha = function(self)
    local profile = get_aesthetic_profile(self)
    if not profile or profile.ui_panel_shadow_enabled ~= true then
        return 0
    end
    return profile.ui_panel_shadow_alpha or 0.35
end

get_human_anim_for_aesthetic = function(self, unit)
    if not unit then
        return nil
    end
    if (unit.current_health or 0) <= 0 then
        if self.aesthetic_mode == AESTHETIC_MODE_BOARDGAME then
            return hash("human_dead_boardgame")
        end
        return hash("human_dead")
    end
    if unit.class_id == UNIT_CLASS_SARGE then
        if self.aesthetic_mode == AESTHETIC_MODE_BOARDGAME then
            return hash("human_sarge_boardgame")
        end
        return hash("human_sarge")
    elseif unit.class_id == UNIT_CLASS_TECHIE then
        if self.aesthetic_mode == AESTHETIC_MODE_BOARDGAME then
            return hash("human_techie_boardgame")
        end
        return hash("human_techie")
    elseif unit.class_id == UNIT_CLASS_MEDIC then
        if self.aesthetic_mode == AESTHETIC_MODE_BOARDGAME then
            return hash("human_medic_boardgame")
        end
        return hash("human_medic")
    elseif unit.class_id == UNIT_CLASS_GUNNER then
        if self.aesthetic_mode == AESTHETIC_MODE_BOARDGAME then
            return hash("human_gunner_boardgame")
        end
        return hash("human_gunner")
    end
    return nil
end

apply_human_aesthetic_animations = function(self)
    if not self or not self.squad_units then
        return
    end
    for _, unit in pairs(self.squad_units) do
        if unit and unit.sprite_path then
            local anim = get_human_anim_for_aesthetic(self, unit)
            if anim then
                pcall(msg.post, unit.sprite_path, "play_animation", { id = anim })
            end
        end
    end
end

apply_alien_aesthetic_animations = function(self)
    if not self or not self.aliens then
        return
    end
    for _, alien in ipairs(self.aliens) do
        if alien and (not alien.is_dead) and alien.go_id then
            local anim = get_alien_anim_for_aesthetic(self, alien.type)
            if anim then
                pcall(msg.post, msg.url(nil, alien.go_id, "sprite"), "play_animation", { id = anim })
                alien.current_aesthetic_anim = anim
            else
                alien.current_aesthetic_anim = nil
            end
            if alien.type == ALIEN_TYPE_BRUTE then
                local shadow_anim = hash("alien_cannonFodder_shadow")
                if self.aesthetic_mode == AESTHETIC_MODE_BOARDGAME then
                    shadow_anim = hash("alien_brute_shadow")
                end
                pcall(msg.post, msg.url(nil, alien.go_id, "shadow"), "play_animation", { id = shadow_anim })
            end
        end
    end
end

apply_computer_emissive_accents = function(self, dt)
    local profile = get_aesthetic_profile(self)
    local enabled = profile
        and profile.computer_emissive_enabled == true
        and self.aesthetic_mode == AESTHETIC_MODE_COMPUTER

    local white_tint = vmath.vector4(1, 1, 1, 1)
    local base = profile and profile.computer_emissive_tint or vmath.vector4(0.7, 0.92, 1.18, 1)
    local min_mul = profile and profile.computer_emissive_min_mul or 0.84
    local max_mul = profile and profile.computer_emissive_max_mul or 1.22
    local variation_amount = profile and profile.computer_emissive_variation_amount or 0.2
    local global_intensity_mul = 1
    if enabled then
        self.computer_emissive_variation_phase = (self.computer_emissive_variation_phase or 0) + (dt * ((profile.computer_emissive_variation_speed or 0.2) * math.pi * 2))
        local variation_wave = math.sin(self.computer_emissive_variation_phase)
        local speed_mul = 1 + (variation_wave * variation_amount)
        global_intensity_mul = 1 + (math.cos(self.computer_emissive_variation_phase * 0.73) * variation_amount)
        local speed = (profile.computer_emissive_pulse_speed or 1.25) * speed_mul * math.pi * 2
        self.computer_emissive_phase = (self.computer_emissive_phase or 0) + (dt * speed)
        self.workshop_emissive_phase = (self.workshop_emissive_phase or 0) + (dt * math.pi * 2 * 0.42)
    end

    local human_tile_instances = {}
    local nearby_human_tile_instances = {}
    if self.world_grid and self.squad_units then
        for _, unit in pairs(self.squad_units) do
            if unit and (unit.current_health or 0) > 0 and unit.cell_id then
                local cell = self.world_grid[unit.cell_id]
                local tile_id = cell and cell.tileInstanceId or nil
                if tile_id and tile_id > 0 then
                    human_tile_instances[tile_id] = true
                    nearby_human_tile_instances[tile_id] = true
                end
            end
        end
    end
    local selected_level = self.level_library and self.level_library[self.current_level_index or 1] or nil
    local nightvision_reveal_enabled, nightvision_tile_instance_id, nightvision_reveal_alpha = get_nightvision_reveal_context(self)
    if selected_level and next(human_tile_instances) ~= nil then
        for human_tile_id, _ in pairs(human_tile_instances) do
            local a = selected_level[human_tile_id]
            if a then
                local a_left = a.x - 1
                local a_right = a.x + 1
                local a_bottom = a.y - 1
                local a_top = a.y + 1
                for tile_id, b in ipairs(selected_level) do
                    if tile_id ~= human_tile_id then
                        local b_left = b.x - 1
                        local b_right = b.x + 1
                        local b_bottom = b.y - 1
                        local b_top = b.y + 1
                        local overlap_y = not (b_top < a_bottom or b_bottom > a_top)
                        local overlap_x = not (b_right < a_left or b_left > a_right)
                        local horizontal_adjacent = overlap_y and (b_left == (a_right + 1) or b_right == (a_left - 1))
                        local vertical_adjacent = overlap_x and (b_bottom == (a_top + 1) or b_top == (a_bottom - 1))
                        if horizontal_adjacent or vertical_adjacent then
                            nearby_human_tile_instances[tile_id] = true
                        end
                    end
                end
            end
        end
    end

    local function get_instance_tint(instance_key, powered, apply_off_human_proximity_rule)
        local n = tonumber(instance_key) or 0
        if (not powered) and nightvision_reveal_enabled and n == nightvision_tile_instance_id then
            local a = math.max(0, math.min(1, tonumber(nightvision_reveal_alpha or 0) or 0))
            return vmath.vector4(
                NIGHTVISION_UNPOWERED_TINT.x * a,
                NIGHTVISION_UNPOWERED_TINT.y * a,
                NIGHTVISION_UNPOWERED_TINT.z * a,
                a
            )
        end
        if apply_off_human_proximity_rule and not powered then
            self.tile_off_proximity_mul_state = self.tile_off_proximity_mul_state or {}
            local target_mul
            if self.aesthetic_mode == AESTHETIC_MODE_COMPUTER then
                -- Keep OFF tiles readable near the squad, but noticeably darker overall.
                target_mul = nearby_human_tile_instances[n] and 0.72 or 0.35
            else
                target_mul = nearby_human_tile_instances[n] and 1 or 0.5
            end
            local current_mul = self.tile_off_proximity_mul_state[n]
            if current_mul == nil then
                current_mul = target_mul
            else
                local fade_speed = 5.5
                local blend = math.min(1, dt * fade_speed)
                current_mul = current_mul + ((target_mul - current_mul) * blend)
            end
            self.tile_off_proximity_mul_state[n] = current_mul
            return vmath.vector4(current_mul, current_mul, current_mul, 1)
        end
        if not powered then
            if self.aesthetic_mode == AESTHETIC_MODE_COMPUTER then
                return vmath.vector4(0.42, 0.42, 0.42, 1)
            end
            return white_tint
        end
        if not enabled then
            return white_tint
        end
        local placement = selected_level and selected_level[n] or nil
        if placement and placement.tile == "workshop" then
            local workshop_wave = 0.5 + (0.5 * math.sin((self.workshop_emissive_phase or 0) + (n * 0.11)))
            local workshop_mul = 0.8 + (0.2 * workshop_wave)
            return vmath.vector4(base.x * workshop_mul, base.y * workshop_mul, base.z * workshop_mul, 1)
        end
        local phase_offset = (0.5 + (0.5 * math.sin((n + 1) * 12.9898))) * math.pi * 2
        local drift = (self.computer_emissive_variation_phase or 0) + phase_offset
        local speed_jitter = 1
            + (math.sin((n + 1) * 4.123 + 1.7) * variation_amount * 1.2)
            + (math.sin(drift * 0.55 + (n * 0.17)) * variation_amount * 0.35)
        local max_speed_jitter = profile and profile.computer_emissive_max_speed_jitter or 1.08
        if speed_jitter > max_speed_jitter then
            speed_jitter = max_speed_jitter
        end
        local intensity_jitter = 1
            + (math.cos((n + 1) * 7.777 + 0.3) * variation_amount * 1.35)
            + (math.cos(drift * 0.42 + (n * 0.11)) * variation_amount * 0.4)
        local wave = 0.5 + (0.5 * math.sin((self.computer_emissive_phase or 0) * speed_jitter + phase_offset))
        local mul = (min_mul + ((max_mul - min_mul) * wave)) * global_intensity_mul * intensity_jitter
        return vmath.vector4(base.x * mul, base.y * mul, base.z * mul, 1)
    end

    if self.tile_light_layers then
        for tile_instance_id, light_go in pairs(self.tile_light_layers) do
            local powered = self.tile_light_power_state and self.tile_light_power_state[tile_instance_id] == true
            local tint = get_instance_tint(tile_instance_id, powered, true)
            if powered and self.tile_light_is_lab and self.tile_light_is_lab[tile_instance_id] then
                tint = vmath.vector4(base.x * max_mul, base.y * max_mul, base.z * max_mul, 1)
            end
            pcall(go.set, msg.url(nil, light_go, "sprite"), "tint", tint)
        end
    end

    for cell_id, marker_id in pairs(machine_objects or {}) do
        local tint = get_instance_tint(cell_id, true)
        pcall(go.set, msg.url(nil, marker_id, "sprite"), "tint", tint)
    end

    if self.power_node_objects then
        for cell_id, marker_id in pairs(self.power_node_objects) do
            local cell = self.world_grid and self.world_grid[cell_id] or nil
            local powered = self.power_node_power_state and self.power_node_power_state[cell_id] == true
            local visible_in_unpowered = nightvision_reveal_enabled
                and cell
                and tonumber(cell.tileInstanceId or 0) == nightvision_tile_instance_id
            local should_show = powered or visible_in_unpowered
            local tint = vmath.vector4(0, 0, 0, 0)
            if should_show then
                if visible_in_unpowered and not powered then
                        local a = math.max(0, math.min(1, tonumber(nightvision_reveal_alpha or 0) or 0))
                        tint = vmath.vector4(
                            NIGHTVISION_POWER_NODE_TINT.x * a,
                            NIGHTVISION_POWER_NODE_TINT.y * a,
                            NIGHTVISION_POWER_NODE_TINT.z * a,
                            a
                        )
                else
                    tint = get_instance_tint(cell_id, powered)
                end
            end
            pcall(go.set, msg.url(nil, marker_id, "sprite"), "tint", tint)
            local shadow_id = self.power_node_shadow_objects and self.power_node_shadow_objects[cell_id] or nil
            if shadow_id then
                local shadow_alpha = should_show and 0.33 or 0
                if visible_in_unpowered and not powered then
                    shadow_alpha = shadow_alpha * (math.max(0, math.min(1, tonumber(nightvision_reveal_alpha or 0) or 0)))
                end
                pcall(go.set, msg.url(nil, shadow_id, "sprite"), "tint", vmath.vector4(0, 0, 0, shadow_alpha))
            end
        end
    end

    if self.wiregap_objects then
        for i, marker_id in ipairs(self.wiregap_objects) do
            local tint = get_instance_tint(i * 97, true)
            pcall(go.set, msg.url(nil, marker_id, "sprite"), "tint", tint)
        end
    end
end

get_tile_alpha_overlay_anim_id = function(tile_def, aesthetic_mode)
    if not tile_def then
        return hash("tile_generic_alpha_layer")
    end
    local mode = tostring(tile_def.alphaOverlayMode or "generic")
    if mode ~= "specified" then
        return hash("tile_generic_alpha_layer")
    end
    local overlay_name = nil
    if aesthetic_mode == AESTHETIC_MODE_BOARDGAME then
        overlay_name = tile_def.alphaOverlayBoardgame
    elseif aesthetic_mode == AESTHETIC_MODE_COMPUTER then
        overlay_name = tile_def.alphaOverlayComputer
    end
    if not overlay_name or overlay_name == "" then
        overlay_name = tile_def.alphaOverlay
    end
    if not overlay_name or overlay_name == "" then
        return hash("tile_generic_alpha_layer")
    end
    local anim = tostring(overlay_name)
    if string.sub(anim, 1, 5) ~= "tile_" then
        anim = "tile_" .. anim
    end
    return hash(anim)
end

apply_aesthetic_mode = function(self)
    local profile = get_aesthetic_profile(self)
    local sheen_enabled = profile and profile.sheen_enabled == true
    local backdrop_enabled = profile and profile.backdrop_enabled == true
    local backdrop_tiled = profile and profile.backdrop_tiled == true
    local backdrop_clouds_enabled = profile and profile.backdrop_clouds_enabled == true
    local table_sweep_shadow_enabled = profile and profile.table_sweep_shadow_enabled == true
    local backdrop_anim = (profile and profile.backdrop_anim) or "tile_generic_alpha_layer"
    local backdrop_tint = (profile and profile.backdrop_tint) or vmath.vector4(1, 1, 1, 0.2)
    local table_sweep_shadow_anim = (profile and profile.table_sweep_shadow_anim) or "tile_generic_alpha_layer"
    local table_sweep_shadow_tint = (profile and profile.table_sweep_shadow_tint) or vmath.vector4(0.2, 0.17, 0.13, 0.2)
    local table_sweep_shadow_factory = "/tile_factory#tile_factory"

    if backdrop_enabled then
        if backdrop_tiled then
            if self.world_backdrop then
                go.delete(self.world_backdrop)
                self.world_backdrop = nil
            end
            local cols = (profile and profile.backdrop_tile_cols) or 5
            local rows = (profile and profile.backdrop_tile_rows) or 5
            local needed = math.max(1, cols * rows)
            self.world_backdrop_tiles = self.world_backdrop_tiles or {}
            while #self.world_backdrop_tiles < needed do
                local tile_id = factory.create("/tile_factory#tile_factory", vmath.vector3(self.camera_pos.x, self.camera_pos.y, self.world_backdrop_z or -0.2))
                if not tile_id then
                    break
                end
                table.insert(self.world_backdrop_tiles, tile_id)
            end
            while #self.world_backdrop_tiles > needed do
                local idx = #self.world_backdrop_tiles
                go.delete(self.world_backdrop_tiles[idx])
                self.world_backdrop_tiles[idx] = nil
            end
            if self.world_backdrop_anim ~= backdrop_anim then
                for _, tile_id in ipairs(self.world_backdrop_tiles) do
                    msg.post(msg.url(nil, tile_id, "sprite"), "play_animation", { id = hash(backdrop_anim) })
                end
                self.world_backdrop_anim = backdrop_anim
            end
            for _, tile_id in ipairs(self.world_backdrop_tiles) do
                go.set(msg.url(nil, tile_id, "sprite"), "tint", backdrop_tint)
            end
        else
            if self.world_backdrop_tiles then
                for i, tile_id in ipairs(self.world_backdrop_tiles) do
                    go.delete(tile_id)
                    self.world_backdrop_tiles[i] = nil
                end
            end
            if not self.world_backdrop then
                self.world_backdrop = factory.create("/tile_factory#tile_factory", vmath.vector3(self.camera_pos.x, self.camera_pos.y, self.world_backdrop_z or -0.2))
            end
            if self.world_backdrop then
                if self.world_backdrop_anim ~= backdrop_anim then
                    msg.post(msg.url(nil, self.world_backdrop, "sprite"), "play_animation", { id = hash(backdrop_anim) })
                    self.world_backdrop_anim = backdrop_anim
                end
                go.set(msg.url(nil, self.world_backdrop, "sprite"), "tint", backdrop_tint)
            end
        end
    else
        if self.world_backdrop then
            go.delete(self.world_backdrop)
            self.world_backdrop = nil
        end
        if self.world_backdrop_tiles then
            for i, tile_id in ipairs(self.world_backdrop_tiles) do
                go.delete(tile_id)
                self.world_backdrop_tiles[i] = nil
            end
        end
        self.world_backdrop_anim = nil
    end

    if backdrop_clouds_enabled then
        if not self.backdrop_cloud_fx then
            self.backdrop_cloud_fx = factory.create(
                "/swirling_clouds1_fx_factory#swirling_clouds1_fx_factory",
                vmath.vector3(self.camera_pos.x, self.camera_pos.y, self.backdrop_cloud_fx_z or 0.015)
            )
            if self.backdrop_cloud_fx then
                go.set_rotation(vmath.quat_rotation_z(math.rad(-90)), self.backdrop_cloud_fx)
                pcall(particlefx.play, msg.url(nil, self.backdrop_cloud_fx, "particlefx"))
            end
        end
    elseif self.backdrop_cloud_fx then
        go.delete(self.backdrop_cloud_fx)
        self.backdrop_cloud_fx = nil
    end

    if table_sweep_shadow_enabled then
        if self.table_sweep_shadow_overlay and self.table_sweep_shadow_factory ~= table_sweep_shadow_factory then
            go.delete(self.table_sweep_shadow_overlay)
            self.table_sweep_shadow_overlay = nil
            self.table_sweep_shadow_anim = nil
        end
        if not self.table_sweep_shadow_overlay then
            self.table_sweep_shadow_overlay = factory.create(
                table_sweep_shadow_factory,
                vmath.vector3(self.camera_pos.x, self.camera_pos.y, self.table_sweep_shadow_z or 0.74)
            )
            self.table_sweep_shadow_factory = table_sweep_shadow_factory
        end
        if self.table_sweep_shadow_overlay then
            if self.table_sweep_shadow_anim ~= table_sweep_shadow_anim then
                msg.post(msg.url(nil, self.table_sweep_shadow_overlay, "sprite"), "play_animation", { id = hash(table_sweep_shadow_anim) })
                self.table_sweep_shadow_anim = table_sweep_shadow_anim
            end
            go.set(msg.url(nil, self.table_sweep_shadow_overlay, "sprite"), "tint", table_sweep_shadow_tint)
        end
    elseif self.table_sweep_shadow_overlay then
        go.delete(self.table_sweep_shadow_overlay)
        self.table_sweep_shadow_overlay = nil
        self.table_sweep_shadow_anim = nil
        self.table_sweep_shadow_factory = nil
    end

    if sheen_enabled then
        if not self.sheen_overlay then
            local sheen_id = factory.create("/ui_factory#ui_factory", vmath.vector3(self.camera_pos.x + (self.sheen_offset_x or 0), self.camera_pos.y + (self.sheen_offset_y or 0), self.sheen_z or 0.4))
            if sheen_id then
                msg.post(msg.url(nil, sheen_id, "sprite"), "play_animation", { id = hash("DVX_sheen") })
                self.sheen_overlay = sheen_id
            end
        end
        if self.sheen_overlay then
            go.set(msg.url(nil, self.sheen_overlay, "sprite"), "tint", vmath.vector4(1, 1, 1, self.sheen_alpha or 0.4))
            local sx = (SCREEN_WIDTH / self.camera_zoom) / (self.sheen_art_w or 550)
            local sy = (SCREEN_HEIGHT / self.camera_zoom) / (self.sheen_art_h or 300)
            go.set_position(vmath.vector3(self.camera_pos.x + (self.sheen_offset_x or 0), self.camera_pos.y + (self.sheen_offset_y or 0), self.sheen_z or 0.4), self.sheen_overlay)
            go.set_scale(vmath.vector3(sx, sy, 1), self.sheen_overlay)
        end
    elseif self.sheen_overlay then
        go.delete(self.sheen_overlay)
        self.sheen_overlay = nil
    end
    if self.tile_room_shadows then
        local tile_shadow_alpha = (profile and profile.tile_room_shadow_alpha) or 0
        local tile_shadow_tint = vmath.vector4(0, 0, 0, tile_shadow_alpha)
        for _, shadow_id in pairs(self.tile_room_shadows) do
            if shadow_id then
                pcall(go.set, msg.url(nil, shadow_id, "sprite"), "tint", tile_shadow_tint)
            end
        end
    end
    if self.exterior_detail_objects then
        local exterior_alpha = (self.aesthetic_mode == AESTHETIC_MODE_BOARDGAME) and 0 or 1
        for _, exterior_id in ipairs(self.exterior_detail_objects) do
            if exterior_id then
                pcall(go.set, msg.url(nil, exterior_id, "sprite"), "tint", vmath.vector4(1, 1, 1, exterior_alpha))
            end
        end
    end
    if self.tile_base_objects and self.level_library and self.current_level_index then
        local selected_level = self.level_library[self.current_level_index]
        for placement_index, placement in ipairs(selected_level or {}) do
            local tile_id = self.tile_base_objects[placement_index]
            local tile_def = self.tile_library and self.tile_library[placement.tile] or nil
            if tile_id then
                local visual_tile_name = (tile_def and tile_def.visualTile) or placement.tile
                if tile_def then
                    if self.aesthetic_mode == AESTHETIC_MODE_BOARDGAME and tile_def.visualTileBoardgame then
                        visual_tile_name = tile_def.visualTileBoardgame
                    elseif self.aesthetic_mode == AESTHETIC_MODE_COMPUTER and tile_def.visualTileComputer then
                        visual_tile_name = tile_def.visualTileComputer
                    end
                end
                msg.post(msg.url(nil, tile_id, "sprite"), "play_animation", { id = hash("tile_" .. visual_tile_name) })
            end
            local alpha_id = self.tile_alpha_layers and self.tile_alpha_layers[placement_index] or nil
            if alpha_id then
                msg.post(
                    msg.url(nil, alpha_id, "sprite"),
                    "play_animation",
                    { id = get_tile_alpha_overlay_anim_id(tile_def, self.aesthetic_mode) }
                )
                local always_visible = tile_def and tile_def.alphaOverlayAlwaysVisible == true
                go.set(msg.url(nil, alpha_id, "sprite"), "tint", vmath.vector4(1, 1, 1, always_visible and 1 or 0))
            end
        end
    end
    apply_human_aesthetic_animations(self)
    apply_alien_aesthetic_animations(self)
end

apply_backdrop_emissive_tint = function(self, dt, profile)
    if not self.world_backdrop then
        return
    end
    local base = (profile and profile.backdrop_tint) or vmath.vector4(1, 1, 1, 1)
    if not (profile and profile.backdrop_emissive_enabled == true and self.aesthetic_mode == AESTHETIC_MODE_COMPUTER) then
        go.set(msg.url(nil, self.world_backdrop, "sprite"), "tint", base)
        return
    end
    local base_speed = profile.backdrop_emissive_speed or 0.03
    local speed_variation = profile.backdrop_emissive_speed_variation_amount or 0
    local speed = base_speed
    if speed_variation > 0 then
        self.backdrop_emissive_speed_timer = (self.backdrop_emissive_speed_timer or 0) - dt
        if self.backdrop_emissive_speed_mul_target == nil then
            self.backdrop_emissive_speed_mul_target = 1
        end
        if self.backdrop_emissive_speed_mul_current == nil then
            self.backdrop_emissive_speed_mul_current = self.backdrop_emissive_speed_mul_target
        end
        if self.backdrop_emissive_speed_timer <= 0 then
            self.backdrop_emissive_speed_mul_target = 1 + (math.random() * 2 - 1) * speed_variation
            local min_s = profile.backdrop_emissive_speed_variation_min_seconds or 3.0
            local max_s = profile.backdrop_emissive_speed_variation_max_seconds or 8.0
            self.backdrop_emissive_speed_timer = min_s + (math.random() * math.max(0, max_s - min_s))
        end
        local blend = math.min(1, dt * 1.25)
        self.backdrop_emissive_speed_mul_current = self.backdrop_emissive_speed_mul_current
            + ((self.backdrop_emissive_speed_mul_target - self.backdrop_emissive_speed_mul_current) * blend)
        speed = base_speed * self.backdrop_emissive_speed_mul_current
    end
    speed = speed * math.pi * 2
    local amount = profile.backdrop_emissive_amount or 0.015
    self.backdrop_emissive_phase = (self.backdrop_emissive_phase or 0) + (dt * speed)
    local wave_a = math.sin(self.backdrop_emissive_phase)
    local wave_b = math.sin((self.backdrop_emissive_phase * 0.37) + 1.2)
    local wave = (wave_a * 0.75) + (wave_b * 0.25)
    local mul = 1 + (wave * amount)
    local alpha = math.max(0, math.min(1, base.w * (1 + (wave * amount * 0.45))))
    go.set(
        msg.url(nil, self.world_backdrop, "sprite"),
        "tint",
        vmath.vector4(base.x * mul, base.y * mul, base.z * mul, alpha)
    )
end

update_backdrop_cloud_fx = function(self)
    if not self.backdrop_cloud_fx then
        local profile = get_aesthetic_profile(self)
        if profile and profile.backdrop_clouds_enabled == true then
            self.backdrop_cloud_fx = factory.create(
                "/swirling_clouds1_fx_factory#swirling_clouds1_fx_factory",
                vmath.vector3(self.camera_pos.x, self.camera_pos.y, self.backdrop_cloud_fx_z or 0.015)
            )
            if self.backdrop_cloud_fx then
                go.set_rotation(vmath.quat_rotation_z(math.rad(-90)), self.backdrop_cloud_fx)
                pcall(particlefx.play, msg.url(nil, self.backdrop_cloud_fx, "particlefx"))
            else
                return
            end
        else
            return
        end
    end
    if self.backdrop_cloud_fx_anchor_y == nil then
        self.backdrop_cloud_fx_anchor_y = self.camera_pos.y + 100
    end
    local left_margin_world = (self.backdrop_cloud_fx_left_margin_screen or 80) / self.camera_zoom
    local left_extra_world = (self.backdrop_cloud_fx_left_extra_screen or 1500) / self.camera_zoom
    local px = self.camera_pos.x - ((SCREEN_WIDTH * 0.5) / self.camera_zoom) - left_margin_world - left_extra_world
    local py = self.backdrop_cloud_fx_anchor_y
    go.set_position(vmath.vector3(px, py, self.backdrop_cloud_fx_z or 0.015), self.backdrop_cloud_fx)
    go.set_rotation(vmath.quat_rotation_z(math.rad(-90)), self.backdrop_cloud_fx)
end

set_aesthetic_mode = function(self, mode)
    if mode ~= AESTHETIC_MODE_COMPUTER and mode ~= AESTHETIC_MODE_BOARDGAME then
        return
    end
    self.aesthetic_mode = mode
    self.world_backdrop_pan_x = 0
    self.world_backdrop_pan_y = 0
    self.world_backdrop_prev_camera_x = nil
    self.world_backdrop_prev_camera_y = nil
    self.world_backdrop_parallax_x = nil
    self.world_backdrop_parallax_y = nil
    self.world_backdrop_anchor_camera_y = nil
    self.world_backdrop_anchor_world_x = nil
    self.world_backdrop_anchor_world_y = nil
    if self.backdrop_cloud_fx then
        go.delete(self.backdrop_cloud_fx)
    end
    self.backdrop_cloud_fx = nil
    self.backdrop_cloud_fx_anchor_y = nil
    self.backdrop_cloud_fx_z = 0.015
    self.backdrop_cloud_fx_left_margin_screen = 80
    self.backdrop_cloud_fx_left_extra_screen = 1500
    self.backdrop_emissive_phase = 0
    self.backdrop_emissive_speed_timer = nil
    self.backdrop_emissive_speed_mul_target = nil
    self.backdrop_emissive_speed_mul_current = nil
    self.table_sweep_shadow_pan_x = nil
    self.table_sweep_shadow_pan_y = 0
    self.table_sweep_shadow_pause_timer = nil
    self.computer_emissive_phase = 0
    self.computer_emissive_variation_phase = 0
    apply_aesthetic_mode(self)
    if LOOT_RUNTIME and LOOT_RUNTIME.refresh_world_item_visuals then
        LOOT_RUNTIME.refresh_world_item_visuals(self)
    end
    if LOOT_RUNTIME then
        if LOOT_RUNTIME.refresh_loot_markers then
            LOOT_RUNTIME.refresh_loot_markers(self)
        end
        if LOOT_RUNTIME.refresh_hazard_fx then
            LOOT_RUNTIME.refresh_hazard_fx(self)
        end
        if LOOT_RUNTIME.refresh_machine_markers then
            LOOT_RUNTIME.refresh_machine_markers(self)
        end
        if LOOT_RUNTIME.refresh_turret_markers then
            LOOT_RUNTIME.refresh_turret_markers(self)
        end
        if LOOT_RUNTIME.refresh_power_node_markers then
            LOOT_RUNTIME.refresh_power_node_markers(self)
        end
        if LOOT_RUNTIME.refresh_door_markers then
            LOOT_RUNTIME.refresh_door_markers(self)
        end
        if LOOT_RUNTIME.refresh_wiregap_markers then
            LOOT_RUNTIME.refresh_wiregap_markers(self)
        end
        if LOOT_RUNTIME.refresh_vent_markers then
            LOOT_RUNTIME.refresh_vent_markers(self)
        end
        if LOOT_RUNTIME.refresh_factory_underlay_visuals then
            LOOT_RUNTIME.refresh_factory_underlay_visuals(self)
        end
    end
    print("Aesthetic mode set to: " .. tostring(mode))
end

toggle_aesthetic_mode = function(self)
    if self.aesthetic_mode == AESTHETIC_MODE_BOARDGAME then
        set_aesthetic_mode(self, AESTHETIC_MODE_COMPUTER)
    else
        set_aesthetic_mode(self, AESTHETIC_MODE_BOARDGAME)
    end
end

function request_level_load(self, level_index, source_tag)
    if self.level_switch_in_progress then
        return false
    end
    if not self.level_library or not self.level_library[level_index] then
        print("Level load request ignored (invalid index): " .. tostring(level_index))
        return false
    end
    self.level_switch_in_progress = true
    local ok = reset_and_load_level(self, level_index)
    self.level_switch_in_progress = false
    if ok then
        print(string.format("Level load requested from %s -> level %d", tostring(source_tag or "unknown"), level_index))
    end
    return ok
end

function try_select_level_button(self, screen_x, screen_y)
    if not self.ui or not self.ui.level_buttons then
        return false
    end
    local half_w = LEVEL_BUTTON_W * 0.5
    local half_h = LEVEL_BUTTON_H * 0.5
    for level_index, btn in ipairs(self.ui.level_buttons) do
        if btn then
            local bx = get_level_button_screen_x(level_index)
            local by = LEVEL_BUTTON_Y
            if screen_x >= (bx - half_w)
                and screen_x <= (bx + half_w)
                and screen_y >= (by - half_h)
                and screen_y <= (by + half_h)
            then
                if self.mp_state and self.mp_state.enabled and self.mp_state.local_player_id ~= self.mp_state.host_player_id then
                    print("Level restart is host-only in multiplayer.")
                    return true
                end
                return request_level_load(self, level_index, "top_bar_button")
            end
        end
    end
    return false
end

LOOT_RUNTIME = require("main.loot_runtime_utils").create({
    LOOT_UI = LOOT_UI,
    COMMAND_UI = COMMAND_UI,
    COMPONENT_UI = COMPONENT_UI,
    UI_COLOR_SLOT = UI_COLOR_SLOT,
    UI_BACKPACK_COLS = UI_BACKPACK_COLS,
    UI_BACKPACK_ROWS = UI_BACKPACK_ROWS,
    UI_BACKPACK_SLOT_SIZE = UI_BACKPACK_SLOT_SIZE,
    UI_BACKPACK_SLOT_GAP = UI_BACKPACK_SLOT_GAP,
    UI_BACKPACK_START_X = UI_BACKPACK_START_X,
    UI_BACKPACK_START_Y = UI_BACKPACK_START_Y,
    UNIT_CLASS_SARGE = UNIT_CLASS_SARGE,
    UI_BAR_START_Y = UI_BAR_START_Y,
    UI_MAX_PIPS = UI_MAX_PIPS,
    UI_BAR_PIP_SIZE = UI_BAR_PIP_SIZE,
    UI_BAR_PIP_GAP = UI_BAR_PIP_GAP,
    UI_BAR_AMMO_X = UI_BAR_AMMO_X,
    UI_BAR_HP_X = UI_BAR_HP_X,
    UI_PANEL_X = UI_PANEL_X,
    UI_PANEL_Y = UI_PANEL_Y,
    BUFF_SLOT_ORDER = BUFF_SLOT_ORDER,
    BUFF_DROP_ZONE_OFFSET_X = BUFF_DROP_ZONE_OFFSET_X,
    BUFF_DROP_ZONE_OFFSET_Y = BUFF_DROP_ZONE_OFFSET_Y,
    BUFF_DROP_ZONE_W = BUFF_DROP_ZONE_W,
    BUFF_DROP_ZONE_H = BUFF_DROP_ZONE_H,
    BUFF_SLOT_RELATIVE_OFFSETS = BUFF_SLOT_RELATIVE_OFFSETS,
    BUFF_SLOT_HIT_SIZE = BUFF_SLOT_HIT_SIZE,
    BUFFS = BUFFS,
    id_to_coords = id_to_coords,
    can_human_cross_between_cells = can_human_cross_between_cells
})

function update_selected_unit_ui(self)
    if (self.game_flow_state or FLOW_STATE_GAME) ~= FLOW_STATE_GAME then
        set_ui_hidden(self)
        return
    end
    local unit = get_selected_unit(self)
    if not self.ui then
        return
    end
    if self.ui.level_buttons then
        local current_idx = self.current_level_index or 1
        for i, btn in ipairs(self.ui.level_buttons) do
            if btn then
                local bx = get_level_button_screen_x(i)
                local active = (i == current_idx)
                local col = active and vmath.vector4(0.2, 0.85, 0.35, 0.95) or vmath.vector4(0.2, 0.6, 0.95, 0.9)
                set_ui_square_transform(self, btn, bx, LEVEL_BUTTON_Y, LEVEL_BUTTON_Z, col, LEVEL_BUTTON_W, LEVEL_BUTTON_H)
            end
        end
    end
    if not unit then
        set_ui_hidden(self)
        update_global_ui_buttons(self)
        if self.ui.level_buttons then
            local current_idx = self.current_level_index or 1
            for i, btn in ipairs(self.ui.level_buttons) do
                if btn then
                    local bx = get_level_button_screen_x(i)
                    local active = (i == current_idx)
                    local col = active and vmath.vector4(0.2, 0.85, 0.35, 0.95) or vmath.vector4(0.2, 0.6, 0.95, 0.9)
                    set_ui_square_transform(self, btn, bx, LEVEL_BUTTON_Y, LEVEL_BUTTON_Z, col, LEVEL_BUTTON_W, LEVEL_BUTTON_H)
                end
            end
        end
        set_ui_square_transform(
            self,
            self.ui.reactive_toggle_button,
            -9999,
            -9999,
            0.84,
            vmath.vector4(0, 0, 0, 0),
            64,
            32
        )
        set_ui_square_transform(
            self,
            self.ui.reactive_advance_button,
            -9999,
            -9999,
            0.84,
            vmath.vector4(0, 0, 0, 0),
            70,
            30
        )
        close_comms_panel(self)
        return
    end

    local panel_shadow_alpha = get_ui_panel_shadow_alpha(self)
    set_ui_panel_transform(
        self,
        self.ui.panel_shadow,
        UI_PANEL_X + 14,
        UI_PANEL_Y - 12,
        0.79,
        UI_PANEL_W,
        UI_PANEL_H,
        vmath.vector4(0, 0, 0, panel_shadow_alpha)
    )
    set_ui_panel_transform(self, self.ui.panel_art, UI_PANEL_X, UI_PANEL_Y, 0.8, UI_PANEL_W, UI_PANEL_H, vmath.vector4(1, 1, 1, 1))
    local panel_anim = get_unit_panel_anim(unit)
    if panel_anim ~= self.ui_panel_anim then
        msg.post(msg.url(nil, self.ui.panel_art, "sprite"), "play_animation", { id = panel_anim })
        self.ui_panel_anim = panel_anim
    end
    local show_not_enough_ap_icon = false
    if self.derple_feedback_by_unit_id and self.derple_feedback_entries and unit.id then
        local entry_index = self.derple_feedback_by_unit_id[unit.id]
        local entry = entry_index and self.derple_feedback_entries[entry_index] or nil
        show_not_enough_ap_icon = entry
            and entry.event_type == "NOT_ENOUGH_AP"
            and (entry.ttl or 0) > 0
            and entry.go_id ~= nil
            and true
            or false
    end
    if show_not_enough_ap_icon then
        set_ui_square_transform(
            self,
            self.ui.not_enough_ap_icon,
            UI_PANEL_X + (UI_PANEL_W * 0.5) + 23,
            UI_PANEL_Y + (UI_PANEL_H * 0.5) + 3,
            0.835,
            vmath.vector4(1, 1, 1, 1),
            0.81,
            0.81
        )
    else
        set_ui_square_transform(self, self.ui.not_enough_ap_icon, -9999, -9999, 0.835, vmath.vector4(0, 0, 0, 0), 0.81, 0.81)
    end

    for i = 1, UI_MAX_PIPS do
        local pip_step = (UI_BAR_PIP_SIZE + UI_BAR_PIP_GAP) * 0.8
        local pip_y = (UI_BAR_START_Y - 32) - (i - 1) * pip_step
        local pip_h = UI_BAR_PIP_SIZE * 0.8
        local ap_count = math.min(unit.current_ap or 0, UI_MAX_PIPS)
        local hp_count = math.min(unit.current_health or 0, UI_MAX_PIPS)
        local ammo_count = math.min(unit.current_ammo or 0, UI_MAX_PIPS)
        -- Count "down": higher pips drain first as values decrease.
        local ap_on = i > (UI_MAX_PIPS - ap_count)
        local hp_on = i > (UI_MAX_PIPS - hp_count)
        local ammo_on = i > (UI_MAX_PIPS - ammo_count)
        local ap_color = ap_on and UI_COLOR_AP or vmath.vector4(UI_COLOR_AP.x, UI_COLOR_AP.y, UI_COLOR_AP.z, 0.2)
        local hp_color = hp_on and UI_COLOR_HP or vmath.vector4(UI_COLOR_HP.x, UI_COLOR_HP.y, UI_COLOR_HP.z, 0.2)
        local ammo_color = ammo_on and UI_COLOR_AMMO or vmath.vector4(UI_COLOR_AMMO.x, UI_COLOR_AMMO.y, UI_COLOR_AMMO.z, 0.2)

        set_ui_square_transform(self, self.ui.ap_pips[i], UI_BAR_AP_X, pip_y, 0.81, ap_color, UI_BAR_PIP_SIZE, pip_h)
        set_ui_square_transform(self, self.ui.hp_pips[i], UI_BAR_HP_X, pip_y, 0.81, hp_color, UI_BAR_PIP_SIZE, pip_h)
        set_ui_square_transform(self, self.ui.ammo_pips[i], UI_BAR_AMMO_X, pip_y, 0.81, ammo_color, UI_BAR_PIP_SIZE, pip_h)
    end

    local show_command = unit.class_id == UNIT_CLASS_SARGE
    local command_count = show_command and math.min(unit.command_points or 0, COMMAND_UI.max_pips) or 0
    for i = 1, COMMAND_UI.max_pips do
        local cx, cy = LOOT_RUNTIME.get_command_pip_screen_pos(i)
        local command_color = (i <= command_count) and COMMAND_UI.active_color or COMMAND_UI.inactive_color
        if self.drag_resource and self.drag_resource.active and self.drag_resource.drag_type == "command" and self.drag_resource.source_slot_index == i then
            command_color = vmath.vector4(command_color.x, command_color.y, command_color.z, 0.25)
        end
        if show_command then
            set_ui_square_transform(self, self.ui.command_pips[i], cx, cy, 0.81, vmath.vector4(0.08, 0.08, 0.1, 0.22), COMMAND_UI.pip_size, COMMAND_UI.pip_size)
            set_ui_square_transform(self, self.ui.command_pip_icons[i], cx, cy, 0.812, command_color, COMMAND_UI.pip_size * 0.021 * 0.75, COMMAND_UI.pip_size * 0.021 * 0.75)
        else
            set_ui_square_transform(self, self.ui.command_pips[i], -9999, -9999, 0.81, vmath.vector4(0, 0, 0, 0), COMMAND_UI.pip_size, COMMAND_UI.pip_size)
            set_ui_square_transform(self, self.ui.command_pip_icons[i], -9999, -9999, 0.812, vmath.vector4(0, 0, 0, 0), COMMAND_UI.pip_size * 0.021 * 0.75, COMMAND_UI.pip_size * 0.021 * 0.75)
        end
    end

    local total_slots = UI_BACKPACK_COLS * UI_BACKPACK_ROWS
    local full_backpack_item_type = nil
    if unit.backpack_items and total_slots > 0 and #unit.backpack_items == total_slots then
        local first_item_type = unit.backpack_items[1]
        if first_item_type == "turret_packed" or first_item_type == "corpse" then
            full_backpack_item_type = first_item_type
        end
        for i = 1, total_slots do
            if unit.backpack_items[i] ~= full_backpack_item_type then
                full_backpack_item_type = nil
                break
            end
        end
    end
    for i = 1, total_slots do
        local slot_x, slot_y = LOOT_RUNTIME.get_backpack_slot_screen_pos(i)
        local item_type = unit.backpack_items and unit.backpack_items[i] or nil
        local slot_color = UI_COLOR_SLOT
        local icon_anim = nil
        if not full_backpack_item_type then
            icon_anim = LOOT_RUNTIME.get_item_visual_animation and LOOT_RUNTIME.get_item_visual_animation(item_type) or nil
        end
        if self.drag_resource and self.drag_resource.active and self.drag_resource.source_unit_id == unit.id and self.drag_resource.source_slot_index == i then
            slot_color = vmath.vector4(slot_color.x, slot_color.y, slot_color.z, 0.25)
        end
        set_ui_square_transform(self, self.ui.backpack_slots[i], slot_x, slot_y, 0.81, slot_color, UI_BACKPACK_SLOT_SIZE, UI_BACKPACK_SLOT_SIZE)
        if icon_anim then
            local icon_color = vmath.vector4(1, 1, 1, 1)
            if self.drag_resource and self.drag_resource.active and self.drag_resource.source_unit_id == unit.id and self.drag_resource.source_slot_index == i then
                icon_color = vmath.vector4(1, 1, 1, 0.25)
            end
            msg.post(msg.url(nil, self.ui.backpack_item_icons[i], "sprite"), "play_animation", { id = icon_anim })
            local icon_scale_x = UI_BACKPACK_SLOT_SIZE * 0.021
            local icon_scale_y = UI_BACKPACK_SLOT_SIZE * 0.021
            local buff_def = item_type and BUFFS_BY_ITEM_TYPE[item_type] or nil
            if buff_def then
                local draw_w = math.max(1, tonumber(buff_def.ui_pixel_w or UI_BACKPACK_SLOT_SIZE) or UI_BACKPACK_SLOT_SIZE)
                local draw_h = math.max(1, tonumber(buff_def.ui_pixel_h or UI_BACKPACK_SLOT_SIZE) or UI_BACKPACK_SLOT_SIZE)
                local draw_scale = tonumber(buff_def.backpack_draw_scale or 1.0) or 1.0
                icon_scale_x = (draw_w * 0.021) * draw_scale
                icon_scale_y = (draw_h * 0.021) * draw_scale
            end
            set_ui_square_transform(self, self.ui.backpack_item_icons[i], slot_x, slot_y, 0.815, icon_color, icon_scale_x, icon_scale_y)
        else
            set_ui_square_transform(self, self.ui.backpack_item_icons[i], -9999, -9999, 0.815, vmath.vector4(0, 0, 0, 0), UI_BACKPACK_SLOT_SIZE * 0.021, UI_BACKPACK_SLOT_SIZE * 0.021)
        end
    end
    if full_backpack_item_type and total_slots > 0 then
        local first_x, first_y = LOOT_RUNTIME.get_backpack_slot_screen_pos(1)
        local last_x, last_y = LOOT_RUNTIME.get_backpack_slot_screen_pos(total_slots)
        local center_x = (first_x + last_x) * 0.5
        local center_y = ((first_y + last_y) * 0.5) + 10
        local grid_w = math.abs(last_x - first_x) + UI_BACKPACK_SLOT_SIZE
        local grid_h = math.abs(last_y - first_y) + UI_BACKPACK_SLOT_SIZE
        local packed_turret_ui_scale = 0.021 * 0.576
        local packed_item_ui_scale_x = packed_turret_ui_scale
        local packed_item_ui_scale_y = packed_turret_ui_scale
        local packed_alpha = 1
        local full_backpack_anim = hash("gun_turret_icon")
        if full_backpack_item_type == "corpse" then
            full_backpack_anim = hash("human_dead_ui")
            local corpse_base_scale = packed_turret_ui_scale * 0.5
            packed_item_ui_scale_x = corpse_base_scale * 0.8
            packed_item_ui_scale_y = corpse_base_scale * 0.6
        end
        if self.drag_resource
            and self.drag_resource.active
            and self.drag_resource.source_unit_id == unit.id
            and self.drag_resource.drag_type == "resource"
            and unit.backpack_items
            and unit.backpack_items[self.drag_resource.source_slot_index] == full_backpack_item_type
        then
            packed_alpha = 0.25
        end
        msg.post(msg.url(nil, self.ui.backpack_item_icons[1], "sprite"), "play_animation", { id = full_backpack_anim })
        set_ui_square_transform(
            self,
            self.ui.backpack_item_icons[1],
            center_x,
            center_y,
            0.815,
            vmath.vector4(1, 1, 1, packed_alpha),
            grid_w * packed_item_ui_scale_x,
            grid_h * packed_item_ui_scale_y
        )
    end

    local equipment = unit.equipment or {}
    local hotspot_cx = UI_PANEL_X + BUFF_DROP_ZONE_OFFSET_X
    local hotspot_cy = UI_PANEL_Y + BUFF_DROP_ZONE_OFFSET_Y
    for i, slot_name in ipairs(BUFF_SLOT_ORDER) do
        local anchor = BUFF_SLOT_RELATIVE_OFFSETS[slot_name] or { x = 0, y = 0 }
        local slot_x = hotspot_cx + (anchor.x or 0)
        local slot_y = hotspot_cy + (anchor.y or 0)
        local slot_tint = vmath.vector4(0.16, 0.2, 0.18, 0.85)
        if self.drag_resource and self.drag_resource.active and self.drag_resource.drag_type == "equipped_buff" and self.drag_resource.source_unit_id == unit.id and self.drag_resource.source_slot_name == slot_name then
            slot_tint = vmath.vector4(slot_tint.x, slot_tint.y, slot_tint.z, 0.35)
        end
        set_ui_square_transform(self, self.ui.buff_slots[i], slot_x, slot_y, 0.813, slot_tint, BUFF_SLOT_FRAME_SIZE, BUFF_SLOT_FRAME_SIZE)
        local equipped_item = equipment[slot_name]
        local buff_def = equipped_item and BUFFS_BY_ITEM_TYPE[equipped_item] or nil
        if buff_def and buff_def.ui_anim then
            local icon_go = self.ui.buff_item_icons[i]
            local icon_color = vmath.vector4(1, 1, 1, 1)
            if self.drag_resource and self.drag_resource.active and self.drag_resource.drag_type == "equipped_buff" and self.drag_resource.source_unit_id == unit.id and self.drag_resource.source_slot_name == slot_name then
                icon_color = vmath.vector4(1, 1, 1, 0.35)
            end
            msg.post(msg.url(nil, icon_go, "sprite"), "play_animation", { id = hash(buff_def.ui_anim) })
            local draw_w = math.max(1, tonumber(buff_def.ui_pixel_w or BUFF_SLOT_FRAME_SIZE) or BUFF_SLOT_FRAME_SIZE)
            local draw_h = math.max(1, tonumber(buff_def.ui_pixel_h or BUFF_SLOT_FRAME_SIZE) or BUFF_SLOT_FRAME_SIZE)
            local draw_scale = tonumber(buff_def.equipped_draw_scale or buff_def.backpack_draw_scale or 1.0) or 1.0
            set_ui_square_transform(self, icon_go, slot_x, slot_y, 0.816, icon_color, (draw_w * 0.021) * draw_scale, (draw_h * 0.021) * draw_scale)
        else
            set_ui_square_transform(self, self.ui.buff_item_icons[i], -9999, -9999, 0.816, vmath.vector4(0, 0, 0, 0), 1, 1)
        end
    end

    set_ui_square_transform(self, self.ui.component_button, -9999, -9999, 0.82, vmath.vector4(0, 0, 0, 0), COMPONENT_UI.button_size, COMPONENT_UI.button_size)
    set_ui_square_transform(self, self.ui.fix_button, -9999, -9999, 0.82, vmath.vector4(0, 0, 0, 0), COMPONENT_UI.fix_button_size, COMPONENT_UI.fix_button_size)
    set_ui_square_transform(self, self.ui.loot_button, -9999, -9999, 0.82, vmath.vector4(0, 0, 0, 0), LOOT_UI.button_size, LOOT_UI.button_size)
    set_ui_square_transform(self, self.ui.retrieve_button, -9999, -9999, 0.82, vmath.vector4(0, 0, 0, 0), LOOT_UI.retrieve_button_size, LOOT_UI.retrieve_button_size)
    local comms_visible = should_show_comms_ui(self, unit)
    if not comms_visible then
        close_comms_panel(self)
    end
    if comms_visible then
        local toggle_tint = self.comms_panel_open and vmath.vector4(1, 1, 1, 1) or vmath.vector4(1, 1, 1, 0.75)
        set_ui_square_transform(self, self.ui.comms_toggle_button, COMMS_TOGGLE_BTN_X, COMMS_TOGGLE_BTN_Y, COMMS_TOGGLE_BTN_Z, toggle_tint, COMMS_TOGGLE_BTN_DRAW, COMMS_TOGGLE_BTN_DRAW)
    else
        set_ui_square_transform(self, self.ui.comms_toggle_button, -9999, -9999, COMMS_TOGGLE_BTN_Z, vmath.vector4(0, 0, 0, 0), COMMS_TOGGLE_BTN_DRAW, COMMS_TOGGLE_BTN_DRAW)
    end
    if comms_visible and self.comms_panel_open then
        set_ui_panel_transform(self, self.ui.comms_panel, COMMS_PANEL_X, COMMS_PANEL_Y, COMMS_PANEL_Z, COMMS_PANEL_W, COMMS_PANEL_H, vmath.vector4(1, 1, 1, 1))
    else
        set_ui_panel_transform(self, self.ui.comms_panel, -9999, -9999, COMMS_PANEL_Z, COMMS_PANEL_W, COMMS_PANEL_H, vmath.vector4(0, 0, 0, 0))
    end
    local close_button_x, close_button_y = get_ui_panel_close_button_center()
    set_ui_square_transform(
        self,
        self.ui.close_button,
        close_button_x,
        close_button_y,
        0.83,
        vmath.vector4(0, 0, 0, 0),
        28,
        28
    )
    local reactive_button_x, reactive_button_y = get_ui_panel_reactive_button_center()
    local unit_reactive_enabled = unit.reactive_fire_enabled ~= false
    local toggle_color = unit_reactive_enabled and vmath.vector4(0.2, 0.8, 0.2, 0.95) or vmath.vector4(0.8, 0.2, 0.2, 0.95)
    set_ui_square_transform(
        self,
        self.ui.reactive_toggle_button,
        reactive_button_x,
        reactive_button_y,
        0.84,
        toggle_color,
        64,
        32
    )
    if self.alien_turn_active and (not self.reactive_combat_enabled) then
        local adv_color = self.alien_turn_waiting_for_advance and vmath.vector4(0.2, 0.8, 0.2, 0.95) or vmath.vector4(0.8, 0.2, 0.2, 0.95)
        set_ui_square_transform(
            self,
            self.ui.reactive_advance_button,
            105,
            SCREEN_HEIGHT - 40,
            0.84,
            adv_color,
            70,
            30
        )
    else
        set_ui_square_transform(
            self,
            self.ui.reactive_advance_button,
            -9999,
            -9999,
            0.84,
            vmath.vector4(0, 0, 0, 0),
            70,
            30
        )
    end
    update_global_ui_buttons(self)
end

local function is_point_in_ui_panel(screen_x, screen_y)
    local min_x = UI_PANEL_X - UI_PANEL_W * 0.5
    local max_x = UI_PANEL_X + UI_PANEL_W * 0.5
    local min_y = UI_PANEL_Y - UI_PANEL_H * 0.5
    local max_y = UI_PANEL_Y + UI_PANEL_H * 0.5
    return screen_x >= min_x and screen_x <= max_x and screen_y >= min_y and screen_y <= max_y
end

function is_point_in_close_ui_button(screen_x, screen_y)
    local button_x, button_y = get_ui_panel_close_button_center()
    local half = 14
    return screen_x >= (button_x - half)
        and screen_x <= (button_x + half)
        and screen_y >= (button_y - half)
        and screen_y <= (button_y + half)
end

function try_close_selected_unit_ui(self, screen_x, screen_y)
    if not get_selected_unit(self) then
        return false
    end
    if not is_point_in_close_ui_button(screen_x, screen_y) then
        return false
    end
    deselect_all_units(self)
    self.ui_close_on_next_non_unit_click = false
    self.awaiting_slot_shuffle_click = false
    self.objective_reminder_visible = false
    self.selected_start_cell = nil
    close_comms_panel(self)
    update_human_visual_state(self)
    print("Unit panel closed.")
    return true
end

local function is_point_in_comms_panel(screen_x, screen_y)
    return is_point_in_screen_rect(screen_x, screen_y, COMMS_PANEL_X, COMMS_PANEL_Y, COMMS_PANEL_W, COMMS_PANEL_H)
end

local function try_toggle_comms_panel(self, screen_x, screen_y)
    local unit = get_selected_unit(self)
    if not should_show_comms_ui(self, unit) then
        close_comms_panel(self)
        return false
    end
    if is_point_in_screen_rect(screen_x, screen_y, COMMS_TOGGLE_BTN_X, COMMS_TOGGLE_BTN_Y, COMMS_TOGGLE_BTN_HIT_W, COMMS_TOGGLE_BTN_HIT_H) then
        self.comms_panel_open = not (self.comms_panel_open == true)
        return true
    end
    return false
end

local function emit_comms_command(self, unit, slot_index)
    if not (unit and unit.id) then
        return false
    end
    local event_type = COMMS_EVENT_TYPE_BY_INDEX[slot_index]
    if not is_valid_comms_event_type(event_type) then
        return false
    end
    if self.mp_state and self.mp_state.enabled then
        multiplayer_transport_send_command(self, "comms_command", {
            turn_id = self.mp_state.turn_id or 1,
            unit_id = unit.id,
            comms_event_type = event_type
        }, multiplayer_get_active_player_id_for_commands(self))
    elseif LOOT_RUNTIME and LOOT_RUNTIME.emit_derple_feedback then
        LOOT_RUNTIME.emit_derple_feedback(self, unit.id, event_type)
    end
    self.comms_panel_open = false
    return true
end

local function try_activate_comms_slot(self, screen_x, screen_y)
    local unit = get_selected_unit(self)
    if not should_show_comms_ui(self, unit) then
        close_comms_panel(self)
        return false
    end
    if self.comms_panel_open ~= true then
        return false
    end
    if not is_point_in_comms_panel(screen_x, screen_y) then
        return false
    end
    for slot_index = 1, (COMMS_SLOT_ROWS * COMMS_SLOT_COLS) do
        local cx, cy = get_comms_slot_center(slot_index)
        if is_point_in_screen_rect(screen_x, screen_y, cx, cy, COMMS_SLOT_HIT_W, COMMS_SLOT_HIT_H) then
            return emit_comms_command(self, unit, slot_index)
        end
    end
    return true
end

function try_toggle_reactive_combat(self, screen_x, screen_y)
    local selected_unit = get_selected_unit(self)
    if not selected_unit then
        return false
    end
    local tx, ty = get_ui_panel_reactive_button_center()
    tx = tx + 5
    ty = ty - 5
    local half_w = 32
    local half_h = 16
    if screen_x >= (tx - half_w) and screen_x <= (tx + half_w) and screen_y >= (ty - half_h) and screen_y <= (ty + half_h) then
        local new_enabled = not (selected_unit.reactive_fire_enabled ~= false)
        if self.mp_state and self.mp_state.enabled then
            multiplayer_transport_send_command(self, "set_reactive_fire", {
                turn_id = self.mp_state.turn_id or 1,
                unit_id = selected_unit.id,
                reactive_fire_enabled = new_enabled
            }, multiplayer_get_active_player_id_for_commands(self))
        else
            selected_unit.reactive_fire_enabled = new_enabled
            print(string.format("%s reactive fire: %s", selected_unit.display_name or "Unit", (selected_unit.reactive_fire_enabled ~= false) and "ON" or "OFF"))
        end
        return true
    end
    return false
end

function try_advance_reactive_alien_turn(self, screen_x, screen_y)
    if not self.alien_turn_active then
        return false
    end
    if self.reactive_combat_enabled then
        return false
    end
    local ax = 105
    local ay = SCREEN_HEIGHT - 40
    if screen_x >= (ax - 35) and screen_x <= (ax + 35) and screen_y >= (ay - 15) and screen_y <= (ay + 15) then
        if self.alien_turn_waiting_for_advance then
            self.alien_turn_waiting_for_advance = false
            print("Alien turn step advanced.")
        elseif not self.reactive_combat_enabled then
            self.alien_turn_manual_pause = true
            self.alien_turn_waiting_for_advance = true
            print("Alien turn paused. Press again to advance steps.")
        end
        return true
    end
    return false
end

function try_next_turn_button(self, screen_x, screen_y)
    if self.realtime_rules_enabled == true then
        return false
    end
    if self.alien_turn_active
        or self.pending_spitter_attack_phase
        or self.pending_melee_attack_phase
        or any_alien_is_moving(self)
        or any_civilian_is_moving(self)
    then
        return false
    end
    local half_w = NEW_TURN_BUTTON_W * 0.5
    local half_h = NEW_TURN_BUTTON_H * 0.5
    if screen_x >= (NEW_TURN_BUTTON_X - half_w)
        and screen_x <= (NEW_TURN_BUTTON_X + half_w)
        and screen_y >= (NEW_TURN_BUTTON_Y - half_h)
        and screen_y <= (NEW_TURN_BUTTON_Y + half_h) then
        if tutorial_rules_locked and tutorial_rules_locked(self) then
            return true
        end
        if not can_advance_next_turn(self, true) then
            return true
        end
        if self.mp_state and self.mp_state.enabled then
            multiplayer_transport_send_command(self, "new_turn_request", {
                turn_id = self.mp_state and self.mp_state.turn_id or 1
            }, self.mp_state and self.mp_state.host_player_id or "p1")
        else
            msg.post(".", "next_turn")
        end
        return true
    end
    return false
end

local multiplayer_sync_trace

multiplayer_transport_emit_event = function(self, event_type, payload)
    local sender_id = self.mp_state and self.mp_state.host_player_id or "p1"
    if self.mp_state then
        self.mp_state.event_seq = (self.mp_state.event_seq or 0) + 1
    end
    local event_id = string.format(
        "evt_%s_%d",
        tostring((self.mp_state and self.mp_state.session_id) or "local_session"),
        tonumber(self.mp_state and self.mp_state.event_seq or 0) or 0
    )
    local evt = {
        version = 1,
        session_id = (self.mp_state and self.mp_state.session_id) or "local_session",
        event_id = event_id,
        sender_player_id = sender_id,
        type = event_type,
        payload = payload or {}
    }
    multiplayer_sync_trace(self, "emit_event", string.format("event=%s id=%s sender=%s", tostring(event_type), tostring(event_id), tostring(sender_id)))
    return evt
end

multiplayer_sync_trace = function(self, tag, details)
    if MP_SYNC_TRACE_ENABLED ~= true then
        return
    end
    local turn_id = tonumber(self and self.mp_state and self.mp_state.turn_id or 0) or 0
    local local_id = tostring(self and self.mp_state and self.mp_state.local_player_id or "p?")
    local host_id = tostring(self and self.mp_state and self.mp_state.host_player_id or "p?")
    local role = (local_id == host_id) and "host" or "client"
    local checksum = "na"
    if multiplayer_compute_turn_checksum then
        local ok, value = pcall(multiplayer_compute_turn_checksum, self)
        if ok and value then
            checksum = tostring(value)
        end
    end
    local suffix = details and (" | " .. tostring(details)) or ""
    print(string.format(
        "MP TRACE | %s | role=%s local=%s host=%s turn=%d checksum=%s%s",
        tostring(tag or "unknown"),
        role,
        local_id,
        host_id,
        turn_id,
        checksum,
        suffix
    ))
end

multiplayer_compute_turn_checksum = function(self)
    if not self then
        return "0"
    end
    local parts = {}
    local function push(...)
        for i = 1, select("#", ...) do
            parts[#parts + 1] = tostring(select(i, ...))
        end
    end

    push("turn", self.mp_state and self.mp_state.turn_id or 1)
    local unit_order = get_spawn_order_unit_id_list()
    for _, unit_id in ipairs(unit_order or {}) do
        local unit = self.squad_units and self.squad_units[unit_id] or nil
        if unit then
            push(
                "u",
                unit_id,
                unit.cell_id or 0,
                unit.current_ap or 0,
                unit.current_health or 0,
                unit.current_ammo or 0,
                unit.backpack_used or 0,
                unit.in_shuttle == true and 1 or 0
            )
            local backpack = unit.backpack_items or {}
            for i = 1, #backpack do
                push("bi", unit_id, i, backpack[i] or "_")
            end
            local equipment = unit.equipment or {}
            for _, slot_name in ipairs(BUFF_SLOT_ORDER) do
                push("eq", unit_id, slot_name, tostring(equipment[slot_name] or "_"))
            end
        else
            push("u", unit_id, "missing")
        end
    end

    local alien_rows = {}
    for _, alien in ipairs(self.aliens or {}) do
        alien_rows[#alien_rows + 1] = string.format(
            "%d|%s|%d|%d|%d|%d",
            tonumber(alien and alien.id or 0) or 0,
            tostring(alien and alien.type or "blip"),
            tonumber(alien and alien.cell_id or 0) or 0,
            tonumber(alien and alien.hp_current or 0) or 0,
            (alien and alien.is_dead == true) and 1 or 0,
            (alien and alien.is_moving == true) and 1 or 0
        )
    end
    table.sort(alien_rows)
    for _, row in ipairs(alien_rows) do
        push("a", row)
    end

    local civilian_rows = {}
    for _, civilian in ipairs(self.civilians or {}) do
        civilian_rows[#civilian_rows + 1] = string.format(
            "%d|%d|%d|%d|%d|%d",
            tonumber(civilian and civilian.id or 0) or 0,
            tonumber(civilian and civilian.cell_id or 0) or 0,
            tonumber(civilian and civilian.current_health or 0) or 0,
            (civilian and civilian.is_awake == true) and 1 or 0,
            (civilian and civilian.is_dead == true) and 1 or 0,
            (civilian and civilian.is_rescued == true) and 1 or 0
        )
    end
    table.sort(civilian_rows)
    for _, row in ipairs(civilian_rows) do
        push("cv", row)
    end

    for cell_id, cell in ipairs(self.world_grid or {}) do
        if cell then
            push(
                "c",
                cell_id,
                cell.isPowered == true and 1 or 0,
                tonumber(cell.lightValue or 0) or 0
            )
            local door_rows = {}
            for _, obj in ipairs(cell.objects or {}) do
                if obj and obj.name == hash("door") then
                    door_rows[#door_rows + 1] = string.format(
                        "%d|%d",
                        tonumber(obj.objectId or 0) or 0,
                        obj.isOpen == true and 1 or 0
                    )
                end
            end
            table.sort(door_rows)
            for _, row in ipairs(door_rows) do
                push("d", cell_id, row)
            end
        end
    end

    local world_item_ids = {}
    for key, _ in pairs(self.world_item_instances or {}) do
        world_item_ids[#world_item_ids + 1] = tonumber(key) or 0
    end
    table.sort(world_item_ids)
    for _, item_id in ipairs(world_item_ids) do
        local item = (self.world_item_instances and (self.world_item_instances[item_id] or self.world_item_instances[tostring(item_id)])) or nil
        if item then
            push(
                "wi",
                item_id,
                tostring(item.item_type or item.type or "_"),
                tonumber(item.cell_id or 0) or 0,
                tonumber(item.world_x or 0) or 0,
                tonumber(item.world_y or 0) or 0
            )
        end
    end

    local serial = table.concat(parts, "|")
    local h = 7
    for i = 1, #serial do
        h = ((h * 131) + string.byte(serial, i) + i) % 2147483647
    end
    return tostring(h)
end

multiplayer_transport_handle_command = function(self, command)
    local events = {}
    if not (self.mp_state and self.mp_state.enabled) then
        return events
    end
    if not command or type(command) ~= "table" then
        return events
    end
    local cmd_type = command.type
    local sender = command.sender_player_id
    local payload = command.payload or {}
    local cmd_message_id = command.message_id
    local is_local_host = (self.mp_state.local_player_id == self.mp_state.host_player_id)
    multiplayer_sync_trace(
        self,
        "recv_command",
        string.format(
            "type=%s sender=%s msg=%s payload_turn=%s",
            tostring(cmd_type),
            tostring(sender),
            tostring(cmd_message_id or "-"),
            tostring(payload.turn_id or "-")
        )
    )
    if not is_local_host then
        return events
    end
    if cmd_message_id and cmd_message_id ~= "" then
        self.mp_state.seen_command_ids = self.mp_state.seen_command_ids or {}
        local dedupe_key = string.format("%s|%s", tostring(sender or "unknown"), tostring(cmd_message_id))
        if self.mp_state.seen_command_ids[dedupe_key] == true then
            multiplayer_sync_trace(self, "drop_command_duplicate", string.format("key=%s type=%s", dedupe_key, tostring(cmd_type)))
            return events
        end
        self.mp_state.seen_command_ids[dedupe_key] = true
    end

    if cmd_type == "set_ready" then
        local target_player_id = payload.player_id
        local ready_on = payload.ready == true
        local is_required = false
        for _, required_id in ipairs(self.mp_state.required_ready_player_ids or {}) do
            if required_id == target_player_id then
                is_required = true
                break
            end
        end
        if (not is_required) or sender ~= target_player_id then
            table.insert(events, multiplayer_transport_emit_event(self, "command_rejected", {
                command_type = "set_ready",
                reason = "invalid_ready_sender_or_target"
            }))
            return events
        end
        table.insert(events, multiplayer_transport_emit_event(self, "ready_state_changed", {
            player_id = target_player_id,
            ready = ready_on,
            turn_id = self.mp_state.turn_id or 1
        }))
        return events
    end

    if cmd_type == "new_turn_request" then
        if sender ~= self.mp_state.host_player_id then
            table.insert(events, multiplayer_transport_emit_event(self, "command_rejected", {
                command_type = "new_turn_request",
                reason = "not_host"
            }))
            return events
        end
        if not can_advance_next_turn(self, true) then
            table.insert(events, multiplayer_transport_emit_event(self, "command_rejected", {
                command_type = "new_turn_request",
                reason = "ready_gate_not_satisfied"
            }))
            return events
        end
        self.mp_state.pending_turn_state_snapshot_turn_id = (self.mp_state.turn_id or 1) + 1
        table.insert(events, multiplayer_transport_emit_event(self, "turn_advanced", {
            turn_id = (self.mp_state.turn_id or 1) + 1
        }))
        return events
    end

    if cmd_type == "request_snapshot" then
        if sender == self.mp_state.host_player_id then
            table.insert(events, multiplayer_transport_emit_event(self, "command_rejected", {
                command_type = "request_snapshot",
                reason = "host_does_not_request_snapshot"
            }))
            return events
        end
        local snapshot = multiplayer_build_snapshot_state(self)
        table.insert(events, multiplayer_transport_emit_event(self, "snapshot_state", {
            target_player_id = sender,
            snapshot = snapshot
        }))
        return events
    end

    if cmd_type == "request_setup_state" then
        local config = multiplayer_setup_build_session_config(self)
        table.insert(events, multiplayer_transport_emit_event(self, "setup_state_updated", {
            target_player_id = sender,
            session_config = config
        }))
        return events
    end

    if cmd_type == "push_setup_state" then
        if sender ~= self.mp_state.host_player_id then
            table.insert(events, multiplayer_transport_emit_event(self, "command_rejected", {
                command_type = "push_setup_state",
                reason = "not_host"
            }))
            return events
        end
        -- Host local state is already authoritative; never re-apply pushed setup to host.
        local config = multiplayer_setup_build_session_config(self)
        table.insert(events, multiplayer_transport_emit_event(self, "setup_state_updated", {
            session_config = config
        }))
        return events
    end

    if cmd_type == "start_match_request" then
        if sender ~= self.mp_state.host_player_id then
            table.insert(events, multiplayer_transport_emit_event(self, "command_rejected", {
                command_type = "start_match_request",
                reason = "not_host"
            }))
            return events
        end
        local config = multiplayer_setup_build_session_config(self)
        if not multiplayer_setup_is_valid(self) then
            table.insert(events, multiplayer_transport_emit_event(self, "command_rejected", {
                command_type = "start_match_request",
                reason = "invalid_setup"
            }))
            return events
        end
        config.level_index = select_level_index_for_mission(self, config.mission_type or MISSION_TYPE_ESCAPE)
        table.insert(events, multiplayer_transport_emit_event(self, "match_started", {
            session_config = config
        }))
        return events
    end

    if cmd_type == "move_unit" then
        local unit_id = payload.unit_id
        local destination_cell_id = tonumber(payload.destination_cell_id)
        local requested_slot = tonumber(payload.destination_slot_index)
        local expected_turn_id = tonumber(payload.turn_id or (self.mp_state.turn_id or 1))
        if expected_turn_id ~= (self.mp_state.turn_id or 1) then
            table.insert(events, multiplayer_transport_emit_event(self, "command_rejected", {
                command_type = "move_unit",
                reason = "stale_turn_id"
            }))
            return events
        end
        if not multiplayer_player_owns_unit(self, sender, unit_id) then
            table.insert(events, multiplayer_transport_emit_event(self, "command_rejected", {
                command_type = "move_unit",
                reason = "unit_not_owned_by_sender"
            }))
            return events
        end
        local unit = self.squad_units and self.squad_units[unit_id] or nil
        if not unit or (unit.current_health or 0) <= 0 or unit.is_moving then
            table.insert(events, multiplayer_transport_emit_event(self, "command_rejected", {
                command_type = "move_unit",
                reason = "unit_not_actionable"
            }))
            return events
        end
        if not destination_cell_id or unit.cell_id == destination_cell_id or not is_walkable_cell(self.world_grid, destination_cell_id) then
            table.insert(events, multiplayer_transport_emit_event(self, "command_rejected", {
                command_type = "move_unit",
                reason = "invalid_destination"
            }))
            return events
        end
        local path, total_cost = find_path(self.world_grid, unit.cell_id, destination_cell_id, nil, MOVEMENT_PROFILE_HUMAN, nil)
        if not path then
            table.insert(events, multiplayer_transport_emit_event(self, "command_rejected", {
                command_type = "move_unit",
                reason = "no_path"
            }))
            return events
        end
        total_cost = tonumber(total_cost)
        if not total_cost then
            total_cost = 0
            for i = 2, #path do
                total_cost = total_cost + (get_step_move_cost(self.world_grid, path[i - 1], path[i]) or 0)
            end
        end
        local ap_before = tonumber(unit.current_ap or 0) or 0
        if total_cost <= 0 or ap_before <= 0 then
            table.insert(events, multiplayer_transport_emit_event(self, "command_rejected", {
                command_type = "move_unit",
                reason = "insufficient_ap"
            }))
            return events
        end
        local approved_path = { path[1] }
        local approved_cost = 0
        for i = 2, #path do
            local step_cost = tonumber(get_step_move_cost(self.world_grid, path[i - 1], path[i]) or 0) or 0
            if step_cost <= 0 then
                break
            end
            if (approved_cost + step_cost) > ap_before then
                break
            end
            approved_cost = approved_cost + step_cost
            table.insert(approved_path, path[i])
        end
        if #approved_path <= 1 or approved_cost <= 0 then
            table.insert(events, multiplayer_transport_emit_event(self, "command_rejected", {
                command_type = "move_unit",
                reason = "insufficient_ap"
            }))
            return events
        end
        local approved_destination_cell_id = approved_path[#approved_path]
        local ap_after = math.max(0, ap_before - approved_cost)
        table.insert(events, multiplayer_transport_emit_event(self, "move_unit_applied", {
            unit_id = unit_id,
            destination_cell_id = approved_destination_cell_id,
            destination_slot_index = multiplayer_resolve_destination_slot(self, unit, approved_destination_cell_id, requested_slot),
            path = multiplayer_clone_simple_table(approved_path),
            ap_cost = approved_cost,
            ap_before = ap_before,
            ap_after = ap_after
        }))
        return events
    end

    if cmd_type == "manual_shot" then
        local unit_id = payload.unit_id
        local alien_id = tonumber(payload.alien_id)
        local expected_turn_id = tonumber(payload.turn_id or (self.mp_state.turn_id or 1))
        if expected_turn_id ~= (self.mp_state.turn_id or 1) then
            table.insert(events, multiplayer_transport_emit_event(self, "command_rejected", {
                command_type = "manual_shot",
                reason = "stale_turn_id"
            }))
            return events
        end
        if not multiplayer_player_owns_unit(self, sender, unit_id) then
            table.insert(events, multiplayer_transport_emit_event(self, "command_rejected", {
                command_type = "manual_shot",
                reason = "unit_not_owned_by_sender"
            }))
            return events
        end
        local unit = self.squad_units and self.squad_units[unit_id] or nil
        local alien = find_alien_by_id(self, alien_id)
        local shot_ap_cost = get_ap_cost_value("manual_ranged_shot", 1)
        if not unit or (unit.current_health or 0) <= 0 or unit.is_moving or unit.current_ap < shot_ap_cost then
            table.insert(events, multiplayer_transport_emit_event(self, "command_rejected", {
                command_type = "manual_shot",
                reason = "unit_not_actionable"
            }))
            return events
        end
        if not alien or alien.is_dead then
            table.insert(events, multiplayer_transport_emit_event(self, "command_rejected", {
                command_type = "manual_shot",
                reason = "invalid_target"
            }))
            return events
        end
        local hit_chance = compute_manual_ranged_hit_chance(self, unit, alien) or 0
        hit_chance = math.max(0, math.min(100, tonumber(hit_chance) or 0))
        local roll = math.random(1, 100)
        local impact_hit = roll <= hit_chance
        table.insert(events, multiplayer_transport_emit_event(self, "manual_shot_applied", {
            unit_id = unit_id,
            alien_id = alien_id,
            hit_chance = hit_chance,
            roll = roll,
            impact_hit = impact_hit
        }))
        return events
    end


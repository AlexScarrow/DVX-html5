local function update_human_ap_debug_label(self)
    local unit = get_controlled_unit(self)
    if not unit then
        return
    end

    self.last_debug_ap_by_unit = self.last_debug_ap_by_unit or {}
    if self.last_debug_ap_by_unit[unit.id] ~= unit.current_ap then
        print(string.format("UI DEBUG | %s AP: %d/%d", unit.display_name, unit.current_ap, unit.max_ap))
        self.last_debug_ap_by_unit[unit.id] = unit.current_ap
    end
end

local function next_turn_reset_human_ap(self)
    if not self.squad_units then
        return
    end

    for _, unit in pairs(self.squad_units) do
        if unit and (unit.current_health or 0) > 0 then
            unit.current_ap = unit.max_ap
        else
            unit.current_ap = 0
            unit.is_moving = false
            unit.move_path = nil
            unit.move_path_index = 0
        end
        unit.is_selected = false
    end

    -- Future hook: Sarge command points increase by 1/turn (max 10).
    local sarge = self.squad_units.sarge
    if sarge then
        sarge.command_points = math.min(sarge.max_command_points, (sarge.command_points or 0) + 1)
        print("UI DEBUG | Sarge Command Points: " .. sarge.command_points)
    end

    update_human_visual_state(self)
    update_human_ap_debug_label(self)
    print("Next turn: squad AP restored")
end

local function get_human_world_pos_for_cell(cell)
    local x, y = coords_to_world_pos(cell.xCell, cell.yCell)
    -- Keep feet near the floor: 10px above each cell's bottom boundary.
    y = y - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM
    return x, y
end

local function get_unit_world_pos_in_cell(self, unit, cell_id)
    local base_x, base_y = get_human_world_pos_for_cell(self.world_grid[cell_id])
    local slot_index = ensure_cell_slot_assignment(self, unit, cell_id)
    local slot_offset = CELL_SLOT_OFFSETS_X[slot_index] or 0
    return base_x + (slot_offset * HUMAN_STACK_SPACING_X), base_y
end

local function refresh_unit_positions_in_cell(self, cell_id)
    if not cell_id then
        return
    end
    local units_in_cell = get_units_on_cell(self, cell_id)
    sort_units_by_spawn_order(units_in_cell)
    for _, unit in ipairs(units_in_cell) do
        if unit.go_path then
            local x, y = get_unit_world_pos_in_cell(self, unit, cell_id)
            go.set_position(vmath.vector3(x, y, 0.5), unit.go_path)
        end
    end
end

local function move_human_to_cell(self, unit, cell_id)
    if not unit then
        return
    end

    local old_cell_id = unit.cell_id
    clear_cell_slot_assignment(self, unit, old_cell_id)
    if old_cell_id and self.world_grid[old_cell_id] and not cell_has_any_unit_except(self, old_cell_id, unit.id) then
        self.world_grid[old_cell_id].isOccupied = hash("empty")
    end

    unit.cell_id = cell_id
    self.world_grid[cell_id].isOccupied = unit.occupancy_hash
    ensure_cell_slot_assignment(self, unit, cell_id)

    refresh_unit_positions_in_cell(self, old_cell_id)
    refresh_unit_positions_in_cell(self, cell_id)
end

local function spawn_human_unit(self)
    if not self.squad_units then
        print("No squad units available for spawn.")
        return
    end

    local spawn_cells = {}
    for cell_id, cell in ipairs(self.world_grid) do
        if cell.tileID ~= hash("empty") then
            table.insert(spawn_cells, cell_id)
        end
    end

    if #spawn_cells < 4 then
        print("Not enough walkable cells to spawn the full squad.")
        return
    end

    self.cell_slot_assignments = {}

    local spawn_order = get_spawn_order_unit_id_list()
    for i, unit_id in ipairs(spawn_order) do
        local unit = self.squad_units[unit_id]
        if unit then
            unit.cell_id = nil
            unit.is_selected = false
            unit.is_moving = false
            unit.move_path = nil
            unit.move_path_index = 0
            unit.anim_phase = 0
            unit.current_ap = unit.max_ap
            unit.backpack_items = {}
            unit.backpack_used = 0

            move_human_to_cell(self, unit, spawn_cells[i])
            set_unit_scale(unit, HUMAN_VISUAL_SCALE, HUMAN_VISUAL_SCALE)
            print(unit.display_name .. " spawned on cell: " .. spawn_cells[i])
        end
    end

    update_human_visual_state(self)
    update_human_ap_debug_label(self)
end

local function begin_human_path_move(self, path)
    local unit = get_controlled_unit(self)
    if not unit then
        return
    end
    if not (unit and (unit.current_health or 0) > 0) then
        print(unit.display_name .. " is dead and cannot move.")
        return
    end

    if not path or #path < 2 then
        unit.is_moving = false
        unit.move_path = nil
        unit.move_path_index = 0
        return
    end

    unit.is_moving = true
    unit.move_path = path
    unit.move_path_index = 2 -- first element is current cell
    unit.anim_phase = 0
end

local function update_single_unit_movement(self, unit, dt)
    if not unit or not unit.is_moving or not unit.move_path then
        return
    end
    if not (unit and (unit.current_health or 0) > 0) then
        unit.is_moving = false
        unit.move_path = nil
        unit.move_path_index = 0
        set_unit_scale(unit, HUMAN_VISUAL_SCALE, HUMAN_VISUAL_SCALE)
        return
    end

    local target_cell_id = unit.move_path[unit.move_path_index]
    if not target_cell_id then
        unit.is_moving = false
        unit.move_path = nil
        unit.move_path_index = 0
        set_unit_scale(unit, HUMAN_VISUAL_SCALE, HUMAN_VISUAL_SCALE)
        return
    end

    local target_x, target_y = get_unit_world_pos_in_cell(self, unit, target_cell_id)
    local target_cost = get_step_move_cost(self.world_grid, unit.cell_id, target_cell_id)
    if target_cost > unit.current_ap then
        unit.is_moving = false
        unit.move_path = nil
        unit.move_path_index = 0
        set_unit_scale(unit, HUMAN_VISUAL_SCALE, HUMAN_VISUAL_SCALE)
        print(unit.display_name .. " stopped before cell " .. target_cell_id .. " (cost " .. target_cost .. ", AP " .. unit.current_ap .. ")")
        update_human_visual_state(self)
        update_human_ap_debug_label(self)
        return
    end

    local current_pos = go.get_position(unit.go_path)
    local dx = target_x - current_pos.x
    local dy = target_y - current_pos.y
    local distance = math.sqrt(dx * dx + dy * dy)
    local step = HUMAN_MOVE_SPEED * dt

    unit.anim_phase = (unit.anim_phase or 0) + (dt * HUMAN_PINGPONG_SPEED * math.pi * 2)
    local ping = math.sin(unit.anim_phase)
    local scale_x = HUMAN_VISUAL_SCALE
    local scale_y = HUMAN_VISUAL_SCALE
    if math.abs(dx) >= math.abs(dy) then
        scale_x = HUMAN_VISUAL_SCALE * (1 + HUMAN_PINGPONG_AMPLITUDE * ping)
    else
        scale_y = HUMAN_VISUAL_SCALE * (1 + HUMAN_PINGPONG_AMPLITUDE * ping)
    end
    set_unit_scale(unit, scale_x, scale_y)

    if distance <= step then
        go.set_position(vmath.vector3(target_x, target_y, 0.5), unit.go_path)
        unit.current_ap = unit.current_ap - target_cost
        move_human_to_cell(self, unit, target_cell_id)
        update_human_ap_debug_label(self)
        unit.move_path_index = unit.move_path_index + 1

        if unit.move_path_index > #unit.move_path then
            unit.is_moving = false
            unit.move_path = nil
            unit.move_path_index = 0
            set_unit_scale(unit, HUMAN_VISUAL_SCALE, HUMAN_VISUAL_SCALE)
            print(unit.display_name .. " move complete on cell: " .. unit.cell_id)
            update_human_visual_state(self)
        end
    else
        local nx = current_pos.x + (dx / distance) * step
        local ny = current_pos.y + (dy / distance) * step
        go.set_position(vmath.vector3(nx, ny, 0.5), unit.go_path)
    end
end

local function update_human_movement(self, dt)
    if not self.squad_units then
        return
    end
    for _, unit in pairs(self.squad_units) do
        update_single_unit_movement(self, unit, dt)
    end
end

local function get_clicked_unit_in_cell(self, cell_id, world_x, world_y)
    local units_in_cell = get_units_on_cell(self, cell_id)
    if #units_in_cell == 0 then
        return nil
    end

    local best_unit = nil
    local best_dist = math.huge
    for _, unit in ipairs(units_in_cell) do
        if unit.go_path then
            local pos = go.get_position(unit.go_path)
            local dx = pos.x - world_x
            local dy = pos.y - world_y
            local dist = math.sqrt(dx * dx + dy * dy)
            if dist < best_dist then
                best_dist = dist
                best_unit = unit
            end
        end
    end

    if best_dist <= UNIT_CLICK_SELECT_RADIUS then
        return best_unit
    end
    return nil
end

local function get_clicked_alien_in_cell(self, cell_id, world_x, world_y)
    if not self.aliens then
        return nil
    end

    local best_alien = nil
    local best_dist = math.huge
    local count_on_cell = 0

    for _, alien in ipairs(self.aliens) do
        if (not alien.is_dead) and alien.cell_id == cell_id then
            count_on_cell = count_on_cell + 1
            if alien.go_id then
                local pos = go.get_position(alien.go_id)
                local dx = pos.x - world_x
                local dy = pos.y - world_y
                local dist = math.sqrt(dx * dx + dy * dy)
                if dist < best_dist then
                    best_dist = dist
                    best_alien = alien
                end
            elseif not best_alien then
                best_alien = alien
            end
        end
    end

    if count_on_cell == 1 then
        return best_alien
    end

    if best_dist <= UNIT_CLICK_SELECT_RADIUS then
        return best_alien
    end
    return nil
end

local function try_manual_human_shot(self, unit, clicked_cell_id, world_x, world_y)
    if not unit or not unit.is_selected then
        return false
    end
    if not (unit and (unit.current_health or 0) > 0) then
        print("Unable to fire: selected unit is dead.")
        return true
    end

    local alien = get_clicked_alien_in_cell(self, clicked_cell_id, world_x, world_y)
    if not alien then
        return false
    end

    -- Keep this command on the human side of the turn boundary.
    if any_alien_is_moving(self) or self.pending_spitter_attack_phase or self.pending_melee_attack_phase then
        print("Unable to fire: alien turn in progress.")
        return true
    end

    if MELEE_RUNTIME.try_manual_human_melee(self, unit, alien) then
        update_human_visual_state(self)
        update_human_ap_debug_label(self)
        return true
    end

    local alien_cell = self.world_grid[alien.cell_id]
    if not alien_cell or alien_cell.tileID == hash("empty") then
        print("Unable to fire: target is in VOID.")
        return true
    end

    if not has_unobstructed_los(self.world_grid, unit.cell_id, alien.cell_id) then
        print("Unable to fire: no line of sight.")
        return true
    end

    if unit.current_ap <= 0 or unit.current_ammo <= 0 then
        print("unable to fire no ammo/ap")
        return true
    end

    unit.current_ap = unit.current_ap - 1
    unit.current_ammo = unit.current_ammo - 1
    spawn_human_reaction_projectile(self, unit, alien)

    local active_light = (alien_cell.isPowered and math.max(0, math.min(3, alien_cell.lightValue or 0))) or 0
    local ranged_model = require("main.config").RANGED_HIT_MODEL
    local base_hit_chance = ranged_model.base_hit_chance + (active_light * ranged_model.per_light_level_bonus)
    local role = CLASS_ROLE_HOOKS[unit.class_id]
    local class_bonus = (role and role.ranged_hit_bonus) or 0
    local hit_chance = math.max(ranged_model.min_hit_chance, math.min(ranged_model.max_hit_chance, base_hit_chance + class_bonus))
    local roll = math.random(1, 100)
    if roll <= hit_chance then
        print(string.format(
            "%s fired at alien #%d and HIT (alien eliminated) [light=%d chance=%d%% roll=%d]",
            unit.display_name, alien.id, active_light, hit_chance, roll
        ))
        alien.is_dead = true
        alien.is_moving = false
        alien.move_path = nil
        alien.move_path_index = 0
    else
        print(string.format(
            "%s fired at alien #%d and MISSED [light=%d chance=%d%% roll=%d]",
            unit.display_name, alien.id, active_light, hit_chance, roll
        ))
    end

    update_human_visual_state(self)
    update_human_ap_debug_label(self)
    return true
end

local function handle_human_click_flow(self, clicked_cell_id, world_x, world_y)
    local unit = get_controlled_unit(self)
    if not unit or not unit.cell_id then
        return false
    end

    local clicked_unit = get_clicked_unit_in_cell(self, clicked_cell_id, world_x, world_y)
    if clicked_unit then
        if not (clicked_unit and (clicked_unit.current_health or 0) > 0) then
            print(clicked_unit.display_name .. " is dead.")
            return true
        end
        self.ui_close_on_next_non_unit_click = false
        if clicked_unit.is_moving then
            print(clicked_unit.display_name .. " is already moving.")
            return true
        end
        if self.controlled_unit_id == clicked_unit.id and clicked_unit.is_selected then
            clicked_unit.is_selected = false
            print(clicked_unit.display_name .. " deselected.")
        else
            self.controlled_unit_id = clicked_unit.id
            deselect_all_units(self)
            clicked_unit.is_selected = true
            print(clicked_unit.display_name .. " selected. Click destination cell.")
        end
        update_human_visual_state(self)
        self.selected_start_cell = nil
        update_human_ap_debug_label(self)
        return true
    end

    unit = get_controlled_unit(self)
    if not (unit and (unit.current_health or 0) > 0) then
        if unit.is_selected then
            unit.is_selected = false
            update_human_visual_state(self)
        end
        print(unit.display_name .. " is dead and cannot act.")
        return true
    end
    if unit.is_selected and self.ui_close_on_next_non_unit_click then
        self.ui_close_on_next_non_unit_click = false
        deselect_all_units(self)
        update_human_visual_state(self)
        print("Selection cleared.")
        return true
    end

    if unit.is_selected then
        if try_manual_human_shot(self, unit, clicked_cell_id, world_x, world_y) then
            self.ui_close_on_next_non_unit_click = true
            return true
        end

        if unit.is_moving then
            print(unit.display_name .. " is already moving.")
            return true
        end
        if unit.current_ap <= 0 then
            print(unit.display_name .. " has no AP. Click next turn to refresh.")
            update_human_visual_state(self)
            return true
        end

        if not is_walkable_cell(self.world_grid, clicked_cell_id) then
            print("Destination is VOID. Choose a valid destination.")
            update_human_visual_state(self)
            return true
        end

        local path, total_cost = find_path(self.world_grid, unit.cell_id, clicked_cell_id, nil, MOVEMENT_PROFILE_HUMAN, nil)
        if path then
            print(unit.display_name .. " route selected:")
            print_path_debug(path, total_cost)
            highlight_path(self, path)
            begin_human_path_move(self, path)
        else
            print("No path found for " .. unit.display_name .. " to cell: " .. clicked_cell_id)
        end

        -- Keep panel visible after destination click; next non-unit click closes it.
        self.ui_close_on_next_non_unit_click = true
        update_human_visual_state(self)
        return true
    end

    return false
end

local function process_cell_selection(self, clicked_cell_id)
    local cell = self.world_grid[clicked_cell_id]
    if cell.tileID == hash("empty") then
        print("Clicked VOID cell. Select a valid cell.")
        return
    end

    if not self.selected_start_cell then
        clear_path_visuals(self)
        self.selected_start_cell = clicked_cell_id
        apply_cell_tint(clicked_cell_id, COLOR_START)
        table.insert(self.path_highlight_cells, clicked_cell_id)
        print("Start cell selected: " .. clicked_cell_id .. ". Click destination cell.")
    else
        local start_id = self.selected_start_cell
        local end_id = clicked_cell_id

        if start_id == end_id then
            clear_path_visuals(self)
            self.selected_start_cell = nil
            print("Selection canceled (same start/destination cell).")
            return
        end

        local path, total_cost = find_path(self.world_grid, start_id, end_id, nil)
        if path then
            print_path_debug(path, total_cost)
            highlight_path(self, path)
        else
            clear_path_visuals(self)
            apply_cell_tint(start_id, COLOR_START)
            table.insert(self.path_highlight_cells, start_id)
            apply_cell_tint(end_id, COLOR_END)
            table.insert(self.path_highlight_cells, end_id)
            print("No valid path from " .. start_id .. " to " .. end_id)
        end

        self.selected_start_cell = nil
    end
end


    -- =============================================================================
    -- VISUAL RENDERING
    -- =============================================================================

    function spawn_visuals(self)
        print("Creating visual representation...")
        local spawned_count = 0
        cell_objects = {}
        tile_objects = {}
        self.tile_light_layers = {}
        self.tile_light_power_state = {}
        self.tile_light_flicker_state = {}
        loot_objects = {}
        machine_objects = {}
        self.power_node_objects = {}
        self.light_value_objects = {}

        -- Spawn tile sprites slightly above cell debug layer (50% opacity).
        local selected_level = self.level_library[1]
        for placement_index, placement in ipairs(selected_level) do
            local center_x, center_y = coords_to_world_pos(placement.x, placement.y)
            local pos = vmath.vector3(center_x, center_y, 0.02)

            local id = factory.create("/tile_factory#tile_factory", pos, nil, {}, vmath.vector3(visual_scale, visual_scale, 1))
            if id then
                local anim = "tile_" .. placement.tile
                msg.post(msg.url(nil, id, "sprite"), "play_animation", { id = hash(anim) })
                go.set(msg.url(nil, id, "sprite"), "tint", vmath.vector4(1, 1, 1, TILE_OPACITY))
                table.insert(tile_objects, id)
            else
                print("Tile factory create failed for: " .. placement.tile)
            end

            if placement.tile == "armoury" then
                local light_id = factory.create("/tile_factory#tile_factory", vmath.vector3(center_x, center_y, 0.3), nil, {}, vmath.vector3(visual_scale, visual_scale, 1))
                if light_id then
                    msg.post(msg.url(nil, light_id, "sprite"), "play_animation", { id = hash("tile_armoury_off") })
                    self.tile_light_layers[placement_index] = light_id
                    self.tile_light_power_state[placement_index] = false
                    self.tile_light_flicker_state[placement_index] = nil
                end
            end
        end
        print("Spawned " .. #tile_objects .. " tiles")

        -- Spawn cell sprites (debug grid under semi-transparent tiles)
        for _, cell in ipairs(self.world_grid) do
            print("making visual cell")
            if cell.tileID ~= hash("empty") then  -- Only spawn cells that are part of tiles
            --if true then  -- spawn ALL CELLS!
                local x, y = coords_to_world_pos(cell.xCell, cell.yCell)
                local pos = vmath.vector3(x, y, 0)

                -- Determine animation
                local animation = "cell_open"
                if not cell.accessRight and not cell.accessDown then
                    animation = "cell_right_down_wall"
                elseif not cell.accessRight then
                    animation = "cell_right_wall"
                elseif not cell.accessDown then
                    animation = "cell_down_wall"
                end
               
                local id = factory.create("/cell_factory#cell_factory", pos, nil, {}, vmath.vector3(visual_scale, visual_scale, 1))
                if id then
                    msg.post(msg.url(nil, id, "cell_sprite1"), "set_animation", {animation = hash(animation)})
                    cell_objects[cell.idNumber] = id
                    spawned_count = spawned_count + 1
                end

                
--                 local id = factory.create("/cell_factory#cell_factory", pos, nil, {}, vmath.vector3(visual_scale, visual_scale, 1))
--                 if id then
--                     print("alex",id)
--                     msg.post(msg.url(nil, id, "cell_sprite"), "set_animation", {animation = hash(animation)})
--                    
-- 
--                     cell_objects[cell.idNumber] = id
--                 end
            end
        end

        print("Spawned " .. spawned_count .. " cells")
        LOOT_RUNTIME.refresh_loot_markers(self)
        LOOT_RUNTIME.refresh_machine_markers(self)
        LOOT_RUNTIME.refresh_fix_markers(self)
        LOOT_RUNTIME.refresh_power_node_markers(self)
        LOOT_RUNTIME.refresh_light_value_markers(self)
    end--of spawn visuals fn






-- =============================================================================
-- INIT FUNCTION
-- =============================================================================

function init(self)
    print("=== DERPLES VS XENOS - Initializing ===")
    print("Chat GPT is here")

   

    -- Initialize edge lists for boundary checking
    initialize_edge_lists()

    -- Create the worldGrid (15x15 = 225 cells)
    self.world_grid = create_world_grid()
    print("WorldGrid created: " .. #self.world_grid .. " cells")

    -- Create tile library
    self.tile_library = create_tile_library()
    print("Tile library created")

    -- Create level designs
    self.level_library = create_level_library()
    print("Level library created")

    -- Select a random level (for now, just use level 1)
    local selected_level = self.level_library[1]
    print("Selected level 1 for baking")

    -- Bake the level onto the worldGrid
    self.world_grid = bake_level_to_world_grid(self.world_grid, selected_level, self.tile_library)
    print("Level baked down to worldGrid")

    -- Camera setup
    self.camera_pos = vmath.vector3(CELL_WIDTH * GRID_COLS / 2, CELL_HEIGHT * GRID_ROWS / 2, 1000)
    self.camera_zoom = 1.0
    self.camera_min_zoom = 0.5
    self.camera_max_zoom = 1.0
    self.drag_threshold_px = 12
    self.is_panning = false
    self.did_drag = false
    self.drag_start_screen_x = 0
    self.drag_start_screen_y = 0
    self.drag_start_camera_pos = self.camera_pos
    self.last_pan_screen_x = 0
    self.last_pan_screen_y = 0
    self.pan_velocity_x = 0
    self.pan_velocity_y = 0
    self.pan_inertia_damping = 8
    self.pan_inertia_min_speed = 3

    --self.camera_pos = vmath.vector3(CELL_WIDTH * GRID_COLS / 2, CELL_HEIGHT * GRID_ROWS / 2, 1000)
    --go.set_position(self.camera_pos, "/camera")

    -- Keep camera position/zoom and click conversion in the same space
    apply_camera_transform(self)

    -- Enable input
    msg.post(".", "acquire_input_focus")

    -- Set camera view
    msg.post("@render:", "use_camera_projection")
    msg.post("/camera#camera", "acquire_camera_focus")

    -- SPAWN VISUALS (add this line)
    spawn_visuals(self)
    initialize_unit_ui(self)
    set_ui_hidden(self)
    self.selected_start_cell = nil
    self.path_highlight_cells = {}
    self.ui_close_on_next_non_unit_click = false
    self.squad_units = create_squad_units()
    self.controlled_unit_id = "sarge"
    print_squad_debug_overview(self)
    spawn_human_unit(self)
    self.aliens = {}
    self.next_alien_id = 0
    self.pending_spitter_attack_phase = false
    self.spitter_attack_started = false
    self.spitter_attack_timer = 0
    self.spitter_attack_queue = {}
    self.spitter_projectiles = {}
    self.pending_melee_attack_phase = false
    self.melee_attack_started = false
    self.melee_attack_timer = 0
    self.melee_action_queue = {}
    self.melee_ap_left_by_alien_id = {}
    self.loot_pickup_blips = {}
    self.drag_resource = { active = false }
    spawn_initial_blips(self, INITIAL_BLIP_COUNT)

    print("=== Initialization Complete ===")

    print("=== Initialization Complete ===")
    print("WorldGrid size: " .. GRID_COLS .. "x" .. GRID_ROWS)
    print("Cell size: " .. CELL_WIDTH .. "x" .. CELL_HEIGHT)
    print("Total world size: " .. (CELL_WIDTH * GRID_COLS) .. "x" .. (CELL_HEIGHT * GRID_ROWS))
end

-- =============================================================================
-- UPDATE FUNCTION
-- =============================================================================

function update(self, dt)
    if self.world_grid and self.tile_light_layers then
        for tile_instance_id, light_go in pairs(self.tile_light_layers) do
            local tile_powered = false
            for _, cell in ipairs(self.world_grid) do
                if cell.tileInstanceId == tile_instance_id and cell.isPowered then
                    tile_powered = true
                    break
                end
            end

            local was_powered = self.tile_light_power_state[tile_instance_id]
            if was_powered == nil or was_powered ~= tile_powered then
                if tile_powered then
                    -- Fluorescent-style startup flicker: OFF/ON pulses before stabilizing ON.
                    self.tile_light_flicker_state[tile_instance_id] = {
                        active = true,
                        timer = 0.06,
                        step = 1
                    }
                    msg.post(msg.url(nil, light_go, "sprite"), "play_animation", { id = hash("tile_armoury_off") })
                else
                    self.tile_light_flicker_state[tile_instance_id] = nil
                    msg.post(msg.url(nil, light_go, "sprite"), "play_animation", { id = hash("tile_armoury_off") })
                end
                self.tile_light_power_state[tile_instance_id] = tile_powered
            end

            local flicker = self.tile_light_flicker_state[tile_instance_id]
            if flicker and flicker.active then
                flicker.timer = flicker.timer - dt
                if flicker.timer <= 0 then
                    if flicker.step == 1 then
                        msg.post(msg.url(nil, light_go, "sprite"), "play_animation", { id = hash("tile_armoury_on") })
                        flicker.timer = 0.05
                    elseif flicker.step == 2 then
                        msg.post(msg.url(nil, light_go, "sprite"), "play_animation", { id = hash("tile_armoury_off") })
                        flicker.timer = 0.06
                    elseif flicker.step == 3 then
                        msg.post(msg.url(nil, light_go, "sprite"), "play_animation", { id = hash("tile_armoury_on") })
                        flicker.timer = 0.05
                    elseif flicker.step == 4 then
                        msg.post(msg.url(nil, light_go, "sprite"), "play_animation", { id = hash("tile_armoury_off") })
                        flicker.timer = 0.04
                    else
                        msg.post(msg.url(nil, light_go, "sprite"), "play_animation", { id = hash("tile_armoury_on") })
                        flicker.active = false
                        flicker.timer = 0
                    end
                    flicker.step = flicker.step + 1
                end
            end
        end
    end

    update_human_movement(self, dt)
    update_alien_movement(self, dt)
    MELEE_RUNTIME.update_human_hit_flash(self, dt)
    MELEE_RUNTIME.update_phase(self, dt)
    update_spitter_projectiles(self, dt)
    update_spitter_attack_phase(self, dt)
    LOOT_RUNTIME.update_loot_pickup_blips(self, dt)
    update_human_visual_state(self)
    update_selected_unit_pulse(self, dt)
    update_selected_unit_ui(self)
    LOOT_RUNTIME.update_drag_visual(self)
    update_human_ap_debug_label(self)

    if not self.is_panning then
        local speed = math.sqrt(self.pan_velocity_x * self.pan_velocity_x + self.pan_velocity_y * self.pan_velocity_y)
        if speed > self.pan_inertia_min_speed then
            self.camera_pos.x = self.camera_pos.x + self.pan_velocity_x * dt
            self.camera_pos.y = self.camera_pos.y + self.pan_velocity_y * dt

            local decay = math.exp(-self.pan_inertia_damping * dt)
            self.pan_velocity_x = self.pan_velocity_x * decay
            self.pan_velocity_y = self.pan_velocity_y * decay

            apply_camera_transform(self)
        else
            self.pan_velocity_x = 0
            self.pan_velocity_y = 0
        end
    end
end

-- =============================================================================
-- INPUT FUNCTION
-- =============================================================================

function on_input(self, action_id, action)
    if action_id == hash("touch") then
        if self.drag_resource and self.drag_resource.active then
            if action.x and action.y then
                LOOT_RUNTIME.update_resource_drag(self, action.x, action.y)
            end
            if action.released then
                LOOT_RUNTIME.end_resource_drag(self, action.x, action.y)
            end
            return true
        end

        if action.pressed then
            if get_selected_unit(self) and is_point_in_ui_panel(action.x, action.y) then
                if LOOT_RUNTIME.begin_command_drag(self, action.x, action.y) then
                    self.is_panning = false
                    self.did_drag = true
                    return true
                end
                if LOOT_RUNTIME.begin_resource_drag(self, action.x, action.y) then
                    self.is_panning = false
                    self.did_drag = true
                    return true
                end
            end

            self.is_panning = true
            self.did_drag = false
            self.drag_start_screen_x = action.x
            self.drag_start_screen_y = action.y
            self.drag_start_camera_pos = vmath.vector3(self.camera_pos)
            self.last_pan_screen_x = action.x
            self.last_pan_screen_y = action.y
            self.pan_velocity_x = 0
            self.pan_velocity_y = 0
        elseif action.released then
            if not self.did_drag then
                if get_selected_unit(self) and is_point_in_ui_panel(action.x, action.y) then
                    if LOOT_RUNTIME.try_fix_selected_unit(self, action.x, action.y) then
                        return
                    end
                    if LOOT_RUNTIME.try_use_component_vending(self, action.x, action.y) then
                        return
                    end
                    if LOOT_RUNTIME.try_scavenge_selected_unit(self, action.x, action.y) then
                        return
                    end
                    return
                end
                local world_x, world_y = screen_to_world(action.x, action.y, self.camera_pos, self.camera_zoom)
                local clicked_cell_id = handle_cell_click(action, self.camera_pos, self.camera_zoom)
                if clicked_cell_id then
                    local handled_by_human = handle_human_click_flow(self, clicked_cell_id, world_x, world_y)
                    if not handled_by_human then
                        process_cell_selection(self, clicked_cell_id)
                    end
                end
            end
            self.is_panning = false
        elseif self.is_panning and action.x and action.y then
            local dx = action.x - self.drag_start_screen_x
            local dy = action.y - self.drag_start_screen_y
            local drag_distance = math.sqrt(dx * dx + dy * dy)

            if drag_distance >= self.drag_threshold_px then
                self.did_drag = true
            end

            if self.did_drag then
                -- Convert screen drag to world offset (zoom-aware).
                local old_cam_x = self.camera_pos.x
                local old_cam_y = self.camera_pos.y
                self.camera_pos.x = self.drag_start_camera_pos.x - (dx / self.camera_zoom)
                self.camera_pos.y = self.drag_start_camera_pos.y - (dy / self.camera_zoom)
                apply_camera_transform(self)

                -- Approximate world-space pan velocity for release inertia.
                local frame_dx = action.x - self.last_pan_screen_x
                local frame_dy = action.y - self.last_pan_screen_y
                self.pan_velocity_x = -(frame_dx / self.camera_zoom) * 60
                self.pan_velocity_y = -(frame_dy / self.camera_zoom) * 60
                self.last_pan_screen_x = action.x
                self.last_pan_screen_y = action.y

                -- If clamped by bounds, don't keep adding outward velocity.
                if self.camera_pos.x == old_cam_x then
                    self.pan_velocity_x = 0
                end
                if self.camera_pos.y == old_cam_y then
                    self.pan_velocity_y = 0
                end
            end
        end
    elseif action_id == hash("zoom_in") then
        local target_zoom = math.min(self.camera_zoom + 0.1, self.camera_max_zoom)
        local focus_x = action.x or (SCREEN_WIDTH * 0.5)
        local focus_y = action.y or (SCREEN_HEIGHT * 0.5)
        zoom_camera_at_screen_point(self, target_zoom, focus_x, focus_y)
    elseif action_id == hash("zoom_out") then
        local target_zoom = math.max(self.camera_zoom - 0.1, self.camera_min_zoom)
        local focus_x = action.x or (SCREEN_WIDTH * 0.5)
        local focus_y = action.y or (SCREEN_HEIGHT * 0.5)
        zoom_camera_at_screen_point(self, target_zoom, focus_x, focus_y)
    elseif action_id == hash("next_turn") and action.pressed then
        next_turn_reset_human_ap(self)
        process_alien_turn(self)
    end
end

-- =============================================================================
-- MESSAGE HANDLER
-- =============================================================================

function on_message(self, message_id, message, sender)
    if message_id == hash("next_turn") then
        next_turn_reset_human_ap(self)
        process_alien_turn(self)
    end
end

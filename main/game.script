MELEE_RUNTIME = require("main.melee_runtime").create({
    MELEE_MODEL = require("main.config").MELEE_MODEL,
    ALIEN_TYPE_BRUTE = ALIEN_TYPE_BRUTE,
    any_alien_is_moving = any_alien_is_moving

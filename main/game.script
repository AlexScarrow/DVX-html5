--[[
    Level designs specify which tiles to place where on the worldGrid
    Format: { x = xCell, y = yCell, tile = "tileName" }
    The x,y coordinate refers to the CENTER cell of the 3x3 tile
]]

function create_level_library()
    local levels = {}

    -- Example Level 1
    levels[1] = {
        { x = 11, y = 11, tile = "armoury" },
        { x = 8, y = 11, tile = "armoury" },
        { x = 8, y = 8, tile = "armoury" },
        { x = 11, y = 8, tile = "armoury" },
        { x = 5, y = 8, tile = "armoury" }
    }

    -- Example Level 2
    levels[2] = {
        { x = 8, y = 8, tile = "corridor" },
        { x = 8, y = 11, tile = "canteen" },
        { x = 8, y = 5, tile = "armoury" }
    }

    -- Add more levels...

    return levels
end

-- =============================================================================
-- BAKING DOWN PROCESS
-- =============================================================================
--[[
    "Bakes down" a level design onto the worldGrid
    - Takes tile placement data and tile library
    - Copies tile data into appropriate worldGrid cells
    - Sets tileID for all 9 cells of each placed tile
]]

function bake_level_to_world_grid(world_grid, level_design, tile_library)
    local function clone_object(obj)
        local dep_list = {}
        if obj and obj.isDependentOn then
            for i, dep in ipairs(obj.isDependentOn) do
                dep_list[i] = dep
            end
        end
        return {
            name = (obj and obj.name) or hash("empty"),
            isFixed = (obj and obj.isFixed) == true,
            isWelded = (obj and obj.isWelded) == true,
            isOpen = (obj and obj.isOpen) == true,
            dependsOn = (obj and obj.dependsOn) or 0,
            isDependentOn = dep_list,
            objectId = (obj and obj.objectId) or 0,
            offsetX = (obj and obj.offsetX) or 0,
            offsetY = (obj and obj.offsetY) or 0,
            fxOffsetX = (obj and obj.fxOffsetX) or 0,
            fxOffsetY = (obj and obj.fxOffsetY) or 0,
            fxRotation = (obj and obj.fxRotation) or 0,
            hitW = (obj and obj.hitW) or 32,
            hitH = (obj and obj.hitH) or 32,
            requiredComponent = obj and obj.requiredComponent or nil
        }
    end

    -- First, ensure all cells start as "empty" (VOID)
    for i = 1, #world_grid do
        world_grid[i].tileID = hash("empty")
        world_grid[i].tileInstanceId = 0
        world_grid[i].hasLoot = false
        world_grid[i].lootOffsetX = 0
        world_grid[i].lootOffsetY = 0
        world_grid[i].object1 = { name = hash("empty"), isFixed = false, isWelded = false, isOpen = false, dependsOn = 0, isDependentOn = {}, objectId = 0, offsetX = 0, offsetY = 0, fxOffsetX = 0, fxOffsetY = 0, fxRotation = 0, hitW = 32, hitH = 32, requiredComponent = nil }
        world_grid[i].object2 = { name = hash("empty"), isFixed = false, isWelded = false, isOpen = false, dependsOn = 0, isDependentOn = {}, objectId = 0, offsetX = 0, offsetY = 0, fxOffsetX = 0, fxOffsetY = 0, fxRotation = 0, hitW = 32, hitH = 32, requiredComponent = nil }
        world_grid[i].object3 = { name = hash("empty"), isFixed = false, isWelded = false, isOpen = false, dependsOn = 0, isDependentOn = {}, objectId = 0, offsetX = 0, offsetY = 0, fxOffsetX = 0, fxOffsetY = 0, fxRotation = 0, hitW = 32, hitH = 32, requiredComponent = nil }
    end

    -- Place each tile from the level design
    for placement_index, placement in ipairs(level_design) do
        local center_x = placement.x
        local center_y = placement.y
        local tile_name = placement.tile
        local tile = tile_library[tile_name]

        if not tile then
            print("ERROR: Tile '" .. tile_name .. "' not found in library")
        else
            -- Map the 3x3 tile cells to worldGrid
            -- Tile cell layout: 7 8 9
            --                   4 5 6
            --                   1 2 3
            local tile_cell_index = 1
            for dy = -1, 1 do
                for dx = -1, 1 do
                    local world_x = center_x + dx
                    local world_y = center_y + dy
                    local world_cell_id = coords_to_id(world_x, world_y)

                    if world_cell_id then
                        local tile_cell = tile.cells[tile_cell_index]
                        local world_cell = world_grid[world_cell_id]

                        -- Copy tile data to world cell
                        world_cell.tileID = tile.tileID
                        world_cell.lightValue = tile_cell.lightValue
                        world_cell.moveValue = tile_cell.moveValue
                        world_cell.coverValue = tile_cell.coverValue
                        world_cell.accessRight = tile_cell.accessRight
                        world_cell.accessDown = tile_cell.accessDown
                        world_cell.isPowered = tile_cell.isPowered
                        world_cell.tileInstanceId = placement_index
                        world_cell.isOccupied = tile_cell.isOccupied
                        world_cell.hasLoot = tile_cell.hasLoot == true
                        world_cell.lootOffsetX = tile_cell.lootOffsetX or 0
                        world_cell.lootOffsetY = tile_cell.lootOffsetY or 0
                        world_cell.object1 = clone_object(tile_cell.object1)
                        world_cell.object2 = clone_object(tile_cell.object2)
                        world_cell.object3 = clone_object(tile_cell.object3)
                    end

                    tile_cell_index = tile_cell_index + 1
                end
            end
        end
    end

    local next_object_id = 1
    local id_remap_by_tile = {}
    for _, cell in ipairs(world_grid) do
        local tile_instance = cell.tileInstanceId or 0
        id_remap_by_tile[tile_instance] = id_remap_by_tile[tile_instance] or {}
        local tile_remap = id_remap_by_tile[tile_instance]
        local objects = { cell.object1, cell.object2, cell.object3 }
        for _, obj in ipairs(objects) do
            if obj then
                obj.dependsOn = obj.dependsOn or 0
                obj.isDependentOn = obj.isDependentOn or {}
                obj.isWelded = obj.isWelded == true
                obj.isOpen = obj.isOpen == true
                obj.offsetX = obj.offsetX or 0
                obj.offsetY = obj.offsetY or 0
                obj.fxOffsetX = obj.fxOffsetX or 0
                obj.fxOffsetY = obj.fxOffsetY or 0
                obj.fxRotation = obj.fxRotation or 0
                obj.hitW = obj.hitW or 32
                obj.hitH = obj.hitH or 32
                obj.requiredComponent = obj.requiredComponent
                if obj.name and obj.name ~= hash("empty") then
                    local source_id = obj.objectId or 0
                    if source_id > 0 and tile_remap[source_id] then
                        obj.objectId = tile_remap[source_id]
                    else
                        obj.objectId = next_object_id
                        if source_id > 0 then
                            tile_remap[source_id] = next_object_id
                        end
                        next_object_id = next_object_id + 1
                    end
                else
                    obj.objectId = obj.objectId or 0
                end
            end
        end
    end
    for _, cell in ipairs(world_grid) do
        local tile_instance = cell.tileInstanceId or 0
        local tile_remap = id_remap_by_tile[tile_instance] or {}
        local objects = { cell.object1, cell.object2, cell.object3 }
        for _, obj in ipairs(objects) do
            if obj and obj.name and obj.name ~= hash("empty") then
                local dep = obj.dependsOn or 0
                if dep > 0 and tile_remap[dep] then
                    obj.dependsOn = tile_remap[dep]
                end
            end
        end
    end

    return world_grid
end

-- =============================================================================
-- PATHFINDING (A* Algorithm)
-- =============================================================================
--[[
    Finds path from start_cell_id to end_cell_id
    Returns: table of cell IDs representing path, or nil if no path found
    Takes into account: moveValue, access permissions, VOID cells
]]

function heuristic(from_id, to_id)
    local x1, y1 = id_to_coords(from_id)
    local x2, y2 = id_to_coords(to_id)
    return math.abs(x2 - x1) + math.abs(y2 - y1)  -- Manhattan distance
end

function find_path(world_grid, start_id, end_id, max_action_points, movement_profile, path_context)
    if not world_grid[start_id] or not world_grid[end_id] then
        return nil
    end

    if world_grid[end_id].tileID == hash("empty") then
        return nil  -- Can't path to VOID cell
    end

    movement_profile = movement_profile or MOVEMENT_PROFILE_HUMAN

    local open_set = { start_id }
    local came_from = {}
    local g_score = {}
    local f_score = {}

    -- Initialize scores
    for i = 1, #world_grid do
        g_score[i] = math.huge
        f_score[i] = math.huge
    end
    g_score[start_id] = 0
    f_score[start_id] = heuristic(start_id, end_id)

    while #open_set > 0 do
        -- Find node in open_set with lowest f_score
        local current = open_set[1]
        local current_index = 1
        for i, node_id in ipairs(open_set) do
            if f_score[node_id] < f_score[current] then
                current = node_id
                current_index = i
            end
        end

        if current == end_id then
            -- Reconstruct path
            local path = { current }
            while came_from[current] do
                current = came_from[current]
                table.insert(path, 1, current)
            end

            -- Calculate total cost
            local total_cost = 0
            for i = 2, #path do
                total_cost = total_cost + get_step_move_cost(world_grid, path[i - 1], path[i])
            end

            if max_action_points and total_cost > max_action_points then
                return nil  -- Path too expensive
            end

            return path, total_cost
        end

        -- Remove current from open_set
        table.remove(open_set, current_index)

        -- Check neighbors
        local neighbors = get_neighbors(current, world_grid, movement_profile, path_context)
        for _, neighbor_data in ipairs(neighbors) do
            local neighbor_id = neighbor_data.id
            local move_cost = neighbor_data.cost

            local tentative_g_score = g_score[current] + move_cost

            if tentative_g_score < g_score[neighbor_id] then
                came_from[neighbor_id] = current
                g_score[neighbor_id] = tentative_g_score
                f_score[neighbor_id] = g_score[neighbor_id] + heuristic(neighbor_id, end_id)

                -- Add to open_set if not already there
                local in_open = false
                for _, id in ipairs(open_set) do
                    if id == neighbor_id then
                        in_open = true
                        break
                    end
                end
                if not in_open then
                    table.insert(open_set, neighbor_id)
                end
            end
        end
    end

    return nil  -- No path found
end

local function find_alien_path(world_grid, alien_type, start_id, end_id, max_action_points)
    if not world_grid[start_id] or not world_grid[end_id] then
        return nil
    end

    local end_is_void = world_grid[end_id].tileID == hash("empty")
    if alien_type ~= ALIEN_TYPE_BLIP and end_is_void then
        return nil
    end

    local open_set = { start_id }
    local came_from = {}
    local g_score = {}
    local f_score = {}

    for i = 1, #world_grid do
        g_score[i] = math.huge
        f_score[i] = math.huge
    end

    g_score[start_id] = 0
    f_score[start_id] = heuristic(start_id, end_id)

    while #open_set > 0 do
        local current = open_set[1]
        local current_index = 1
        for i, node_id in ipairs(open_set) do
            if f_score[node_id] < f_score[current] then
                current = node_id
                current_index = i
            end
        end

        if current == end_id then
            local path = { current }
            while came_from[current] do
                current = came_from[current]
                table.insert(path, 1, current)
            end

            local total_cost = 0
            for i = 2, #path do
                local step_cost = 1
                if alien_type ~= ALIEN_TYPE_BLIP then
                    step_cost = get_alien_step_move_cost(world_grid, path[i - 1], path[i])
                end
                total_cost = total_cost + step_cost
            end

            if max_action_points and total_cost > max_action_points then
                return nil
            end

            return path, total_cost
        end

        table.remove(open_set, current_index)

        local neighbors = get_alien_neighbors(current, world_grid, alien_type)
        for _, neighbor_data in ipairs(neighbors) do
            local neighbor_id = neighbor_data.id
            local move_cost = neighbor_data.cost
            local tentative_g_score = g_score[current] + move_cost

            if tentative_g_score < g_score[neighbor_id] then
                came_from[neighbor_id] = current
                g_score[neighbor_id] = tentative_g_score
                f_score[neighbor_id] = g_score[neighbor_id] + heuristic(neighbor_id, end_id)

                local in_open = false
                for _, id in ipairs(open_set) do
                    if id == neighbor_id then
                        in_open = true
                        break
                    end
                end
                if not in_open then
                    table.insert(open_set, neighbor_id)
                end
            end
        end
    end

    return nil
end

local function pick_weighted_blip_reveal_type()
    local weighted = {
        { type = ALIEN_TYPE_CANNON, w = ALIEN_REVEAL_WEIGHT_CANNON },
        { type = ALIEN_TYPE_SPEEDY, w = ALIEN_REVEAL_WEIGHT_SPEEDY },
        { type = ALIEN_TYPE_SPITTER, w = ALIEN_REVEAL_WEIGHT_SPITTER },
        { type = ALIEN_TYPE_BRUTE, w = ALIEN_REVEAL_WEIGHT_BRUTE }
    }

    local total = 0
    for _, item in ipairs(weighted) do
        total = total + item.w
    end

    if total <= 0 then
        return ALIEN_TYPE_CANNON
    end

    local roll = math.random() * total
    local running = 0
    for _, item in ipairs(weighted) do
        running = running + item.w
        if roll <= running then
            return item.type
        end
    end

    return ALIEN_TYPE_CANNON
end

local function get_human_cell_ids(self)
    local ids = {}
    if not self.squad_units then
        return ids
    end
    for _, unit in pairs(self.squad_units) do
        if unit.cell_id and (unit.current_health or 0) > 0 then
            table.insert(ids, unit.cell_id)
        end
    end
    return ids
end

local function get_nearest_human_cell_id(self, from_cell_id)
    local nearest = nil
    local best = math.huge
    for _, human_cell_id in ipairs(get_human_cell_ids(self)) do
        local d = heuristic(from_cell_id, human_cell_id)
        if d < best then
            best = d
            nearest = human_cell_id
        end
    end
    return nearest
end

local function get_nearest_reachable_human_cell_id(self, alien_type, from_cell_id)
    local human_ids = get_human_cell_ids(self)
    local best_target = nil
    local best_path = nil
    local best_cost = math.huge
    local from_cell = self.world_grid and self.world_grid[from_cell_id]
    local blip_in_void = (alien_type == ALIEN_TYPE_BLIP) and (from_cell and from_cell.tileID == hash("empty"))
    local can_use_vent = alien_type ~= ALIEN_TYPE_BRUTE and not blip_in_void
    for _, human_cell_id in ipairs(human_ids) do
        local normal_path, normal_cost
        if alien_type == ALIEN_TYPE_BLIP then
            normal_path, normal_cost = find_alien_path(self.world_grid, alien_type, from_cell_id, human_cell_id, nil)
        else
            normal_path, normal_cost = find_path(self.world_grid, from_cell_id, human_cell_id, nil, MOVEMENT_PROFILE_HUMAN, nil)
        end
        local chosen_path = normal_path
        local chosen_cost = normal_cost or math.huge
        if can_use_vent then
            local vent_path, vent_cost = find_path(
                self.world_grid,
                from_cell_id,
                human_cell_id,
                nil,
                MOVEMENT_PROFILE_ALIEN_VENT,
                { target_cell_id = human_cell_id }
            )
            if vent_path and vent_cost and (vent_cost < chosen_cost or vent_cost == chosen_cost) then
                chosen_path = vent_path
                chosen_cost = vent_cost
            end
        end
        if chosen_path and chosen_cost then
            if chosen_cost < best_cost
                or (chosen_cost == best_cost and (best_target == nil or human_cell_id < best_target))
            then
                best_target = human_cell_id
                best_path = chosen_path
                best_cost = chosen_cost
            end
        end
    end
    if best_target and best_path then
        return best_target, best_path
    end
    return nil, nil
end

local function has_unobstructed_los(world_grid, from_id, to_id)
    local from_cell = world_grid[from_id]
    local to_cell = world_grid[to_id]
    if not from_cell or not to_cell then
        return false
    end

    if from_cell.xCell ~= to_cell.xCell and from_cell.yCell ~= to_cell.yCell then
        return false
    end

    if from_cell.xCell == to_cell.xCell then
        local step = (to_cell.yCell > from_cell.yCell) and 1 or -1
        local current_id = from_id
        while current_id ~= to_id do
            local next_id = current_id + (GRID_COLS * step)
            if not can_human_cross_between_cells(world_grid, current_id, next_id) then
                return false
            end
            current_id = next_id
        end
        return true
    end

    local step = (to_cell.xCell > from_cell.xCell) and 1 or -1
    local current_id = from_id
    while current_id ~= to_id do
        local next_id = current_id + step
        if not can_human_cross_between_cells(world_grid, current_id, next_id) then
            return false
        end
        current_id = next_id
    end
    return true
end

local function get_edge_spawn_cell_ids(world_grid)
    local ids = {}
    for cell_id, cell in ipairs(world_grid) do
        if cell.xCell == 1 or cell.xCell == GRID_COLS or cell.yCell == 1 or cell.yCell == GRID_ROWS then
            table.insert(ids, cell_id)
        end
    end
    return ids
end

local function ensure_alien_visual(self, alien)
    if alien.go_id then
        return
    end

    local x, y = coords_to_world_pos(self.world_grid[alien.cell_id].xCell, self.world_grid[alien.cell_id].yCell)
    if alien.type ~= ALIEN_TYPE_BLIP then
        x = x + (CELL_WIDTH * 0.25)
        local human_count = 0
        if self.squad_units then
            for _, unit in pairs(self.squad_units) do
                if unit.cell_id == alien.cell_id and (unit.current_health or 0) > 0 then
                    human_count = human_count + 1
                end
            end
        end
        if human_count > 0 and self.aliens then
            local on_cell = {}
            for _, scan in ipairs(self.aliens) do
                if (not scan.is_dead) and scan.cell_id == alien.cell_id and scan.type ~= ALIEN_TYPE_BLIP then
                    table.insert(on_cell, scan)
                end
            end
            table.sort(on_cell, function(a, b)
                return (a.id or 0) < (b.id or 0)
            end)
            local idx = 1
            for i, scan in ipairs(on_cell) do
                if scan.id == alien.id then
                    idx = i
                    break
                end
            end
            local lane = { 20, -20, 40, -40, 60, -60 }
            x = x + (lane[idx] or 0)
        end
        x = clamp_world_x_to_cell(self.world_grid[alien.cell_id], x)
    end
    if alien.type == ALIEN_TYPE_SPEEDY then
        y = y + 50
    elseif alien.type == ALIEN_TYPE_SPITTER then
        y = y - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM
    elseif alien.type == ALIEN_TYPE_CANNON then
        y = y - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM - 25
    else
        y = y + 0
    end
    local pos = vmath.vector3(x, y, 0.6)
    local visual_kind = "marker"
    if alien.type == ALIEN_TYPE_BLIP then
        alien.go_id = factory.create("/alien_blip_factory#alien_blip_factory", pos)
        alien.uses_blip_sprite = true
        visual_kind = "blip"
    elseif alien.type == ALIEN_TYPE_CANNON then
        alien.go_id = factory.create("/alien_cannon_fodder_factory#alien_cannon_fodder_factory", pos)
        alien.uses_blip_sprite = true
        visual_kind = "cannon"
    elseif alien.type == ALIEN_TYPE_SPITTER then
        alien.go_id = factory.create("/alien_spitter_factory#alien_spitter_factory", pos)
        alien.uses_blip_sprite = true
        visual_kind = "spitter"
    elseif alien.type == ALIEN_TYPE_SPEEDY then
        alien.go_id = factory.create("/alien_speedy_factory#alien_speedy_factory", pos)
        alien.uses_blip_sprite = true
        visual_kind = "speedy"
    else
        alien.go_id = factory.create("/ui_factory#ui_factory", pos)
        alien.uses_blip_sprite = false
        visual_kind = "marker"
    end
    alien.visual_kind = visual_kind
    if alien.go_id then
        if alien.uses_blip_sprite then
            if alien.type == ALIEN_TYPE_CANNON or alien.type == ALIEN_TYPE_SPITTER or alien.type == ALIEN_TYPE_SPEEDY then
                local scale = 0.33333334
                if alien.type == ALIEN_TYPE_CANNON then
                    scale = 0.22
                end
                sprite.set_hflip(msg.url(nil, alien.go_id, "sprite"), false)
                sprite.set_hflip(msg.url(nil, alien.go_id, "shadow"), false)
                go.set(msg.url(nil, alien.go_id, "shadow"), "tint", vmath.vector4(1, 1, 1, 0.5))
                alien.spitter_flip = false
                go.set_scale(vmath.vector3(scale, scale, 1), alien.go_id)
            else
                go.set_scale(vmath.vector3(1, 1, 1), alien.go_id)
            end
        else
            go.set_scale(vmath.vector3(ALIEN_MARKER_SIZE, ALIEN_MARKER_SIZE, 1), alien.go_id)
        end
    end
end

local function refresh_alien_visual(self, alien)
    local wanted_visual_kind = "marker"
    if alien.type == ALIEN_TYPE_BLIP then
        wanted_visual_kind = "blip"
    elseif alien.type == ALIEN_TYPE_CANNON then
        wanted_visual_kind = "cannon"
    elseif alien.type == ALIEN_TYPE_SPITTER then
        wanted_visual_kind = "spitter"
    elseif alien.type == ALIEN_TYPE_SPEEDY then
        wanted_visual_kind = "speedy"
    end
    if alien.go_id and alien.visual_kind ~= wanted_visual_kind then
        go.delete(alien.go_id)
        alien.go_id = nil
    end
    if not alien.go_id then
        ensure_alien_visual(self, alien)
    end
    if not alien.go_id then
        return
    end

    local cfg = ALIEN_TYPE_CONFIG[alien.type]
    local x, y = coords_to_world_pos(self.world_grid[alien.cell_id].xCell, self.world_grid[alien.cell_id].yCell)
    if alien.type ~= ALIEN_TYPE_BLIP then
        x = x + (CELL_WIDTH * 0.25)
        local human_count = 0
        if self.squad_units then
            for _, unit in pairs(self.squad_units) do
                if unit.cell_id == alien.cell_id and (unit.current_health or 0) > 0 then
                    human_count = human_count + 1
                end
            end
        end
        if human_count > 0 and self.aliens then
            local on_cell = {}
            for _, scan in ipairs(self.aliens) do
                if (not scan.is_dead) and scan.cell_id == alien.cell_id and scan.type ~= ALIEN_TYPE_BLIP then
                    table.insert(on_cell, scan)
                end
            end
            table.sort(on_cell, function(a, b)
                return (a.id or 0) < (b.id or 0)
            end)
            local idx = 1
            for i, scan in ipairs(on_cell) do
                if scan.id == alien.id then
                    idx = i
                    break
                end
            end
            local lane = { 20, -20, 40, -40, 60, -60 }
            x = x + (lane[idx] or 0)
        end
        x = clamp_world_x_to_cell(self.world_grid[alien.cell_id], x)
    end
    if alien.type == ALIEN_TYPE_SPEEDY then
        y = y + 50
    elseif alien.type == ALIEN_TYPE_SPITTER then
        y = y - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM
    elseif alien.type == ALIEN_TYPE_CANNON then
        y = y - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM - 25
    else
        y = y + 0
    end
    go.set_position(vmath.vector3(x, y, 0.6), alien.go_id)
    if (not alien.uses_blip_sprite) and cfg and cfg.marker_tint then
        go.set(msg.url(nil, alien.go_id, "sprite"), "tint", cfg.marker_tint)
    end
end

local function spawn_alien(self, alien_type, cell_id)
    local cfg = ALIEN_TYPE_CONFIG[alien_type]
    if not cfg then
        return nil
    end

    self.next_alien_id = (self.next_alien_id or 0) + 1
    local alien = {
        id = self.next_alien_id,
        type = alien_type,
        cell_id = cell_id,
        ap_max = cfg.ap_per_turn,
        hp_max = cfg.hp,
        hp_current = cfg.hp,
        can_traverse_void = cfg.can_traverse_void == true,
        has_ranged = cfg.has_ranged == true,
        ranged_cells = cfg.ranged_cells or 0,
        go_id = nil,
        is_moving = false,
        move_path = nil,
        move_path_index = 0,
        spitter_anim_phase = math.random() * math.pi * 2,
        spitter_flip = false
    }

    table.insert(self.aliens, alien)
    ensure_alien_visual(self, alien)
    refresh_alien_visual(self, alien)
    print(string.format("Alien spawned: #%d %s at cell %d", alien.id, alien.type, alien.cell_id))
    return alien
end

local function maybe_reveal_blip(self, alien)
    if alien.type ~= ALIEN_TYPE_BLIP then
        return
    end

    -- Blips cannot reveal while standing in VOID cells.
    local current_cell = self.world_grid[alien.cell_id]
    if not current_cell or current_cell.tileID == hash("empty") then
        return
    end

    for _, human_cell_id in ipairs(get_human_cell_ids(self)) do
        if has_unobstructed_los(self.world_grid, alien.cell_id, human_cell_id) then
            local revealed_type = pick_weighted_blip_reveal_type()
            local cfg = ALIEN_TYPE_CONFIG[revealed_type]
            alien.type = revealed_type
            alien.ap_max = cfg.ap_per_turn
            alien.hp_max = cfg.hp
            alien.hp_current = cfg.hp
            alien.can_traverse_void = cfg.can_traverse_void == true
            alien.has_ranged = cfg.has_ranged == true
            alien.ranged_cells = cfg.ranged_cells or 0
            refresh_alien_visual(self, alien)
            print(string.format("Blip #%d revealed as %s", alien.id, revealed_type))
            return
        end
    end
end

local function get_alien_turn_movement_segment(self, alien, path, max_ap)
    if not path or #path < 2 then
        return nil, 0
    end

    local ap_spent = 0
    local segment = { path[1] }

    for i = 2, #path do
        local from_cell = path[i - 1]
        local to_cell = path[i]
        local step_cost = 1
        if alien.type ~= ALIEN_TYPE_BLIP then
            step_cost = get_alien_step_move_cost(self.world_grid, from_cell, to_cell)
        end

        if ap_spent + step_cost > max_ap then
            break
        end

        ap_spent = ap_spent + step_cost
        table.insert(segment, to_cell)
    end

    if #segment < 2 then
        return nil, 0
    end

    return segment, ap_spent
end

local function get_vent_object_on_cell(cell)
    if not cell then
        return nil
    end
    local objs = { cell.object1, cell.object2, cell.object3 }
    for _, obj in ipairs(objs) do
        if object_is_vent(obj) then
            if obj.isWelded ~= true and obj.isSealed ~= true then
                return obj
            end
        end
    end
    return nil
end

local function begin_alien_path_animation(alien, segment_path)
    alien.move_path = segment_path
    alien.move_path_index = 2 -- first is current position
    alien.is_moving = true
end

local function any_alien_is_moving(self)
    if not self.aliens then
        return false
    end
    for _, alien in ipairs(self.aliens) do
        if alien.is_moving then
            return true
        end
    end
    return false
end

local function remove_dead_aliens(self)
    if not self.aliens then
        return
    end
    for i = #self.aliens, 1, -1 do
        if self.aliens[i].is_dead then
            local alien = self.aliens[i]
            if alien.go_id then
                go.delete(alien.go_id)
                alien.go_id = nil
            end
            table.remove(self.aliens, i)
        end
    end
end

local function spawn_human_reaction_projectile(self, shooter_unit, target_alien, impact_hit, impact_light, impact_chance, impact_roll)
    if not shooter_unit or not shooter_unit.go_path or not target_alien or not target_alien.go_id then
        return
    end

    local from = go.get_position(shooter_unit.go_path)
    local to = go.get_position(target_alien.go_id)
    local projectile_id = factory.create("/ui_factory#ui_factory", vmath.vector3(from.x, from.y, 0.75))
    if not projectile_id then
        return
    end

    go.set_scale(vmath.vector3(SPITTER_PROJECTILE_SIZE * 0.2, SPITTER_PROJECTILE_SIZE * 0.2, 1), projectile_id)
    msg.post(msg.url(nil, projectile_id, "sprite"), "play_animation", { id = hash("human_projectile_1") })
    go.set(msg.url(nil, projectile_id, "sprite"), "tint", vmath.vector4(1, 1, 1, 1))
    local dir_x = to.x - from.x
    local dir_y = to.y - (from.y + 20)
    if math.abs(dir_x) > 0.01 or math.abs(dir_y) > 0.01 then
        go.set_rotation(vmath.quat_rotation_z(math.atan2(dir_y, dir_x) + math.pi), projectile_id)
    end

    table.insert(self.spitter_projectiles, {
        kind = "human",
        go_id = projectile_id,
        from = vmath.vector3(from.x, from.y + 20, 0.75),
        to = vmath.vector3(to.x, to.y, 0.75),
        t = 0,
        speed = SPITTER_PROJECTILE_SPEED * 1.4,
        target_alien_id = target_alien.id,
        shooter_name = shooter_unit.display_name,
        impact_hit = impact_hit == true,
        impact_light = impact_light or 0,
        impact_chance = impact_chance or 0,
        impact_roll = impact_roll or 0
    })
end

local function resolve_human_reaction_fire(self, alien)
    if not self.reactive_combat_enabled then
        return false
    end
    if not alien or alien.is_dead then
        return false
    end

    local alien_cell = self.world_grid[alien.cell_id]
    if not alien_cell or alien_cell.tileID == hash("empty") then
        return false
    end

    local fired_any = false
    local target_cell_id = alien.cell_id
    local reaction_order = { "sarge", "techie", "medic", "gunner" }
    for _, unit_id in ipairs(reaction_order) do
        local unit = self.squad_units and self.squad_units[unit_id]
        if unit and unit.cell_id and has_unobstructed_los(self.world_grid, unit.cell_id, target_cell_id) then
            if unit.current_ap <= 0 and unit.current_ammo <= 0 then
                print(string.format("%s cannot fire at alien #%d (no AP and no ammo)", unit.display_name, alien.id))
            elseif unit.current_ap <= 0 then
                print(string.format("%s cannot fire at alien #%d (no AP)", unit.display_name, alien.id))
            elseif unit.current_ammo <= 0 then
                print(string.format("%s cannot fire at alien #%d (no ammo)", unit.display_name, alien.id))
            else
                fired_any = true
                unit.current_ap = unit.current_ap - 1
                unit.current_ammo = unit.current_ammo - 1
                local active_light = (alien_cell.isPowered and math.max(0, math.min(3, alien_cell.lightValue or 0))) or 0
                local ranged_model = require("main.config").RANGED_HIT_MODEL
                local base_hit_chance = ranged_model.base_hit_chance + (active_light * ranged_model.per_light_level_bonus)
                local role = CLASS_ROLE_HOOKS[unit.class_id]
                local class_bonus = (role and role.ranged_hit_bonus) or 0
                local hit_chance = math.max(ranged_model.min_hit_chance, math.min(ranged_model.max_hit_chance, base_hit_chance + class_bonus))
                local roll = math.random(1, 100)
                spawn_human_reaction_projectile(self, unit, alien, roll <= hit_chance, active_light, hit_chance, roll)
            end
        end
    end

    return false
end

local function get_living_humans(self)
    local living = {}
    if not self.squad_units then
        return living
    end
    for _, unit in pairs(self.squad_units) do
        if unit.cell_id and unit.current_health and unit.current_health > 0 then
            table.insert(living, unit)
        end
    end
    return living
end

local function choose_spitter_target(self, alien)
    local candidates = {}
    local range_cells = alien.ranged_cells or SPITTER_MAX_RANGE_CELLS
    for _, human in ipairs(get_living_humans(self)) do
        local dist = heuristic(alien.cell_id, human.cell_id)
        if dist <= range_cells and has_unobstructed_los(self.world_grid, alien.cell_id, human.cell_id) then
            table.insert(candidates, { unit = human, dist = dist, hp = human.current_health })
        end
    end

    if #candidates == 0 then
        return nil
    end

    local nearest_dist = math.huge
    for _, candidate in ipairs(candidates) do
        if candidate.dist < nearest_dist then
            nearest_dist = candidate.dist
        end
    end

    local nearest = {}
    for _, candidate in ipairs(candidates) do
        if candidate.dist == nearest_dist then
            table.insert(nearest, candidate)
        end
    end

    local lowest_hp = math.huge
    for _, candidate in ipairs(nearest) do
        if candidate.hp < lowest_hp then
            lowest_hp = candidate.hp
        end
    end

    local best = {}
    for _, candidate in ipairs(nearest) do
        if candidate.hp == lowest_hp then
            table.insert(best, candidate)
        end
    end

    if #best == 1 then
        return best[1].unit
    end
    return best[math.random(1, #best)].unit
end

local function spawn_spitter_projectile(self, alien, target_human)
    if not alien.go_id or not target_human.go_path then
        return
    end

    local from = go.get_position(alien.go_id)
    local to = go.get_position(target_human.go_path)
    local projectile_id = factory.create("/ui_factory#ui_factory", vmath.vector3(from.x, from.y, 0.75))
    if not projectile_id then
        return
    end

    go.set_scale(vmath.vector3(SPITTER_PROJECTILE_SIZE * 0.2, SPITTER_PROJECTILE_SIZE * 0.2, 1), projectile_id)
    msg.post(msg.url(nil, projectile_id, "sprite"), "play_animation", { id = hash("alien_projectile_1") })
    go.set(msg.url(nil, projectile_id, "sprite"), "tint", vmath.vector4(1, 1, 1, 1))
    local dir_x = to.x - from.x
    local dir_y = (to.y + 20) - from.y
    if math.abs(dir_x) > 0.01 or math.abs(dir_y) > 0.01 then
        go.set_rotation(vmath.quat_rotation_z(math.atan2(dir_y, dir_x) + math.pi), projectile_id)
    end

    table.insert(self.spitter_projectiles, {
        kind = "alien",
        go_id = projectile_id,
        from = vmath.vector3(from.x, from.y, 0.75),
        to = vmath.vector3(to.x, to.y + 20, 0.75),
        t = 0
    })
end

local function begin_spitter_attack_phase(self)
    self.pending_spitter_attack_phase = true
    self.spitter_attack_started = false
    self.spitter_attack_timer = 0
end

local function start_spitter_attack_queue(self)
    self.spitter_attack_queue = {}
    if not self.aliens then
        return
    end

    for _, alien in ipairs(self.aliens) do
        if (not alien.is_dead) and alien.type == ALIEN_TYPE_SPITTER then
            table.insert(self.spitter_attack_queue, {
                alien_id = alien.id,
                ap_left = alien.ap_max or 0
            })
        end
    end
end

local function update_spitter_projectiles(self, dt)
    if not self.spitter_projectiles then
        return
    end

    for i = #self.spitter_projectiles, 1, -1 do
        local p = self.spitter_projectiles[i]
        if not p.go_id then
            table.remove(self.spitter_projectiles, i)
        else
            local dx = p.to.x - p.from.x
            local dy = p.to.y - p.from.y
            local dist = math.sqrt(dx * dx + dy * dy)
            local travel_time = math.max(0.05, dist / (p.speed or SPITTER_PROJECTILE_SPEED))
            p.t = math.min(1, p.t + (dt / travel_time))
            local px = p.from.x + (dx * p.t)
            local py = p.from.y + (dy * p.t)
            go.set_position(vmath.vector3(px, py, 0.75), p.go_id)
            if p.t >= 1 then
                if p.kind == "human" then
                    local target = nil
                    if self.aliens and p.target_alien_id then
                        for _, a in ipairs(self.aliens) do
                            if a.id == p.target_alien_id then
                                target = a
                                break
                            end
                        end
                    end
                    if target and (not target.is_dead) and p.impact_hit then
                        if MELEE_RUNTIME and MELEE_RUNTIME.spawn_alien_blood_splatter_fx then
                            MELEE_RUNTIME.spawn_alien_blood_splatter_fx(self, target)
                        end
                        print(string.format(
                            "%s fired at alien #%d and HIT (alien eliminated) [light=%d chance=%d%% roll=%d]",
                            p.shooter_name or "Human", target.id, p.impact_light or 0, p.impact_chance or 0, p.impact_roll or 0
                        ))
                        target.is_dead = true
                        target.is_moving = false
                        target.move_path = nil
                        target.move_path_index = 0
                    elseif target and (not target.is_dead) then
                        print(string.format(
                            "%s fired at alien #%d and MISSED [light=%d chance=%d%% roll=%d]",
                            p.shooter_name or "Human", target.id, p.impact_light or 0, p.impact_chance or 0, p.impact_roll or 0
                        ))
                    end
                end
                go.delete(p.go_id)
                table.remove(self.spitter_projectiles, i)
            end
        end
    end
end

local function find_alien_by_id(self, alien_id)
    if not self.aliens then
        return nil
    end
    for _, alien in ipairs(self.aliens) do
        if alien.id == alien_id then
            return alien
        end
    end
    return nil
end

local function update_spitter_attack_phase(self, dt)
    if not self.pending_spitter_attack_phase then
        return
    end
    if self.pending_melee_attack_phase then
        return
    end
    if self.alien_turn_waiting_for_advance then
        return
    end

    if not self.spitter_attack_started then
        if any_alien_is_moving(self) then
            return
        end
        self.spitter_attack_started = true
        start_spitter_attack_queue(self)
        if #self.spitter_attack_queue == 0 then
            self.pending_spitter_attack_phase = false
            return
        end
    end

    self.spitter_attack_timer = self.spitter_attack_timer - dt
    if self.spitter_attack_timer > 0 then
        return
    end

    if #self.spitter_attack_queue == 0 then
        self.pending_spitter_attack_phase = false
        return
    end

    local attacker = table.remove(self.spitter_attack_queue, 1)
    if not attacker or attacker.ap_left < SPITTER_SHOT_AP_COST then
        return
    end

    local spitter = find_alien_by_id(self, attacker.alien_id)
    if not spitter or spitter.is_dead then
        return
    end

    local target = choose_spitter_target(self, spitter)
    if not target then
        print(string.format("Spitter #%d cannot fire (no valid target in LOS/range)", spitter.id))
        return
    end

    if spitter.go_id and target.go_path then
        local spitter_pos = go.get_position(spitter.go_id)
        local target_pos = go.get_position(target.go_path)
        local dx = target_pos.x - spitter_pos.x
        if math.abs(dx) > 2 then
            spitter.spitter_flip = dx > 0
            sprite.set_hflip(msg.url(nil, spitter.go_id, "sprite"), spitter.spitter_flip)
            sprite.set_hflip(msg.url(nil, spitter.go_id, "shadow"), spitter.spitter_flip)
        end
    end

    attacker.ap_left = attacker.ap_left - SPITTER_SHOT_AP_COST
    spawn_spitter_projectile(self, spitter, target)

    local target_cell = self.world_grid and self.world_grid[target.cell_id] or nil
    local active_light = (target_cell and target_cell.isPowered and math.max(0, math.min(3, target_cell.lightValue or 0))) or 0
    local ranged_model = require("main.config").RANGED_HIT_MODEL
    local hit_chance = math.max(
        ranged_model.min_hit_chance,
        math.min(ranged_model.max_hit_chance, ranged_model.base_hit_chance + (active_light * ranged_model.per_light_level_bonus))
    )
    local roll = math.random(1, 100)
    if roll <= hit_chance then
        target.current_health = math.max(0, target.current_health - 1)
        if MELEE_RUNTIME and MELEE_RUNTIME.spawn_human_blood_splatter_fx then
            MELEE_RUNTIME.spawn_human_blood_splatter_fx(self, target)
        end
        print(string.format(
            "Spitter #%d fired at %s and HIT (HP now %d) [light=%d chance=%d%% roll=%d]",
            spitter.id, target.display_name, target.current_health, active_light, hit_chance, roll
        ))
        if target.current_health <= 0 then
            print(target.display_name .. " is dead")
        end
    else
        print(string.format(
            "Spitter #%d fired at %s and MISSED [light=%d chance=%d%% roll=%d]",
            spitter.id, target.display_name, active_light, hit_chance, roll
        ))
    end

    if attacker.ap_left >= SPITTER_SHOT_AP_COST then
        table.insert(self.spitter_attack_queue, attacker)
    end
    self.spitter_attack_timer = SPITTER_SHOT_INTERVAL_SECONDS
end

local function update_alien_movement(self, dt)
    if not self.aliens then
        return
    end

    for _, alien in ipairs(self.aliens) do
        if alien.type == ALIEN_TYPE_SPEEDY and alien.go_id and (not alien.is_moving) then
            go.set_rotation(vmath.quat_rotation_z(0), alien.go_id)
        end
        if (not alien.is_dead) and alien.is_moving and alien.move_path and alien.go_id then
            local target_cell_id = alien.move_path[alien.move_path_index]
            if not target_cell_id then
                if alien.melee_shuffle_target_x and alien.melee_shuffle_target_y then
                    local pos = go.get_position(alien.go_id)
                    local sdx = alien.melee_shuffle_target_x - pos.x
                    local sdy = alien.melee_shuffle_target_y - pos.y
                    local sdist = math.sqrt(sdx * sdx + sdy * sdy)
                    local sstep = ALIEN_MOVE_SPEED * dt
                    if alien.type == ALIEN_TYPE_CANNON or alien.type == ALIEN_TYPE_SPITTER or alien.type == ALIEN_TYPE_SPEEDY then
                        alien.spitter_anim_phase = (alien.spitter_anim_phase or 0) + (dt * HUMAN_PINGPONG_SPEED * math.pi * 2)
                        local ping = math.sin(alien.spitter_anim_phase)
                        local base_scale = 0.33333334
                        if alien.type == ALIEN_TYPE_CANNON then
                            base_scale = 0.22
                        end
                        local sx = base_scale
                        local sy = base_scale
                        if math.abs(sdx) >= math.abs(sdy) then
                            sx = base_scale * (1 + (HUMAN_PINGPONG_AMPLITUDE * 1.8) * ping)
                        else
                            sy = base_scale * (1 + (HUMAN_PINGPONG_AMPLITUDE * 1.8) * ping)
                        end
                        go.set_scale(vmath.vector3(sx, sy, 1), alien.go_id)
                    end
                    if sdist <= sstep then
                        go.set_position(vmath.vector3(alien.melee_shuffle_target_x, alien.melee_shuffle_target_y, 0.6), alien.go_id)
                        alien.melee_shuffle_target_x = nil
                        alien.melee_shuffle_target_y = nil
                        alien.is_moving = false
                        alien.move_path = nil
                        alien.move_path_index = 0
                        if alien.type == ALIEN_TYPE_SPEEDY then
                            go.set_rotation(vmath.quat_rotation_z(0), alien.go_id)
                        end
                    else
                        local nsx = pos.x + (sdx / sdist) * sstep
                        local nsy = pos.y + (sdy / sdist) * sstep
                        go.set_position(vmath.vector3(nsx, nsy, 0.6), alien.go_id)
                    end
                else
                    alien.is_moving = false
                    alien.move_path = nil
                    alien.move_path_index = 0
                    if alien.type == ALIEN_TYPE_SPEEDY then
                        go.set_rotation(vmath.quat_rotation_z(0), alien.go_id)
                    end
                end
            else
                local target_cell = self.world_grid[target_cell_id]
                local from_cell_before_step = alien.cell_id
                local from_cell = self.world_grid[from_cell_before_step]
                local to_cell = self.world_grid[target_cell_id]
                local from_vent = get_vent_object_on_cell(from_cell)
                local to_vent = get_vent_object_on_cell(to_cell)
                local is_vent_jump = from_vent and to_vent and from_cell_before_step ~= target_cell_id
                local tx, ty = coords_to_world_pos(target_cell.xCell, target_cell.yCell)
                if alien.type ~= ALIEN_TYPE_BLIP then
                    tx = tx + (CELL_WIDTH * 0.25)
                    local human_count = 0
                    if self.squad_units then
                        for _, unit in pairs(self.squad_units) do
                            if unit.cell_id == target_cell_id and (unit.current_health or 0) > 0 then
                                human_count = human_count + 1
                            end
                        end
                    end
                    if human_count > 0 and self.aliens then
                        local on_cell = {}
                        for _, scan in ipairs(self.aliens) do
                            if (not scan.is_dead)
                                and scan.type ~= ALIEN_TYPE_BLIP
                                and (scan.cell_id == target_cell_id or scan.id == alien.id)
                            then
                                table.insert(on_cell, scan)
                            end
                        end
                        table.sort(on_cell, function(a, b)
                            return (a.id or 0) < (b.id or 0)
                        end)
                        local idx = 1
                        for i, scan in ipairs(on_cell) do
                            if scan.id == alien.id then
                                idx = i
                                break
                            end
                        end
                        local lane = { 20, -20, 40, -40, 60, -60 }
                        tx = tx + (lane[idx] or 0)
                    end
                    tx = clamp_world_x_to_cell(target_cell, tx)
                end
                if alien.type == ALIEN_TYPE_SPEEDY then
                    ty = ty + 50
                elseif alien.type == ALIEN_TYPE_SPITTER then
                    ty = ty - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM
                elseif alien.type == ALIEN_TYPE_CANNON then
                    ty = ty - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM - 25
                else
                    ty = ty + 0
                end

                local pos = go.get_position(alien.go_id)
                local dx = tx - pos.x
                local dy = ty - pos.y
                local dist = math.sqrt(dx * dx + dy * dy)
                local step = ALIEN_MOVE_SPEED * dt
                if (not is_vent_jump) and (alien.type == ALIEN_TYPE_CANNON or alien.type == ALIEN_TYPE_SPITTER or alien.type == ALIEN_TYPE_SPEEDY) then
                    alien.spitter_anim_phase = (alien.spitter_anim_phase or 0) + (dt * HUMAN_PINGPONG_SPEED * math.pi * 2)
                    local ping = math.sin(alien.spitter_anim_phase)
                    local base_scale = 0.33333334
                    if alien.type == ALIEN_TYPE_CANNON then
                        base_scale = 0.22
                    end
                    local sx = base_scale
                    local sy = base_scale
                    if math.abs(dx) >= math.abs(dy) then
                        sx = base_scale * (1 + (HUMAN_PINGPONG_AMPLITUDE * 1.8) * ping)
                    else
                        sy = base_scale * (1 + (HUMAN_PINGPONG_AMPLITUDE * 1.8) * ping)
                    end
                    go.set_scale(vmath.vector3(sx, sy, 1), alien.go_id)
                end
                if (not is_vent_jump) and alien.type == ALIEN_TYPE_SPEEDY then
                    if math.abs(dy) > math.abs(dx) and math.abs(dy) > 0.1 then
                        if dy > 0 then
                            go.set_rotation(vmath.quat_rotation_z(math.rad(-90)), alien.go_id)
                        else
                            go.set_rotation(vmath.quat_rotation_z(math.rad(90)), alien.go_id)
                        end
                    else
                        go.set_rotation(vmath.quat_rotation_z(0), alien.go_id)
                    end
                end
                if (not is_vent_jump) and (alien.type == ALIEN_TYPE_CANNON or alien.type == ALIEN_TYPE_SPITTER or alien.type == ALIEN_TYPE_SPEEDY) then
                    if math.abs(dx) > 0.1 then
                        -- Requirement: flip sprite while moving right; unflipped while moving left.
                        alien.spitter_flip = dx > 0
                        sprite.set_hflip(msg.url(nil, alien.go_id, "sprite"), alien.spitter_flip)
                        sprite.set_hflip(msg.url(nil, alien.go_id, "shadow"), alien.spitter_flip)
                    end
                end

                if is_vent_jump or dist <= step then
                    if is_vent_jump then
                        local cx, cy = coords_to_world_pos(to_cell.xCell, to_cell.yCell)
                        local vx = cx + (to_vent.offsetX or 0)
                        local vy = cy + (to_vent.offsetY or 0)
                        go.set_position(vmath.vector3(vx, vy, 0.6), alien.go_id)
                    else
                        go.set_position(vmath.vector3(tx, ty, 0.6), alien.go_id)
                    end
                    alien.cell_id = target_cell_id
                    local door_owner_cell, door_obj, door_closed = get_edge_door_context(self.world_grid, from_cell_before_step, target_cell_id)
                    if door_obj and door_closed and alien.type == ALIEN_TYPE_BRUTE then
                        door_obj.isFixed = false
                        door_obj.isOpen = true
                        if LOOT_RUNTIME and LOOT_RUNTIME.refresh_fix_markers then
                            LOOT_RUNTIME.refresh_fix_markers(self)
                        end
                        if LOOT_RUNTIME and LOOT_RUNTIME.refresh_door_markers then
                            LOOT_RUNTIME.refresh_door_markers(self)
                        end
                        print(string.format("Brute #%d smashed door object #%d open.", alien.id, door_obj.objectId or 0))
                    end
                    if from_vent and to_vent and from_cell_before_step ~= target_cell_id then
                        local cx, cy = coords_to_world_pos(to_cell.xCell, to_cell.yCell)
                        local vx = cx + (to_vent.offsetX or 0)
                        local vy = cy + (to_vent.offsetY or 0)
                        go.set_position(vmath.vector3(vx, vy, 0.6), alien.go_id)
                    end
                    alien.move_path_index = alien.move_path_index + 1
                    maybe_reveal_blip(self, alien)
                    local killed = resolve_human_reaction_fire(self, alien)
                    if not killed then
                        if alien.move_path_index > #alien.move_path then
                            local weakest_human = nil
                            if self.squad_units then
                                for _, unit in pairs(self.squad_units) do
                                    if unit.cell_id == alien.cell_id and (unit.current_health or 0) > 0 then
                                        if (not weakest_human)
                                            or ((unit.current_health or 0) < (weakest_human.current_health or 0))
                                            or (((unit.current_health or 0) == (weakest_human.current_health or 0)) and tostring(unit.id) < tostring(weakest_human.id))
                                        then
                                            weakest_human = unit
                                        end
                                    end
                                end
                            end
                            if weakest_human and weakest_human.go_path then
                                local hpos = go.get_position(weakest_human.go_path)
                                local apos = go.get_position(alien.go_id)
                                local desired_x = hpos.x + 38
                                if apos.x < hpos.x then
                                    desired_x = hpos.x - 38
                                end
                                desired_x = clamp_world_x_to_cell(self.world_grid[alien.cell_id], desired_x)
                                local _, ty_adj = coords_to_world_pos(self.world_grid[alien.cell_id].xCell, self.world_grid[alien.cell_id].yCell)
                                if alien.type == ALIEN_TYPE_SPEEDY then
                                    ty_adj = ty_adj + 50
                                elseif alien.type == ALIEN_TYPE_SPITTER then
                                    ty_adj = ty_adj - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM
                                elseif alien.type == ALIEN_TYPE_CANNON then
                                    ty_adj = ty_adj - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM - 25
                                end
                                local occupied = {}
                                if self.aliens then
                                    for _, other in ipairs(self.aliens) do
                                        if other.id ~= alien.id and (not other.is_dead) and other.cell_id == alien.cell_id and other.go_id then
                                            local op = go.get_position(other.go_id)
                                            table.insert(occupied, op.x)
                                        end
                                    end
                                end
                                local final_x = desired_x
                                for hop = 0, 4 do
                                    local cand_a = clamp_world_x_to_cell(self.world_grid[alien.cell_id], desired_x + (hop * 24))
                                    local cand_b = clamp_world_x_to_cell(self.world_grid[alien.cell_id], desired_x - (hop * 24))
                                    local cand = cand_a
                                    if hop % 2 == 1 then
                                        cand = cand_b
                                    end
                                    local ok = true
                                    for i = 1, #occupied do
                                        if math.abs(cand - occupied[i]) < 18 then
                                            ok = false
                                            break
                                        end
                                    end
                                    if ok then
                                        final_x = cand
                                        break
                                    end
                                end
                                if math.abs(final_x - apos.x) > 1 then
                                    alien.melee_shuffle_target_x = final_x
                                    alien.melee_shuffle_target_y = ty_adj
                                else
                                    alien.is_moving = false
                                    alien.move_path = nil
                                    alien.move_path_index = 0
                                    if alien.type == ALIEN_TYPE_SPEEDY then
                                        go.set_rotation(vmath.quat_rotation_z(0), alien.go_id)
                                    end
                                end
                            else
                                alien.is_moving = false
                                alien.move_path = nil
                                alien.move_path_index = 0
                                if alien.type == ALIEN_TYPE_SPEEDY then
                                    go.set_rotation(vmath.quat_rotation_z(0), alien.go_id)
                                end
                            end
                        end
                    end
                else
                    local nx = pos.x + (dx / dist) * step
                    local ny = pos.y + (dy / dist) * step
                    go.set_position(vmath.vector3(nx, ny, 0.6), alien.go_id)
                end
            end
        end
    end

    remove_dead_aliens(self)
end

local function process_alien_turn(self)
    if not self.aliens or #self.aliens == 0 then
        return
    end

    if any_alien_is_moving(self) or self.pending_spitter_attack_phase or self.pending_melee_attack_phase then
        return
    end

    if self.alien_turn_waiting_for_advance then
        return
    end

    if not self.alien_turn_active then
        -- Temporary turn rule: spawn one new blip every new turn.
        local edge_cells = get_edge_spawn_cell_ids(self.world_grid)
        if #edge_cells > 0 then
            local idx = math.random(1, #edge_cells)
            spawn_alien(self, ALIEN_TYPE_BLIP, edge_cells[idx])
            print("Turn event: spawned 1 new blip")
        end
        self.alien_turn_active = true
        self.alien_turn_waiting_for_advance = false
        print("=== Alien Turn Start ===")
        for _, alien in ipairs(self.aliens) do
            if not alien.is_dead then
                local cfg = ALIEN_TYPE_CONFIG[alien.type]
                local ap_budget = cfg and cfg.ap_per_turn or 1
                alien.turn_ap_remaining = ap_budget
            end
        end
    end

    local any_step = false
    local step_mode = self.alien_turn_manual_pause
    for _, alien in ipairs(self.aliens) do
        if (not alien.is_dead) and (alien.turn_ap_remaining or 0) > 0 then
            local ap_budget = alien.turn_ap_remaining or 0
            local target_cell_id, path = get_nearest_reachable_human_cell_id(self, alien.type, alien.cell_id)
            if target_cell_id then
                local step_budget = ap_budget
                if step_mode then
                    step_budget = 1
                end
                local segment_path, spent = get_alien_turn_movement_segment(self, alien, path, step_budget)
                spent = spent or 0
                if spent <= 0 then
                    alien.turn_ap_remaining = 0
                else
                    alien.turn_ap_remaining = math.max(0, ap_budget - spent)
                    any_step = true
                end
                if segment_path then
                    begin_alien_path_animation(alien, segment_path)
                end
                print(string.format(
                    "Alien #%d (%s) target=%d moved=%s spent=%d rem=%d",
                    alien.id, alien.type, target_cell_id, tostring(segment_path ~= nil), spent, alien.turn_ap_remaining or 0
                ))
            else
                alien.turn_ap_remaining = 0
                print(string.format("Alien #%d (%s) has no reachable human target", alien.id, alien.type))
            end
        end
    end

    if any_step then
        MELEE_RUNTIME.begin_phase(self)
        begin_spitter_attack_phase(self)
        if step_mode and self.alien_turn_manual_pause then
            self.alien_turn_waiting_for_advance = true
        end
        if not step_mode then
            self.alien_turn_active = false
        end
        return
    end

    self.alien_turn_active = false
    self.alien_turn_waiting_for_advance = false
    self.alien_turn_manual_pause = false
    print("=== Alien Turn End ===")
end

local function spawn_initial_blips(self, count)
    local edge_cells = get_edge_spawn_cell_ids(self.world_grid)
    if #edge_cells == 0 then
        return
    end

    local used = {}
    for i = 1, math.min(count, #edge_cells) do
        local idx = math.random(1, #edge_cells)
        while used[idx] do
            idx = math.random(1, #edge_cells)
        end
        used[idx] = true
        spawn_alien(self, ALIEN_TYPE_BLIP, edge_cells[idx])
    end
end

function can_any_human_reactively_attack(self)
    if not self.squad_units or not self.aliens then
        return false
    end
    for _, unit in pairs(self.squad_units) do
        if (unit.current_health or 0) > 0 and unit.cell_id then
            local can_melee = unit.current_ap > 0
            local can_ranged = unit.current_ap > 0 and unit.current_ammo > 0
            if can_melee or can_ranged then
                for _, alien in ipairs(self.aliens) do
                    if (not alien.is_dead) and alien.cell_id then
                        if can_melee and alien.cell_id == unit.cell_id then
                            return true
                        end
                        if can_ranged and has_unobstructed_los(self.world_grid, unit.cell_id, alien.cell_id) then
                            return true
                        end
                    end
                end
            end
        end
    end
    return false
end

-- =============================================================================
-- VISUAL CELL FACTORY
-- =============================================================================
--[[
    Creates visual representation of cells using factory
    Debug sprites show access permissions (walls/floors)
]]

function create_cell_visuals(world_grid, factory_url)
    local cell_objects = {}

    for cell_id, cell in ipairs(world_grid) do
        local x_pos, y_pos = coords_to_world_pos(cell.xCell, cell.yCell)

        -- Determine which debug sprite to use based on access booleans
        local sprite_name = "cell_open"
        if not cell.accessRight and not cell.accessDown then
            sprite_name = "cell_right_down_wall"
        elseif not cell.accessRight then
            sprite_name = "cell_right_wall"
        elseif not cell.accessDown then
            sprite_name = "cell_down_wall"
        end

        -- If cell is VOID, use different sprite
        if cell.tileID == hash("empty") then
            sprite_name = "cell_void"
        end

        -- Create cell game object via factory
        local pos = vmath.vector3(x_pos, y_pos, 0)
        local cell_go = factory.create(factory_url, pos)

        -- Store reference
        cell_objects[cell_id] = {
            go_id = cell_go,
            sprite_name = sprite_name
        }

        -- Set sprite (would need to send message to sprite component)
        -- msg.post(msg.url(nil, cell_go, "sprite"), "play_animation", {id = hash(sprite_name)})
    end

    return cell_objects
end

-- =============================================================================
-- INPUT HANDLING
-- =============================================================================
--[[
    Handles touch/click input to select cells
    Converts screen coordinates to world grid coordinates
]]

function screen_to_world(action_x, action_y, camera_pos, zoom)
    -- Adjust for camera position and zoom
    local world_x = (action_x - SCREEN_WIDTH / 2) / zoom + camera_pos.x
    local world_y = (action_y - SCREEN_HEIGHT / 2) / zoom + camera_pos.y
    return world_x, world_y
end

function handle_cell_click(action, camera_pos, zoom)
    local world_x, world_y = screen_to_world(action.x, action.y, camera_pos, zoom)
    local x_cell, y_cell = world_pos_to_coords(world_x, world_y)
    local cell_id = coords_to_id(x_cell, y_cell)

    if cell_id then
        print(string.format("Clicked Cell ID: %d at (%d, %d) - World: (%.1f, %.1f)",
            cell_id, x_cell, y_cell, world_x, world_y))
        return cell_id
    end

    return nil
end

local function reset_cell_tint(cell_id)
    local go_id = cell_objects[cell_id]
    if go_id then
        msg.post(msg.url(nil, go_id, "cell_sprite1"), "set_tint", { tint = COLOR_DEFAULT })
    end
end

local function apply_cell_tint(cell_id, tint_color)
    local go_id = cell_objects[cell_id]
    if go_id then
        msg.post(msg.url(nil, go_id, "cell_sprite1"), "set_tint", { tint = tint_color })
    end
end

local function clear_path_visuals(self)
    if self.path_highlight_cells then
        for _, cell_id in ipairs(self.path_highlight_cells) do
            reset_cell_tint(cell_id)
        end
    end
    self.path_highlight_cells = {}
end

local function print_path_debug(path, total_cost)
    local ids = {}
    for i, cell_id in ipairs(path) do
        ids[i] = tostring(cell_id)
    end
    print("Path found:")
    print("  Steps: " .. #path)
    print("  Cost: " .. total_cost)
    print("  Route: " .. table.concat(ids, " -> "))
end

local function highlight_path(self, path)
    clear_path_visuals(self)
    self.path_highlight_cells = {}

    for _, cell_id in ipairs(path) do
        apply_cell_tint(cell_id, COLOR_PATH)
        table.insert(self.path_highlight_cells, cell_id)
    end

    if #path >= 1 then
        apply_cell_tint(path[1], COLOR_START)
    end
    if #path >= 2 then
        apply_cell_tint(path[#path], COLOR_END)
    end
end

local function clamp(value, min_value, max_value)
    if value < min_value then
        return min_value
    end
    if value > max_value then
        return max_value
    end
    return value
end

local function get_camera_clamped_pos(camera_pos, zoom)
    local world_w = CELL_WIDTH * GRID_COLS
    local world_h = CELL_HEIGHT * GRID_ROWS
    local half_view_w = (SCREEN_WIDTH * 0.5) / zoom
    local half_view_h = (SCREEN_HEIGHT * 0.5) / zoom

    local min_x = half_view_w - CAMERA_EDGE_PADDING_X
    local max_x = world_w - half_view_w + CAMERA_EDGE_PADDING_X
    local min_y = half_view_h - CAMERA_EDGE_PADDING_Y
    local max_y = world_h - half_view_h + CAMERA_EDGE_PADDING_Y

    local clamped_x = camera_pos.x
    local clamped_y = camera_pos.y

    if min_x > max_x then
        clamped_x = world_w * 0.5
    else
        clamped_x = clamp(camera_pos.x, min_x, max_x)
    end

    if min_y > max_y then
        clamped_y = world_h * 0.5
    else
        clamped_y = clamp(camera_pos.y, min_y, max_y)
    end

    return vmath.vector3(clamped_x, clamped_y, camera_pos.z)
end

local function apply_camera_transform(self)
    self.camera_pos = get_camera_clamped_pos(self.camera_pos, self.camera_zoom)
    go.set_position(self.camera_pos, "/camera")
    go.set("/camera#camera", "orthographic_zoom", self.camera_zoom)
end

local function zoom_camera_at_screen_point(self, target_zoom, screen_x, screen_y)
    local old_zoom = self.camera_zoom
    if target_zoom == old_zoom then
        return
    end

    -- Keep the world point under cursor fixed during zoom.
    local world_x, world_y = screen_to_world(screen_x, screen_y, self.camera_pos, old_zoom)
    self.camera_zoom = target_zoom
    self.camera_pos.x = world_x - ((screen_x - SCREEN_WIDTH * 0.5) / self.camera_zoom)
    self.camera_pos.y = world_y - ((screen_y - SCREEN_HEIGHT * 0.5) / self.camera_zoom)
    apply_camera_transform(self)
end

local function is_walkable_cell(world_grid, cell_id)
    local cell = world_grid[cell_id]
    return cell and cell.tileID ~= hash("empty")
end


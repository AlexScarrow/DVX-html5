local function get_controlled_unit(self)
    if not self.squad_units or not self.controlled_unit_id then
        return nil
    end
    return self.squad_units[self.controlled_unit_id]
end

local function get_unit_by_id(self, unit_id)
    if not self.squad_units or not unit_id then
        return nil
    end
    return self.squad_units[unit_id]
end

local function get_unit_on_cell(self, cell_id)
    if not self.squad_units then
        return nil
    end
    for _, unit in pairs(self.squad_units) do
        if unit.cell_id == cell_id then
            return unit
        end
    end
    return nil
end

local function get_units_on_cell(self, cell_id)
    local units = {}
    if not self.squad_units then
        return units
    end
    for _, unit in pairs(self.squad_units) do
        if unit.cell_id == cell_id then
            table.insert(units, unit)
        end
    end
    return units
end

local function get_spawn_order_unit_id_list()
    return { "sarge", "techie", "medic", "gunner" }
end

local function sort_units_by_spawn_order(units)
    local order = { sarge = 1, techie = 2, medic = 3, gunner = 4 }
    table.sort(units, function(a, b)
        return (order[a.id] or 99) < (order[b.id] or 99)
    end)
end

local function ensure_cell_slot_assignment(self, unit, cell_id)
    if not unit or not cell_id then
        return 1
    end

    self.cell_slot_assignments = self.cell_slot_assignments or {}
    self.cell_slot_assignments[cell_id] = self.cell_slot_assignments[cell_id] or {}
    local assignment = self.cell_slot_assignments[cell_id]

    if assignment[unit.id] then
        return assignment[unit.id]
    end

    local used = {}
    for _, slot_index in pairs(assignment) do
        used[slot_index] = true
    end

    local selected_slot = 1
    for i = 1, #CELL_SLOT_OFFSETS_X do
        if not used[i] then
            selected_slot = i
            break
        end
    end

    assignment[unit.id] = selected_slot
    return selected_slot
end

local function clear_cell_slot_assignment(self, unit, cell_id)
    if not unit or not cell_id or not self.cell_slot_assignments then
        return
    end
    local assignment = self.cell_slot_assignments[cell_id]
    if assignment then
        assignment[unit.id] = nil
    end
end

local function cell_has_any_unit_except(self, cell_id, except_unit_id)
    if not self.squad_units then
        return false
    end
    for _, unit in pairs(self.squad_units) do
        if unit.id ~= except_unit_id and unit.cell_id == cell_id then
            return true
        end
    end
    return false
end

local function deselect_all_units(self)
    if not self.squad_units then
        return
    end
    for _, unit in pairs(self.squad_units) do
        unit.is_selected = false
    end
end

local function any_unit_is_moving(self)
    if not self.squad_units then
        return false
    end
    for _, unit in pairs(self.squad_units) do
        if unit.is_moving then
            return true
        end
    end
    return false
end

local function unit_has_role(unit, role_key)
    if not unit then
        return false
    end
    local role = CLASS_ROLE_HOOKS[unit.class_id]
    return role and role[role_key] == true
end

local function get_unit_base_tint(unit)
    if not unit then
        return vmath.vector4(1, 1, 1, 1)
    end
    if unit.class_id == UNIT_CLASS_SARGE then
        return HUMAN_TINT_SARGE
    elseif unit.class_id == UNIT_CLASS_TECHIE then
        return HUMAN_TINT_TECHIE
    elseif unit.class_id == UNIT_CLASS_MEDIC then
        return HUMAN_TINT_MEDIC
    elseif unit.class_id == UNIT_CLASS_GUNNER then
        return HUMAN_TINT_GUNNER
    end
    return vmath.vector4(1, 1, 1, 1)
end

local function get_selected_tint(base_tint)
    return vmath.vector4(
        math.min(base_tint.x + 0.2, 1),
        math.min(base_tint.y + 0.2, 1),
        math.min(base_tint.z + 0.2, 1),
        1
    )
end

-- FUTURE GAMEPLAY HOOKS (role-gated actions)
local function can_donate_ap(unit)
    return unit_has_role(unit, "can_donate_ap")
end

local function can_fix(unit)
    return unit_has_role(unit, "can_fix")
end

local function can_heal(unit)
    return unit_has_role(unit, "can_heal")
end

local function has_heavy_weapon(unit)
    return unit_has_role(unit, "heavy_weapon")
end

local function get_unit_ranged_hit_bonus(unit)
    if not unit then
        return 0
    end
    local role = CLASS_ROLE_HOOKS[unit.class_id]
    return (role and role.ranged_hit_bonus) or 0
end

local function print_squad_debug_overview(self)
    if not self.squad_units then
        return
    end

    print("=== SQUAD DEBUG (UI placeholder in console) ===")
    for _, unit in pairs(self.squad_units) do
        print(string.format(
            "  %s class=%s AP=%d/%d roles{donate=%s fix=%s heal=%s heavy=%s}",
            unit.display_name,
            unit.class_id,
            unit.current_ap,
            unit.max_ap,
            tostring(unit_has_role(unit, "can_donate_ap")),
            tostring(unit_has_role(unit, "can_fix")),
            tostring(unit_has_role(unit, "can_heal")),
            tostring(unit_has_role(unit, "heavy_weapon"))
        ))
    end
end

local function find_first_walkable_cell(world_grid)
    for cell_id, cell in ipairs(world_grid) do
        if cell.tileID ~= hash("empty") then
            return cell_id
        end
    end
    return nil
end

local function set_unit_scale(unit, scale_x, scale_y)
    if unit and unit.go_path then
        local ok = pcall(go.set_scale, vmath.vector3(scale_x, scale_y, 1), unit.go_path)
        if not ok then
            unit.go_path = nil
            unit.sprite_path = nil
        end
    end
end

get_counter_shadow_offset = function(profile, move_arc)
    local base_x = (profile and profile.counter_shadow_base_offset_x) or 0
    local base_y = (profile and profile.counter_shadow_base_offset_y) or 0
    local extra_x = (profile and profile.counter_shadow_lift_extra_x) or 108
    local extra_y = (profile and profile.counter_shadow_lift_extra_y) or -104
    local arc = move_arc or 0
    return vmath.vector3(
        30 + base_x + (extra_x * arc),
        -30 + base_y + (extra_y * arc),
        -0.01
    )
end

get_counter_shadow_anim_for_alien = function(alien_type)
    if alien_type == ALIEN_TYPE_CANNON then
        return hash("alien_cannonFodder_shadow")
    elseif alien_type == ALIEN_TYPE_BRUTE then
        return hash("alien_brute_shadow")
    elseif alien_type == ALIEN_TYPE_SPITTER then
        return hash("alien_spitter_shadow")
    elseif alien_type == ALIEN_TYPE_SPEEDY then
        return hash("alien_speedy_shadow")
    end
    return nil
end

get_alien_anim_for_aesthetic = function(self, alien_type)
    if not self then
        return nil
    end
    if self.aesthetic_mode == AESTHETIC_MODE_BOARDGAME then
        if alien_type == ALIEN_TYPE_CANNON then
            return hash("alien_cannonFodder_boardgame")
        elseif alien_type == ALIEN_TYPE_BRUTE then
            return hash("alien_brute_boardgame")
        elseif alien_type == ALIEN_TYPE_SPITTER then
            return hash("alien_spitter_boardgame")
        elseif alien_type == ALIEN_TYPE_SPEEDY then
            return hash("alien_speedy_boardgame")
        end
    end
    if alien_type == ALIEN_TYPE_CANNON then
        return hash("alien_cannonFodder")
    elseif alien_type == ALIEN_TYPE_BRUTE then
        return hash("alien_brute")
    elseif alien_type == ALIEN_TYPE_SPITTER then
        return hash("alien_spitter")
    elseif alien_type == ALIEN_TYPE_SPEEDY then
        return hash("alien_speedy")
    end
    return nil
end

get_counter_shadow_anim_for_human = function(self, unit)
    if not unit then
        return hash("human_dropShadow"), vmath.vector4(1, 1, 1, 0.5)
    end
    if self and self.aesthetic_mode == AESTHETIC_MODE_BOARDGAME then
        return hash("human_proxyShadow_boardgame"), vmath.vector4(1, 1, 1, 0.5)
    end
    return hash("human_dropShadow"), vmath.vector4(1, 1, 1, 0.5)
end

ensure_counter_shadow_proxy = function(entity, anim_hash, tint, factory_path)
    if not anim_hash then
        return nil
    end
    if entity.shadow_proxy_id then
        return entity.shadow_proxy_id
    end
    local proxy_factory = factory_path or "/tile_factory#tile_factory"
    local proxy_id = factory.create(proxy_factory, vmath.vector3(0, 0, 0.49))
    if proxy_id then
        msg.post(msg.url(nil, proxy_id, "sprite"), "play_animation", { id = anim_hash })
        go.set_scale(vmath.vector3(0.75, 0.75, 1), proxy_id)
        go.set(msg.url(nil, proxy_id, "sprite"), "tint", tint or vmath.vector4(1, 1, 1, 0.5))
        entity.shadow_proxy_id = proxy_id
    end
    return proxy_id
end

clear_counter_shadow_proxy = function(entity)
    if entity and entity.shadow_proxy_id then
        go.delete(entity.shadow_proxy_id)
        entity.shadow_proxy_id = nil
    end
    if entity then
        entity.shadow_proxy_pending_clear = false
        entity.shadow_proxy_clear_token = nil
    end
end

schedule_counter_shadow_proxy_clear = function(entity, delay_s)
    if not entity or not entity.shadow_proxy_id then
        return
    end
    if entity.shadow_proxy_pending_clear then
        return
    end
    entity.shadow_proxy_pending_clear = true
    entity.shadow_proxy_clear_token = (entity.shadow_proxy_clear_token or 0) + 1
    local token = entity.shadow_proxy_clear_token
    timer.delay(delay_s or 0.08, false, function()
        if entity
            and entity.shadow_proxy_pending_clear
            and entity.shadow_proxy_id
            and entity.shadow_proxy_clear_token == token then
            clear_counter_shadow_proxy(entity)
        end
    end)
end

local function update_human_visual_state(self)
    if not self.squad_units then
        return
    end

    local shadow_alpha = get_world_shadow_alpha(self)
    local profile = get_aesthetic_profile(self)
    local counter_move_enabled = profile and profile.counter_token_move_enabled == true
    local shadow_origin = vmath.vector3(30, -30, -0.01)
    for _, unit in pairs(self.squad_units) do
        if unit.sprite_path then
            local function safe_set_tint(color)
                local ok = pcall(go.set, unit.sprite_path, "tint", color)
                if not ok then
                    unit.go_path = nil
                    unit.sprite_path = nil
                end
            end
            local flash_timer = unit.hit_flash_timer or 0
            if not (unit and (unit.current_health or 0) > 0) then
                local dead_anim = get_human_anim_for_aesthetic(self, unit)
                if dead_anim then
                    pcall(msg.post, unit.sprite_path, "play_animation", { id = dead_anim })
                end
                safe_set_tint(vmath.vector4(1, 1, 1, 1))
            elseif flash_timer > 0 then
                local flash_band = math.floor(flash_timer * 24) % 2
                if flash_band == 0 then
                    safe_set_tint(vmath.vector4(1, 0.15, 0.15, 1))
                else
                    safe_set_tint(vmath.vector4(0.65, 0.05, 0.05, 1))
                end
            elseif unit.current_ap <= 0 then
                safe_set_tint(HUMAN_TINT_NO_AP)
            else
                local base_tint = get_unit_base_tint(unit)
                if unit.is_selected then
                    safe_set_tint(get_selected_tint(base_tint))
                else
                    safe_set_tint(base_tint)
                end
            end
        end
        if unit.shadow_path then
            local ok = pcall(go.set, unit.shadow_path, "tint", vmath.vector4(1, 1, 1, shadow_alpha))
            if not ok then
                unit.shadow_path = nil
            else
                local shadow_pos = shadow_origin
                if counter_move_enabled then
                    shadow_pos = unit.shadow_motion_offset or get_counter_shadow_offset(profile, 0)
                end
                local use_proxy_shadow = counter_move_enabled and (unit.is_moving or unit.shadow_proxy_pending_clear) and unit.go_path ~= nil
                if use_proxy_shadow then
                    local proxy_anim, proxy_tint = get_counter_shadow_anim_for_human(self, unit)
                    local proxy_id = ensure_counter_shadow_proxy(unit, proxy_anim, proxy_tint, "/human_shadow_proxy_factory#human_shadow_proxy_factory")
                    if proxy_id and unit.go_path then
                        local pos = go.get_position(unit.go_path)
                        go.set_position(vmath.vector3(pos.x + shadow_pos.x, pos.y + shadow_pos.y, pos.z - 0.01), proxy_id)
                    end
                    pcall(go.set, unit.shadow_path, "tint", vmath.vector4(1, 1, 1, 0))
                    if counter_move_enabled and (not unit.is_moving) and unit.shadow_proxy_id then
                        schedule_counter_shadow_proxy_clear(unit, 0.08)
                    end
                else
                    clear_counter_shadow_proxy(unit)
                    pcall(go.set, unit.shadow_path, "position", shadow_pos)
                end
            end
        end
    end
end

local function update_selected_unit_pulse(self, dt)
    if not self.squad_units then
        return
    end

    for _, unit in pairs(self.squad_units) do
        if unit.go_path and not unit.is_moving then
            local receive_timer = unit.receive_pulse_timer or 0
            if receive_timer > 0 then
                receive_timer = math.max(0, receive_timer - dt)
                unit.receive_pulse_timer = receive_timer
                local progress = 1 - (receive_timer / 0.24)
                local pulse = 1 + (0.26 * math.sin(progress * math.pi))
                set_unit_scale(unit, HUMAN_VISUAL_SCALE * pulse, HUMAN_VISUAL_SCALE * pulse)
            elseif unit.is_selected and unit.current_ap > 0 then
                unit.select_pulse_phase = (unit.select_pulse_phase or 0) + (dt * UNIT_SELECTED_PULSE_SPEED * math.pi * 2)
                local pulse = 1 + UNIT_SELECTED_PULSE_AMPLITUDE * math.sin(unit.select_pulse_phase)
                set_unit_scale(unit, HUMAN_VISUAL_SCALE * pulse, HUMAN_VISUAL_SCALE * pulse)
            else
                unit.select_pulse_phase = 0
                set_unit_scale(unit, HUMAN_VISUAL_SCALE, HUMAN_VISUAL_SCALE)
            end
        end
    end
end

local function create_ui_square(screen_x, screen_y, z, color, scale_x, scale_y)
    local pos = vmath.vector3(screen_x, screen_y, z)
    local id = factory.create("/ui_factory#ui_factory", pos)
    if id then
        go.set_scale(vmath.vector3(scale_x, scale_y, 1), id)
        go.set(msg.url(nil, id, "sprite"), "tint", color)
    end
    return id
end

local function create_ui_panel_sprite(screen_x, screen_y, z, scale_x, scale_y)
    local pos = vmath.vector3(screen_x, screen_y, z)
    local id = factory.create("/ui_panel_factory#ui_panel_factory", pos)
    if id then
        go.set_scale(vmath.vector3(scale_x, scale_y, 1), id)
    end
    return id
end

create_ui_marker_sprite = function(anim_id, z)
    local id = factory.create("/loot_marker_factory#loot_marker_factory", vmath.vector3(-9999, -9999, z or FLOW_UI_BUTTON_Z))
    if id and anim_id then
        msg.post(msg.url(nil, id, "sprite"), "play_animation", { id = anim_id })
    end
    return id
end

local function set_ui_square_transform(self, go_id, screen_x, screen_y, z, color, scale_x, scale_y)
    if not go_id then
        return
    end
    if self and self.ui and scale_x and scale_y and scale_x > 1.2 and scale_y > 1.2 then
        local function scale_div(div_x, div_y)
            if div_x > 0 and div_y > 0 then
                scale_x = scale_x / div_x
                scale_y = scale_y / div_y
            end
        end
        if go_id == self.ui.flow_mp_setup_panel then
            scale_div(MP_SETUP_PANEL_W * 0.021, MP_SETUP_PANEL_H * 0.021)
        elseif go_id == self.ui.flow_mp_count_active_ring then
            scale_div(MP_SETUP_COUNT_ACTIVE_RING_W * 0.021, MP_SETUP_COUNT_ACTIVE_RING_H * 0.021)
        elseif go_id == self.ui.flow_mp_back_button
            or go_id == self.ui.flow_mp_start_button
            or go_id == self.ui.flow_mp_start_disabled_overlay
            or go_id == self.ui.flow_mp_start_enabled_glow then
            scale_div(171 * 0.021, 72 * 0.021)
        elseif self.ui.flow_mp_count_buttons then
            for _, btn in ipairs(self.ui.flow_mp_count_buttons) do
                if go_id == btn then
                    scale_div(120 * 0.021, 64 * 0.021)
                    break
                end
            end
        end
        if self.ui.flow_mp_unit_buttons then
            for _, btn in ipairs(self.ui.flow_mp_unit_buttons) do
                if go_id == btn then
                    scale_div(84 * 0.021, 84 * 0.021)
                    break
                end
            end
        end
        if self.ui.flow_mp_slot_icons then
            for _, slot_icons in pairs(self.ui.flow_mp_slot_icons) do
                for _, slot_icon in ipairs(slot_icons) do
                    if go_id == slot_icon then
                        scale_div(84 * 0.021, 84 * 0.021)
                        break
                    end
                end
            end
        end
    end
    local wx, wy = screen_to_world(screen_x, screen_y, self.camera_pos, self.camera_zoom)
    go.set_position(vmath.vector3(wx, wy, z), go_id)
    go.set_scale(vmath.vector3(scale_x / self.camera_zoom, scale_y / self.camera_zoom, 1), go_id)
    go.set(msg.url(nil, go_id, "sprite"), "tint", color)
end

local function set_ui_panel_transform(self, go_id, screen_x, screen_y, z, scale_x, scale_y, tint)
    if not go_id then
        return
    end
    local wx, wy = screen_to_world(screen_x, screen_y, self.camera_pos, self.camera_zoom)
    local sx = (scale_x / UI_PANEL_ART_W) / self.camera_zoom
    local sy = (scale_y / UI_PANEL_ART_H) / self.camera_zoom
    go.set_position(vmath.vector3(wx, wy, z), go_id)
    go.set_scale(vmath.vector3(sx, sy, 1), go_id)
    go.set(msg.url(nil, go_id, "sprite"), "tint", tint or vmath.vector4(1, 1, 1, 1))
end

get_multiplayer_transport_status_tint = function(self)
    local status = self.mp_state and self.mp_state.transport_status or "idle"
    if status == "connected" then
        return vmath.vector4(0.2, 0.95, 0.3, 0.95)
    elseif status == "connecting" then
        return vmath.vector4(0.95, 0.8, 0.2, 0.95)
    elseif status == "reconnecting" then
        return vmath.vector4(1, 0.55, 0.2, 0.95)
    elseif status == "fallback_loopback" then
        return vmath.vector4(0.65, 0.55, 1, 0.95)
    elseif status == "shutdown" then
        return vmath.vector4(0.6, 0.6, 0.6, 0.95)
    end
    return vmath.vector4(0.7, 0.7, 0.7, 0.95)
end

get_multiplayer_ready_button_x = function(slot_index)
    local start_x = NEW_TURN_BUTTON_X + (NEW_TURN_BUTTON_W * 0.5) + 26
    return start_x + ((slot_index - 1) * (MULTIPLAYER_READY_BUTTON_W + MULTIPLAYER_READY_BUTTON_GAP))
end

multiplayer_get_unit_anim_id = function(unit_id)
    if unit_id == "sarge" then
        return hash("mp_unit_sarge")
    elseif unit_id == "techie" then
        return hash("mp_unit_techie")
    elseif unit_id == "medic" then
        return hash("mp_unit_medic")
    elseif unit_id == "gunner" then
        return hash("mp_unit_gunner")
    end
    return hash("mp_unit_sarge")
end

multiplayer_normalize_mission_type = function(mission_type)
    local value = tostring(mission_type or MISSION_TYPE_ESCAPE)
    if value == MISSION_TYPE_ESCAPE
        or value == MISSION_TYPE_RESCUE
        or value == MISSION_TYPE_PURGE
        or value == MISSION_TYPE_DNA_SAMPLE
    then
        return value
    end
    return MISSION_TYPE_ESCAPE
end

multiplayer_get_mission_anim_id = function(mission_type)
    local m = multiplayer_normalize_mission_type(mission_type)
    if m == MISSION_TYPE_RESCUE then
        return hash("mp_btn_mission_rescue")
    elseif m == MISSION_TYPE_PURGE then
        return hash("mp_btn_mission_purge")
    elseif m == MISSION_TYPE_DNA_SAMPLE then
        return hash("mp_btn_mission_dna")
    end
    return hash("mp_btn_mission_escape")
end

get_level_mission_type = function(level_def)
    if type(level_def) ~= "table" then
        return MISSION_TYPE_ESCAPE
    end
    local tagged = rawget(level_def, "mission_type")
    return multiplayer_normalize_mission_type(tagged or MISSION_TYPE_ESCAPE)
end

select_level_index_for_mission = function(self, mission_type)
    local requested = multiplayer_normalize_mission_type(mission_type)
    local levels = self and self.level_library or nil
    local candidates = {}
    if type(levels) == "table" then
        for level_index, level_def in ipairs(levels) do
            if type(level_def) == "table" and get_level_mission_type(level_def) == requested then
                table.insert(candidates, level_index)
            end
        end
    end
    if #candidates == 0 and requested ~= MISSION_TYPE_ESCAPE and type(levels) == "table" then
        for level_index, level_def in ipairs(levels) do
            if type(level_def) == "table" and get_level_mission_type(level_def) == MISSION_TYPE_ESCAPE then
                table.insert(candidates, level_index)
            end
        end
    end
    if #candidates == 0 and type(levels) == "table" then
        for level_index, level_def in ipairs(levels) do
            if type(level_def) == "table" then
                table.insert(candidates, level_index)
            end
        end
    end
    if #candidates == 0 then
        return 1
    end
    return candidates[math.random(1, #candidates)]
end

multiplayer_get_slot_count_for_player = function(player_count, player_id)
    if player_count == 2 then
        if player_id == "p1" or player_id == "p2" then
            return 2
        end
        return 0
    elseif player_count == 3 then
        if player_id == "p1" or player_id == "p2" or player_id == "p3" then
            return 2
        end
        return 0
    end
    if player_id == "p1" or player_id == "p2" or player_id == "p3" or player_id == "p4" then
        return 1
    end
    return 0
end

multiplayer_get_required_ready_player_ids_for_count = function(player_count)
    local ids = {}
    local max_players = math.max(2, math.min(4, player_count or 4))
    for i = 2, max_players do
        table.insert(ids, "p" .. tostring(i))
    end
    return ids
end

multiplayer_get_default_seat_assignments = function(player_count)
    local count = math.max(2, math.min(4, player_count or 4))
    if count == 2 then
        return {
            p1 = { "sarge", "techie" },
            p2 = { "medic", "gunner" }
        }
    elseif count == 3 then
        return {
            p1 = { "sarge", "techie" },
            p2 = { "medic" },
            p3 = { "gunner" }
        }
    end
    return {
        p1 = { "sarge" },
        p2 = { "techie" },
        p3 = { "medic" },
        p4 = { "gunner" }
    }
end

multiplayer_clone_seat_assignments = function(src_assignments, player_count)
    local out = {}
    local count = math.max(2, math.min(4, player_count or 4))
    for i = 1, count do
        local player_id = "p" .. tostring(i)
        out[player_id] = {}
        local src = src_assignments and src_assignments[player_id] or nil
        if src then
            for _, unit_id in ipairs(src) do
                table.insert(out[player_id], unit_id)
            end
        end
    end
    return out
end

multiplayer_get_player_for_unit = function(assignments, player_count, unit_id)
    if not assignments then
        return nil
    end
    local count = math.max(2, math.min(4, player_count or 4))
    for i = 1, count do
        local player_id = "p" .. tostring(i)
        local units = assignments[player_id] or {}
        for _, owned_id in ipairs(units) do
            if owned_id == unit_id then
                return player_id
            end
        end
    end
    return nil
end

PANEL_ART_ANIM_BY_CLASS_ID = {
    [UNIT_CLASS_SARGE] = hash("sarge_ui"),
    [UNIT_CLASS_MEDIC] = hash("medic_ui"),
    [UNIT_CLASS_TECHIE] = hash("techie_ui"),
    [UNIT_CLASS_GUNNER] = hash("gunner_ui")
}

get_unit_panel_anim = function(unit)
    if not unit then
        return hash("derple_ui_panel")
    end
    return PANEL_ART_ANIM_BY_CLASS_ID[unit.class_id] or hash("derple_ui_panel")
end

get_ui_panel_close_button_center = function()
    return UI_PANEL_X + (UI_PANEL_W * 0.5) - 38, UI_PANEL_Y - (UI_PANEL_H * 0.5) + 38
end

get_ui_panel_reactive_button_center = function()
    local close_x, close_y = get_ui_panel_close_button_center()
    return close_x - 74, close_y
end

count_non_nil_entries = function(t)
    if not t then
        return 0
    end
    local n = 0
    for _, v in pairs(t) do
        if v ~= nil then
            n = n + 1
        end
    end
    return n
end

collect_runtime_reference_counts = function(self)
    local c = {}
    c.tile_objects = count_non_nil_entries(tile_objects)
    c.cell_objects = count_non_nil_entries(cell_objects)
    c.loot_objects = count_non_nil_entries(loot_objects)
    c.machine_objects = count_non_nil_entries(machine_objects)
    c.tile_base_objects = count_non_nil_entries(self.tile_base_objects)
    c.tile_room_shadows = count_non_nil_entries(self.tile_room_shadows)
    c.tile_light_layers = count_non_nil_entries(self.tile_light_layers)
    c.tile_alpha_layers = count_non_nil_entries(self.tile_alpha_layers)
    c.entry_fire_fx_objects = count_non_nil_entries(self.entry_fire_fx_objects)
    c.exit_green_smoke_fx_objects = count_non_nil_entries(self.exit_green_smoke_fx_objects)
    c.world_item_visuals = count_non_nil_entries(self.world_item_visuals)
    c.world_item_shadow_visuals = count_non_nil_entries(self.world_item_shadow_visuals)
    c.loot_shadow_objects = count_non_nil_entries(self.loot_shadow_objects)
    c.machine_shadow_objects = count_non_nil_entries(self.machine_shadow_objects)
    c.turret_shadow_objects = count_non_nil_entries(self.turret_shadow_objects)
    c.power_node_shadow_objects = count_non_nil_entries(self.power_node_shadow_objects)
    c.vent_shadow_objects = count_non_nil_entries(self.vent_shadow_objects)
    c.door_shadow_objects = count_non_nil_entries(self.door_shadow_objects)
    c.fix_objects = count_non_nil_entries(self.fix_objects)
    c.power_node_objects = count_non_nil_entries(self.power_node_objects)
    c.vent_objects = count_non_nil_entries(self.vent_objects)
    c.door_objects = count_non_nil_entries(self.door_objects)
    c.turret_tripod_objects = count_non_nil_entries(self.turret_tripod_objects)
    c.turret_gun_objects = count_non_nil_entries(self.turret_gun_objects)
    c.wiregap_objects = count_non_nil_entries(self.wiregap_objects)
    c.wiregap_shadow_objects = count_non_nil_entries(self.wiregap_shadow_objects)
    c.wiregap_fx_objects = count_non_nil_entries(self.wiregap_fx_objects)
    c.light_value_objects = count_non_nil_entries(self.light_value_objects)
    c.escape_pod_power_slot_markers = count_non_nil_entries(self.escape_pod_power_slot_markers)
    c.exit_requirement_markers = count_non_nil_entries(self.exit_requirement_markers)
    c.world_backdrop_tiles = count_non_nil_entries(self.world_backdrop_tiles)
    c.loot_pickup_blips = count_non_nil_entries(self.loot_pickup_blips)
    c.world_item_instances = count_non_nil_entries(self.world_item_instances)
    c.power_node_loop_fx = count_non_nil_entries(self.power_node_loop_fx)
    c.melee_swipe_fx = count_non_nil_entries(self.melee_swipe_fx)
    c.aliens = count_non_nil_entries(self.aliens)
    c.spitter_projectiles = count_non_nil_entries(self.spitter_projectiles)
    c.turret_projectiles = count_non_nil_entries(self.turret_projectiles)
    c.ui_ap_pips = self.ui and self.ui.ap_pips and #self.ui.ap_pips or 0
    c.ui_hp_pips = self.ui and self.ui.hp_pips and #self.ui.hp_pips or 0
    c.ui_ammo_pips = self.ui and self.ui.ammo_pips and #self.ui.ammo_pips or 0
    c.ui_command_pips = self.ui and self.ui.command_pips and #self.ui.command_pips or 0
    c.ui_backpack_slots = self.ui and self.ui.backpack_slots and #self.ui.backpack_slots or 0
    c.ui_backpack_item_icons = self.ui and self.ui.backpack_item_icons and #self.ui.backpack_item_icons or 0
    c.ui_level_buttons = self.ui and self.ui.level_buttons and #self.ui.level_buttons or 0
    c.ui_flow_rows = self.ui and self.ui.flow_score_rows and #self.ui.flow_score_rows or 0
    c.ui_named_nodes = 0
    if self.ui then
        local named = {
            "panel_art", "panel_shadow", "component_button", "fix_button", "loot_button", "retrieve_button",
            "close_button", "not_enough_ap_icon", "new_turn_button", "launch_button", "aesthetic_toggle_button", "reactive_toggle_button",
            "reactive_advance_button", "drag_command_pip", "drag_pip", "flow_overlay", "flow_panel",
            "flow_outro_ship", "flow_outro_skip_button", "flow_score_submit_button", "flow_score_title_button",
            "flow_title_solo_button", "flow_title_multiplayer_button"
        }
        for _, k in ipairs(named) do
            if self.ui[k] ~= nil then
                c.ui_named_nodes = c.ui_named_nodes + 1
            end
        end
    end
    c.total = 0
    for k, v in pairs(c) do
        if k ~= "total" and type(v) == "number" then
            c.total = c.total + v
        end
    end
    return c
end

log_runtime_reference_audit = function(self, phase)
    self.runtime_ref_audit = self.runtime_ref_audit or {}
    local c = collect_runtime_reference_counts(self)
    print(string.format(
        "REF AUDIT | %s | total=%d tiles=%d cells=%d loot=%d machine=%d worldItems=%d itemVisuals=%d uiIcons=%d uiNamed=%d aliens=%d",
        phase or "unknown",
        c.total or 0,
        c.tile_objects or 0,
        c.cell_objects or 0,
        c.loot_objects or 0,
        c.machine_objects or 0,
        c.world_item_instances or 0,
        c.world_item_visuals or 0,
        c.ui_backpack_item_icons or 0,
        c.ui_named_nodes or 0,
        c.aliens or 0
    ))
    if phase == "post_load" then
        local prev = self.runtime_ref_audit.last_post_load
        if prev and prev.total and c.total and c.total > (prev.total + 120) then
            print(string.format(
                "REF AUDIT WARNING | post_load references grew from %d to %d",
                prev.total or 0,
                c.total or 0
            ))
        end
        self.runtime_ref_audit.last_post_load = c
    elseif phase == "pre_clear" then
        self.runtime_ref_audit.last_pre_clear = c
    elseif phase == "post_clear" then
        self.runtime_ref_audit.last_post_clear = c
    end
end


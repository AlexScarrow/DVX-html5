local function get_controlled_unit(self)
    if not self.squad_units or not self.controlled_unit_id then
        return nil
    end
    return self.squad_units[self.controlled_unit_id]
end

local function get_unit_by_id(self, unit_id)
    if not self.squad_units or not unit_id then
        return nil
    end
    return self.squad_units[unit_id]
end

local function get_unit_on_cell(self, cell_id)
    if not self.squad_units then
        return nil
    end
    for _, unit in pairs(self.squad_units) do
        if unit.cell_id == cell_id then
            return unit
        end
    end
    return nil
end

local function get_units_on_cell(self, cell_id)
    local units = {}
    if not self.squad_units then
        return units
    end
    for _, unit in pairs(self.squad_units) do
        if unit.cell_id == cell_id then
            table.insert(units, unit)
        end
    end
    return units
end

local function get_spawn_order_unit_id_list()
    return { "sarge", "techie", "medic", "gunner" }
end

local function sort_units_by_spawn_order(units)
    local order = { sarge = 1, techie = 2, medic = 3, gunner = 4 }
    table.sort(units, function(a, b)
        return (order[a.id] or 99) < (order[b.id] or 99)
    end)
end

local function ensure_cell_slot_assignment(self, unit, cell_id)
    if not unit or not cell_id then
        return 1
    end

    self.cell_slot_assignments = self.cell_slot_assignments or {}
    self.cell_slot_assignments[cell_id] = self.cell_slot_assignments[cell_id] or {}
    local assignment = self.cell_slot_assignments[cell_id]

    if assignment[unit.id] then
        return assignment[unit.id]
    end

    local used = {}
    for _, slot_index in pairs(assignment) do
        used[slot_index] = true
    end

    local selected_slot = 1
    for i = 1, #CELL_SLOT_OFFSETS_X do
        if not used[i] then
            selected_slot = i
            break
        end
    end

    assignment[unit.id] = selected_slot
    return selected_slot
end

local function clear_cell_slot_assignment(self, unit, cell_id)
    if not unit or not cell_id or not self.cell_slot_assignments then
        return
    end
    local assignment = self.cell_slot_assignments[cell_id]
    if assignment then
        assignment[unit.id] = nil
    end
end

local function cell_has_any_unit_except(self, cell_id, except_unit_id)
    if not self.squad_units then
        return false
    end
    for _, unit in pairs(self.squad_units) do
        if unit.id ~= except_unit_id and unit.cell_id == cell_id then
            return true
        end
    end
    return false
end

local function deselect_all_units(self)
    if not self.squad_units then
        return
    end
    for _, unit in pairs(self.squad_units) do
        unit.is_selected = false
    end
end

local function any_unit_is_moving(self)
    if not self.squad_units then
        return false
    end
    for _, unit in pairs(self.squad_units) do
        if unit.is_moving then
            return true
        end
    end
    return false
end

local function unit_has_role(unit, role_key)
    if not unit then
        return false
    end
    local role = CLASS_ROLE_HOOKS[unit.class_id]
    return role and role[role_key] == true
end

local function get_unit_base_tint(unit)
    if not unit then
        return vmath.vector4(1, 1, 1, 1)
    end
    if unit.class_id == UNIT_CLASS_SARGE then
        return HUMAN_TINT_SARGE
    elseif unit.class_id == UNIT_CLASS_TECHIE then
        return HUMAN_TINT_TECHIE
    elseif unit.class_id == UNIT_CLASS_MEDIC then
        return HUMAN_TINT_MEDIC
    elseif unit.class_id == UNIT_CLASS_GUNNER then
        return HUMAN_TINT_GUNNER
    end
    return vmath.vector4(1, 1, 1, 1)
end

local function get_selected_tint(base_tint)
    return vmath.vector4(
        math.min(base_tint.x + 0.2, 1),
        math.min(base_tint.y + 0.2, 1),
        math.min(base_tint.z + 0.2, 1),
        1
    )
end

-- FUTURE GAMEPLAY HOOKS (role-gated actions)
local function can_donate_ap(unit)
    return unit_has_role(unit, "can_donate_ap")
end

local function can_fix(unit)
    return unit_has_role(unit, "can_fix")
end

local function can_heal(unit)
    return unit_has_role(unit, "can_heal")
end

local function has_heavy_weapon(unit)
    return unit_has_role(unit, "heavy_weapon")
end

local function print_squad_debug_overview(self)
    if not self.squad_units then
        return
    end

    print("=== SQUAD DEBUG (UI placeholder in console) ===")
    for _, unit in pairs(self.squad_units) do
        print(string.format(
            "  %s class=%s AP=%d/%d roles{donate=%s fix=%s heal=%s heavy=%s}",
            unit.display_name,
            unit.class_id,
            unit.current_ap,
            unit.max_ap,
            tostring(unit_has_role(unit, "can_donate_ap")),
            tostring(unit_has_role(unit, "can_fix")),
            tostring(unit_has_role(unit, "can_heal")),
            tostring(unit_has_role(unit, "heavy_weapon"))
        ))
    end
end

local function find_first_walkable_cell(world_grid)
    for cell_id, cell in ipairs(world_grid) do
        if cell.tileID ~= hash("empty") then
            return cell_id
        end
    end
    return nil
end

local function set_unit_scale(unit, scale_x, scale_y)
    if unit and unit.go_path then
        go.set_scale(vmath.vector3(scale_x, scale_y, 1), unit.go_path)
    end
end

local function update_human_visual_state(self)
    if not self.squad_units then
        return
    end

    for _, unit in pairs(self.squad_units) do
        if unit.sprite_path then
            if unit.current_ap <= 0 then
                go.set(unit.sprite_path, "tint", HUMAN_TINT_NO_AP)
            else
                local base_tint = get_unit_base_tint(unit)
                if unit.is_selected then
                    go.set(unit.sprite_path, "tint", get_selected_tint(base_tint))
                else
                    go.set(unit.sprite_path, "tint", base_tint)
                end
            end
        end
    end
end

local function update_selected_unit_pulse(self, dt)
    if not self.squad_units then
        return
    end

    for _, unit in pairs(self.squad_units) do
        if unit.go_path and not unit.is_moving then
            if unit.is_selected and unit.current_ap > 0 then
                unit.select_pulse_phase = (unit.select_pulse_phase or 0) + (dt * UNIT_SELECTED_PULSE_SPEED * math.pi * 2)
                local pulse = 1 + UNIT_SELECTED_PULSE_AMPLITUDE * math.sin(unit.select_pulse_phase)
                set_unit_scale(unit, HUMAN_VISUAL_SCALE * pulse, HUMAN_VISUAL_SCALE * pulse)
            else
                unit.select_pulse_phase = 0
                set_unit_scale(unit, HUMAN_VISUAL_SCALE, HUMAN_VISUAL_SCALE)
            end
        end
    end
end

local function create_ui_square(screen_x, screen_y, z, color, scale_x, scale_y)
    local pos = vmath.vector3(screen_x, screen_y, z)
    local id = factory.create("/ui_factory#ui_factory", pos)
    if id then
        go.set_scale(vmath.vector3(scale_x, scale_y, 1), id)
        go.set(msg.url(nil, id, "sprite"), "tint", color)
    end
    return id
end

local function create_ui_panel_sprite(screen_x, screen_y, z, scale_x, scale_y)
    local pos = vmath.vector3(screen_x, screen_y, z)
    local id = factory.create("/ui_panel_factory#ui_panel_factory", pos)
    if id then
        go.set_scale(vmath.vector3(scale_x, scale_y, 1), id)
    end
    return id
end

local function set_ui_square_transform(self, go_id, screen_x, screen_y, z, color, scale_x, scale_y)
    if not go_id then
        return
    end
    local wx, wy = screen_to_world(screen_x, screen_y, self.camera_pos, self.camera_zoom)
    go.set_position(vmath.vector3(wx, wy, z), go_id)
    go.set_scale(vmath.vector3(scale_x / self.camera_zoom, scale_y / self.camera_zoom, 1), go_id)
    go.set(msg.url(nil, go_id, "sprite"), "tint", color)
end

local function set_ui_panel_transform(self, go_id, screen_x, screen_y, z, scale_x, scale_y)
    if not go_id then
        return
    end
    local wx, wy = screen_to_world(screen_x, screen_y, self.camera_pos, self.camera_zoom)
    local sx = (scale_x / UI_PANEL_ART_W) / self.camera_zoom
    local sy = (scale_y / UI_PANEL_ART_H) / self.camera_zoom
    go.set_position(vmath.vector3(wx, wy, z), go_id)
    go.set_scale(vmath.vector3(sx, sy, 1), go_id)
    go.set(msg.url(nil, go_id, "sprite"), "tint", vmath.vector4(1, 1, 1, 1))
end

local function initialize_unit_ui(self)
    self.ui = {
        panel_art = nil,
        ap_pips = {},
        hp_pips = {},
        ammo_pips = {},
        backpack_slots = {}
    }

    self.ui.panel_art = create_ui_panel_sprite(UI_PANEL_X, UI_PANEL_Y, 0.8, UI_PANEL_W, UI_PANEL_H)

    for i = 1, UI_MAX_PIPS do
        self.ui.ap_pips[i] = create_ui_square(0, 0, 0.81, UI_COLOR_AP, UI_BAR_PIP_SIZE, UI_BAR_PIP_SIZE)
        self.ui.hp_pips[i] = create_ui_square(0, 0, 0.81, UI_COLOR_HP, UI_BAR_PIP_SIZE, UI_BAR_PIP_SIZE)
        self.ui.ammo_pips[i] = create_ui_square(0, 0, 0.81, UI_COLOR_AMMO, UI_BAR_PIP_SIZE, UI_BAR_PIP_SIZE)
    end

    for i = 1, (UI_BACKPACK_COLS * UI_BACKPACK_ROWS) do
        self.ui.backpack_slots[i] = create_ui_square(0, 0, 0.81, UI_COLOR_SLOT, UI_BACKPACK_SLOT_SIZE, UI_BACKPACK_SLOT_SIZE)
    end

    print(string.format(
        "UI panel pixels: panel=%dx%d, portrait=%dx%d, footer=%dx%d, pip=%dx%d (max %d), backpack slots=%d (%dx%d each, %dx%d grid)",
        UI_PANEL_W, UI_PANEL_H, UI_PORTRAIT_W, UI_PORTRAIT_H, UI_FOOTER_W, UI_FOOTER_H,
        UI_BAR_PIP_SIZE, UI_BAR_PIP_SIZE, UI_MAX_PIPS, UI_BACKPACK_COLS * UI_BACKPACK_ROWS,
        UI_BACKPACK_SLOT_SIZE, UI_BACKPACK_SLOT_SIZE, UI_BACKPACK_COLS, UI_BACKPACK_ROWS
    ))
end

local function set_ui_hidden(self)
    if not self.ui then
        return
    end

    local hidden = vmath.vector4(0, 0, 0, 0)
    set_ui_panel_transform(self, self.ui.panel_art, -9999, -9999, 0.8, UI_PANEL_W, UI_PANEL_H)
    for i = 1, UI_MAX_PIPS do
        set_ui_square_transform(self, self.ui.ap_pips[i], -9999, -9999, 0.81, hidden, UI_BAR_PIP_SIZE, UI_BAR_PIP_SIZE)
        set_ui_square_transform(self, self.ui.hp_pips[i], -9999, -9999, 0.81, hidden, UI_BAR_PIP_SIZE, UI_BAR_PIP_SIZE)
        set_ui_square_transform(self, self.ui.ammo_pips[i], -9999, -9999, 0.81, hidden, UI_BAR_PIP_SIZE, UI_BAR_PIP_SIZE)
    end
    for i = 1, (UI_BACKPACK_COLS * UI_BACKPACK_ROWS) do
        set_ui_square_transform(self, self.ui.backpack_slots[i], -9999, -9999, 0.81, hidden, UI_BACKPACK_SLOT_SIZE, UI_BACKPACK_SLOT_SIZE)
    end
end

local function get_selected_unit(self)
    if not self.squad_units then
        return nil
    end
    for _, unit in pairs(self.squad_units) do
        if unit.is_selected then
            return unit
        end
    end
    return nil
end

local function update_selected_unit_ui(self)
    local unit = get_selected_unit(self)
    if not unit or not self.ui then
        set_ui_hidden(self)
        return
    end

    set_ui_panel_transform(self, self.ui.panel_art, UI_PANEL_X, UI_PANEL_Y, 0.8, UI_PANEL_W, UI_PANEL_H)

    for i = 1, UI_MAX_PIPS do
        local pip_y = UI_BAR_START_Y - (i - 1) * (UI_BAR_PIP_SIZE + UI_BAR_PIP_GAP)
        local ap_count = math.min(unit.current_ap or 0, UI_MAX_PIPS)
        local hp_count = math.min(unit.current_health or 0, UI_MAX_PIPS)
        local ammo_count = math.min(unit.current_ammo or 0, UI_MAX_PIPS)
        -- Count "down": higher pips drain first as values decrease.
        local ap_on = i > (UI_MAX_PIPS - ap_count)
        local hp_on = i > (UI_MAX_PIPS - hp_count)
        local ammo_on = i > (UI_MAX_PIPS - ammo_count)
        local ap_color = ap_on and UI_COLOR_AP or vmath.vector4(UI_COLOR_AP.x, UI_COLOR_AP.y, UI_COLOR_AP.z, 0.2)
        local hp_color = hp_on and UI_COLOR_HP or vmath.vector4(UI_COLOR_HP.x, UI_COLOR_HP.y, UI_COLOR_HP.z, 0.2)
        local ammo_color = ammo_on and UI_COLOR_AMMO or vmath.vector4(UI_COLOR_AMMO.x, UI_COLOR_AMMO.y, UI_COLOR_AMMO.z, 0.2)

        set_ui_square_transform(self, self.ui.ap_pips[i], UI_BAR_AP_X, pip_y, 0.81, ap_color, UI_BAR_PIP_SIZE, UI_BAR_PIP_SIZE)
        set_ui_square_transform(self, self.ui.hp_pips[i], UI_BAR_HP_X, pip_y, 0.81, hp_color, UI_BAR_PIP_SIZE, UI_BAR_PIP_SIZE)
        set_ui_square_transform(self, self.ui.ammo_pips[i], UI_BAR_AMMO_X, pip_y, 0.81, ammo_color, UI_BAR_PIP_SIZE, UI_BAR_PIP_SIZE)
    end

    local total_slots = UI_BACKPACK_COLS * UI_BACKPACK_ROWS
    for i = 1, total_slots do
        local col = (i - 1) % UI_BACKPACK_COLS
        local row = math.floor((i - 1) / UI_BACKPACK_COLS)
        local slot_x = UI_BACKPACK_START_X + col * (UI_BACKPACK_SLOT_SIZE + UI_BACKPACK_SLOT_GAP)
        local slot_y = UI_BACKPACK_START_Y - row * (UI_BACKPACK_SLOT_SIZE + UI_BACKPACK_SLOT_GAP)
        local slot_color = (i <= unit.backpack_used) and UI_COLOR_SLOT_ACTIVE or UI_COLOR_SLOT
        set_ui_square_transform(self, self.ui.backpack_slots[i], slot_x, slot_y, 0.81, slot_color, UI_BACKPACK_SLOT_SIZE, UI_BACKPACK_SLOT_SIZE)
    end
end

local function is_point_in_ui_panel(screen_x, screen_y)
    local min_x = UI_PANEL_X - UI_PANEL_W * 0.5
    local max_x = UI_PANEL_X + UI_PANEL_W * 0.5
    local min_y = UI_PANEL_Y - UI_PANEL_H * 0.5
    local max_y = UI_PANEL_Y + UI_PANEL_H * 0.5
    return screen_x >= min_x and screen_x <= max_x and screen_y >= min_y and screen_y <= max_y
end

local function update_human_ap_debug_label(self)
    local unit = get_controlled_unit(self)
    if not unit then
        return
    end

    self.last_debug_ap_by_unit = self.last_debug_ap_by_unit or {}
    if self.last_debug_ap_by_unit[unit.id] ~= unit.current_ap then
        print(string.format("UI DEBUG | %s AP: %d/%d", unit.display_name, unit.current_ap, unit.max_ap))
        self.last_debug_ap_by_unit[unit.id] = unit.current_ap
    end
end

local function next_turn_reset_human_ap(self)
    if not self.squad_units then
        return
    end

    for _, unit in pairs(self.squad_units) do
        unit.current_ap = unit.max_ap
        unit.is_selected = false
    end

    -- Future hook: Sarge command points increase by 1/turn (max 10).
    local sarge = self.squad_units.sarge
    if sarge then
        sarge.command_points = math.min(sarge.max_command_points, (sarge.command_points or 0) + 1)
        print("UI DEBUG | Sarge Command Points: " .. sarge.command_points)
    end

    update_human_visual_state(self)
    update_human_ap_debug_label(self)
    print("Next turn: squad AP restored")
end

local function get_human_world_pos_for_cell(cell)
    local x, y = coords_to_world_pos(cell.xCell, cell.yCell)
    -- Keep feet near the floor: 10px above each cell's bottom boundary.
    y = y - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM
    return x, y
end

local function get_unit_world_pos_in_cell(self, unit, cell_id)
    local base_x, base_y = get_human_world_pos_for_cell(self.world_grid[cell_id])
    local slot_index = ensure_cell_slot_assignment(self, unit, cell_id)
    local slot_offset = CELL_SLOT_OFFSETS_X[slot_index] or 0
    return base_x + (slot_offset * HUMAN_STACK_SPACING_X), base_y
end

local function refresh_unit_positions_in_cell(self, cell_id)
    if not cell_id then
        return
    end
    local units_in_cell = get_units_on_cell(self, cell_id)
    sort_units_by_spawn_order(units_in_cell)
    for _, unit in ipairs(units_in_cell) do
        if unit.go_path then
            local x, y = get_unit_world_pos_in_cell(self, unit, cell_id)
            go.set_position(vmath.vector3(x, y, 0.5), unit.go_path)
        end
    end
end

local function move_human_to_cell(self, unit, cell_id)
    if not unit then
        return
    end

    local old_cell_id = unit.cell_id
    clear_cell_slot_assignment(self, unit, old_cell_id)
    if old_cell_id and self.world_grid[old_cell_id] and not cell_has_any_unit_except(self, old_cell_id, unit.id) then
        self.world_grid[old_cell_id].isOccupied = hash("empty")
    end

    unit.cell_id = cell_id
    self.world_grid[cell_id].isOccupied = unit.occupancy_hash
    ensure_cell_slot_assignment(self, unit, cell_id)

    refresh_unit_positions_in_cell(self, old_cell_id)
    refresh_unit_positions_in_cell(self, cell_id)
end

local function spawn_human_unit(self)
    if not self.squad_units then
        print("No squad units available for spawn.")
        return
    end

    local spawn_cells = {}
    for cell_id, cell in ipairs(self.world_grid) do
        if cell.tileID ~= hash("empty") then
            table.insert(spawn_cells, cell_id)
        end
    end

    if #spawn_cells < 4 then
        print("Not enough walkable cells to spawn the full squad.")
        return
    end

    self.cell_slot_assignments = {}

    local spawn_order = get_spawn_order_unit_id_list()
    for i, unit_id in ipairs(spawn_order) do
        local unit = self.squad_units[unit_id]
        if unit then
            unit.cell_id = nil
            unit.is_selected = false
            unit.is_moving = false
            unit.move_path = nil
            unit.move_path_index = 0
            unit.anim_phase = 0
            unit.current_ap = unit.max_ap

            move_human_to_cell(self, unit, spawn_cells[i])
            set_unit_scale(unit, HUMAN_VISUAL_SCALE, HUMAN_VISUAL_SCALE)
            print(unit.display_name .. " spawned on cell: " .. spawn_cells[i])
        end
    end

    update_human_visual_state(self)
    update_human_ap_debug_label(self)
end

local function begin_human_path_move(self, path)
    local unit = get_controlled_unit(self)
    if not unit then
        return
    end

    if not path or #path < 2 then
        unit.is_moving = false
        unit.move_path = nil
        unit.move_path_index = 0
        return
    end

    unit.is_moving = true
    unit.move_path = path
    unit.move_path_index = 2 -- first element is current cell
    unit.anim_phase = 0
end

local function update_single_unit_movement(self, unit, dt)
    if not unit or not unit.is_moving or not unit.move_path then
        return
    end

    local target_cell_id = unit.move_path[unit.move_path_index]
    if not target_cell_id then
        unit.is_moving = false
        unit.move_path = nil
        unit.move_path_index = 0
        set_unit_scale(unit, HUMAN_VISUAL_SCALE, HUMAN_VISUAL_SCALE)
        return
    end

    local target_x, target_y = get_unit_world_pos_in_cell(self, unit, target_cell_id)
    local target_cost = get_step_move_cost(self.world_grid, unit.cell_id, target_cell_id)
    if target_cost > unit.current_ap then
        unit.is_moving = false
        unit.move_path = nil
        unit.move_path_index = 0
        set_unit_scale(unit, HUMAN_VISUAL_SCALE, HUMAN_VISUAL_SCALE)
        print(unit.display_name .. " stopped before cell " .. target_cell_id .. " (cost " .. target_cost .. ", AP " .. unit.current_ap .. ")")
        update_human_visual_state(self)
        update_human_ap_debug_label(self)
        return
    end

    local current_pos = go.get_position(unit.go_path)
    local dx = target_x - current_pos.x
    local dy = target_y - current_pos.y
    local distance = math.sqrt(dx * dx + dy * dy)
    local step = HUMAN_MOVE_SPEED * dt

    unit.anim_phase = (unit.anim_phase or 0) + (dt * HUMAN_PINGPONG_SPEED * math.pi * 2)
    local ping = math.sin(unit.anim_phase)
    local scale_x = HUMAN_VISUAL_SCALE
    local scale_y = HUMAN_VISUAL_SCALE
    if math.abs(dx) >= math.abs(dy) then
        scale_x = HUMAN_VISUAL_SCALE * (1 + HUMAN_PINGPONG_AMPLITUDE * ping)
    else
        scale_y = HUMAN_VISUAL_SCALE * (1 + HUMAN_PINGPONG_AMPLITUDE * ping)
    end
    set_unit_scale(unit, scale_x, scale_y)

    if distance <= step then
        go.set_position(vmath.vector3(target_x, target_y, 0.5), unit.go_path)
        unit.current_ap = unit.current_ap - target_cost
        move_human_to_cell(self, unit, target_cell_id)
        update_human_ap_debug_label(self)
        unit.move_path_index = unit.move_path_index + 1

        if unit.move_path_index > #unit.move_path then
            unit.is_moving = false
            unit.move_path = nil
            unit.move_path_index = 0
            set_unit_scale(unit, HUMAN_VISUAL_SCALE, HUMAN_VISUAL_SCALE)
            print(unit.display_name .. " move complete on cell: " .. unit.cell_id)
            update_human_visual_state(self)
        end
    else
        local nx = current_pos.x + (dx / distance) * step
        local ny = current_pos.y + (dy / distance) * step
        go.set_position(vmath.vector3(nx, ny, 0.5), unit.go_path)
    end
end

local function update_human_movement(self, dt)
    if not self.squad_units then
        return
    end
    for _, unit in pairs(self.squad_units) do
        update_single_unit_movement(self, unit, dt)
    end
end

local function get_clicked_unit_in_cell(self, cell_id, world_x, world_y)
    local units_in_cell = get_units_on_cell(self, cell_id)
    if #units_in_cell == 0 then
        return nil
    end

    local best_unit = nil
    local best_dist = math.huge
    for _, unit in ipairs(units_in_cell) do
        if unit.go_path then
            local pos = go.get_position(unit.go_path)
            local dx = pos.x - world_x
            local dy = pos.y - world_y
            local dist = math.sqrt(dx * dx + dy * dy)
            if dist < best_dist then
                best_dist = dist
                best_unit = unit
            end
        end
    end

    if best_dist <= UNIT_CLICK_SELECT_RADIUS then
        return best_unit
    end
    return nil
end

local function handle_human_click_flow(self, clicked_cell_id, world_x, world_y)
    local unit = get_controlled_unit(self)
    if not unit or not unit.cell_id then
        return false
    end

    local clicked_unit = get_clicked_unit_in_cell(self, clicked_cell_id, world_x, world_y)
    if clicked_unit then
        self.ui_close_on_next_non_unit_click = false
        if clicked_unit.is_moving then
            print(clicked_unit.display_name .. " is already moving.")
            return true
        end
        if self.controlled_unit_id == clicked_unit.id and clicked_unit.is_selected then
            clicked_unit.is_selected = false
            print(clicked_unit.display_name .. " deselected.")
        else
            self.controlled_unit_id = clicked_unit.id
            deselect_all_units(self)
            clicked_unit.is_selected = true
            print(clicked_unit.display_name .. " selected. Click destination cell.")
        end
        update_human_visual_state(self)
        self.selected_start_cell = nil
        update_human_ap_debug_label(self)
        return true
    end

    unit = get_controlled_unit(self)
    if unit.is_selected and self.ui_close_on_next_non_unit_click then
        self.ui_close_on_next_non_unit_click = false
        deselect_all_units(self)
        update_human_visual_state(self)
        print("Selection cleared.")
        return true
    end

    if unit.is_selected then
        if unit.is_moving then
            print(unit.display_name .. " is already moving.")
            return true
        end
        if unit.current_ap <= 0 then
            print(unit.display_name .. " has no AP. Click next turn to refresh.")
            update_human_visual_state(self)
            return true
        end

        if not is_walkable_cell(self.world_grid, clicked_cell_id) then
            print("Destination is VOID. Choose a valid destination.")
            update_human_visual_state(self)
            return true
        end

        local path, total_cost = find_path(self.world_grid, unit.cell_id, clicked_cell_id, nil, MOVEMENT_PROFILE_HUMAN, nil)
        if path then
            print(unit.display_name .. " route selected:")
            print_path_debug(path, total_cost)
            highlight_path(self, path)
            begin_human_path_move(self, path)
        else
            print("No path found for " .. unit.display_name .. " to cell: " .. clicked_cell_id)
        end

        -- Keep panel visible after destination click; next non-unit click closes it.
        self.ui_close_on_next_non_unit_click = true
        update_human_visual_state(self)
        return true
    end

    return false
end

local function process_cell_selection(self, clicked_cell_id)
    local cell = self.world_grid[clicked_cell_id]
    if cell.tileID == hash("empty") then
        print("Clicked VOID cell. Select a valid cell.")
        return
    end

    if not self.selected_start_cell then
        clear_path_visuals(self)
        self.selected_start_cell = clicked_cell_id
        apply_cell_tint(clicked_cell_id, COLOR_START)
        table.insert(self.path_highlight_cells, clicked_cell_id)
        print("Start cell selected: " .. clicked_cell_id .. ". Click destination cell.")
    else
        local start_id = self.selected_start_cell
        local end_id = clicked_cell_id

        if start_id == end_id then
            clear_path_visuals(self)
            self.selected_start_cell = nil
            print("Selection canceled (same start/destination cell).")
            return
        end

        local path, total_cost = find_path(self.world_grid, start_id, end_id, nil)
        if path then
            print_path_debug(path, total_cost)
            highlight_path(self, path)
        else
            clear_path_visuals(self)
            apply_cell_tint(start_id, COLOR_START)
            table.insert(self.path_highlight_cells, start_id)
            apply_cell_tint(end_id, COLOR_END)
            table.insert(self.path_highlight_cells, end_id)
            print("No valid path from " .. start_id .. " to " .. end_id)
        end

        self.selected_start_cell = nil
    end
end



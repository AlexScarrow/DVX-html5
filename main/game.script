-- =============================================================================
-- ADJACENT CELL HELPERS
-- =============================================================================
--[[
    Get adjacent cell IDs using simple arithmetic:
    - Right: current_id + 1
    - Left: current_id - 1
    - Up: current_id + GRID_COLS
    - Down: current_id - GRID_COLS

    Edge cells are tracked to prevent stepping out of grid
]]

-- Edge cell lists
local LEFT_EDGE = {}
local RIGHT_EDGE = {}
local TOP_EDGE = {}
local BOTTOM_EDGE = {}

function initialize_edge_lists()
    for y = 1, GRID_ROWS do
        table.insert(LEFT_EDGE, coords_to_id(1, y))
        table.insert(RIGHT_EDGE, coords_to_id(GRID_COLS, y))
    end
    for x = 1, GRID_COLS do
        table.insert(BOTTOM_EDGE, coords_to_id(x, 1))
        table.insert(TOP_EDGE, coords_to_id(x, GRID_ROWS))
    end
end

function is_in_list(value, list) --is in one of the EDGE lists!
    for _, v in ipairs(list) do
        if v == value then
            return true
        end
    end
    return false
end

-- Get adjacent cell ID with boundary checking
function get_adjacent_cell(cell_id, direction)
    local adjacent_id = nil

    if direction == "right" then
        if is_in_list(cell_id, RIGHT_EDGE) then
            return nil  -- Can't go right from right edge
        end
        adjacent_id = cell_id + 1
    elseif direction == "left" then
        if is_in_list(cell_id, LEFT_EDGE) then
            return nil  -- Can't go left from left edge
        end
        adjacent_id = cell_id - 1
    elseif direction == "up" then
        if is_in_list(cell_id, TOP_EDGE) then
            return nil  -- Can't go up from top edge
        end
        adjacent_id = cell_id + GRID_COLS
    elseif direction == "down" then
        if is_in_list(cell_id, BOTTOM_EDGE) then
            return nil  -- Can't go down from bottom edge
        end
        adjacent_id = cell_id - GRID_COLS
    end

    return adjacent_id
end

local function get_step_move_cost(world_grid, from_cell_id, to_cell_id)
    local from_cell = world_grid[from_cell_id]
    local to_cell = world_grid[to_cell_id]
    if not from_cell or not to_cell then
        return math.huge
    end

    -- Vertical transitions are always a flat ladder cost.
    if from_cell.xCell == to_cell.xCell and from_cell.yCell ~= to_cell.yCell then
        return VERTICAL_MOVE_AP_COST
    end

    -- Horizontal transitions use destination cell's moveValue.
    return to_cell.moveValue
end

-- Get all valid adjacent cells (4-directional)
function get_neighbors(cell_id, world_grid, movement_profile, path_context)
    local neighbors = {}
    local directions = {"right", "left", "up", "down"}
    movement_profile = movement_profile or MOVEMENT_PROFILE_HUMAN

    for _, dir in ipairs(directions) do
        local adj_id = get_adjacent_cell(cell_id, dir)
        if adj_id then
            local cell = world_grid[adj_id]
            -- Check if cell is not VOID (part of a valid tile)
            if cell.tileID ~= hash("empty") then
                -- Check access permissions
                local can_access = false
                if dir == "right" and world_grid[cell_id].accessRight then
                    can_access = true
                elseif dir == "left" and cell.accessRight then
                    can_access = true
                elseif dir == "up" and world_grid[cell_id].accessDown then
                    can_access = false  -- Moving up means crossing bottom border of target
                elseif dir == "down" and cell.accessDown then
                    can_access = false  -- Moving down means crossing our bottom border
                end

                -- Actually for up/down we need to think differently
                -- Moving UP: check if current cell's TOP is open (but we store right/down only)
                -- Moving DOWN: check if current cell's accessDown
                if dir == "up" and cell.accessDown then  -- Target's bottom must be open
                    can_access = true
                elseif dir == "down" and world_grid[cell_id].accessDown then  -- Our bottom must be open
                    can_access = true
                end

                if can_access then
                    table.insert(neighbors, { id = adj_id, cost = get_step_move_cost(world_grid, cell_id, adj_id) })
                end
            end
        end
    end

    -- FUTURE HOOK (not active yet):
    -- For alien vent-capable pathfinding, append additional neighbor edges here.
    -- That lets aliens choose either:
    -- 1) regular cell-to-cell movement (already in neighbors table), or
    -- 2) vent transition edges (once implemented).
    --
    -- Example future use:
    -- if movement_profile == MOVEMENT_PROFILE_ALIEN_VENT then
    --     local vent_neighbors = get_vent_neighbors_for_path(cell_id, world_grid, path_context)
    --     for _, vent_neighbor in ipairs(vent_neighbors) do
    --         table.insert(neighbors, vent_neighbor)
    --     end
    -- end

    return neighbors
end

-- =============================================================================
-- FUTURE: VENT PATHFINDING HOOKS (SCaffold ONLY, NOT ACTIVE YET)
-- =============================================================================
--[[
    Design intent:
    - Humans use normal adjacency edges only.
    - Aliens can use normal edges + optional vent transition edges.
    - Techie can "seal" vents so alien vent graph updates dynamically.
]]

local function object_is_vent(obj)
    return obj and obj.name == hash("vent")
end

local function cell_has_active_vent(cell)
    if not cell then
        return false
    end

    local candidates = { cell.object1, cell.object2, cell.object3 }
    for _, obj in ipairs(candidates) do
        if object_is_vent(obj) then
            -- Future rule: treat sealed vents as inactive.
            -- Expected schema later: obj.isSealed == true/false
            if obj.isSealed ~= true then
                return true
            end
        end
    end

    return false
end

local function get_active_vent_cell_ids(world_grid)
    local vent_cells = {}
    for cell_id, cell in ipairs(world_grid) do
        if cell_has_active_vent(cell) then
            table.insert(vent_cells, cell_id)
        end
    end
    return vent_cells
end

local function manhattan_distance_by_id(from_id, to_id)
    local x1, y1 = id_to_coords(from_id)
    local x2, y2 = id_to_coords(to_id)
    return math.abs(x2 - x1) + math.abs(y2 - y1)
end

local function get_nearest_active_vent(from_cell_id, world_grid)
    local vents = get_active_vent_cell_ids(world_grid)
    local nearest_id = nil
    local best_dist = math.huge

    for _, vent_id in ipairs(vents) do
        if vent_id ~= from_cell_id then
            local d = manhattan_distance_by_id(from_cell_id, vent_id)
            if d < best_dist then
                best_dist = d
                nearest_id = vent_id
            end
        end
    end

    return nearest_id
end

local function get_vent_neighbors_for_path(cell_id, world_grid, path_context)
    -- Placeholder only; intentionally returns no extra neighbors for now.
    -- Later this should return entries shaped like:
    --   { id = <target_cell_id>, cost = <vent_travel_cost> }
    -- and be appended inside get_neighbors() for alien movement profile.
    --
    -- Suggested future behavior:
    -- - If current cell has active vent, allow jump to nearest active vent.
    -- - If multiple vent choices are desired, return more than one edge.
    -- - Respect sealed-vent state (Techie interaction) dynamically.
    return {}
end


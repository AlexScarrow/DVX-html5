            table.insert(events, multiplayer_transport_emit_event(self, "command_rejected", {
                command_type = "toggle_door",
                reason = "door_not_functional"
            }))
            return events
        end
        local desired_open = payload.is_open == true
        door_obj.isOpen = desired_open
        local ap_after = math.max(0, (tonumber(unit.current_ap or 0) or 0) - door_ap_cost)
        table.insert(events, multiplayer_transport_emit_event(self, "toggle_door_applied", {
            unit_id = unit_id,
            object_id = object_id,

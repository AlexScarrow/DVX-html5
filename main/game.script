        end
        if crate_object_id > 0 and (crate_obj.objectId or 0) ~= crate_object_id then
            table.insert(events, multiplayer_transport_emit_event(self, "command_rejected", {
                command_type = "scavenge_crate",
                reason = "stale_crate_object_id"
            }))
            return events
        end
        table.insert(events, multiplayer_transport_emit_event(self, "scavenge_crate_applied", {
            unit_id = unit_id,
            cell_id = cell_id,
            crate_object_id = crate_obj.objectId or crate_object_id
        }))
        return events
    end

    table.insert(events, multiplayer_transport_emit_event(self, "command_rejected", {
        command_type = tostring(cmd_type or "unknown"),
        reason = "unsupported_command"
    }))
    return events
end

multiplayer_transport_on_event = function(self, event)
    if not (self.mp_state and self.mp_state.enabled and event and type(event) == "table") then
        return
    end
    local event_id = event.event_id
    multiplayer_sync_trace(
        self,
        "recv_event",
        string.format(
            "type=%s id=%s sender=%s payload_turn=%s",
            tostring(event.type),
            tostring(event_id or "-"),
            tostring(event.sender_player_id or "-"),
            tostring(event.payload and event.payload.turn_id or "-")
        )
    )
    if event_id and event_id ~= "" then
        self.mp_state.seen_event_ids = self.mp_state.seen_event_ids or {}
        if self.mp_state.seen_event_ids[event_id] == true then
            multiplayer_sync_trace(self, "drop_event_duplicate", string.format("id=%s type=%s", tostring(event_id), tostring(event.type)))
            return
        end
        self.mp_state.seen_event_ids[event_id] = true
    end
    if event.type == "ready_state_changed" then
        local player_id = event.payload and event.payload.player_id or nil
        if player_id then
            local ready_on = event.payload.ready == true
            self.mp_state.ready_by_player_id[player_id] = ready_on
            print(string.format(
                "MP READY | %s | player_id=%s | turn_id=%d",
                ready_on and "ready_on" or "ready_off",
                tostring(player_id),
                self.mp_state.turn_id or 1
            ))
        end
        return
    end
    if event.type == "turn_advanced" then
        print(string.format("MP TURN | request_accepted | next_turn_id=%d", (event.payload and event.payload.turn_id) or 0))
        if self.mp_state and self.mp_state.local_player_id ~= self.mp_state.host_player_id then
            -- Non-host does an AP/UI turn reset and waits for host-broadcast turn_state_snapshot.
            local requested_turn_id = tonumber(event.payload and event.payload.turn_id or 0) or ((self.mp_state.turn_id or 1) + 1)
            self.mp_state.awaiting_snapshot = false
            self.mp_state.snapshot_blocking = false
            self.mp_state.awaiting_snapshot_timeout_s = 0
            self.mp_state.expected_snapshot_turn_id = requested_turn_id
            self.mp_state.post_turn_snapshot_delay_s = 0
            msg.post(".", "next_turn", { from_mp_turn_advanced = true, skip_authoritative_sim = true })
            print(string.format("MP TURNSTATE | awaiting_host_broadcast | turn_id=%d", requested_turn_id))
        else
            msg.post(".", "next_turn", { from_mp_turn_advanced = true })
        end
        return
    end
    if event.type == "turn_state_snapshot" then
        local sender_player_id = event.sender_player_id or nil
        if self.mp_state.local_player_id == self.mp_state.host_player_id
            and sender_player_id == self.mp_state.host_player_id
        then
            return
        end
        local payload_turn_id = tonumber(event.payload and event.payload.turn_id or 0) or 0
        local expected_turn_id = tonumber(self.mp_state and self.mp_state.expected_snapshot_turn_id or 0) or 0
        local snapshot = event.payload and event.payload.snapshot or nil
        local snapshot_turn_id = tonumber(snapshot and snapshot.turn_id or 0) or payload_turn_id
        if expected_turn_id > 0 and snapshot_turn_id > 0 and snapshot_turn_id < expected_turn_id then
            print(string.format(
                "MP TURNSTATE | stale_ignored | snapshot_turn=%d expected_turn=%d",
                snapshot_turn_id,
                expected_turn_id
            ))
            return
        end
        if not multiplayer_apply_snapshot_state(self, snapshot) then
            print("MP TURNSTATE | apply_failed")
            return
        end
        self.mp_state.awaiting_snapshot = false
        self.mp_state.snapshot_blocking = false
        self.mp_state.awaiting_snapshot_timeout_s = 0
        self.mp_state.expected_snapshot_turn_id = 0
        self.mp_state.last_snapshot_retry_turn_id = 0
        print(string.format(
            "MP TURNSTATE | applied | turn_id=%d level=%d",
            self.mp_state.turn_id or 1,
            self.current_level_index or 0
        ))
        self.mp_state.turn_based_heartbeat_mismatch_streak = 0
        self.mp_state.turn_based_heartbeat_last_request_turn_id = 0
        return
    end
    if event.type == "turn_state_heartbeat" then
        if not (self.mp_state and self.mp_state.enabled) then
            return
        end
        local sender_player_id = event.sender_player_id or nil
        if sender_player_id ~= self.mp_state.host_player_id then
            return
        end
        if self.mp_state.local_player_id == self.mp_state.host_player_id then
            return
        end
        if self.realtime_rules_enabled == true then
            self.mp_state.turn_based_heartbeat_mismatch_streak = 0
            return
        end
        local payload = event.payload or {}
        local host_turn_id = tonumber(payload.turn_id or 0) or 0
        local local_turn_id = tonumber(self.mp_state.turn_id or 0) or 0
        if host_turn_id > 0 and local_turn_id > 0 and host_turn_id ~= local_turn_id then
            self.mp_state.turn_based_heartbeat_mismatch_streak = 0
            return
        end
        local host_checksum = tostring(payload.checksum or "")
        if host_checksum == "" then
            return
        end
        local local_checksum = tostring(multiplayer_compute_turn_checksum(self))
        if local_checksum == host_checksum then
            self.mp_state.turn_based_heartbeat_mismatch_streak = 0
            return
        end
        self.mp_state.turn_based_heartbeat_mismatch_streak = (tonumber(self.mp_state.turn_based_heartbeat_mismatch_streak or 0) or 0) + 1
        local mismatch_threshold = math.max(1, tonumber(TURN_BASED_MP_HEARTBEAT_MISMATCH_THRESHOLD or 2) or 2)
        if self.mp_state.turn_based_heartbeat_mismatch_streak < mismatch_threshold then
            return
        end
        local request_turn_id = host_turn_id > 0 and host_turn_id or local_turn_id
        if self.mp_state.turn_based_heartbeat_last_request_turn_id == request_turn_id then
            return
        end
        self.mp_state.turn_based_heartbeat_last_request_turn_id = request_turn_id
        self.mp_state.turn_based_heartbeat_mismatch_streak = 0
        multiplayer_transport_send_command(self, "request_snapshot", {
            turn_id = request_turn_id,
            reason = "heartbeat_checksum_mismatch",
            expected_turn_id = request_turn_id
        }, self.mp_state.local_player_id)
        print(string.format("MP SNAPSHOT | requested_heartbeat_mismatch | turn_id=%d", request_turn_id))
        return
    end
    if event.type == "realtime_state_snapshot" then
        local sender_player_id = event.sender_player_id or nil
        if self.mp_state.local_player_id == self.mp_state.host_player_id
            and sender_player_id == self.mp_state.host_player_id
        then
            return
        end
        if not (self.mp_state and self.mp_state.enabled) then
            return
        end
        local seq = tonumber(event.payload and event.payload.seq or 0) or 0
        local last_seq = tonumber(self.mp_state.realtime_last_applied_snapshot_seq or 0) or 0
        if seq > 0 and last_seq > 0 and seq <= last_seq then
            return
        end
        local snapshot = event.payload and event.payload.snapshot or nil
        if not multiplayer_apply_realtime_snapshot_state(self, snapshot) then
            print("MP RT SNAPSHOT | apply_failed")
            return
        end
        if seq > 0 then
            self.mp_state.realtime_last_applied_snapshot_seq = seq
        end
        print(string.format("MP RT SNAPSHOT | applied | seq=%d turn_id=%d", seq, self.mp_state.turn_id or 1))
        return
    end
    if event.type == "realtime_mode_changed" then
        if not (self.mp_state and self.mp_state.enabled) then
            return
        end
        local sender_player_id = event.sender_player_id or nil
        if sender_player_id ~= self.mp_state.host_player_id then
            return
        end
        local enabled = event.payload and event.payload.enabled == true
        self.realtime_rules_enabled = enabled
        update_realtime_toggle_button_visual(self)
        self.realtime_alien_tick_accum = 0
        self.realtime_civilian_tick_accum = 0
        self.realtime_blip_spawn_accum = 0
        self.realtime_client_settle_timer = 0.4
        if self.mp_state and self.mp_state.local_player_id == self.mp_state.host_player_id then
            self.mp_state.realtime_snapshot_accum_s = 0
            self.mp_state.realtime_snapshot_heartbeat_accum_s = 0
            self.mp_state.realtime_last_sent_signature = ""
        end
        if self.mp_state and self.mp_state.local_player_id ~= self.mp_state.host_player_id then
            self.mp_state.awaiting_snapshot = false
            self.mp_state.snapshot_blocking = false
            self.mp_state.awaiting_snapshot_timeout_s = 0
            self.mp_state.expected_snapshot_turn_id = 0
            self.mp_state.post_turn_snapshot_delay_s = 0
            self.mp_state.last_snapshot_retry_turn_id = 0
            self.mp_state.realtime_last_applied_snapshot_seq = 0
        end
        print(string.format("MP RT MODE | synced_from_host | %s", enabled and "ON" or "OFF"))
        return
    end
    if event.type == "workshop_state_changed" then
        if not (self.mp_state and self.mp_state.enabled) then
            return
        end
        local sender_player_id = event.sender_player_id or nil
        if sender_player_id ~= self.mp_state.host_player_id then
            return
        end
        if self.mp_state.local_player_id == self.mp_state.host_player_id then
            return
        end
        if LOOT_RUNTIME and LOOT_RUNTIME.apply_workshop_sync_state then
            LOOT_RUNTIME.apply_workshop_sync_state(self, event.payload and event.payload.workshop_state or {})
            self.mp_state.workshop_state_sync_signature = workshop_state_signature(event.payload and event.payload.workshop_state or {})
        end
        return
    end
    if event.type == "factory_state_changed" then
        if not (self.mp_state and self.mp_state.enabled) then
            return
        end
        local sender_player_id = event.sender_player_id or nil
        if sender_player_id ~= self.mp_state.host_player_id then
            return
        end
        if self.mp_state.local_player_id == self.mp_state.host_player_id then
            return
        end
        if LOOT_RUNTIME and LOOT_RUNTIME.apply_factory_sync_state then
            LOOT_RUNTIME.apply_factory_sync_state(self, event.payload and event.payload.factory_state or {})
            self.mp_state.factory_state_sync_signature = factory_state_signature(event.payload and event.payload.factory_state or {})
        end
        return
    end
    if event.type == "factory_token_spawned" then
        if not (self.mp_state and self.mp_state.enabled) then
            return
        end
        local sender_player_id = event.sender_player_id or nil
        if sender_player_id ~= self.mp_state.host_player_id then
            return
        end
        if self.mp_state.local_player_id == self.mp_state.host_player_id then
            return
        end
        if LOOT_RUNTIME and LOOT_RUNTIME.spawn_factory_conveyor_token_visual then
            local payload = multiplayer_clone_simple_table(event.payload or {}) or {}
            payload.remote_visual_only = true
            LOOT_RUNTIME.spawn_factory_conveyor_token_visual(self, payload)
        end
        return
    end
    if event.type == "combat_fx" then
        if not (self.mp_state and self.mp_state.enabled) then
            return
        end
        local sender_player_id = event.sender_player_id or nil
        if sender_player_id ~= self.mp_state.host_player_id then
            return
        end
        if self.mp_state.local_player_id == self.mp_state.host_player_id then
            return
        end
        self.mp_state.applying_remote_event = true
        multiplayer_apply_combat_fx_event(self, event.payload or {})
        self.mp_state.applying_remote_event = false
        return
    end
    if event.type == "realtime_spitter_projectile" then
        if not (self.mp_state and self.mp_state.enabled) then
            return
        end
        local sender_player_id = event.sender_player_id or nil
        if sender_player_id ~= self.mp_state.host_player_id then
            return
        end
        if self.mp_state.local_player_id == self.mp_state.host_player_id then
            return
        end
        local from_x = tonumber(event.payload and event.payload.from_x or nil)
        local from_y = tonumber(event.payload and event.payload.from_y or nil)
        local to_x = tonumber(event.payload and event.payload.to_x or nil)
        local to_y = tonumber(event.payload and event.payload.to_y or nil)
        if not (from_x and from_y and to_x and to_y) then
            return
        end
        local projectile_id = factory.create("/ui_factory#ui_factory", vmath.vector3(from_x, from_y, 0.75))
        if not projectile_id then
            return
        end
        go.set_scale(vmath.vector3(SPITTER_PROJECTILE_SIZE * 0.2, SPITTER_PROJECTILE_SIZE * 0.2, 1), projectile_id)
        msg.post(msg.url(nil, projectile_id, "sprite"), "play_animation", { id = hash("alien_projectile_1") })
        go.set(msg.url(nil, projectile_id, "sprite"), "tint", vmath.vector4(1, 1, 1, 1))
        local dir_x = to_x - from_x
        local dir_y = to_y - from_y
        if math.abs(dir_x) > 0.01 or math.abs(dir_y) > 0.01 then
            go.set_rotation(vmath.quat_rotation_z(math.atan2(dir_y, dir_x) + math.pi), projectile_id)
        end
        self.spitter_projectiles = self.spitter_projectiles or {}
        table.insert(self.spitter_projectiles, {
            kind = "alien",
            go_id = projectile_id,
            from = vmath.vector3(from_x, from_y, 0.75),
            to = vmath.vector3(to_x, to_y, 0.75),
            t = 0
        })
        return
    end
    if event.type == "realtime_human_projectile" then
        if not (self.mp_state and self.mp_state.enabled) then
            return
        end
        local sender_player_id = event.sender_player_id or nil
        if sender_player_id ~= self.mp_state.host_player_id then
            return
        end
        if self.mp_state.local_player_id == self.mp_state.host_player_id then
            return
        end
        local from_x = tonumber(event.payload and event.payload.from_x or nil)
        local from_y = tonumber(event.payload and event.payload.from_y or nil)
        local to_x = tonumber(event.payload and event.payload.to_x or nil)
        local to_y = tonumber(event.payload and event.payload.to_y or nil)
        if not (from_x and from_y and to_x and to_y) then
            return
        end
        local projectile_id = factory.create("/ui_factory#ui_factory", vmath.vector3(from_x, from_y, 0.75))
        if not projectile_id then
            return
        end
        go.set_scale(vmath.vector3(SPITTER_PROJECTILE_SIZE * 0.2, SPITTER_PROJECTILE_SIZE * 0.2, 1), projectile_id)
        msg.post(msg.url(nil, projectile_id, "sprite"), "play_animation", { id = hash("human_projectile_1") })
        go.set(msg.url(nil, projectile_id, "sprite"), "tint", vmath.vector4(1, 1, 1, 1))
        local dir_x = to_x - from_x
        local dir_y = to_y - from_y
        if math.abs(dir_x) > 0.01 or math.abs(dir_y) > 0.01 then
            go.set_rotation(vmath.quat_rotation_z(math.atan2(dir_y, dir_x) + math.pi), projectile_id)
        end
        self.spitter_projectiles = self.spitter_projectiles or {}
        table.insert(self.spitter_projectiles, {
            kind = "human_remote",
            go_id = projectile_id,
            from = vmath.vector3(from_x, from_y, 0.75),
            to = vmath.vector3(to_x, to_y, 0.75),
            t = 0,
            speed = SPITTER_PROJECTILE_SPEED * 1.4
        })
        return
    end
    if event.type == "realtime_turret_projectile" then
        if not (self.mp_state and self.mp_state.enabled) then
            return
        end
        local sender_player_id = event.sender_player_id or nil
        if sender_player_id ~= self.mp_state.host_player_id then
            return
        end
        if self.mp_state.local_player_id == self.mp_state.host_player_id then
            return
        end
        local from_x = tonumber(event.payload and event.payload.from_x or nil)
        local from_y = tonumber(event.payload and event.payload.from_y or nil)
        local to_x = tonumber(event.payload and event.payload.to_x or nil)
        local to_y = tonumber(event.payload and event.payload.to_y or nil)
        local delay = tonumber(event.payload and event.payload.delay or 0) or 0
        if not (from_x and from_y and to_x and to_y) then
            return
        end
        local projectile_id = factory.create("/ui_factory#ui_factory", vmath.vector3(from_x, from_y, 0.76))
        if not projectile_id then
            return
        end
        go.set_scale(vmath.vector3(SPITTER_PROJECTILE_SIZE * 0.16, SPITTER_PROJECTILE_SIZE * 0.16, 1), projectile_id)
        msg.post(msg.url(nil, projectile_id, "sprite"), "play_animation", { id = hash("human_projectile_1") })
        go.set(msg.url(nil, projectile_id, "sprite"), "tint", vmath.vector4(1, 1, 1, 1))
        local dir_x = to_x - from_x
        local dir_y = to_y - from_y
        if math.abs(dir_x) > 0.001 or math.abs(dir_y) > 0.001 then
            go.set_rotation(vmath.quat_rotation_z(math.atan2(dir_y, dir_x) + math.pi), projectile_id)
        end
        self.turret_projectiles = self.turret_projectiles or {}
        table.insert(self.turret_projectiles, {
            go_id = projectile_id,
            from = vmath.vector3(from_x, from_y, 0.76),
            to = vmath.vector3(to_x, to_y, 0.76),
            t = 0,
            delay = math.max(0, delay)
        })
        return
    end
    if event.type == "turn_checksum" then
        local checksum_turn_id = tonumber(event.payload and event.payload.turn_id or 0) or 0
        local host_checksum = tostring(event.payload and event.payload.checksum or "")
        local local_turn_id = tonumber(self.mp_state and self.mp_state.turn_id or 0) or 0
        if checksum_turn_id ~= local_turn_id then
            print(string.format(
                "MP DESYNC | checksum_skipped | host_turn=%d local_turn=%d",
                checksum_turn_id,
                local_turn_id
            ))
            return
        end
        local local_checksum = multiplayer_compute_turn_checksum(self)
        if local_checksum == host_checksum then
            print(string.format("MP DESYNC | checksum_ok | turn_id=%d checksum=%s", local_turn_id, local_checksum))
            return
        end
        print(string.format(
            "MP DESYNC | checksum_mismatch | turn_id=%d host=%s local=%s",
            local_turn_id,
            host_checksum,
            local_checksum
        ))
        if self.mp_state.local_player_id ~= self.mp_state.host_player_id then
            self.mp_state.awaiting_snapshot = true
            self.mp_state.snapshot_blocking = false
            self.mp_state.awaiting_snapshot_timeout_s = 0
            self.mp_state.expected_snapshot_turn_id = tonumber(self.mp_state.turn_id or 1) or 1
            multiplayer_transport_send_command(self, "request_snapshot", {
                turn_id = self.mp_state.turn_id or 1,
                reason = "checksum_mismatch",
                host_checksum = host_checksum,
                local_checksum = local_checksum
            }, self.mp_state.local_player_id)
            print("MP SNAPSHOT | requested_checksum_mismatch")
        end
        return
    end
    if event.type == "snapshot_state" then
        local target_player_id = event.payload and event.payload.target_player_id or nil
        local local_player_id = self.mp_state and self.mp_state.local_player_id or "p1"
        if target_player_id and target_player_id ~= local_player_id then
            return
        end
        local snapshot = event.payload and event.payload.snapshot or nil
        local snapshot_turn_id = tonumber(snapshot and snapshot.turn_id or 0) or 0
        local local_turn_id = tonumber(self.mp_state and self.mp_state.turn_id or 0) or 0
        local expected_turn_id = tonumber(self.mp_state and self.mp_state.expected_snapshot_turn_id or 0) or 0
        if snapshot_turn_id > 0 and local_turn_id > 0 and snapshot_turn_id < local_turn_id then
            print(string.format(
                "MP SNAPSHOT | stale_ignored | snapshot_turn=%d local_turn=%d",
                snapshot_turn_id,
                local_turn_id
            ))
            if self.mp_state and self.mp_state.local_player_id ~= self.mp_state.host_player_id then
                local retry_turn_id = math.max(local_turn_id, expected_turn_id)
                if retry_turn_id > 0 and self.mp_state.last_snapshot_retry_turn_id ~= retry_turn_id then
                    self.mp_state.last_snapshot_retry_turn_id = retry_turn_id
                    self.mp_state.awaiting_snapshot = true
                    self.mp_state.snapshot_blocking = false
                    self.mp_state.awaiting_snapshot_timeout_s = 0
                    self.mp_state.expected_snapshot_turn_id = retry_turn_id
                    multiplayer_transport_send_command(self, "request_snapshot", {
                        turn_id = retry_turn_id,
                        reason = "stale_snapshot_retry"
                    }, self.mp_state.local_player_id)
                    print(string.format("MP SNAPSHOT | requested_stale_retry | turn_id=%d", retry_turn_id))
                end
            end
            return
        end
        if expected_turn_id > 0 and snapshot_turn_id > 0 and snapshot_turn_id < expected_turn_id then
            print(string.format(
                "MP SNAPSHOT | stale_expected_ignored | snapshot_turn=%d expected_turn=%d",
                snapshot_turn_id,
                expected_turn_id
            ))
            return
        end
        if not multiplayer_apply_snapshot_state(self, snapshot) then
            print("MP SNAPSHOT | apply_failed")
            self.mp_state.awaiting_snapshot = false
            self.mp_state.snapshot_blocking = false
            self.mp_state.awaiting_snapshot_timeout_s = 0
            self.mp_state.expected_snapshot_turn_id = 0
            return
        end
        self.mp_state.awaiting_snapshot = false
        self.mp_state.snapshot_blocking = false
        self.mp_state.awaiting_snapshot_timeout_s = 0
        self.mp_state.expected_snapshot_turn_id = 0
        self.mp_state.last_snapshot_retry_turn_id = 0
        multiplayer_drain_pending_events(self)
        print(string.format(
            "MP SNAPSHOT | applied | turn_id=%d level=%d",
            self.mp_state.turn_id or 1,
            self.current_level_index or 0
        ))
        return
    end
    if event.type == "setup_state_updated" then
        local target_player_id = event.payload and event.payload.target_player_id or nil
        local local_player_id = self.mp_state and self.mp_state.local_player_id or "p1"
        if target_player_id and target_player_id ~= local_player_id then
            return
        end
        local config = event.payload and event.payload.session_config or nil
        if type(config) == "table" then
            multiplayer_setup_apply_session_config(self, config)
            print(string.format("MP SETUP | synced | player_count=%d", tonumber(config.player_count or 0) or 0))
        end
        return
    end
    if event.type == "match_started" then
        local config = event.payload and event.payload.session_config or nil
        if type(config) ~= "table" then
            config = multiplayer_setup_build_session_config(self)
        end
        start_multiplayer_game_flow(self, config)
        print("MP SETUP | match_started event applied.")
        return
    end
    if event.type == "move_unit_applied" then
        if self.mp_state.awaiting_snapshot and self.mp_state.snapshot_blocking == true then
            multiplayer_queue_pending_event(self, event)
            return
        end
        multiplayer_sync_trace(self, "apply_event_begin", "type=move_unit_applied")
        if not multiplayer_apply_move_unit_event(self, event.payload or {}) then
            print("MP COMMAND | move_unit_applied ignored.")
            multiplayer_sync_trace(self, "apply_event_end", "type=move_unit_applied ok=false")
        else
            multiplayer_sync_trace(self, "apply_event_end", "type=move_unit_applied ok=true")
        end
        return
    end
    if event.type == "manual_shot_applied" then
        if self.mp_state.awaiting_snapshot and self.mp_state.snapshot_blocking == true then
            multiplayer_queue_pending_event(self, event)
            return
        end
        multiplayer_sync_trace(self, "apply_event_begin", "type=manual_shot_applied")
        if not multiplayer_apply_manual_shot_event(self, event.payload or {}) then
            print("MP COMMAND | manual_shot_applied ignored.")
            multiplayer_sync_trace(self, "apply_event_end", "type=manual_shot_applied ok=false")
        else
            multiplayer_sync_trace(self, "apply_event_end", "type=manual_shot_applied ok=true")
        end
        return
    end
    if event.type == "comms_command_applied" then
        if self.mp_state.awaiting_snapshot and self.mp_state.snapshot_blocking == true then
            multiplayer_queue_pending_event(self, event)
            return
        end
        if not multiplayer_apply_comms_command_event(self, event.payload or {}) then
            print("MP COMMAND | comms_command_applied ignored.")
        end
        return
    end
    if event.type == "set_reactive_fire_applied" then
        if self.mp_state.awaiting_snapshot and self.mp_state.snapshot_blocking == true then
            multiplayer_queue_pending_event(self, event)
            return
        end
        if not multiplayer_apply_set_reactive_fire_event(self, event.payload or {}) then
            print("MP COMMAND | set_reactive_fire_applied ignored.")
        end
        return
    end
    if event.type == "resource_drag_applied" then
        if self.mp_state.awaiting_snapshot and self.mp_state.snapshot_blocking == true then
            multiplayer_queue_pending_event(self, event)
            return
        end
        multiplayer_sync_trace(self, "apply_event_begin", "type=resource_drag_applied")
        self.mp_state.applying_remote_event = true
        local ok = multiplayer_apply_resource_drag_event(self, event.payload or {})
        self.mp_state.applying_remote_event = false
        if not ok then
            print("MP COMMAND | resource_drag_applied ignored.")
            multiplayer_sync_trace(self, "apply_event_end", "type=resource_drag_applied ok=false")
        else
            multiplayer_sync_trace(self, "apply_event_end", "type=resource_drag_applied ok=true")
        end
        return
    end
    if event.type == "pickup_obstacle_applied" then
        if self.mp_state.awaiting_snapshot and self.mp_state.snapshot_blocking == true then
            multiplayer_queue_pending_event(self, event)
            return
        end
        if not multiplayer_apply_pickup_obstacle_event(self, event.payload or {}) then
            print("MP COMMAND | pickup_obstacle_applied ignored.")
        end
        return
    end
    if event.type == "pickup_corpse_applied" then
        if self.mp_state.awaiting_snapshot and self.mp_state.snapshot_blocking == true then
            multiplayer_queue_pending_event(self, event)
            return
        end
        if not multiplayer_apply_pickup_corpse_event(self, event.payload or {}) then
            print("MP COMMAND | pickup_corpse_applied ignored.")
        end
        return
    end
    if event.type == "pickup_turret_applied" then
        if self.mp_state.awaiting_snapshot and self.mp_state.snapshot_blocking == true then
            multiplayer_queue_pending_event(self, event)
            return
        end
        multiplayer_sync_trace(self, "apply_event_begin", "type=pickup_turret_applied")
        if not multiplayer_apply_pickup_turret_event(self, event.payload or {}) then
            print("MP COMMAND | pickup_turret_applied ignored.")
            multiplayer_sync_trace(self, "apply_event_end", "type=pickup_turret_applied ok=false")
        else
            multiplayer_sync_trace(self, "apply_event_end", "type=pickup_turret_applied ok=true")
        end
        return
    end
    if event.type == "workshop_select_applied" then
        if self.mp_state.awaiting_snapshot and self.mp_state.snapshot_blocking == true then
            multiplayer_queue_pending_event(self, event)
            return
        end
        if not multiplayer_apply_workshop_select_event(self, event.payload or {}) then
            print("MP COMMAND | workshop_select_applied ignored.")
        end
        return
    end
    if event.type == "supply_loader_interact_applied" then
        if self.mp_state.awaiting_snapshot and self.mp_state.snapshot_blocking == true then
            multiplayer_queue_pending_event(self, event)
            return
        end
        if not multiplayer_apply_supply_loader_interact_event(self, event.payload or {}) then
            print("MP COMMAND | supply_loader_interact_applied ignored.")
        end
        return
    end
    if event.type == "nav_computer_interact_applied" then
        if self.mp_state.awaiting_snapshot and self.mp_state.snapshot_blocking == true then
            multiplayer_queue_pending_event(self, event)
            return
        end
        if not multiplayer_apply_nav_computer_interact_event(self, event.payload or {}) then
            print("MP COMMAND | nav_computer_interact_applied ignored.")
        end
        return
    end
    if event.type == "retrieve_power_applied" then
        if self.mp_state.awaiting_snapshot and self.mp_state.snapshot_blocking == true then
            multiplayer_queue_pending_event(self, event)
            return
        end
        if not multiplayer_apply_retrieve_power_event(self, event.payload or {}) then
            print("MP COMMAND | retrieve_power_applied ignored.")
        end
        return
    end
    if event.type == "retrieve_world_item_applied" then
        if self.mp_state.awaiting_snapshot and self.mp_state.snapshot_blocking == true then
            multiplayer_queue_pending_event(self, event)
            return
        end
        if not multiplayer_apply_retrieve_world_item_event(self, event.payload or {}) then
            print("MP COMMAND | retrieve_world_item_applied ignored.")
        end
        return
    end
    if event.type == "toggle_door_applied" then
        if self.mp_state.awaiting_snapshot and self.mp_state.snapshot_blocking == true then
            multiplayer_queue_pending_event(self, event)
            return
        end
        multiplayer_sync_trace(self, "apply_event_begin", "type=toggle_door_applied")
        if not multiplayer_apply_toggle_door_event(self, event.payload or {}) then
            print("MP COMMAND | toggle_door_applied ignored.")
            multiplayer_sync_trace(self, "apply_event_end", "type=toggle_door_applied ok=false")
        else
            multiplayer_sync_trace(self, "apply_event_end", "type=toggle_door_applied ok=true")
        end
        return
    end
    if event.type == "scavenge_crate_applied" then
        if self.mp_state.awaiting_snapshot and self.mp_state.snapshot_blocking == true then
            multiplayer_queue_pending_event(self, event)
            return
        end
        multiplayer_sync_trace(self, "apply_event_begin", "type=scavenge_crate_applied")
        if not multiplayer_apply_scavenge_crate_event(self, event.payload or {}) then
            print("MP COMMAND | scavenge_crate_applied ignored.")
            multiplayer_sync_trace(self, "apply_event_end", "type=scavenge_crate_applied ok=false")
        else
            multiplayer_sync_trace(self, "apply_event_end", "type=scavenge_crate_applied ok=true")
        end
        return
    end
    if event.type == "command_rejected" then
        local reason = event.payload and event.payload.reason or "unknown"
        local cmd = event.payload and event.payload.command_type or "unknown"
        print(string.format("MP COMMAND | rejected | type=%s reason=%s", tostring(cmd), tostring(reason)))
        if cmd == "manual_shot"
            and reason == "invalid_target"
            and self.mp_state
            and self.mp_state.enabled
            and self.mp_state.local_player_id ~= self.mp_state.host_player_id
        then
            local current_turn_id = tonumber(self.mp_state.turn_id or 1) or 1
            if self.mp_state.last_invalid_target_snapshot_turn_id ~= current_turn_id then
                self.mp_state.last_invalid_target_snapshot_turn_id = current_turn_id
                multiplayer_transport_send_command(self, "request_snapshot", {
                    turn_id = current_turn_id,
                    reason = "manual_shot_invalid_target",
                    expected_turn_id = current_turn_id
                }, self.mp_state.local_player_id)
                print(string.format("MP SNAPSHOT | requested_manual_shot_invalid_target | turn_id=%d", current_turn_id))
            end
        end
        return
    end
    if event.type == "joined_room" then
        self.mp_state.seen_command_ids = {}
        self.mp_state.seen_event_ids = {}
        self.mp_state.event_seq = 0
        self.mp_state.pending_turn_state_snapshot_turn_id = 0
        self.mp_state.last_turn_state_snapshot_broadcast_turn_id = 0
        self.mp_state.connected_players = {}
        local players = event.payload and event.payload.players or {}
        for _, player_id in ipairs(players) do
            self.mp_state.connected_players[player_id] = true
        end
        self.mp_state.connected_players[self.mp_state.local_player_id or "p1"] = true
        local count = 0
        for _, _ in pairs(self.mp_state.connected_players) do
            count = count + 1
        end
        print(string.format("MP NET | joined_room | room_id=%s connected_players=%d", tostring(event.payload and event.payload.room_id or "unknown"), count))
        local is_local_host = (self.mp_state.local_player_id == self.mp_state.host_player_id)
        if is_local_host then
            multiplayer_setup_push_state(self)
        else
            multiplayer_transport_send_command(self, "request_setup_state", {}, self.mp_state.local_player_id)
            print("MP SETUP | requested_from_host")
        end
        if not is_local_host then
            self.mp_state.awaiting_snapshot = true
            self.mp_state.snapshot_blocking = true
            self.mp_state.expected_snapshot_turn_id = tonumber(self.mp_state.turn_id or 1) or 1
            multiplayer_transport_send_command(self, "request_snapshot", {
                turn_id = self.mp_state.turn_id or 1
            }, self.mp_state.local_player_id)
            print("MP SNAPSHOT | requested_from_host")
        end
        return
    end
    if event.type == "player_joined" then
        local player_id = event.payload and event.payload.player_id or nil
        if player_id then
            self.mp_state.connected_players = self.mp_state.connected_players or {}
            self.mp_state.connected_players[player_id] = true
            print(string.format("MP NET | player_joined | player_id=%s", tostring(player_id)))
            if self.mp_state.local_player_id == self.mp_state.host_player_id then
                multiplayer_setup_push_state(self)
            end
        end
        return
    end
    if event.type == "player_left" then
        local player_id = event.payload and event.payload.player_id or nil
        if player_id and self.mp_state.connected_players then
            self.mp_state.connected_players[player_id] = nil
            print(string.format("MP NET | player_left | player_id=%s", tostring(player_id)))
        end
        return
    end
    if event.type == "hello" then
        print("MP NET | relay_hello received.")
        return
    end
    if event.type == "pong" then
        print("MP NET | relay_pong.")
        return
    end
    if event.type == "error" then
        local code = event.payload and event.payload.code or "unknown"
        local message = event.payload and event.payload.message or "unknown"
        print(string.format("MP NET | relay_error | code=%s message=%s", tostring(code), tostring(message)))
        return
    end
end

multiplayer_transport_send_command = function(self, cmd_type, payload, sender_player_id)
    if not (self.mp_state and self.mp_state.enabled and self.mp_transport) then
        return
    end
    local sender = sender_player_id
    if not sender then
        sender = self.mp_state.local_player_id or "p1"
    end
    multiplayer_sync_trace(
        self,
        "send_command",
        string.format(
            "type=%s sender=%s payload_turn=%s",
            tostring(cmd_type),
            tostring(sender),
            tostring(payload and payload.turn_id or "-")
        )
    )
    self.mp_transport.send_command({
        version = 1,
        session_id = self.mp_state.session_id or "local_session",
        sender_player_id = sender,
        type = cmd_type,
        payload = payload or {}
    })
end

multiplayer_transport_broadcast_events = function(self, events)
    if not (self.mp_state and self.mp_state.enabled and self.mp_transport and type(events) == "table" and #events > 0) then
        return
    end
    if self.mp_transport.send_events then
        self.mp_transport.send_events(events)
    else
        print("MP NET | transport_missing_send_events | events_dropped")
    end
end

multiplayer_transport_broadcast_event = function(self, event_type, payload)
    if not (self.mp_state and self.mp_state.enabled) then
        return
    end
    local evt = multiplayer_transport_emit_event(self, event_type, payload or {})
    multiplayer_transport_broadcast_events(self, { evt })
end

multiplayer_transport_init = function(self)
    self.mp_transport = MP_TRANSPORT.create({
        mode = MULTIPLAYER_TRANSPORT_MODE,
        ws_url = MULTIPLAYER_TRANSPORT_WS_URL,
        ws_room_id = MULTIPLAYER_TRANSPORT_ROOM_ID,
        ws_player_id = (self.mp_state and self.mp_state.local_player_id) or "p1",
        ws_host_player_id = (self.mp_state and self.mp_state.host_player_id) or "p1",
        ws_adapter = MP_WS_ADAPTER,
        on_command = function(command)
            return multiplayer_transport_handle_command(self, command)
        end,
        on_event = function(event)
            multiplayer_transport_on_event(self, event)
        end,
        on_status = function(status, detail)
            if self.mp_state then
                self.mp_state.transport_status = status
                self.mp_state.transport_status_detail = detail or {}
            end
            print(string.format("MP NET | transport_status=%s", tostring(status)))
        end
    })
    if self.mp_transport and self.mp_transport.connect then
        self.mp_transport.connect()
    end
end

multiplayer_reset_ready_gate = function(self)
    if not (self.mp_state and self.mp_state.enabled) then
        return
    end
    self.mp_state.ready_by_player_id = {}
    for _, player_id in ipairs(self.mp_state.required_ready_player_ids or {}) do
        self.mp_state.ready_by_player_id[player_id] = false
    end
end

multiplayer_get_owned_unit_id_for_player = function(player_id)
    local defaults = multiplayer_get_default_seat_assignments(4)
    local units = defaults[player_id] or { "sarge" }
    return units[1] or "sarge"
end

multiplayer_get_runtime_local_player_id = function()
    local configured = MULTIPLAYER_LOCAL_PLAYER_ID or "p1"
    local config_override = sys.get_config and sys.get_config("multiplayer.local_player_id") or nil
    local has_explicit_override = false
    if config_override == "p1" or config_override == "p2" or config_override == "p3" or config_override == "p4" then
        configured = config_override
        has_explicit_override = true
    end
    local info = sys.get_sys_info and sys.get_sys_info() or nil
    local system_name = info and info.system_name or ""
    local is_html5_runtime = (system_name == "HTML5")
    -- Single-machine host+browser testing: if no explicit player override is set, browser defaults to p2.
    if is_html5_runtime and (not has_explicit_override) and configured == MULTIPLAYER_HOST_PLAYER_ID then
        return "p2"
    end
    return configured
end

multiplayer_get_active_player_id_for_commands = function(self)
    if not (self.mp_state and self.mp_state.enabled) then
        return "p1"
    end
    if self.mp_state.local_player_id ~= self.mp_state.host_player_id then
        return self.mp_state.local_player_id
    end
    return self.mp_state.debug_active_player_id or self.mp_state.host_player_id or "p1"
end

multiplayer_get_owned_unit_id_for_active_player = function(self)
    local player_id = multiplayer_get_active_player_id_for_commands(self)
    if self.mp_state and self.mp_state.seat_assignments and self.mp_state.seat_assignments[player_id] then
        local owned = self.mp_state.seat_assignments[player_id]
        return owned[1] or multiplayer_get_owned_unit_id_for_player(player_id)
    end
    return multiplayer_get_owned_unit_id_for_player(player_id)
end

multiplayer_can_control_unit = function(self, unit_id)
    if not (self.mp_state and self.mp_state.enabled) then
        return true
    end
    local active_player = multiplayer_get_active_player_id_for_commands(self)
    local owner = multiplayer_get_player_for_unit(self.mp_state.seat_assignments, self.mp_state.player_count or 4, unit_id)
    if not owner then
        return unit_id == multiplayer_get_owned_unit_id_for_active_player(self)
    end
    return owner == active_player
end

multiplayer_player_owns_unit = function(self, player_id, unit_id)
    if not (self and self.mp_state and self.mp_state.seat_assignments) then
        return false
    end
    local owner = multiplayer_get_player_for_unit(self.mp_state.seat_assignments, self.mp_state.player_count or 4, unit_id)
    return owner == player_id
end

multiplayer_enforce_controlled_unit = function(self, force_select)
    if not self.squad_units then
        return
    end
    local active_player = multiplayer_get_active_player_id_for_commands(self)
    local owned_units = (self.mp_state and self.mp_state.seat_assignments and self.mp_state.seat_assignments[active_player]) or { multiplayer_get_owned_unit_id_for_active_player(self) }
    local chosen_unit_id = nil
    if self.controlled_unit_id then
        for _, unit_id in ipairs(owned_units) do
            if unit_id == self.controlled_unit_id then
                chosen_unit_id = unit_id
                break
            end
        end
    end
    if not chosen_unit_id then
        for _, unit_id in ipairs(owned_units) do
            local unit = self.squad_units[unit_id]
            if unit and (unit.current_health or 0) > 0 then
                chosen_unit_id = unit_id
                break
            end
        end
    end
    if not chosen_unit_id then
        chosen_unit_id = owned_units[1]
    end
    local owned_unit = chosen_unit_id and self.squad_units[chosen_unit_id] or nil
    if not (chosen_unit_id and owned_unit) then
        return
    end
    self.controlled_unit_id = chosen_unit_id

    -- Keep selection deterministic when switching active multiplayer player:
    -- exactly one selected unit, and it must be the controlled owned unit.
    for _, unit in pairs(self.squad_units) do
        unit.is_selected = (unit.id == chosen_unit_id) and ((unit.current_health or 0) > 0) or false
    end
    self.comms_panel_open = false
    if force_select == true and (owned_unit.current_health or 0) <= 0 then
        owned_unit.is_selected = false
    end
end

init_multiplayer_runtime = function(self)
    local default_player_count = 4
    self.mp_state = {
        enabled = (MULTIPLAYER_ENABLED == true) and (self.multiplayer_mode_active == true),
        session_id = "local_session",
        host_player_id = MULTIPLAYER_HOST_PLAYER_ID,
        local_player_id = multiplayer_get_runtime_local_player_id(),
        mission_type = MISSION_TYPE_ESCAPE,
        turn_id = 1,
        player_count = default_player_count,
        required_ready_player_ids = multiplayer_get_required_ready_player_ids_for_count(default_player_count),
        seat_assignments = multiplayer_get_default_seat_assignments(default_player_count),
        ready_by_player_id = {},
        connected_players = {},
        transport_status = "idle",
        transport_status_detail = {},
        debug_active_player_id = nil,
        applying_remote_event = false,
        awaiting_snapshot = false,
        snapshot_blocking = false,
        awaiting_snapshot_timeout_s = 0,
        expected_snapshot_turn_id = 0,
        last_snapshot_retry_turn_id = 0,
        last_invalid_target_snapshot_turn_id = 0,
        pending_turn_state_snapshot_turn_id = 0,
        last_turn_state_snapshot_broadcast_turn_id = 0,
        realtime_snapshot_accum_s = 0,
        realtime_snapshot_seq = 0,
        realtime_last_applied_snapshot_seq = 0,
        realtime_snapshot_heartbeat_accum_s = 0,
        turn_based_snapshot_accum_s = 0,
        turn_based_heartbeat_mismatch_streak = 0,
        turn_based_heartbeat_last_request_turn_id = 0,
        realtime_last_sent_signature = "",
        workshop_state_sync_accum_s = 0,
        workshop_state_sync_signature = "",
        factory_state_sync_accum_s = 0,
        factory_state_sync_signature = "",
        pending_events = {},
        post_turn_snapshot_delay_s = 0,
        event_seq = 0,
        seen_command_ids = {},
        seen_event_ids = {}
    }
    self.mp_state.debug_active_player_id = self.mp_state.local_player_id
    print(string.format(
        "MP NET | identity | local=%s host=%s",
        tostring(self.mp_state.local_player_id),
        tostring(self.mp_state.host_player_id)
    ))
    multiplayer_reset_ready_gate(self)
    multiplayer_transport_init(self)
end

workshop_state_signature = function(workshop_state)
    if type(workshop_state) ~= "table" then
        return ""
    end
    local tile_ids = {}
    for tile_instance_id, _ in pairs(workshop_state) do
        local tile_id = tonumber(tile_instance_id)
        if tile_id then
            table.insert(tile_ids, tile_id)
        end
    end
    table.sort(tile_ids)
    local parts = {}
    for _, tile_id in ipairs(tile_ids) do
        local state = workshop_state[tile_id] or workshop_state[tostring(tile_id)] or {}
        parts[#parts + 1] = string.format(
            "%d:%d:%d:%d:%.3f:%.3f",
            tile_id,
            tonumber(state.selected_slot or 0) or 0,
            tonumber(state.paid_units or 0) or 0,
            state.payment_locked == true and 1 or 0,
            tonumber(state.production_time_left or 0) or 0,
            tonumber(state.payment_confirm_flash or 0) or 0
        )
    end
    return table.concat(parts, "|")
end

factory_state_signature = function(factory_state)
    if type(factory_state) ~= "table" then
        return ""
    end
    local tile_ids = {}
    for tile_instance_id, _ in pairs(factory_state) do
        local tile_id = tonumber(tile_instance_id)
        if tile_id then
            table.insert(tile_ids, tile_id)
        end
    end
    table.sort(tile_ids)
    local parts = {}
    for _, tile_id in ipairs(tile_ids) do
        local state = factory_state[tile_id] or factory_state[tostring(tile_id)] or {}
        parts[#parts + 1] = string.format(
            "%d:%d:%d:%d:%d",
            tile_id,
            state.powered == true and 1 or 0,
            state.functional == true and 1 or 0,
            tonumber(state.pending_tokens or 0) or 0,
            tonumber(state.stock_total or 0) or 0
        )
    end
    return table.concat(parts, "|")
end

multiplayer_get_civilian_by_id = function(self, civilian_id)
    if not (self and self.civilians and civilian_id) then
        return nil
    end
    local wanted_id = tonumber(civilian_id)
    if not wanted_id then
        return nil
    end
    for _, civilian in ipairs(self.civilians) do
        if civilian and tonumber(civilian.id or 0) == wanted_id then
            return civilian
        end
    end
    return nil
end

multiplayer_emit_combat_fx_event = function(self, payload)
    if not (self and self.mp_state and self.mp_state.enabled) then
        return
    end
    if self.mp_state.local_player_id ~= self.mp_state.host_player_id then
        return
    end
    if self.mp_state.applying_remote_event == true then
        return
    end
    if type(payload) ~= "table" then
        return
    end
    multiplayer_transport_broadcast_event(self, "combat_fx", payload)
end

multiplayer_apply_combat_fx_event = function(self, payload)
    if type(payload) ~= "table" then
        return false
    end
    local fx_type = tostring(payload.fx_type or "")
    if fx_type == "alien_blood" then
        local alien = find_alien_by_id(self, tonumber(payload.alien_id or 0))
        if alien and (not alien.is_dead) and MELEE_RUNTIME and MELEE_RUNTIME.spawn_alien_blood_splatter_fx then
            MELEE_RUNTIME.spawn_alien_blood_splatter_fx(self, alien)
            return true
        end
        return false
    elseif fx_type == "human_blood" then
        local target_kind = tostring(payload.target_kind or "human")
        local target = nil
        if target_kind == "civilian" then
            target = multiplayer_get_civilian_by_id(self, payload.target_id)
            if target then
                target.target_kind = "civilian"
            end
        else
            target = self.squad_units and self.squad_units[payload.target_id] or nil
            if target then
                target.target_kind = "human"
            end
        end
        if target and MELEE_RUNTIME and MELEE_RUNTIME.spawn_human_blood_splatter_fx then
            MELEE_RUNTIME.spawn_human_blood_splatter_fx(self, target)
            return true
        end
        return false
    elseif fx_type == "alien_red_flash" then
        local alien = find_alien_by_id(self, tonumber(payload.alien_id or 0))
        if alien and (not alien.is_dead) and MELEE_RUNTIME and MELEE_RUNTIME.play_target_red_flash then
            MELEE_RUNTIME.play_target_red_flash(self, alien)
            return true
        end
        return false
    elseif fx_type == "alien_melee_swipe" then
        local target_kind = tostring(payload.target_kind or "human")
        local target = nil
        if target_kind == "civilian" then
            target = multiplayer_get_civilian_by_id(self, payload.target_id)
            if target then
                target.target_kind = "civilian"
            end
        else
            target = self.squad_units and self.squad_units[payload.target_id] or nil
            if target then
                target.target_kind = "human"
            end
        end
        if target and MELEE_RUNTIME and MELEE_RUNTIME.spawn_alien_melee_swipe_fx then
            MELEE_RUNTIME.spawn_alien_melee_swipe_fx(self, target)
            return true
        end
        return false
    elseif fx_type == "hazard_flash" then
        local target_kind = tostring(payload.target_kind or "human")
        local target = nil
        if target_kind == "civilian" then
            target = multiplayer_get_civilian_by_id(self, payload.target_id)
        else
            target = self.squad_units and self.squad_units[payload.target_id] or nil
        end
        if not target then
            return false
        end
        local tint = vmath.vector4(
            tonumber(payload.tint_r or 1) or 1,
            tonumber(payload.tint_g or 1) or 1,
            tonumber(payload.tint_b or 1) or 1,
            1
        )
        target.hazard_flash_tint = tint
        target.hazard_flash_active = true
        target.hazard_flash_token = (target.hazard_flash_token or 0) + 1
        local token = target.hazard_flash_token
        local duration_s = math.max(0.05, tonumber(payload.duration_s or 0.75) or 0.75)
        timer.delay(duration_s, false, function()
            if target and target.hazard_flash_token == token then
                target.hazard_flash_active = false
            end
        end)
        return true
    elseif fx_type == "brute_damage_flash" then
        local alien = find_alien_by_id(self, tonumber(payload.alien_id or 0))
        if alien and (not alien.is_dead) then
            alien.brute_damage_flash_timer = math.max(0.05, tonumber(payload.duration_s or 0.24) or 0.24)
            return true
        end
        return false
    end
    return false
end

multiplayer_queue_pending_event = function(self, event)
    if not (self and self.mp_state and event and type(event) == "table") then
        return
    end
    self.mp_state.pending_events = self.mp_state.pending_events or {}
    table.insert(self.mp_state.pending_events, multiplayer_clone_simple_table(event) or {})
end

multiplayer_drain_pending_events = function(self)
    if not (self and self.mp_state) then
        return
    end
    local pending = self.mp_state.pending_events or {}
    self.mp_state.pending_events = {}
    for _, queued_event in ipairs(pending) do
        if queued_event and queued_event.type then
            multiplayer_transport_on_event(self, queued_event)
        end
    end
end

multiplayer_on_turn_advanced = function(self)
    if not (self.mp_state and self.mp_state.enabled) then
        return
    end
    self.mp_state.turn_id = (self.mp_state.turn_id or 1) + 1
    print(string.format("MP TURN | turn_advanced | turn_id=%d", self.mp_state.turn_id))
    print(string.format(
        "XXXXXX NEW TURN!!!! TURN IS %d | local=%s host=%s",
        self.mp_state.turn_id or 1,
        tostring(self.mp_state.local_player_id or "p1"),
        tostring(self.mp_state.host_player_id or "p1")
    ))
    multiplayer_reset_ready_gate(self)
end

can_advance_next_turn = function(self, emit_log)
    if not (self.mp_state and self.mp_state.enabled) then
        return true
    end
    if self.mp_state.local_player_id ~= self.mp_state.host_player_id then
        if emit_log then
            print("MP TURN | turn_advance_blocked | reason=not_host")
        end
        return false
    end
    for _, player_id in ipairs(self.mp_state.required_ready_player_ids or {}) do
        if self.mp_state.ready_by_player_id[player_id] ~= true then
            if emit_log then
                print(string.format("MP TURN | turn_advance_blocked | reason=ready_gate_not_satisfied | missing_player=%s", tostring(player_id)))
            end
            return false
        end
    end
    return true
end

try_multiplayer_ready_buttons = function(self, screen_x, screen_y)
    if not (self.mp_state and self.mp_state.enabled) then
        return false
    end
    if self.mp_state.local_player_id == self.mp_state.host_player_id then
        return false
    end
    if not is_point_in_screen_rect(screen_x, screen_y, NEW_TURN_BUTTON_X, NEW_TURN_BUTTON_Y, NEW_TURN_BUTTON_W, NEW_TURN_BUTTON_H) then
        return false
    end
    local player_id = self.mp_state.local_player_id
    local ready_on = not (self.mp_state.ready_by_player_id[player_id] == true)
    multiplayer_transport_send_command(self, "set_ready", {
        player_id = player_id,
        ready = ready_on,
        turn_id = self.mp_state.turn_id or 1
    }, player_id)
    return true
end

try_multiplayer_debug_player_buttons = function(self, screen_x, screen_y)
    if not (self.mp_state and self.mp_state.enabled and self.ui and self.ui.mp_debug_player_buttons) then
        return false
    end
    if self.mp_state.local_player_id ~= self.mp_state.host_player_id then
        return false
    end
    for i, player_id in ipairs(self.mp_state.required_ready_player_ids or {}) do
        local remote_connected = (player_id ~= self.mp_state.host_player_id)
            and self.mp_state.connected_players
            and self.mp_state.connected_players[player_id] == true
        local by = MULTIPLAYER_DEBUG_BUTTON_START_Y - ((i - 1) * MULTIPLAYER_DEBUG_BUTTON_Y_GAP)
        if is_point_in_screen_rect(
            screen_x,
            screen_y,
            MULTIPLAYER_DEBUG_BUTTON_X,
            by,
            MULTIPLAYER_DEBUG_BUTTON_HIT_SIZE,
            MULTIPLAYER_DEBUG_BUTTON_HIT_SIZE
        ) then
            if remote_connected then
                print(string.format("MP DEBUG | blocked | real player connected for %s", tostring(player_id)))
                return true
            end
            self.mp_state.debug_active_player_id = player_id
            multiplayer_enforce_controlled_unit(self, true)
            update_human_visual_state(self)
            update_selected_unit_ui(self)
            print(string.format("MP DEBUG | acting_as=%s", tostring(player_id)))
            return true
        end
    end
    return false
end

function try_launch_button(self, screen_x, screen_y)
    if (self.game_flow_state or FLOW_STATE_GAME) ~= FLOW_STATE_GAME then
        return false
    end
    local half_w = LAUNCH_BUTTON_W * 0.5
    local half_h = LAUNCH_BUTTON_H * 0.5
    if screen_x >= (LAUNCH_BUTTON_X - half_w)
        and screen_x <= (LAUNCH_BUTTON_X + half_w)
        and screen_y >= (LAUNCH_BUTTON_Y - half_h)
        and screen_y <= (LAUNCH_BUTTON_Y + half_h) then
        if self.mp_state and self.mp_state.enabled and self.mp_state.local_player_id ~= self.mp_state.host_player_id then
            print("Launch is host-only in multiplayer.")
            return true
        end
        if LOOT_RUNTIME.try_launch_escape_pod then
            local launched = LOOT_RUNTIME.try_launch_escape_pod(self)
            if launched then
                enter_outro_flow_from_launch(self)
            end
        end
        return true
    end
    return false
end

local function try_toggle_realtime_button(self, screen_x, screen_y)
    if (self.game_flow_state or FLOW_STATE_GAME) ~= FLOW_STATE_GAME then
        return false
    end
    local half_w = REALTIME_TOGGLE_BUTTON_W * 0.5
    local half_h = REALTIME_TOGGLE_BUTTON_H * 0.5
    if screen_x >= (REALTIME_TOGGLE_BUTTON_X - half_w)
        and screen_x <= (REALTIME_TOGGLE_BUTTON_X + half_w)
        and screen_y >= (REALTIME_TOGGLE_BUTTON_Y - half_h)
        and screen_y <= (REALTIME_TOGGLE_BUTTON_Y + half_h) then
        if self.mp_state and self.mp_state.enabled then
            if self.realtime_mp_enabled ~= true then
                print("Realtime multiplayer is disabled in config.")
                return true
            end
            if self.mp_state.local_player_id ~= self.mp_state.host_player_id then
                print("Realtime toggle is host-only in multiplayer.")
                return true
            end
        end
        self.realtime_rules_enabled = not (self.realtime_rules_enabled == true)
        update_realtime_toggle_button_visual(self)
        self.realtime_alien_tick_accum = 0
        self.realtime_civilian_tick_accum = 0
        self.realtime_blip_spawn_accum = 0
        if self.mp_state and self.mp_state.enabled and self.mp_state.local_player_id == self.mp_state.host_player_id then
            multiplayer_transport_broadcast_event(self, "realtime_mode_changed", {
                enabled = self.realtime_rules_enabled == true,
                turn_id = self.mp_state.turn_id or 1
            })
        end
        print(string.format("Realtime rules: %s", self.realtime_rules_enabled and "ON" or "OFF"))
        return true
    end
    return false
end

local function try_toggle_objective_button(self, screen_x, screen_y)
    if (self.game_flow_state or FLOW_STATE_GAME) ~= FLOW_STATE_GAME then
        return false
    end
    if is_point_in_screen_rect(screen_x, screen_y, OBJECTIVE_BUTTON_X, OBJECTIVE_BUTTON_Y, OBJECTIVE_BUTTON_W, OBJECTIVE_BUTTON_H) then
        self.objective_reminder_visible = not (self.objective_reminder_visible == true)
        return true
    end
    return false
end

realtime_mp_host_can_simulate = function(self)
    if not (self and self.realtime_rules_enabled == true) then
        return false
    end
    if not self.mp_state or self.mp_state.enabled ~= true then
        return true
    end
    if self.realtime_mp_enabled ~= true then
        return false
    end
    return self.mp_state.local_player_id == self.mp_state.host_player_id
end

function try_toggle_aesthetic_ui_button(self, screen_x, screen_y)
    local half_w = AESTHETIC_BUTTON_W * 0.5
    local half_h = AESTHETIC_BUTTON_H * 0.5
    if screen_x >= (AESTHETIC_BUTTON_X - half_w)
        and screen_x <= (AESTHETIC_BUTTON_X + half_w)
        and screen_y >= (AESTHETIC_BUTTON_Y - half_h)
        and screen_y <= (AESTHETIC_BUTTON_Y + half_h) then
        toggle_aesthetic_mode(self)
        return true
    end
    return false
end

function try_zoom_in_button(self, screen_x, screen_y)
    local half_w = ZOOM_IN_BUTTON_W * 0.5
    local half_h = ZOOM_IN_BUTTON_H * 0.5
    if screen_x >= (ZOOM_IN_BUTTON_X - half_w)
        and screen_x <= (ZOOM_IN_BUTTON_X + half_w)
        and screen_y >= (ZOOM_IN_BUTTON_Y - half_h)
        and screen_y <= (ZOOM_IN_BUTTON_Y + half_h) then
        request_zoom_delta(self, 0.12, screen_x, screen_y)
        return true
    end
    return false
end

function try_zoom_out_button(self, screen_x, screen_y)
    local half_w = ZOOM_OUT_BUTTON_W * 0.5
    local half_h = ZOOM_OUT_BUTTON_H * 0.5
    if screen_x >= (ZOOM_OUT_BUTTON_X - half_w)
        and screen_x <= (ZOOM_OUT_BUTTON_X + half_w)
        and screen_y >= (ZOOM_OUT_BUTTON_Y - half_h)
        and screen_y <= (ZOOM_OUT_BUTTON_Y + half_h) then
        request_zoom_delta(self, -0.12, screen_x, screen_y)
        return true
    end
    return false
end


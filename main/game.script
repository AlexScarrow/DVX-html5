local function try_manual_human_shot(self, unit, clicked_cell_id, world_x, world_y)
    if not unit or not unit.is_selected then
        return false
    end
    if not (unit and (unit.current_health or 0) > 0) then
        print("Unable to fire: selected unit is dead.")
        return true
    end

    local alien = get_clicked_alien_in_cell(self, clicked_cell_id, world_x, world_y)
    if not alien then
        return false
    end
    if self.mp_state and self.mp_state.enabled then
        multiplayer_transport_send_command(self, "manual_shot", {
            turn_id = self.mp_state.turn_id or 1,
            unit_id = unit.id,
            alien_id = alien.id
        }, multiplayer_get_active_player_id_for_commands(self))
        return true
    end
    return multiplayer_attempt_manual_shot_on_target(self, unit, alien)
end

local function handle_human_click_flow(self, clicked_cell_id, world_x, world_y)
    local unit = get_controlled_unit(self)
    if not unit or not unit.cell_id then
        return false
    end

    local clicked_unit = get_clicked_unit_in_cell(self, clicked_cell_id, world_x, world_y)
    if clicked_unit then
        if not multiplayer_can_control_unit(self, clicked_unit.id) then
            print(string.format(
                "MP CONTROL | blocked | acting_as=%s unit=%s",
                tostring(multiplayer_get_active_player_id_for_commands(self)),
                tostring(clicked_unit.id)
            ))
            return true
        end
        if not (clicked_unit and (clicked_unit.current_health or 0) > 0) then
            print(clicked_unit.display_name .. " is dead.")
            return true
        end
        if clicked_unit.is_moving then
            print(clicked_unit.display_name .. " is already moving.")
            return true
        end
        if self.controlled_unit_id == clicked_unit.id and clicked_unit.is_selected then
            if self.cell_slot_assignments and self.cell_slot_assignments[clicked_cell_id] then
                local assignment = self.cell_slot_assignments[clicked_cell_id]
                local current_slot = assignment[clicked_unit.id] or 1
                local used = {}
                for unit_id, slot_index in pairs(assignment) do
                    if unit_id ~= clicked_unit.id then
                        used[slot_index] = true
                    end
                end
                local next_slot = current_slot
                for step = 1, #CELL_SLOT_OFFSETS_X do
                    local candidate = ((current_slot + step - 1) % #CELL_SLOT_OFFSETS_X) + 1
                    if not used[candidate] then
                        next_slot = candidate
                        break
                    end
                end
                assignment[clicked_unit.id] = next_slot
                local target_x, target_y = get_unit_world_pos_in_cell(self, clicked_unit, clicked_cell_id)
                local current_pos = go.get_position(clicked_unit.go_path)
                local dx = target_x - current_pos.x
                local dy = target_y - current_pos.y
                local distance = math.sqrt(dx * dx + dy * dy)
                local move_duration = math.max(0.06, distance / HUMAN_MOVE_SPEED)
                go.cancel_animations(clicked_unit.go_path, "position")
                go.animate(
                    clicked_unit.go_path,
                    "position",
                    go.PLAYBACK_ONCE_FORWARD,
                    vmath.vector3(target_x, target_y, 0.5),
                    go.EASING_INOUTSINE,
                    move_duration
                )
                print(clicked_unit.display_name .. " shifted position within cell.")
            end
        else
            self.controlled_unit_id = clicked_unit.id
            deselect_all_units(self)
            clicked_unit.is_selected = true
            print(clicked_unit.display_name .. " selected. Click destination cell.")
        end
        self.ui_close_on_next_non_unit_click = false
        self.awaiting_slot_shuffle_click = false
        update_human_visual_state(self)
        self.selected_start_cell = nil
        update_human_ap_debug_label(self)
        return true
    end

    unit = get_controlled_unit(self)
    if unit and not multiplayer_can_control_unit(self, unit.id) then
        multiplayer_enforce_controlled_unit(self, true)
        unit = get_controlled_unit(self)
    end
    if not (unit and (unit.current_health or 0) > 0) then
        if unit.is_selected then
            unit.is_selected = false
            update_human_visual_state(self)
        end
        print(unit.display_name .. " is dead and cannot act.")
        return true
    end

    if unit.is_selected then
        if try_toggle_door_with_selected_human(self, unit, world_x, world_y) then
            self.ui_close_on_next_non_unit_click = false
            update_human_visual_state(self)
            update_human_ap_debug_label(self)
            return true
        end
        if try_manual_human_shot(self, unit, clicked_cell_id, world_x, world_y) then
            self.ui_close_on_next_non_unit_click = false
            return true
        end
        if self.alien_turn_active then
            print("Alien turn paused: select humans and fire, or press advance.")
            return true
        end

        if clicked_cell_id == unit.cell_id then
            if self.cell_slot_assignments and self.cell_slot_assignments[clicked_cell_id] then
                local assignment = self.cell_slot_assignments[clicked_cell_id]
                local current_slot = assignment[unit.id] or 1
                local used = {}
                for unit_id, slot_index in pairs(assignment) do
                    if unit_id ~= unit.id then
                        used[slot_index] = true
                    end
                end
                local base_x, _ = get_human_world_pos_for_cell(self.world_grid[clicked_cell_id])
                local best_slot = current_slot
                local best_dist = math.huge
                for i = 1, #CELL_SLOT_OFFSETS_X do
                    if i == current_slot or not used[i] then
                        local slot_x = base_x + ((CELL_SLOT_OFFSETS_X[i] or 0) * HUMAN_STACK_SPACING_X)
                        local dist = math.abs(world_x - slot_x)
                        if dist < best_dist then
                            best_dist = dist
                            best_slot = i
                        end
                    end
                end
                assignment[unit.id] = best_slot
                local target_x, target_y = get_unit_world_pos_in_cell(self, unit, clicked_cell_id)
                local current_pos = go.get_position(unit.go_path)
                local dx = target_x - current_pos.x
                local dy = target_y - current_pos.y
                local distance = math.sqrt(dx * dx + dy * dy)
                local move_duration = math.max(0.06, distance / HUMAN_MOVE_SPEED)
                go.cancel_animations(unit.go_path, "position")
                go.animate(
                    unit.go_path,
                    "position",
                    go.PLAYBACK_ONCE_FORWARD,
                    vmath.vector3(target_x, target_y, 0.5),
                    go.EASING_INOUTSINE,
                    move_duration
                )
                print(unit.display_name .. " repositioned within cell (0 AP).")
            end
            self.ui_close_on_next_non_unit_click = false
            update_human_visual_state(self)
            update_human_ap_debug_label(self)
            return true
        end

        if unit.is_moving then
            print(unit.display_name .. " is already moving.")
            return true
        end
        if unit.current_ap <= 0 then
            print(unit.display_name .. " has no AP. Click next turn to refresh.")
            update_human_visual_state(self)
            return true
        end

        if not is_walkable_cell(self.world_grid, clicked_cell_id) then
            print("Destination is VOID. Choose a valid destination.")
            update_human_visual_state(self)
            return true
        end

        local path, total_cost = find_path(self.world_grid, unit.cell_id, clicked_cell_id, nil, MOVEMENT_PROFILE_HUMAN, nil)
        if path then
            local destination_slot_index = nil
            local destination_slot_requested = nil
            local destination_cell = self.world_grid and self.world_grid[clicked_cell_id] or nil
            if destination_cell then
                local base_x, _ = get_human_world_pos_for_cell(destination_cell)
                local assignment = self.cell_slot_assignments and self.cell_slot_assignments[clicked_cell_id] or nil
                local used = {}
                if assignment then
                    for unit_id, slot_index in pairs(assignment) do
                        if unit_id ~= unit.id then
                            used[slot_index] = true
                        end
                    end
                end
                local best_slot = 1
                local best_dist = math.huge
                for i = 1, #CELL_SLOT_OFFSETS_X do
                    local slot_x = base_x + ((CELL_SLOT_OFFSETS_X[i] or 0) * HUMAN_STACK_SPACING_X)
                    local dist = math.abs(world_x - slot_x)
                    if dist < best_dist then
                        best_dist = dist
                        best_slot = i
                    end
                end
                destination_slot_requested = best_slot
                if not used[best_slot] then
                    destination_slot_index = best_slot
                else
                    local desired_offset = CELL_SLOT_OFFSETS_X[best_slot] or 0
                    for i = 1, #CELL_SLOT_OFFSETS_X do
                        if not used[i] then
                            local dist = math.abs((CELL_SLOT_OFFSETS_X[i] or 0) - desired_offset)
                            if destination_slot_index == nil
                                or dist < math.abs((CELL_SLOT_OFFSETS_X[destination_slot_index] or 0) - desired_offset)
                            then
                                destination_slot_index = i
                            end
                        end
                    end
                end
            end
            print(unit.display_name .. " route selected:")
            if destination_slot_requested then
                print(string.format(
                    "%s destination slot click on cell %d -> requested slot %d, resolved slot %d",
                    unit.display_name,
                    clicked_cell_id,
                    destination_slot_requested,
                    destination_slot_index or destination_slot_requested
                ))
            end
            print_path_debug(path, total_cost)
            highlight_path(self, path)
            if self.mp_state and self.mp_state.enabled then
                local active_player_id = multiplayer_get_active_player_id_for_commands(self)
                local is_non_host_client = (self.mp_state.local_player_id ~= self.mp_state.host_player_id)
                if is_non_host_client then
                    -- Responsiveness improvement: apply local prediction immediately for client-owned moves.
                    -- Host remains authoritative and turn_state snapshots will reconcile any mismatch.
                    begin_human_path_move(self, path, clicked_cell_id, destination_slot_index or destination_slot_requested)
                    print(string.format("MP PREDICT | move_unit local_apply | unit=%s", tostring(unit.id)))
                end
                multiplayer_transport_send_command(self, "move_unit", {
                    turn_id = self.mp_state.turn_id or 1,
                    unit_id = unit.id,
                    destination_cell_id = clicked_cell_id,
                    destination_slot_index = destination_slot_index or destination_slot_requested
                }, active_player_id)
            else
                begin_human_path_move(self, path, clicked_cell_id, destination_slot_index or destination_slot_requested)
            end
        else
            print("No path found for " .. unit.display_name .. " to cell: " .. clicked_cell_id)
        end

        self.ui_close_on_next_non_unit_click = false
        update_human_visual_state(self)
        return true
    end

    return false
end

function process_cell_selection(self, clicked_cell_id)
    local cell = self.world_grid[clicked_cell_id]
    if cell.tileID == hash("empty") then
        print("Clicked VOID cell. Select a valid cell.")
        return
    end

    if not self.selected_start_cell then
        clear_path_visuals(self)
        self.selected_start_cell = clicked_cell_id
        apply_cell_tint(clicked_cell_id, COLOR_START)
        table.insert(self.path_highlight_cells, clicked_cell_id)
        print("Start cell selected: " .. clicked_cell_id .. ". Click destination cell.")
    else
        local start_id = self.selected_start_cell
        local end_id = clicked_cell_id

        if start_id == end_id then
            clear_path_visuals(self)
            self.selected_start_cell = nil
            print("Selection canceled (same start/destination cell).")
            return
        end

        local path, total_cost = find_path(self.world_grid, start_id, end_id, nil)
        if path then
            print_path_debug(path, total_cost)
            highlight_path(self, path)
        else
            clear_path_visuals(self)
            apply_cell_tint(start_id, COLOR_START)
            table.insert(self.path_highlight_cells, start_id)
            apply_cell_tint(end_id, COLOR_END)
            table.insert(self.path_highlight_cells, end_id)
            print("No valid path from " .. start_id .. " to " .. end_id)
        end

        self.selected_start_cell = nil
    end
end


    -- =============================================================================
    -- VISUAL RENDERING
    -- =============================================================================

    function spawn_visuals(self)
        print("Creating visual representation...")
        local spawned_count = 0
        cell_objects = {}
        tile_objects = {}
        self.tile_light_layers = {}
        self.tile_light_power_state = {}
        self.tile_light_flicker_state = {}
        self.tile_light_anim_ids = {}
        self.tile_light_is_workshop = {}
        self.tile_alpha_layers = {}
        self.tile_room_shadows = {}
        self.exterior_detail_objects = {}
        self.entry_fire_fx_objects = {}
        self.exit_green_smoke_fx_objects = {}
        self.exit_green_smoke_fx_power_state = {}
        self.tile_base_objects = {}
        self.tile_alpha_power_state = {}
        self.tile_off_proximity_mul_state = {}
        loot_objects = {}
        machine_objects = {}
        self.turret_tripod_objects = {}
        self.turret_gun_objects = {}
        self.power_node_objects = {}
        self.vent_objects = {}
        self.light_value_objects = {}

        -- Spawn tile sprites slightly above cell debug layer (50% opacity).
        local selected_level = self.level_library[self.current_level_index or 1]
        for placement_index, placement in ipairs(selected_level) do
            local center_x, center_y = coords_to_world_pos(placement.x, placement.y)
            local pos = vmath.vector3(center_x, center_y, 0.02)

            local tile_def = self.tile_library and self.tile_library[placement.tile] or nil
            local visual_tile_name = (tile_def and tile_def.visualTile) or placement.tile
            if tile_def then
                if self.aesthetic_mode == AESTHETIC_MODE_BOARDGAME and tile_def.visualTileBoardgame then
                    visual_tile_name = tile_def.visualTileBoardgame
                elseif self.aesthetic_mode == AESTHETIC_MODE_COMPUTER and tile_def.visualTileComputer then
                    visual_tile_name = tile_def.visualTileComputer
                end
            end
            local id = factory.create("/tile_factory#tile_factory", pos, nil, {}, vmath.vector3(visual_scale, visual_scale, 1))
            if id then
                local anim = "tile_" .. visual_tile_name
                msg.post(msg.url(nil, id, "sprite"), "play_animation", { id = hash(anim) })
                go.set(msg.url(nil, id, "sprite"), "tint", vmath.vector4(1, 1, 1, TILE_OPACITY))
                table.insert(tile_objects, id)
                self.tile_base_objects[placement_index] = id
            else
                print("Tile factory create failed for: " .. placement.tile)
            end

            local tile_shadow_id = factory.create(
                "/shadow_box_factory#shadow_box_factory",
                vmath.vector3(center_x + 12, center_y - 12, 0.005),
                nil,
                {},
                vmath.vector3(750, 450, 1)
            )
            if tile_shadow_id then
                go.set(msg.url(nil, tile_shadow_id, "sprite"), "tint", vmath.vector4(0, 0, 0, 0))
                self.tile_room_shadows[placement_index] = tile_shadow_id
            end

            if placement.tile == "entry" then
                local fire_cell_id = coords_to_id(placement.x, placement.y - 1)
                if fire_cell_id and self.world_grid and self.world_grid[fire_cell_id] and self.world_grid[fire_cell_id].tileID ~= hash("empty") then
                    local fire_x, fire_y = coords_to_world_pos(placement.x, placement.y - 1)
                    local fire_fx_id = factory.create(
                        "/crash_spaceship_fire_fx_factory#crash_spaceship_fire_fx_factory",
                        vmath.vector3(fire_x + ENTRY_FIRE_OFFSET_X, fire_y + ENTRY_FIRE_OFFSET_Y, ENTRY_FIRE_Z)
                    )
                    if fire_fx_id then
                        self.entry_fire_fx_objects[placement_index] = fire_fx_id
                        go.set_rotation(vmath.quat_rotation_z(math.rad(ENTRY_FIRE_ROTATION_DEG)), fire_fx_id)
                        pcall(particlefx.play, msg.url(nil, fire_fx_id, "particlefx"))
                    end
                end
            end
            if placement.tile == "exit" then
                local smoke_cell_id = coords_to_id(placement.x + 1, placement.y - 1) -- exit tile cell 3
                if smoke_cell_id and self.world_grid and self.world_grid[smoke_cell_id] and self.world_grid[smoke_cell_id].tileID ~= hash("empty") then
                    local smoke_x, smoke_y = coords_to_world_pos(placement.x + 1, placement.y - 1)
                    local smoke_fx_id = factory.create(
                        "/escape_pod_green_smoke_fx_factory#escape_pod_green_smoke_fx_factory",
                        vmath.vector3(
                            smoke_x + EXIT_GREEN_SMOKE_CELL3_BOTTOM_OFFSET_X,
                            smoke_y + EXIT_GREEN_SMOKE_CELL3_BOTTOM_OFFSET_Y,
                            EXIT_GREEN_SMOKE_Z
                        )
                    )
                    if smoke_fx_id then
                        self.exit_green_smoke_fx_objects[placement_index] = smoke_fx_id
                        self.exit_green_smoke_fx_power_state[placement_index] = false
                        pcall(particlefx.stop, msg.url(nil, smoke_fx_id, "particlefx"), { clear = true })
                    end
                end
            end

            if placement.tile ~= "entry" then
                -- Exterior details are only for truly exposed silhouettes:
                -- roof: no overlapping tile anywhere above; left wall: no overlapping tile anywhere to the left.
                local has_tile_above = false
                local has_tile_left = false
                local p_left = placement.x - 1
                local p_right = placement.x + 1
                local p_bottom = placement.y - 1
                local p_top = placement.y + 1
                for _, scan in ipairs(selected_level) do
                    if scan ~= placement then
                        local s_left = scan.x - 1
                        local s_right = scan.x + 1
                        local s_bottom = scan.y - 1
                        local s_top = scan.y + 1
                        local overlaps_x = not (s_right < p_left or s_left > p_right)
                        local overlaps_y = not (s_top < p_bottom or s_bottom > p_top)
                        if (not has_tile_above) and overlaps_x and scan.y > placement.y then
                            has_tile_above = true
                        end
                        if (not has_tile_left) and overlaps_y and scan.x < placement.x then
                            has_tile_left = true
                        end
                        if has_tile_above and has_tile_left then
                            break
                        end
                    end
                end
                if not has_tile_above then
                    local roof_id = factory.create(
                        "/tile_factory#tile_factory",
                        vmath.vector3(center_x, center_y + (CELL_HEIGHT * 3), 0.02),
                        nil,
                        {},
                        vmath.vector3(visual_scale, visual_scale, 1)
                    )
                    if roof_id then
                        msg.post(msg.url(nil, roof_id, "sprite"), "play_animation", { id = hash("exterior_roof1") })
                        go.set(msg.url(nil, roof_id, "sprite"), "tint", vmath.vector4(1, 1, 1, 1))
                        table.insert(tile_objects, roof_id)
                        table.insert(self.exterior_detail_objects, roof_id)
                    end
                end
                if not has_tile_left then
                    local left_wall_id = factory.create(
                        "/tile_factory#tile_factory",
                        vmath.vector3(center_x - (CELL_WIDTH * 3), center_y, 0.02),
                        nil,
                        {},
                        vmath.vector3(visual_scale, visual_scale, 1)
                    )
                    if left_wall_id then
                        msg.post(msg.url(nil, left_wall_id, "sprite"), "play_animation", { id = hash("exterior_leftWall1") })
                        go.set(msg.url(nil, left_wall_id, "sprite"), "tint", vmath.vector4(1, 1, 1, 1))
                        table.insert(tile_objects, left_wall_id)
                        table.insert(self.exterior_detail_objects, left_wall_id)
                    end
                end
            end

            local power_light_off_anim = tile_def and tile_def.powerLightOffAnim or nil
            local power_light_on_anim = tile_def and tile_def.powerLightOnAnim or nil
            if power_light_off_anim and power_light_on_anim then
                local light_id = factory.create("/tile_factory#tile_factory", vmath.vector3(center_x, center_y, 0.3), nil, {}, vmath.vector3(visual_scale, visual_scale, 1))
                if light_id then
                    msg.post(msg.url(nil, light_id, "sprite"), "play_animation", { id = hash(power_light_off_anim) })
                    self.tile_light_layers[placement_index] = light_id
                    self.tile_light_power_state[placement_index] = false
                    self.tile_light_flicker_state[placement_index] = nil
                    self.tile_light_is_workshop[placement_index] = (placement.tile == "workshop")
                    self.tile_light_anim_ids[placement_index] = {
                        on = hash(power_light_on_anim),
                        off = hash(power_light_off_anim)
                    }
                end
            end

            -- Shared foreground alpha layer for depth, rendered above units/objects.
            local alpha_id = factory.create("/tile_factory#tile_factory", vmath.vector3(center_x, center_y, 0.7), nil, {}, vmath.vector3(visual_scale, visual_scale, 1))
            if alpha_id then
                msg.post(msg.url(nil, alpha_id, "sprite"), "play_animation", { id = hash("tile_generic_alpha_layer") })
                go.set(msg.url(nil, alpha_id, "sprite"), "tint", vmath.vector4(1, 1, 1, 0))
                self.tile_alpha_layers[placement_index] = alpha_id
                self.tile_alpha_power_state[placement_index] = false
            end
        end
        print("Spawned " .. #tile_objects .. " tiles")

        -- Spawn cell sprites (debug grid under semi-transparent tiles)
        for _, cell in ipairs(self.world_grid) do
            print("making visual cell")
            if cell.tileID ~= hash("empty") then  -- Only spawn cells that are part of tiles
            --if true then  -- spawn ALL CELLS!
                local x, y = coords_to_world_pos(cell.xCell, cell.yCell)
                local pos = vmath.vector3(x, y, 0)

                -- Determine animation
                local animation = "cell_open"
                if not cell.accessRight and not cell.accessDown then
                    animation = "cell_right_down_wall"
                elseif not cell.accessRight then
                    animation = "cell_right_wall"
                elseif not cell.accessDown then
                    animation = "cell_down_wall"
                end
               
                local id = factory.create("/cell_factory#cell_factory", pos, nil, {}, vmath.vector3(visual_scale, visual_scale, 1))
                if id then
                    msg.post(msg.url(nil, id, "cell_sprite1"), "set_animation", {animation = hash(animation)})
                    msg.post(msg.url(nil, id, "cell_sprite1"), "set_tint", { tint = vmath.vector4(1, 1, 1, 0) })
                    cell_objects[cell.idNumber] = id
                    spawned_count = spawned_count + 1
                end

                
--                 local id = factory.create("/cell_factory#cell_factory", pos, nil, {}, vmath.vector3(visual_scale, visual_scale, 1))
--                 if id then
--                     print("alex",id)
--                     msg.post(msg.url(nil, id, "cell_sprite"), "set_animation", {animation = hash(animation)})
--                    
-- 
--                     cell_objects[cell.idNumber] = id
--                 end
            end
        end

        print("Spawned " .. spawned_count .. " cells")
        LOOT_RUNTIME.refresh_loot_markers(self)
        LOOT_RUNTIME.refresh_machine_markers(self)
        LOOT_RUNTIME.refresh_turret_markers(self)
        LOOT_RUNTIME.refresh_fix_markers(self)
        LOOT_RUNTIME.refresh_power_node_markers(self)
        LOOT_RUNTIME.refresh_door_markers(self)
        LOOT_RUNTIME.refresh_wiregap_markers(self)
        LOOT_RUNTIME.refresh_vent_markers(self)
        LOOT_RUNTIME.refresh_light_value_markers(self)
        if LOOT_RUNTIME.refresh_factory_underlay_visuals then
            LOOT_RUNTIME.refresh_factory_underlay_visuals(self)
        end
    end--of spawn visuals fn

local function update_exit_green_smoke_fx(self)
    if not (self.exit_green_smoke_fx_objects and self.world_grid) then
        return
    end
    self.exit_green_smoke_fx_power_state = self.exit_green_smoke_fx_power_state or {}
    for tile_instance_id, fx_id in pairs(self.exit_green_smoke_fx_objects) do
        if fx_id then
            local tile_powered = false
            for _, cell in ipairs(self.world_grid) do
                if cell.tileInstanceId == tile_instance_id and cell.isPowered == true then
                    tile_powered = true
                    break
                end
            end
            local was_powered = self.exit_green_smoke_fx_power_state[tile_instance_id]
            if was_powered == nil or was_powered ~= tile_powered then
                if tile_powered then
                    pcall(particlefx.play, msg.url(nil, fx_id, "particlefx"))
                else
                    pcall(particlefx.stop, msg.url(nil, fx_id, "particlefx"), { clear = true })
                end
                self.exit_green_smoke_fx_power_state[tile_instance_id] = tile_powered
            end
        end
    end
end






-- =============================================================================
-- INIT FUNCTION
-- =============================================================================

function init(self)
    print("=== DERPLES VS XENOS - Initializing ===")
    print("Chat GPT is here")

   

    -- Initialize edge lists for boundary checking
    initialize_edge_lists()

    -- Create the worldGrid (15x15 = 225 cells)
    self.world_grid = create_world_grid()
    print("WorldGrid created: " .. #self.world_grid .. " cells")

    -- Create tile library
    self.tile_library = require("main.tile_defs").create_tile_library(COMPONENT_UI)
    print("Tile library created")

    -- Create level designs
    self.level_library = require("main.level_defs").create_level_library()
    print("Level library created")

    -- Select a random level (for now, just use level 1)
    self.current_level_index = 1
    local selected_level = self.level_library[self.current_level_index]
    print("Selected level 1 for baking")

    -- Bake the level onto the worldGrid
    self.world_grid = bake_level_to_world_grid(self.world_grid, selected_level, self.tile_library)
    print("Level baked down to worldGrid")

    -- Camera setup
    self.camera_pos = vmath.vector3(CELL_WIDTH * GRID_COLS / 2, CELL_HEIGHT * GRID_ROWS / 2, 1000)
    self.camera_zoom = 1.0
    self.camera_min_zoom = 0.25--0.5
    self.camera_max_zoom = 1.5--1.0
    self.drag_threshold_px = 12
    self.is_panning = false
    self.did_drag = false
    self.drag_start_screen_x = 0
    self.drag_start_screen_y = 0
    self.drag_start_camera_pos = self.camera_pos
    self.last_pan_screen_x = 0
    self.last_pan_screen_y = 0
    self.pan_velocity_x = 0
    self.pan_velocity_y = 0
    self.pan_inertia_damping = 1--8
    self.pan_inertia_min_speed = 3
    self.zoom_input_armed = false
    self.zoom_block_timer = 0.6
    self.zoom_target = nil
    self.zoom_focus_x = SCREEN_WIDTH * 0.5
    self.zoom_focus_y = SCREEN_HEIGHT * 0.5
    self.zoom_smooth_speed = 12

    --self.camera_pos = vmath.vector3(CELL_WIDTH * GRID_COLS / 2, CELL_HEIGHT * GRID_ROWS / 2, 1000)
    --go.set_position(self.camera_pos, "/camera")

    -- Keep camera position/zoom and click conversion in the same space
    apply_camera_transform(self)

    -- Enable input
    msg.post(".", "acquire_input_focus")
    if not IS_HTML5 then
        enforce_fixed_window_size(self, 0, true)
    end

    -- Set camera view
    msg.post("@render:", "use_camera_projection")
    msg.post("/camera#camera", "acquire_camera_focus")

    self.sheen_z = 1.2--0.3
    self.sheen_alpha = 0.48--0.8--0.22
    self.sheen_art_w = 550--768
    self.sheen_art_h = 300--576
    self.sheen_offset_x = 0
    self.sheen_offset_y = 100
    self.aesthetic_mode = self.aesthetic_mode or AESTHETIC_MODE_BOARDGAME
    self.world_backdrop = nil
    self.world_backdrop_tiles = nil
    self.world_backdrop_anim = nil
    self.world_backdrop_z = 0.001
    self.world_backdrop_art_w = 1024
    self.world_backdrop_art_h = 576
    self.world_backdrop_base_offset_x = 0
    self.world_backdrop_base_offset_y = 0
    self.world_backdrop_pan_x = 0
    self.world_backdrop_pan_y = 0
    self.world_backdrop_prev_camera_x = nil
    self.world_backdrop_prev_camera_y = nil
    self.world_backdrop_parallax_x = nil
    self.world_backdrop_parallax_y = nil
    self.world_backdrop_anchor_camera_y = nil
    self.backdrop_emissive_phase = 0
    self.backdrop_emissive_speed_timer = nil
    self.backdrop_emissive_speed_mul_target = nil
    self.backdrop_emissive_speed_mul_current = nil
    self.table_sweep_shadow_overlay = nil
    self.table_sweep_shadow_anim = nil
    self.table_sweep_shadow_factory = nil
    self.table_sweep_shadow_z = 1.3
    self.table_sweep_shadow_art_w = 256
    self.table_sweep_shadow_art_h = 256
    self.table_sweep_shadow_scale_x = 1.2
    self.table_sweep_shadow_scale_y = 1.0
    self.table_sweep_shadow_base_offset_x = 0
    self.table_sweep_shadow_base_offset_y = 180
    self.table_sweep_shadow_pan_x = nil
    self.table_sweep_shadow_pan_y = 0
    self.table_sweep_shadow_pause_timer = nil

    -- SPAWN VISUALS (add this line)
    spawn_visuals(self)
    apply_aesthetic_mode(self)
    initialize_unit_ui(self)
    set_ui_hidden(self)
    self.selected_start_cell = nil
    self.path_highlight_cells = {}
    self.ui_close_on_next_non_unit_click = false
    self.squad_units = create_squad_units()
    self.controlled_unit_id = "sarge"
    self.spawn_human_unit_fn = spawn_human_unit
    print_squad_debug_overview(self)
    spawn_human_unit(self)
    self.aliens = {}
    self.next_alien_id = 0
    self.pending_spitter_attack_phase = false
    self.spitter_attack_started = false
    self.spitter_attack_timer = 0
    self.spitter_attack_queue = {}
    self.spitter_projectiles = {}
    self.turret_projectiles = {}
    self.turret_pending_shots = {}
    self.next_turret_shot_id = 0
    self.turret_last_human_cell_by_id = {}
    self.turret_last_alien_cell_by_id = {}
    self.turret_fire_cooldown_by_object_id = {}
    self.turret_fired_this_alien_turn_by_object_id = {}
    self.human_reactive_fire_cooldown_by_unit_id = {}
    self.pending_melee_attack_phase = false
    self.melee_attack_started = false
    self.melee_attack_timer = 0
    self.melee_action_queue = {}
    self.melee_ap_left_by_alien_id = {}
    self.reactive_combat_enabled = true
    init_multiplayer_runtime(self)
    multiplayer_setup_set_player_count(self, 2)
    self.alien_turn_active = false
    self.alien_turn_waiting_for_advance = false
    self.alien_turn_manual_pause = false
    self.loot_pickup_blips = {}
    self.world_item_instances = {}
    self.world_item_visuals = {}
    self.world_item_shadow_visuals = {}
    self.loot_shadow_objects = {}
    self.machine_shadow_objects = {}
    self.turret_shadow_objects = {}
    self.power_node_shadow_objects = {}
    self.vent_shadow_objects = {}
    self.door_shadow_objects = {}
    self.entry_fire_fx_objects = {}
    self.wiregap_shadow_objects = {}
    self.next_world_item_id = 0
    self.drag_resource = { active = false }
    reset_derple_feedback_runtime(self)
    spawn_initial_blips(self, INITIAL_BLIP_COUNT)
    self.score_turn_counter = 0
    self.score_state = SCORE_RUNTIME.create_state("escape_pod")
    self.score_display_total = 0
    self.multiplayer_mode_active = false
    print("SCORE TRACE READY | scoring runtime initialized")
    score_log_snapshot(self, "init")
    self.flow_score_breakdown = { total = 0, survivors = 0, seated = 0, dead = 0, power_units = 0, objectives = 0 }
    self.flow_outro_timer = 0
    self.flow_submit_done = false
    enter_flow_state(self, FLOW_STATE_TITLE)

    print("=== Initialization Complete ===")

    print("=== Initialization Complete ===")
    print("WorldGrid size: " .. GRID_COLS .. "x" .. GRID_ROWS)
    print("Cell size: " .. CELL_WIDTH .. "x" .. CELL_HEIGHT)
    print("Total world size: " .. (CELL_WIDTH * GRID_COLS) .. "x" .. (CELL_HEIGHT * GRID_ROWS))
end

-- =============================================================================
-- UPDATE FUNCTION
-- =============================================================================

function update(self, dt)
    if self.mp_transport and self.mp_transport.update then
        self.mp_transport.update(dt)
    end
    if self.mp_state and self.mp_state.enabled and self.mp_state.local_player_id == self.mp_state.host_player_id then
        local pending_turn_state_turn_id = tonumber(self.mp_state.pending_turn_state_snapshot_turn_id or 0) or 0
        if pending_turn_state_turn_id > 0 then
            local alien_cycle_active = self.alien_turn_active
                or self.pending_spitter_attack_phase
                or self.pending_melee_attack_phase
                or any_alien_is_moving(self)
            if (not alien_cycle_active) and (tonumber(self.mp_state.turn_id or 0) or 0) >= pending_turn_state_turn_id then
                local last_sent_turn = tonumber(self.mp_state.last_turn_state_snapshot_broadcast_turn_id or 0) or 0
                if pending_turn_state_turn_id > last_sent_turn then
                    multiplayer_transport_broadcast_event(self, "turn_state_snapshot", {
                        turn_id = pending_turn_state_turn_id,
                        snapshot = multiplayer_build_snapshot_state(self)
                    })
                    self.mp_state.last_turn_state_snapshot_broadcast_turn_id = pending_turn_state_turn_id
                    print(string.format("MP TURNSTATE | host_broadcast | turn_id=%d", pending_turn_state_turn_id))
                end
                self.mp_state.pending_turn_state_snapshot_turn_id = 0
            end
        end
    end
    if self.mp_state and self.mp_state.enabled and self.mp_state.local_player_id ~= self.mp_state.host_player_id then
        local wait_timeout = tonumber(self.mp_state.awaiting_snapshot_timeout_s or 0) or 0
        if self.mp_state.awaiting_snapshot and self.mp_state.snapshot_blocking == true and wait_timeout > 0 then
            wait_timeout = math.max(0, wait_timeout - dt)
            self.mp_state.awaiting_snapshot_timeout_s = wait_timeout
            if wait_timeout <= 0 then
                -- Avoid permanent input freeze if a snapshot is delayed/lost.
                self.mp_state.awaiting_snapshot = false
                self.mp_state.snapshot_blocking = false
                print("MP SNAPSHOT | timeout_unblocked")
            end
        end
        local delay = tonumber(self.mp_state.post_turn_snapshot_delay_s or 0) or 0
        if delay > 0 then
            delay = math.max(0, delay - dt)
            self.mp_state.post_turn_snapshot_delay_s = delay
            if delay <= 0 and not self.mp_state.awaiting_snapshot then
                self.mp_state.awaiting_snapshot = true
                self.mp_state.snapshot_blocking = false
                multiplayer_transport_send_command(self, "request_snapshot", {
                    turn_id = self.mp_state.turn_id or 1
                }, self.mp_state.local_player_id)
                print("MP SNAPSHOT | requested_post_turn_settle")
            end
        end
    end
    if self.zoom_block_timer and self.zoom_block_timer > 0 then
        self.zoom_block_timer = math.max(0, self.zoom_block_timer - dt)
    end
    if not IS_HTML5 then
        enforce_fixed_window_size(self, dt, false)
    end
    update_smooth_zoom(self, dt)
    if self.world_grid and self.tile_light_layers then
        for tile_instance_id, light_go in pairs(self.tile_light_layers) do
            local light_anim_cfg = self.tile_light_anim_ids and self.tile_light_anim_ids[tile_instance_id] or nil
            if light_anim_cfg and light_anim_cfg.on and light_anim_cfg.off then
                local light_anim_on = light_anim_cfg.on
                local light_anim_off = light_anim_cfg.off
                local tile_powered = false
                for _, cell in ipairs(self.world_grid) do
                    if cell.tileInstanceId == tile_instance_id and cell.isPowered then
                        tile_powered = true
                        break
                    end
                end

                local was_powered = self.tile_light_power_state[tile_instance_id]
                if was_powered == nil or was_powered ~= tile_powered then
                    if tile_powered then
                        if self.tile_light_is_workshop and self.tile_light_is_workshop[tile_instance_id] then
                            -- Workshop keeps its own smooth emissive profile without startup stutter.
                            self.tile_light_flicker_state[tile_instance_id] = nil
                            msg.post(msg.url(nil, light_go, "sprite"), "play_animation", { id = light_anim_on })
                        else
                            -- Fluorescent-style startup flicker: OFF/ON pulses before stabilizing ON.
                            self.tile_light_flicker_state[tile_instance_id] = {
                                active = true,
                                timer = 0.06,
                                step = 1
                            }
                            msg.post(msg.url(nil, light_go, "sprite"), "play_animation", { id = light_anim_off })
                        end
                    else
                        self.tile_light_flicker_state[tile_instance_id] = nil
                        msg.post(msg.url(nil, light_go, "sprite"), "play_animation", { id = light_anim_off })
                    end
                    self.tile_light_power_state[tile_instance_id] = tile_powered
                end

                local flicker = self.tile_light_flicker_state[tile_instance_id]
                if flicker and flicker.active then
                    flicker.timer = flicker.timer - dt
                    if flicker.timer <= 0 then
                        if flicker.step == 1 then
                            msg.post(msg.url(nil, light_go, "sprite"), "play_animation", { id = light_anim_on })
                            flicker.timer = 0.05
                        elseif flicker.step == 2 then
                            msg.post(msg.url(nil, light_go, "sprite"), "play_animation", { id = light_anim_off })
                            flicker.timer = 0.06
                        elseif flicker.step == 3 then
                            msg.post(msg.url(nil, light_go, "sprite"), "play_animation", { id = light_anim_on })
                            flicker.timer = 0.05
                        elseif flicker.step == 4 then
                            msg.post(msg.url(nil, light_go, "sprite"), "play_animation", { id = light_anim_off })
                            flicker.timer = 0.04
                        else
                            msg.post(msg.url(nil, light_go, "sprite"), "play_animation", { id = light_anim_on })
                            flicker.active = false
                            flicker.timer = 0
                        end
                        flicker.step = flicker.step + 1
                    end
                end
            end
        end
    end

    if self.world_grid and self.tile_alpha_layers then
        for tile_instance_id, alpha_go in pairs(self.tile_alpha_layers) do
            local tile_powered = false
            for _, cell in ipairs(self.world_grid) do
                if cell.tileInstanceId == tile_instance_id and cell.isPowered then
                    tile_powered = true
                    break
                end
            end
            local was_powered = self.tile_alpha_power_state[tile_instance_id]
            if was_powered == nil or was_powered ~= tile_powered then
                if tile_powered then
                    go.set(msg.url(nil, alpha_go, "sprite"), "tint", vmath.vector4(1, 1, 1, 1))
                else
                    go.set(msg.url(nil, alpha_go, "sprite"), "tint", vmath.vector4(1, 1, 1, 0))
                end
                self.tile_alpha_power_state[tile_instance_id] = tile_powered
            end
        end
    end
    apply_computer_emissive_accents(self, dt)

    update_human_movement(self, dt)
    update_alien_movement(self, dt)
    local obstacle_shudder_active = false
    local door_shudder_active = false
    if self.world_grid then
        for _, cell in ipairs(self.world_grid) do
            if cell and (cell.obstacleShudderTimer or 0) > 0 then
                cell.obstacleShudderTimer = math.max(0, (cell.obstacleShudderTimer or 0) - dt)
                cell.obstacleShudderPhase = (cell.obstacleShudderPhase or 0) + (dt * 48)
                if cell.obstacleShudderTimer > 0 then
                    obstacle_shudder_active = true
                else
                    cell.obstacleShudderTimer = nil
                    cell.obstacleShudderPhase = nil
                end
            end
            if cell then
                if cell.obstacleNudgeEventClock ~= nil then
                    cell.obstacleNudgeEventClock = (cell.obstacleNudgeEventClock or 0) + dt
                end
                local current_by_index = cell.obstacleNudgeCurrentByIndex
                local target_by_index = cell.obstacleNudgeTargetByIndex
                local lag_by_index = cell.obstacleNudgeLagByIndex
                if current_by_index and target_by_index then
                    local has_active_nudge = false
                    local clock = cell.obstacleNudgeEventClock or 0
                    local blend = math.min(1, dt * 6.8)
                    local decay = math.max(0, 1 - (dt * 0.175))
                    local max_idx = #current_by_index
                    if #target_by_index > max_idx then
                        max_idx = #target_by_index
                    end
                    for i = 1, max_idx do
                        local current_x = current_by_index[i] or 0
                        local target_x = target_by_index[i] or 0
                        local lag_s = (lag_by_index and lag_by_index[i]) or 0
                        if clock >= lag_s then
                            current_x = current_x + ((target_x - current_x) * blend)
                            target_x = target_x * decay
                        end
                        if math.abs(current_x) < 0.02 then
                            current_x = 0
                        end
                        if math.abs(target_x) < 0.02 then
                            target_x = 0
                        end
                        current_by_index[i] = current_x
                        target_by_index[i] = target_x
                        if math.abs(current_x) > 0.01 or math.abs(target_x) > 0.01 then
                            has_active_nudge = true
                        end
                    end
                    if has_active_nudge then
                        obstacle_shudder_active = true
                    else
                        cell.obstacleNudgeEventClock = nil
                    end
                end
            end
            if cell and (cell.barricade_scale_pulse_timer or 0) > 0 then
                cell.barricade_scale_pulse_timer = math.max(0, (cell.barricade_scale_pulse_timer or 0) - dt)
                if cell.barricade_scale_pulse_timer > 0 then
                    obstacle_shudder_active = true
                    cell.barricade_scale_pulse = 0.1 * (cell.barricade_scale_pulse_timer / 0.22)
                else
                    cell.barricade_scale_pulse_timer = nil
                    cell.barricade_scale_pulse = nil
                end
            end
            if cell then
                local door_objs = { cell.object1, cell.object2, cell.object3 }
                for _, obj in ipairs(door_objs) do
                    if obj and obj.name == hash("door") and (obj.door_shudder_timer or 0) > 0 then
                        obj.door_shudder_timer = math.max(0, (obj.door_shudder_timer or 0) - dt)
                        obj.door_shudder_phase = (obj.door_shudder_phase or 0) + (dt * 48)
                        if obj.door_shudder_timer > 0 then
                            door_shudder_active = true
                        else
                            obj.door_shudder_timer = nil
                            obj.door_shudder_phase = nil
                        end
                    end
                end
            end
        end
    end
    if obstacle_shudder_active or door_shudder_active then
        self.obstacle_shudder_refresh_timer = (self.obstacle_shudder_refresh_timer or 0) - dt
        if self.obstacle_shudder_refresh_timer <= 0 then
            self.obstacle_shudder_refresh_timer = 0.016
            if LOOT_RUNTIME and LOOT_RUNTIME.refresh_fix_markers then
                LOOT_RUNTIME.refresh_fix_markers(self)
            end
            if LOOT_RUNTIME and LOOT_RUNTIME.refresh_door_markers then
                LOOT_RUNTIME.refresh_door_markers(self)
            end
        end
    else
        self.obstacle_shudder_refresh_timer = 0
    end
    if LOOT_RUNTIME.update_exit_boarding then
        LOOT_RUNTIME.update_exit_boarding(self)
    end
    if self.aliens then
        local world_shadow_alpha = get_world_shadow_alpha(self)
        local profile = get_aesthetic_profile(self)
        local counter_move_enabled = profile and profile.counter_token_move_enabled == true
        local shadow_origin = vmath.vector3(30, -30, -0.01)
        for _, alien in ipairs(self.aliens) do
            if alien and (alien.melee_pose_lock_timer or 0) > 0 then
                alien.melee_pose_lock_timer = math.max(0, (alien.melee_pose_lock_timer or 0) - dt)
            end
            apply_brute_alpha_pulse(self, alien, dt)
            if alien
                and (not alien.is_dead)
                and (alien.type == ALIEN_TYPE_CANNON or alien.type == ALIEN_TYPE_SPITTER or alien.type == ALIEN_TYPE_SPEEDY or alien.type == ALIEN_TYPE_BRUTE)
                and alien.go_id then
                local shadow_pos = shadow_origin
                if counter_move_enabled then
                    shadow_pos = alien.counter_shadow_offset or get_counter_shadow_offset(profile, 0)
                end
                local use_proxy_shadow = counter_move_enabled and (alien.is_moving or alien.shadow_proxy_pending_clear)
                if use_proxy_shadow then
                    local proxy_id = ensure_counter_shadow_proxy(
                        alien,
                        get_counter_shadow_anim_for_alien(alien.type),
                        vmath.vector4(1, 1, 1, 0.5)
                    )
                    if proxy_id then
                        local apos = go.get_position(alien.go_id)
                        go.set_position(vmath.vector3(apos.x + shadow_pos.x, apos.y + shadow_pos.y, apos.z - 0.01), proxy_id)
                    end
                    pcall(go.set, msg.url(nil, alien.go_id, "shadow"), "tint", vmath.vector4(1, 1, 1, 0))
                    if counter_move_enabled and (not alien.is_moving) and alien.shadow_proxy_id then
                        schedule_counter_shadow_proxy_clear(alien, 0.08)
                    end
                else
                    clear_counter_shadow_proxy(alien)
                    pcall(go.set, msg.url(nil, alien.go_id, "shadow"), "tint", vmath.vector4(1, 1, 1, world_shadow_alpha))
                    pcall(go.set, msg.url(nil, alien.go_id, "shadow"), "position", shadow_pos)
                end
                if not alien.is_moving then
                    alien.counter_shadow_offset = nil
                end
            end
            if alien
                and (not alien.is_dead)
                and (alien.type == ALIEN_TYPE_CANNON or alien.type == ALIEN_TYPE_SPITTER or alien.type == ALIEN_TYPE_SPEEDY or alien.type == ALIEN_TYPE_BRUTE)
                and (not alien.is_moving)
                and alien.go_id then
                alien.spitter_anim_phase = (alien.spitter_anim_phase or 0) + (dt * 2.2 * math.pi * 2)
                local pulse = math.sin(alien.spitter_anim_phase)
                local base_scale = 0.33333334
                if alien.type == ALIEN_TYPE_CANNON then
                    base_scale = 0.22
                elseif alien.type == ALIEN_TYPE_SPITTER or alien.type == ALIEN_TYPE_SPEEDY then
                    base_scale = base_scale * 0.75
                elseif alien.type == ALIEN_TYPE_BRUTE then
                    pcall(go.set_rotation, vmath.quat_rotation_z(0), alien.go_id)
                    if (alien.melee_pose_lock_timer or 0) <= 0 then
                        local front_anim = get_alien_anim_for_aesthetic(self, alien.type)
                        if front_anim and alien.current_aesthetic_anim ~= front_anim then
                            pcall(msg.post, msg.url(nil, alien.go_id, "sprite"), "play_animation", { id = front_anim })
                            alien.current_aesthetic_anim = front_anim
                        end
                        sprite.set_hflip(msg.url(nil, alien.go_id, "sprite"), false)
                        sprite.set_hflip(msg.url(nil, alien.go_id, "shadow"), false)
                    end
                    base_scale = (0.22 * 1.5 * 1.25 * 1.2 * 1.1) * ((self.aesthetic_mode == AESTHETIC_MODE_COMPUTER) and 1.2 or 1.0)
                end
                local sx = base_scale * (1 - (0.045 * pulse))
                local sy = base_scale * (1 + (0.0675 * pulse))
                go.set_scale(vmath.vector3(sx, sy, 1), alien.go_id)
            end
        end
    end
    MELEE_RUNTIME.update_human_hit_flash(self, dt)
    MELEE_RUNTIME.update_swipe_fx(self, dt)
    MELEE_RUNTIME.update_phase(self, dt)
    update_spitter_projectiles(self, dt)
    update_turret_projectiles(self, dt)
    update_spitter_attack_phase(self, dt)
    tick_human_reactive_fire_cooldowns(self, dt)
    process_turret_reactive_fire(self, dt)
    if self.alien_turn_active and (not self.alien_turn_waiting_for_advance) and (not any_alien_is_moving(self)) and (not self.pending_spitter_attack_phase) and (not self.pending_melee_attack_phase) then
        process_alien_turn(self)
    end
    LOOT_RUNTIME.update_loot_pickup_blips(self, dt)
    LOOT_RUNTIME.update_derple_feedback_bubbles(self, dt)
    LOOT_RUNTIME.update_power_node_flicker(self, dt)
    if LOOT_RUNTIME.update_factory_conveyor_tokens then
        LOOT_RUNTIME.update_factory_conveyor_tokens(self, dt)
    end
    if LOOT_RUNTIME.update_factory_underlay_animations then
        LOOT_RUNTIME.update_factory_underlay_animations(self, dt)
    end
    update_human_visual_state(self)
    update_derple_feedback_triggers(self, dt)
    update_exit_green_smoke_fx(self)
    update_selected_unit_pulse(self, dt)
    update_selected_unit_ui(self)
    if (self.game_flow_state or FLOW_STATE_GAME) == FLOW_STATE_OUTRO then
        self.flow_outro_timer = (self.flow_outro_timer or 0) + dt
        if (self.flow_outro_timer or 0) >= 8.0 then
            enter_score_flow(self)
        end
    end
    update_flow_ui(self, dt)
    LOOT_RUNTIME.update_drag_visual(self)
    update_human_ap_debug_label(self)
    if self.world_backdrop or (self.world_backdrop_tiles and #self.world_backdrop_tiles > 0) then
        local profile = get_aesthetic_profile(self)
        local pan_speed_x = (profile and profile.backdrop_pan_speed_x) or 0
        local pan_speed_y = (profile and profile.backdrop_pan_speed_y) or 0
        local parallax_factor = (profile and profile.backdrop_parallax_factor) or 1
        local follow_camera = not (profile and profile.backdrop_follow_camera == false)
        self.world_backdrop_pan_x = (self.world_backdrop_pan_x or 0) + (pan_speed_x * dt)
        self.world_backdrop_pan_y = (self.world_backdrop_pan_y or 0) + (pan_speed_y * dt)
        if follow_camera then
            if self.world_backdrop_prev_camera_x == nil or self.world_backdrop_prev_camera_y == nil then
                self.world_backdrop_prev_camera_x = self.camera_pos.x
                self.world_backdrop_prev_camera_y = self.camera_pos.y
                self.world_backdrop_parallax_x = self.camera_pos.x
                self.world_backdrop_parallax_y = self.camera_pos.y
            else
                local camera_dx = self.camera_pos.x - self.world_backdrop_prev_camera_x
                local camera_dy = self.camera_pos.y - self.world_backdrop_prev_camera_y
                self.world_backdrop_parallax_x = (self.world_backdrop_parallax_x or self.camera_pos.x) + (camera_dx * parallax_factor)
                self.world_backdrop_parallax_y = (self.world_backdrop_parallax_y or self.camera_pos.y) + (camera_dy * parallax_factor)
                self.world_backdrop_prev_camera_x = self.camera_pos.x
                self.world_backdrop_prev_camera_y = self.camera_pos.y
            end
        else
            if self.world_backdrop_anchor_world_x == nil or self.world_backdrop_anchor_world_y == nil then
                self.world_backdrop_anchor_world_x = self.camera_pos.x
                self.world_backdrop_anchor_world_y = self.camera_pos.y
            end
            self.world_backdrop_prev_camera_x = nil
            self.world_backdrop_prev_camera_y = nil
            self.world_backdrop_parallax_x = nil
            self.world_backdrop_parallax_y = nil
        end
        local backdrop_cam_x = nil
        local backdrop_cam_y = nil
        if follow_camera then
            backdrop_cam_x = (parallax_factor == 1) and self.camera_pos.x or (self.world_backdrop_parallax_x or self.camera_pos.x)
            backdrop_cam_y = (parallax_factor == 1) and self.camera_pos.y or (self.world_backdrop_parallax_y or self.camera_pos.y)
        else
            backdrop_cam_x = self.world_backdrop_anchor_world_x or self.camera_pos.x
            backdrop_cam_y = self.world_backdrop_anchor_world_y or self.camera_pos.y
        end
        local bx = backdrop_cam_x + (self.world_backdrop_base_offset_x or 0) + (self.world_backdrop_pan_x or 0)
        local by = backdrop_cam_y + (self.world_backdrop_base_offset_y or 0) + (self.world_backdrop_pan_y or 0)
        if self.world_backdrop then
            local backdrop_scale = (profile and profile.backdrop_scale) or 1
            local sx = (SCREEN_WIDTH / (self.world_backdrop_art_w or 256)) * backdrop_scale
            local sy = (SCREEN_HEIGHT / (self.world_backdrop_art_h or 256)) * backdrop_scale
            local final_by = by
            local align_bottom_world_y = profile and profile.backdrop_align_bottom_world_y
            if align_bottom_world_y == nil and profile and profile.backdrop_align_to_lowest_tile_floor == true and self.world_grid then
                local lowest_y_cell = nil
                for _, cell in ipairs(self.world_grid) do
                    if cell and cell.tileID and cell.tileID ~= hash("empty") then
                        local y_cell = cell.yCell or 1
                        if lowest_y_cell == nil or y_cell < lowest_y_cell then
                            lowest_y_cell = y_cell
                        end
                    end
                end
                if lowest_y_cell ~= nil then
                    local _, lowest_row_center_y = coords_to_world_pos(1, lowest_y_cell)
                    align_bottom_world_y = lowest_row_center_y - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM + ((profile.backdrop_floor_align_offset_y) or 0)
                end
            end
            if align_bottom_world_y ~= nil then
                if self.world_backdrop_anchor_camera_y == nil then
                    self.world_backdrop_anchor_camera_y = backdrop_cam_y
                end
                local parallax_delta_y = backdrop_cam_y - self.world_backdrop_anchor_camera_y
                local backdrop_height = (self.world_backdrop_art_h or 256) * sy
                final_by = align_bottom_world_y + (backdrop_height * 0.5) + parallax_delta_y + (self.world_backdrop_pan_y or 0)
            end
            go.set_position(vmath.vector3(bx, final_by, self.world_backdrop_z or -0.2), self.world_backdrop)
            go.set_scale(vmath.vector3(sx, sy, 1), self.world_backdrop)
            apply_backdrop_emissive_tint(self, dt, profile)
        end
        if self.world_backdrop_tiles and #self.world_backdrop_tiles > 0 then
            local cols = (profile and profile.backdrop_tile_cols) or 5
            local rows = (profile and profile.backdrop_tile_rows) or 5
            local tile_art_w = (profile and profile.backdrop_tile_art_w) or 256
            local tile_art_h = (profile and profile.backdrop_tile_art_h) or 256
            local tile_scale_base = (profile and profile.backdrop_tile_scale) or 1
            local tile_scale_x = tile_scale_base
            local tile_scale_y = tile_scale_base
            local tile_span_x = tile_art_w * tile_scale_x
            local tile_span_y = tile_art_h * tile_scale_y
            local x0 = bx - (((cols - 1) * tile_span_x) * 0.5)
            local y0 = by - (((rows - 1) * tile_span_y) * 0.5)
            local tile_i = 1
            for row = 1, rows do
                for col = 1, cols do
                    local tile_id = self.world_backdrop_tiles[tile_i]
                    if tile_id then
                        local px = x0 + ((col - 1) * tile_span_x)
                        local py = y0 + ((row - 1) * tile_span_y)
                        go.set_position(vmath.vector3(px, py, self.world_backdrop_z or -0.2), tile_id)
                        go.set_scale(vmath.vector3(tile_scale_x, tile_scale_y, 1), tile_id)
                    end
                    tile_i = tile_i + 1
                end
            end
        end
    end
    update_backdrop_cloud_fx(self)
    if self.table_sweep_shadow_overlay then
        local profile = get_aesthetic_profile(self)
        local pan_speed_x = (profile and profile.table_sweep_shadow_pan_speed_x) or 0
        local pan_speed_y = (profile and profile.table_sweep_shadow_pan_speed_y) or 0
        -- Treat sweep offsets/speed as screen-space so motion feels identical across zoom levels.
        local start_x = (-SCREEN_WIDTH * 0.6) - 1000
        local end_x = (SCREEN_WIDTH * 0.6) + 1000
        local pan_x = self.table_sweep_shadow_pan_x
        local pause_timer = self.table_sweep_shadow_pause_timer or 0
        if pan_x == nil then
            pan_x = start_x
        elseif pause_timer > 0 then
            pause_timer = math.max(0, pause_timer - dt)
        else
            pan_x = pan_x + (pan_speed_x * dt)
            if pan_x > end_x then
                pan_x = start_x
                pause_timer = 10 + (math.random() * 10)
            end
        end
        local pan_y = (self.table_sweep_shadow_pan_y or 0) + (pan_speed_y * dt)
        self.table_sweep_shadow_pan_x = pan_x
        self.table_sweep_shadow_pan_y = pan_y
        self.table_sweep_shadow_pause_timer = pause_timer
        local sx = ((SCREEN_WIDTH / self.camera_zoom) / (self.table_sweep_shadow_art_w or 256)) * (self.table_sweep_shadow_scale_x or 1)
        local sy = ((SCREEN_HEIGHT / self.camera_zoom) / (self.table_sweep_shadow_art_h or 256)) * (self.table_sweep_shadow_scale_y or 1)
        local ox = ((self.table_sweep_shadow_base_offset_x or 0) + pan_x) / self.camera_zoom
        local oy = ((self.table_sweep_shadow_base_offset_y or 0) + pan_y) / self.camera_zoom
        go.set_position(vmath.vector3(self.camera_pos.x + ox, self.camera_pos.y + oy, self.table_sweep_shadow_z or 0.74), self.table_sweep_shadow_overlay)
        go.set_scale(vmath.vector3(sx, sy, 1), self.table_sweep_shadow_overlay)
    end
    if self.sheen_overlay then
        local sx = (SCREEN_WIDTH / self.camera_zoom) / (self.sheen_art_w or 768)
        local sy = (SCREEN_HEIGHT / self.camera_zoom) / (self.sheen_art_h or 576)
        local ox = self.sheen_offset_x or 0
        local oy = self.sheen_offset_y or 0
        go.set_position(vmath.vector3(self.camera_pos.x + ox, self.camera_pos.y + oy, self.sheen_z or 0.4), self.sheen_overlay)
        go.set_scale(vmath.vector3(sx, sy, 1), self.sheen_overlay)
    end

    if not self.is_panning then
        local speed = math.sqrt(self.pan_velocity_x * self.pan_velocity_x + self.pan_velocity_y * self.pan_velocity_y)
        if speed > self.pan_inertia_min_speed then
            self.camera_pos.x = self.camera_pos.x + self.pan_velocity_x * dt
            self.camera_pos.y = self.camera_pos.y + self.pan_velocity_y * dt

            local decay = math.exp(-self.pan_inertia_damping * dt)
            self.pan_velocity_x = self.pan_velocity_x * decay
            self.pan_velocity_y = self.pan_velocity_y * decay

            apply_camera_transform(self)
        else
            self.pan_velocity_x = 0
            self.pan_velocity_y = 0
        end
    end
end

-- =============================================================================
-- INPUT FUNCTION
-- =============================================================================

function on_input(self, action_id, action)
    if action_id == hash("touch") then
        local input_x, input_y, inside_view = map_window_input_to_logical(action.x, action.y, action.screen_x, action.screen_y)
        if (self.game_flow_state or FLOW_STATE_GAME) ~= FLOW_STATE_GAME then
            if action.released and inside_view and input_x and input_y then
                handle_flow_touch(self, input_x, input_y)
            end
            return true
        end
        if self.drag_resource and self.drag_resource.active then
            if input_x and input_y then
                LOOT_RUNTIME.update_resource_drag(self, input_x, input_y)
            end
            if action.released then
                if self.mp_state and self.mp_state.enabled then
                    local world_x, world_y = screen_to_world(input_x, input_y, self.camera_pos, self.camera_zoom)
                    multiplayer_transport_send_command(self, "resource_drag_end", {
                        turn_id = self.mp_state.turn_id or 1,
                        screen_x = input_x,
                        screen_y = input_y,
                        world_x = world_x,
                        world_y = world_y,
                        drag = multiplayer_clone_flat_table(self.drag_resource)
                    }, multiplayer_get_active_player_id_for_commands(self))
                    self.drag_resource = { active = false }
                else
                    LOOT_RUNTIME.end_resource_drag(self, input_x, input_y)
                end
            end
            return true
        end

        if action.pressed then
            self.zoom_input_armed = true
            if not inside_view then
                return true
            end
            if get_selected_unit(self) and is_point_in_ui_panel(input_x, input_y) then
                if LOOT_RUNTIME.begin_command_drag(self, input_x, input_y) then
                    self.is_panning = false
                    self.did_drag = true
                    return true
                end
                if LOOT_RUNTIME.begin_resource_drag(self, input_x, input_y) then
                    self.is_panning = false
                    self.did_drag = true
                    return true
                end
            end

            self.is_panning = true
            self.did_drag = false
            self.drag_start_screen_x = input_x
            self.drag_start_screen_y = input_y
            self.drag_start_camera_pos = vmath.vector3(self.camera_pos)
            self.last_pan_screen_x = input_x
            self.last_pan_screen_y = input_y
            self.pan_velocity_x = 0
            self.pan_velocity_y = 0
        elseif action.released then
            if not inside_view then
                self.is_panning = false
                self.pan_velocity_x = 0
                self.pan_velocity_y = 0
                return true
            end
            if not self.did_drag then
                if try_multiplayer_debug_player_buttons(self, input_x, input_y) then
                    return true
                end
                if try_multiplayer_ready_buttons(self, input_x, input_y) then
                    return true
                end
                if try_next_turn_button(self, input_x, input_y) then
                    return true
                end
                if try_launch_button(self, input_x, input_y) then
                    return true
                end
                if try_toggle_aesthetic_ui_button(self, input_x, input_y) then
                    return true
                end
                if try_zoom_in_button(self, input_x, input_y) then
                    return true
                end
                if try_zoom_out_button(self, input_x, input_y) then
                    return true
                end
                if try_toggle_reactive_combat(self, input_x, input_y) then
                    return true
                end
                if try_select_level_button(self, input_x, input_y) then
                    return true
                end
                if try_advance_reactive_alien_turn(self, input_x, input_y) then
                    return true
                end
                if get_selected_unit(self) and is_point_in_ui_panel(input_x, input_y) then
                    if try_close_selected_unit_ui(self, input_x, input_y) then
                        return
                    end
                    return
                end
                local mapped_action = { x = input_x, y = input_y }
                local world_x, world_y = screen_to_world(input_x, input_y, self.camera_pos, self.camera_zoom)
                local clicked_cell_id = handle_cell_click(mapped_action, self.camera_pos, self.camera_zoom)
                if clicked_cell_id then
                    if LOOT_RUNTIME.handle_world_click_selected_unit(self, input_x, input_y, clicked_cell_id) then
                        return true
                    end
                    local handled_by_human = handle_human_click_flow(self, clicked_cell_id, world_x, world_y)
                    if not handled_by_human then
                        process_cell_selection(self, clicked_cell_id)
                    end
                end
            end
            self.is_panning = false
            self.pan_velocity_x = 0
            self.pan_velocity_y = 0
        elseif self.is_panning and input_x and input_y and inside_view then
            local dx = input_x - self.drag_start_screen_x
            local dy = input_y - self.drag_start_screen_y
            local drag_distance = math.sqrt(dx * dx + dy * dy)

            if drag_distance >= self.drag_threshold_px then
                self.did_drag = true
            end

            if self.did_drag then
                -- Convert screen drag to world offset (zoom-aware).
                local old_cam_x = self.camera_pos.x
                local old_cam_y = self.camera_pos.y
                self.camera_pos.x = self.drag_start_camera_pos.x - (dx / self.camera_zoom)
                self.camera_pos.y = self.drag_start_camera_pos.y - (dy / self.camera_zoom)
                apply_camera_transform(self)

                -- Approximate world-space pan velocity for release inertia.
                local frame_dx = input_x - self.last_pan_screen_x
                local frame_dy = input_y - self.last_pan_screen_y
                self.pan_velocity_x = -(frame_dx / self.camera_zoom) * 60
                self.pan_velocity_y = -(frame_dy / self.camera_zoom) * 60
                self.last_pan_screen_x = input_x
                self.last_pan_screen_y = input_y

                -- If clamped by bounds, don't keep adding outward velocity.
                if self.camera_pos.x == old_cam_x then
                    self.pan_velocity_x = 0
                end
                if self.camera_pos.y == old_cam_y then
                    self.pan_velocity_y = 0
                end
            end
        end
    elseif action_id == hash("zoom_in") then
        if (self.game_flow_state or FLOW_STATE_GAME) ~= FLOW_STATE_GAME then
            return true
        end
        if self.zoom_block_timer and self.zoom_block_timer > 0 then
            return true
        end
        if not ((action.value and action.value ~= 0) or action.pressed or action.repeated) then
            return true
        end
        local focus_x, focus_y, inside_view = map_window_input_to_logical(action.x, action.y, action.screen_x, action.screen_y)
        if not inside_view then
            focus_x = SCREEN_WIDTH * 0.5
            focus_y = SCREEN_HEIGHT * 0.5
        end
        focus_x = focus_x or (SCREEN_WIDTH * 0.5)
        focus_y = focus_y or (SCREEN_HEIGHT * 0.5)
        request_zoom_delta(self, 0.12, focus_x, focus_y)
    elseif action_id == hash("zoom_out") then
        if (self.game_flow_state or FLOW_STATE_GAME) ~= FLOW_STATE_GAME then
            return true
        end
        if self.zoom_block_timer and self.zoom_block_timer > 0 then
            return true
        end
        if not ((action.value and action.value ~= 0) or action.pressed or action.repeated) then
            return true
        end
        local focus_x, focus_y, inside_view = map_window_input_to_logical(action.x, action.y, action.screen_x, action.screen_y)
        if not inside_view then
            focus_x = SCREEN_WIDTH * 0.5
            focus_y = SCREEN_HEIGHT * 0.5
        end
        focus_x = focus_x or (SCREEN_WIDTH * 0.5)
        focus_y = focus_y or (SCREEN_HEIGHT * 0.5)
        request_zoom_delta(self, -0.12, focus_x, focus_y)
    elseif action_id == hash("toggle_aesthetic_mode") and action.pressed then
        if (self.game_flow_state or FLOW_STATE_GAME) ~= FLOW_STATE_GAME then
            return true
        end
        toggle_aesthetic_mode(self)
        return true
    elseif action_id == hash("next_turn") and action.pressed then
        if (self.game_flow_state or FLOW_STATE_GAME) ~= FLOW_STATE_GAME then
            return true
        end
        if self.alien_turn_active
            or self.pending_spitter_attack_phase
            or self.pending_melee_attack_phase
            or any_alien_is_moving(self)
        then
            return true
        end
        if not can_advance_next_turn(self, true) then
            return true
        end
        if self.mp_state and self.mp_state.enabled then
            multiplayer_transport_send_command(self, "new_turn_request", {
                turn_id = self.mp_state and self.mp_state.turn_id or 1
            }, self.mp_state and self.mp_state.host_player_id or "p1")
        else
            next_turn_reset_human_ap(self)
            if LOOT_RUNTIME.process_factory_turn then
                LOOT_RUNTIME.process_factory_turn(self)
            end
            process_alien_turn(self)
        end
    end
end

-- =============================================================================
-- MESSAGE HANDLER
-- =============================================================================

function on_message(self, message_id, message, sender)
    if message_id == hash("next_turn") then
        if (self.game_flow_state or FLOW_STATE_GAME) ~= FLOW_STATE_GAME then
            return
        end
        if self.alien_turn_active
            or self.pending_spitter_attack_phase
            or self.pending_melee_attack_phase
            or any_alien_is_moving(self)
        then
            return
        end
        local is_network_authoritative_turn = message and message.from_mp_turn_advanced == true
        if (not is_network_authoritative_turn) and (not can_advance_next_turn(self, true)) then
            return
        end
        next_turn_reset_human_ap(self)
        local skip_authoritative_sim = message and message.skip_authoritative_sim == true
        if skip_authoritative_sim then
            print("MP TURN | non_host_skip_local_alien_factory_sim")
            return
        end
        if LOOT_RUNTIME.process_factory_turn then
            LOOT_RUNTIME.process_factory_turn(self)
        end
        process_alien_turn(self)
    end
end

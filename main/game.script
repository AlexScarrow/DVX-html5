local function get_controlled_unit(self)
    if not self.squad_units or not self.controlled_unit_id then
        return nil
    end
    return self.squad_units[self.controlled_unit_id]
end

local function get_unit_by_id(self, unit_id)
    if not self.squad_units or not unit_id then
        return nil
    end
    return self.squad_units[unit_id]
end

local function get_unit_on_cell(self, cell_id)
    if not self.squad_units then
        return nil
    end
    for _, unit in pairs(self.squad_units) do
        if unit.cell_id == cell_id then
            return unit
        end
    end
    return nil
end

local function get_units_on_cell(self, cell_id)
    local units = {}
    if not self.squad_units then
        return units
    end
    for _, unit in pairs(self.squad_units) do
        if unit.cell_id == cell_id then
            table.insert(units, unit)
        end
    end
    return units
end

local function get_spawn_order_unit_id_list()
    return { "sarge", "techie", "medic", "gunner" }
end

local function sort_units_by_spawn_order(units)
    local order = { sarge = 1, techie = 2, medic = 3, gunner = 4 }
    table.sort(units, function(a, b)
        return (order[a.id] or 99) < (order[b.id] or 99)
    end)
end

local function ensure_cell_slot_assignment(self, unit, cell_id)
    if not unit or not cell_id then
        return 1
    end

    self.cell_slot_assignments = self.cell_slot_assignments or {}
    self.cell_slot_assignments[cell_id] = self.cell_slot_assignments[cell_id] or {}
    local assignment = self.cell_slot_assignments[cell_id]

    if assignment[unit.id] then
        return assignment[unit.id]
    end

    local used = {}
    for _, slot_index in pairs(assignment) do
        used[slot_index] = true
    end

    local selected_slot = 1
    for i = 1, #CELL_SLOT_OFFSETS_X do
        if not used[i] then
            selected_slot = i
            break
        end
    end

    assignment[unit.id] = selected_slot
    return selected_slot
end

local function clear_cell_slot_assignment(self, unit, cell_id)
    if not unit or not cell_id or not self.cell_slot_assignments then
        return
    end
    local assignment = self.cell_slot_assignments[cell_id]
    if assignment then
        assignment[unit.id] = nil
    end
end

local function cell_has_any_unit_except(self, cell_id, except_unit_id)
    if not self.squad_units then
        return false
    end
    for _, unit in pairs(self.squad_units) do
        if unit.id ~= except_unit_id and unit.cell_id == cell_id then
            return true
        end
    end
    return false
end

local function deselect_all_units(self)
    if not self.squad_units then
        return
    end
    for _, unit in pairs(self.squad_units) do
        unit.is_selected = false
    end
end

local function any_unit_is_moving(self)
    if not self.squad_units then
        return false
    end
    for _, unit in pairs(self.squad_units) do
        if unit.is_moving then
            return true
        end
    end
    return false
end

local function unit_has_role(unit, role_key)
    if not unit then
        return false
    end
    local role = CLASS_ROLE_HOOKS[unit.class_id]
    return role and role[role_key] == true
end

local function get_unit_base_tint(unit)
    if not unit then
        return vmath.vector4(1, 1, 1, 1)
    end
    if unit.class_id == UNIT_CLASS_SARGE then
        return HUMAN_TINT_SARGE
    elseif unit.class_id == UNIT_CLASS_TECHIE then
        return HUMAN_TINT_TECHIE
    elseif unit.class_id == UNIT_CLASS_MEDIC then
        return HUMAN_TINT_MEDIC
    elseif unit.class_id == UNIT_CLASS_GUNNER then
        return HUMAN_TINT_GUNNER
    end
    return vmath.vector4(1, 1, 1, 1)
end

local function get_selected_tint(base_tint)
    return vmath.vector4(
        math.min(base_tint.x + 0.2, 1),
        math.min(base_tint.y + 0.2, 1),
        math.min(base_tint.z + 0.2, 1),
        1
    )
end

-- FUTURE GAMEPLAY HOOKS (role-gated actions)
local function can_donate_ap(unit)
    return unit_has_role(unit, "can_donate_ap")
end

local function can_fix(unit)
    return unit_has_role(unit, "can_fix")
end

local function can_heal(unit)
    return unit_has_role(unit, "can_heal")
end

local function has_heavy_weapon(unit)
    return unit_has_role(unit, "heavy_weapon")
end

local function get_unit_ranged_hit_bonus(unit)
    if not unit then
        return 0
    end
    local role = CLASS_ROLE_HOOKS[unit.class_id]
    return (role and role.ranged_hit_bonus) or 0
end

local function print_squad_debug_overview(self)
    if not self.squad_units then
        return
    end

    print("=== SQUAD DEBUG (UI placeholder in console) ===")
    for _, unit in pairs(self.squad_units) do
        print(string.format(
            "  %s class=%s AP=%d/%d roles{donate=%s fix=%s heal=%s heavy=%s}",
            unit.display_name,
            unit.class_id,
            unit.current_ap,
            unit.max_ap,
            tostring(unit_has_role(unit, "can_donate_ap")),
            tostring(unit_has_role(unit, "can_fix")),
            tostring(unit_has_role(unit, "can_heal")),
            tostring(unit_has_role(unit, "heavy_weapon"))
        ))
    end
end

local function find_first_walkable_cell(world_grid)
    for cell_id, cell in ipairs(world_grid) do
        if cell.tileID ~= hash("empty") then
            return cell_id
        end
    end
    return nil
end

local function set_unit_scale(unit, scale_x, scale_y)
    if unit and unit.go_path then
        go.set_scale(vmath.vector3(scale_x, scale_y, 1), unit.go_path)
    end
end

local function update_human_visual_state(self)
    if not self.squad_units then
        return
    end

    for _, unit in pairs(self.squad_units) do
        if unit.sprite_path then
            local flash_timer = unit.hit_flash_timer or 0
            if not (unit and (unit.current_health or 0) > 0) then
                go.set(unit.sprite_path, "tint", vmath.vector4(0.18, 0.18, 0.18, 1))
            elseif flash_timer > 0 then
                local flash_band = math.floor(flash_timer * 24) % 2
                if flash_band == 0 then
                    go.set(unit.sprite_path, "tint", vmath.vector4(1, 0.15, 0.15, 1))
                else
                    go.set(unit.sprite_path, "tint", vmath.vector4(0.65, 0.05, 0.05, 1))
                end
            elseif unit.current_ap <= 0 then
                go.set(unit.sprite_path, "tint", HUMAN_TINT_NO_AP)
            else
                local base_tint = get_unit_base_tint(unit)
                if unit.is_selected then
                    go.set(unit.sprite_path, "tint", get_selected_tint(base_tint))
                else
                    go.set(unit.sprite_path, "tint", base_tint)
                end
            end
        end
    end
end

local function update_selected_unit_pulse(self, dt)
    if not self.squad_units then
        return
    end

    for _, unit in pairs(self.squad_units) do
        if unit.go_path and not unit.is_moving then
            if unit.is_selected and unit.current_ap > 0 then
                unit.select_pulse_phase = (unit.select_pulse_phase or 0) + (dt * UNIT_SELECTED_PULSE_SPEED * math.pi * 2)
                local pulse = 1 + UNIT_SELECTED_PULSE_AMPLITUDE * math.sin(unit.select_pulse_phase)
                set_unit_scale(unit, HUMAN_VISUAL_SCALE * pulse, HUMAN_VISUAL_SCALE * pulse)
            else
                unit.select_pulse_phase = 0
                set_unit_scale(unit, HUMAN_VISUAL_SCALE, HUMAN_VISUAL_SCALE)
            end
        end
    end
end

local function create_ui_square(screen_x, screen_y, z, color, scale_x, scale_y)
    local pos = vmath.vector3(screen_x, screen_y, z)
    local id = factory.create("/ui_factory#ui_factory", pos)
    if id then
        go.set_scale(vmath.vector3(scale_x, scale_y, 1), id)
        go.set(msg.url(nil, id, "sprite"), "tint", color)
    end
    return id
end

local function create_ui_panel_sprite(screen_x, screen_y, z, scale_x, scale_y)
    local pos = vmath.vector3(screen_x, screen_y, z)
    local id = factory.create("/ui_panel_factory#ui_panel_factory", pos)
    if id then
        go.set_scale(vmath.vector3(scale_x, scale_y, 1), id)
    end
    return id
end

local function set_ui_square_transform(self, go_id, screen_x, screen_y, z, color, scale_x, scale_y)
    if not go_id then
        return
    end
    local wx, wy = screen_to_world(screen_x, screen_y, self.camera_pos, self.camera_zoom)
    go.set_position(vmath.vector3(wx, wy, z), go_id)
    go.set_scale(vmath.vector3(scale_x / self.camera_zoom, scale_y / self.camera_zoom, 1), go_id)
    go.set(msg.url(nil, go_id, "sprite"), "tint", color)
end

local function set_ui_panel_transform(self, go_id, screen_x, screen_y, z, scale_x, scale_y)
    if not go_id then
        return
    end
    local wx, wy = screen_to_world(screen_x, screen_y, self.camera_pos, self.camera_zoom)
    local sx = (scale_x / UI_PANEL_ART_W) / self.camera_zoom
    local sy = (scale_y / UI_PANEL_ART_H) / self.camera_zoom
    go.set_position(vmath.vector3(wx, wy, z), go_id)
    go.set_scale(vmath.vector3(sx, sy, 1), go_id)
    go.set(msg.url(nil, go_id, "sprite"), "tint", vmath.vector4(1, 1, 1, 1))
end

local function initialize_unit_ui(self)
    self.ui = {
        panel_art = nil,
        ap_pips = {},
        hp_pips = {},
        ammo_pips = {},
        command_pips = {},
        backpack_slots = {},
        backpack_item_icons = {},
        component_button = nil,
        fix_button = nil,
        loot_button = nil,
        retrieve_button = nil,
        close_button = nil,
        reactive_toggle_button = nil,
        reactive_advance_button = nil,
        drag_pip = nil
    }

    self.ui.panel_art = create_ui_panel_sprite(UI_PANEL_X, UI_PANEL_Y, 0.8, UI_PANEL_W, UI_PANEL_H)

    for i = 1, UI_MAX_PIPS do
        self.ui.ap_pips[i] = create_ui_square(0, 0, 0.81, UI_COLOR_AP, UI_BAR_PIP_SIZE, UI_BAR_PIP_SIZE)
        self.ui.hp_pips[i] = create_ui_square(0, 0, 0.81, UI_COLOR_HP, UI_BAR_PIP_SIZE, UI_BAR_PIP_SIZE)
        self.ui.ammo_pips[i] = create_ui_square(0, 0, 0.81, UI_COLOR_AMMO, UI_BAR_PIP_SIZE, UI_BAR_PIP_SIZE)
    end

    for i = 1, COMMAND_UI.max_pips do
        self.ui.command_pips[i] = create_ui_square(0, 0, 0.81, COMMAND_UI.inactive_color, COMMAND_UI.pip_size, COMMAND_UI.pip_size)
    end

    for i = 1, (UI_BACKPACK_COLS * UI_BACKPACK_ROWS) do
        self.ui.backpack_slots[i] = create_ui_square(0, 0, 0.81, UI_COLOR_SLOT, UI_BACKPACK_SLOT_SIZE, UI_BACKPACK_SLOT_SIZE)
        self.ui.backpack_item_icons[i] = factory.create("/loot_marker_factory#loot_marker_factory", vmath.vector3(-9999, -9999, 0.815))
    end
    self.ui.component_button = create_ui_square(0, 0, 0.82, COMPONENT_UI.button_color, COMPONENT_UI.button_size, COMPONENT_UI.button_size)
    self.ui.fix_button = create_ui_square(0, 0, 0.82, COMPONENT_UI.fix_button_color, COMPONENT_UI.fix_button_size, COMPONENT_UI.fix_button_size)
    self.ui.loot_button = create_ui_square(0, 0, 0.82, LOOT_UI.button_color, LOOT_UI.button_size, LOOT_UI.button_size)
    self.ui.retrieve_button = create_ui_square(0, 0, 0.82, LOOT_UI.retrieve_button_color, LOOT_UI.retrieve_button_size, LOOT_UI.retrieve_button_size)
    self.ui.close_button = create_ui_square(0, 0, 0.83, vmath.vector4(0.8, 0.2, 0.2, 0.95), 28, 28)
    self.ui.reactive_toggle_button = create_ui_square(0, 0, 0.84, vmath.vector4(0.8, 0.2, 0.2, 0.95), 30, 30)
    self.ui.reactive_advance_button = create_ui_square(0, 0, 0.84, vmath.vector4(0.2, 0.8, 0.2, 0.95), 70, 30)
    self.ui.drag_pip = create_ui_square(0, 0, 0.9, vmath.vector4(0, 0, 0, 0), LOOT_UI.drag_pip_size, LOOT_UI.drag_pip_size)

    print(string.format(
        "UI panel pixels: panel=%dx%d, portrait=%dx%d, footer=%dx%d, pip=%dx%d (max %d), backpack slots=%d (%dx%d each, %dx%d grid)",
        UI_PANEL_W, UI_PANEL_H, UI_PORTRAIT_W, UI_PORTRAIT_H, UI_FOOTER_W, UI_FOOTER_H,
        UI_BAR_PIP_SIZE, UI_BAR_PIP_SIZE, UI_MAX_PIPS, UI_BACKPACK_COLS * UI_BACKPACK_ROWS,
        UI_BACKPACK_SLOT_SIZE, UI_BACKPACK_SLOT_SIZE, UI_BACKPACK_COLS, UI_BACKPACK_ROWS
    ))
end

local function set_ui_hidden(self)
    if not self.ui then
        return
    end

    local hidden = vmath.vector4(0, 0, 0, 0)
    set_ui_panel_transform(self, self.ui.panel_art, -9999, -9999, 0.8, UI_PANEL_W, UI_PANEL_H)
    for i = 1, UI_MAX_PIPS do
        set_ui_square_transform(self, self.ui.ap_pips[i], -9999, -9999, 0.81, hidden, UI_BAR_PIP_SIZE, UI_BAR_PIP_SIZE)
        set_ui_square_transform(self, self.ui.hp_pips[i], -9999, -9999, 0.81, hidden, UI_BAR_PIP_SIZE, UI_BAR_PIP_SIZE)
        set_ui_square_transform(self, self.ui.ammo_pips[i], -9999, -9999, 0.81, hidden, UI_BAR_PIP_SIZE, UI_BAR_PIP_SIZE)
    end
    for i = 1, COMMAND_UI.max_pips do
        set_ui_square_transform(self, self.ui.command_pips[i], -9999, -9999, 0.81, hidden, COMMAND_UI.pip_size, COMMAND_UI.pip_size)
    end
    for i = 1, (UI_BACKPACK_COLS * UI_BACKPACK_ROWS) do
        set_ui_square_transform(self, self.ui.backpack_slots[i], -9999, -9999, 0.81, hidden, UI_BACKPACK_SLOT_SIZE, UI_BACKPACK_SLOT_SIZE)
        set_ui_square_transform(self, self.ui.backpack_item_icons[i], -9999, -9999, 0.815, hidden, UI_BACKPACK_SLOT_SIZE * 0.021, UI_BACKPACK_SLOT_SIZE * 0.021)
    end
    set_ui_square_transform(self, self.ui.component_button, -9999, -9999, 0.82, hidden, COMPONENT_UI.button_size, COMPONENT_UI.button_size)
    set_ui_square_transform(self, self.ui.fix_button, -9999, -9999, 0.82, hidden, COMPONENT_UI.fix_button_size, COMPONENT_UI.fix_button_size)
    set_ui_square_transform(self, self.ui.loot_button, -9999, -9999, 0.82, hidden, LOOT_UI.button_size, LOOT_UI.button_size)
    set_ui_square_transform(self, self.ui.retrieve_button, -9999, -9999, 0.82, hidden, LOOT_UI.retrieve_button_size, LOOT_UI.retrieve_button_size)
    set_ui_square_transform(self, self.ui.close_button, -9999, -9999, 0.83, hidden, 28, 28)
    set_ui_square_transform(self, self.ui.reactive_toggle_button, -9999, -9999, 0.84, hidden, 30, 30)
    set_ui_square_transform(self, self.ui.reactive_advance_button, -9999, -9999, 0.84, hidden, 70, 30)
    set_ui_square_transform(self, self.ui.drag_pip, -9999, -9999, 0.9, hidden, LOOT_UI.drag_pip_size, LOOT_UI.drag_pip_size)
end

local function get_selected_unit(self)
    if not self.squad_units then
        return nil
    end
    for _, unit in pairs(self.squad_units) do
        if unit.is_selected then
            return unit
        end
    end
    return nil
end

LOOT_RUNTIME = require("main.loot_runtime_utils").create({
    LOOT_UI = LOOT_UI,
    COMMAND_UI = COMMAND_UI,
    COMPONENT_UI = COMPONENT_UI,
    UI_COLOR_SLOT = UI_COLOR_SLOT,
    UI_BACKPACK_COLS = UI_BACKPACK_COLS,
    UI_BACKPACK_ROWS = UI_BACKPACK_ROWS,
    UI_BACKPACK_SLOT_SIZE = UI_BACKPACK_SLOT_SIZE,
    UI_BACKPACK_SLOT_GAP = UI_BACKPACK_SLOT_GAP,
    UI_BACKPACK_START_X = UI_BACKPACK_START_X,
    UI_BACKPACK_START_Y = UI_BACKPACK_START_Y,
    UNIT_CLASS_SARGE = UNIT_CLASS_SARGE,
    UI_BAR_START_Y = UI_BAR_START_Y,
    UI_MAX_PIPS = UI_MAX_PIPS,
    UI_BAR_PIP_SIZE = UI_BAR_PIP_SIZE,
    UI_BAR_PIP_GAP = UI_BAR_PIP_GAP,
    UI_BAR_AMMO_X = UI_BAR_AMMO_X,
    UI_BAR_HP_X = UI_BAR_HP_X,
    id_to_coords = id_to_coords
})

local function update_selected_unit_ui(self)
    local unit = get_selected_unit(self)
    if not self.ui then
        return
    end
    if not unit then
        set_ui_hidden(self)
        local toggle_color = self.reactive_combat_enabled and vmath.vector4(0.2, 0.8, 0.2, 0.95) or vmath.vector4(0.8, 0.2, 0.2, 0.95)
        set_ui_square_transform(
            self,
            self.ui.reactive_toggle_button,
            40,
            SCREEN_HEIGHT - 40,
            0.84,
            toggle_color,
            30,
            30
        )
        if self.alien_turn_active and (not self.reactive_combat_enabled) then
            local adv_color = self.alien_turn_waiting_for_advance and vmath.vector4(0.2, 0.8, 0.2, 0.95) or vmath.vector4(0.8, 0.2, 0.2, 0.95)
            set_ui_square_transform(
                self,
                self.ui.reactive_advance_button,
                105,
                SCREEN_HEIGHT - 40,
                0.84,
                adv_color,
                70,
                30
            )
        else
            set_ui_square_transform(
                self,
                self.ui.reactive_advance_button,
                -9999,
                -9999,
                0.84,
                vmath.vector4(0, 0, 0, 0),
                70,
                30
            )
        end
        return
    end

    set_ui_panel_transform(self, self.ui.panel_art, UI_PANEL_X, UI_PANEL_Y, 0.8, UI_PANEL_W, UI_PANEL_H)

    for i = 1, UI_MAX_PIPS do
        local pip_y = UI_BAR_START_Y - (i - 1) * (UI_BAR_PIP_SIZE + UI_BAR_PIP_GAP)
        local ap_count = math.min(unit.current_ap or 0, UI_MAX_PIPS)
        local hp_count = math.min(unit.current_health or 0, UI_MAX_PIPS)
        local ammo_count = math.min(unit.current_ammo or 0, UI_MAX_PIPS)
        -- Count "down": higher pips drain first as values decrease.
        local ap_on = i > (UI_MAX_PIPS - ap_count)
        local hp_on = i > (UI_MAX_PIPS - hp_count)
        local ammo_on = i > (UI_MAX_PIPS - ammo_count)
        local ap_color = ap_on and UI_COLOR_AP or vmath.vector4(UI_COLOR_AP.x, UI_COLOR_AP.y, UI_COLOR_AP.z, 0.2)
        local hp_color = hp_on and UI_COLOR_HP or vmath.vector4(UI_COLOR_HP.x, UI_COLOR_HP.y, UI_COLOR_HP.z, 0.2)
        local ammo_color = ammo_on and UI_COLOR_AMMO or vmath.vector4(UI_COLOR_AMMO.x, UI_COLOR_AMMO.y, UI_COLOR_AMMO.z, 0.2)

        set_ui_square_transform(self, self.ui.ap_pips[i], UI_BAR_AP_X, pip_y, 0.81, ap_color, UI_BAR_PIP_SIZE, UI_BAR_PIP_SIZE)
        set_ui_square_transform(self, self.ui.hp_pips[i], UI_BAR_HP_X, pip_y, 0.81, hp_color, UI_BAR_PIP_SIZE, UI_BAR_PIP_SIZE)
        set_ui_square_transform(self, self.ui.ammo_pips[i], UI_BAR_AMMO_X, pip_y, 0.81, ammo_color, UI_BAR_PIP_SIZE, UI_BAR_PIP_SIZE)
    end

    local show_command = unit.class_id == UNIT_CLASS_SARGE
    local command_count = show_command and math.min(unit.command_points or 0, COMMAND_UI.max_pips) or 0
    for i = 1, COMMAND_UI.max_pips do
        local cx, cy = LOOT_RUNTIME.get_command_pip_screen_pos(i)
        local command_color = (i <= command_count) and COMMAND_UI.active_color or COMMAND_UI.inactive_color
        if self.drag_resource and self.drag_resource.active and self.drag_resource.drag_type == "command" and self.drag_resource.source_slot_index == i then
            command_color = vmath.vector4(command_color.x, command_color.y, command_color.z, 0.25)
        end
        if show_command then
            set_ui_square_transform(self, self.ui.command_pips[i], cx, cy, 0.81, command_color, COMMAND_UI.pip_size, COMMAND_UI.pip_size)
        else
            set_ui_square_transform(self, self.ui.command_pips[i], -9999, -9999, 0.81, vmath.vector4(0, 0, 0, 0), COMMAND_UI.pip_size, COMMAND_UI.pip_size)
        end
    end

    local total_slots = UI_BACKPACK_COLS * UI_BACKPACK_ROWS
    for i = 1, total_slots do
        local slot_x, slot_y = LOOT_RUNTIME.get_backpack_slot_screen_pos(i)
        local item_type = unit.backpack_items and unit.backpack_items[i] or nil
        local slot_color = item_type and LOOT_RUNTIME.get_backpack_item_color(item_type) or UI_COLOR_SLOT
        local icon_anim = nil
        if item_type == "material" then
            icon_anim = hash("material_unit")
        elseif item_type == "meds" then
            icon_anim = hash("med_unit")
        elseif item_type == "ammo" then
            icon_anim = hash("ammo_unit")
        elseif item_type == "power" then
            icon_anim = hash("power_unit")
        elseif item_type == COMPONENT_UI.component_wiring_straight then
            icon_anim = hash("wiregap_straight_on")
        elseif item_type == COMPONENT_UI.component_wiring_corner then
            icon_anim = hash("wiregap_corner_on")
        elseif item_type == COMPONENT_UI.component_fuse then
            icon_anim = hash("fuse")
        elseif item_type == COMPONENT_UI.component_plate then
            icon_anim = hash("plate")
        end
        if self.drag_resource and self.drag_resource.active and self.drag_resource.source_unit_id == unit.id and self.drag_resource.source_slot_index == i then
            slot_color = vmath.vector4(slot_color.x, slot_color.y, slot_color.z, 0.25)
        end
        set_ui_square_transform(self, self.ui.backpack_slots[i], slot_x, slot_y, 0.81, slot_color, UI_BACKPACK_SLOT_SIZE, UI_BACKPACK_SLOT_SIZE)
        if icon_anim then
            local icon_color = vmath.vector4(1, 1, 1, 1)
            if self.drag_resource and self.drag_resource.active and self.drag_resource.source_unit_id == unit.id and self.drag_resource.source_slot_index == i then
                icon_color = vmath.vector4(1, 1, 1, 0.25)
            end
            msg.post(msg.url(nil, self.ui.backpack_item_icons[i], "sprite"), "play_animation", { id = icon_anim })
            set_ui_square_transform(self, self.ui.backpack_item_icons[i], slot_x, slot_y, 0.815, icon_color, UI_BACKPACK_SLOT_SIZE * 0.021, UI_BACKPACK_SLOT_SIZE * 0.021)
        else
            set_ui_square_transform(self, self.ui.backpack_item_icons[i], -9999, -9999, 0.815, vmath.vector4(0, 0, 0, 0), UI_BACKPACK_SLOT_SIZE * 0.021, UI_BACKPACK_SLOT_SIZE * 0.021)
        end
    end

    local current_cell = unit.cell_id and self.world_grid and self.world_grid[unit.cell_id] or nil
    local show_component_button = false
    if current_cell and current_cell.isPowered and LOOT_RUNTIME.cell_has_any_vending_machine(current_cell) then
        local vm = LOOT_RUNTIME.get_vending_machine_on_cell(current_cell)
        if vm and vm.isFixed == true and LOOT_RUNTIME.is_object_dependency_met(self.world_grid, vm) then
            show_component_button = true
        end
    end
    if show_component_button then
        set_ui_square_transform(
            self,
            self.ui.component_button,
            COMPONENT_UI.button_x,
            COMPONENT_UI.button_y,
            0.82,
            COMPONENT_UI.button_color,
            COMPONENT_UI.button_size,
            COMPONENT_UI.button_size
        )
    else
        set_ui_square_transform(
            self,
            self.ui.component_button,
            -9999,
            -9999,
            0.82,
            vmath.vector4(0, 0, 0, 0),
            COMPONENT_UI.button_size,
            COMPONENT_UI.button_size
        )
    end

    set_ui_square_transform(
        self,
        self.ui.fix_button,
        -9999,
        -9999,
        0.82,
        vmath.vector4(0, 0, 0, 0),
        COMPONENT_UI.fix_button_size,
        COMPONENT_UI.fix_button_size
    )

    if current_cell and current_cell.hasLoot and current_cell.isPowered then
        set_ui_square_transform(
            self,
            self.ui.loot_button,
            LOOT_UI.button_x,
            LOOT_UI.button_y,
            0.82,
            LOOT_UI.button_color,
            LOOT_UI.button_size,
            LOOT_UI.button_size
        )
    else
        set_ui_square_transform(
            self,
            self.ui.loot_button,
            -9999,
            -9999,
            0.82,
            vmath.vector4(0, 0, 0, 0),
            LOOT_UI.button_size,
            LOOT_UI.button_size
        )
    end

    local power_node_on_cell = current_cell and LOOT_RUNTIME.get_power_node_object(current_cell) or nil
    local backpack_capacity = unit.backpack_slots or (UI_BACKPACK_COLS * UI_BACKPACK_ROWS)
    local backpack_count = unit.backpack_items and #unit.backpack_items or 0
    local show_retrieve_button = current_cell
        and current_cell.isPowered
        and power_node_on_cell ~= nil
        and backpack_count < backpack_capacity
    if show_retrieve_button then
        set_ui_square_transform(
            self,
            self.ui.retrieve_button,
            LOOT_UI.retrieve_button_x,
            LOOT_UI.retrieve_button_y,
            0.82,
            LOOT_UI.retrieve_button_color,
            LOOT_UI.retrieve_button_size,
            LOOT_UI.retrieve_button_size
        )
    else
        set_ui_square_transform(
            self,
            self.ui.retrieve_button,
            -9999,
            -9999,
            0.82,
            vmath.vector4(0, 0, 0, 0),
            LOOT_UI.retrieve_button_size,
            LOOT_UI.retrieve_button_size
        )
    end
    set_ui_square_transform(
        self,
        self.ui.close_button,
        UI_PANEL_X + (UI_PANEL_W * 0.5) - 22,
        UI_PANEL_Y + (UI_PANEL_H * 0.5) - 22,
        0.83,
        vmath.vector4(0.8, 0.2, 0.2, 0.95),
        28,
        28
    )
    local toggle_color = self.reactive_combat_enabled and vmath.vector4(0.2, 0.8, 0.2, 0.95) or vmath.vector4(0.8, 0.2, 0.2, 0.95)
    set_ui_square_transform(
        self,
        self.ui.reactive_toggle_button,
        40,
        SCREEN_HEIGHT - 40,
        0.84,
        toggle_color,
        30,
        30
    )
    if self.alien_turn_active and (not self.reactive_combat_enabled) then
        local adv_color = self.alien_turn_waiting_for_advance and vmath.vector4(0.2, 0.8, 0.2, 0.95) or vmath.vector4(0.8, 0.2, 0.2, 0.95)
        set_ui_square_transform(
            self,
            self.ui.reactive_advance_button,
            105,
            SCREEN_HEIGHT - 40,
            0.84,
            adv_color,
            70,
            30
        )
    else
        set_ui_square_transform(
            self,
            self.ui.reactive_advance_button,
            -9999,
            -9999,
            0.84,
            vmath.vector4(0, 0, 0, 0),
            70,
            30
        )
    end
end

local function is_point_in_ui_panel(screen_x, screen_y)
    local min_x = UI_PANEL_X - UI_PANEL_W * 0.5
    local max_x = UI_PANEL_X + UI_PANEL_W * 0.5
    local min_y = UI_PANEL_Y - UI_PANEL_H * 0.5
    local max_y = UI_PANEL_Y + UI_PANEL_H * 0.5
    return screen_x >= min_x and screen_x <= max_x and screen_y >= min_y and screen_y <= max_y
end

function is_point_in_close_ui_button(screen_x, screen_y)
    local button_x = UI_PANEL_X + (UI_PANEL_W * 0.5) - 22
    local button_y = UI_PANEL_Y + (UI_PANEL_H * 0.5) - 22
    local half = 14
    return screen_x >= (button_x - half)
        and screen_x <= (button_x + half)
        and screen_y >= (button_y - half)
        and screen_y <= (button_y + half)
end

function try_close_selected_unit_ui(self, screen_x, screen_y)
    if not get_selected_unit(self) then
        return false
    end
    if not is_point_in_close_ui_button(screen_x, screen_y) then
        return false
    end
    deselect_all_units(self)
    self.ui_close_on_next_non_unit_click = false
    self.awaiting_slot_shuffle_click = false
    self.selected_start_cell = nil
    update_human_visual_state(self)
    print("Unit panel closed.")
    return true
end

function try_toggle_reactive_combat(self, screen_x, screen_y)
    local tx = 40
    local ty = SCREEN_HEIGHT - 40
    if screen_x >= (tx - 15) and screen_x <= (tx + 15) and screen_y >= (ty - 15) and screen_y <= (ty + 15) then
        self.reactive_combat_enabled = not self.reactive_combat_enabled
        if self.alien_turn_active then
            -- Reactive ON should never depend on manual step-through state.
            self.alien_turn_manual_pause = false
            self.alien_turn_waiting_for_advance = false
        end
        print("Reactive combat: " .. (self.reactive_combat_enabled and "ON" or "OFF"))
        return true
    end
    return false
end

function try_advance_reactive_alien_turn(self, screen_x, screen_y)
    if not self.alien_turn_active then
        return false
    end
    if self.reactive_combat_enabled then
        return false
    end
    local ax = 105
    local ay = SCREEN_HEIGHT - 40
    if screen_x >= (ax - 35) and screen_x <= (ax + 35) and screen_y >= (ay - 15) and screen_y <= (ay + 15) then
        if self.alien_turn_waiting_for_advance then
            self.alien_turn_waiting_for_advance = false
            print("Alien turn step advanced.")
        elseif not self.reactive_combat_enabled then
            self.alien_turn_manual_pause = true
            self.alien_turn_waiting_for_advance = true
            print("Alien turn paused. Press again to advance steps.")
        end
        return true
    end
    return false
end


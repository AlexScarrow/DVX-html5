stop_speedy_move_sfx = function(self)
    if not (self and self.sfx_state and self.sfx_state.speedy_playing_by_voice and self.sfx_state.speedy_voice_urls) then
        return
    end
    for i = 1, #self.sfx_state.speedy_playing_by_voice do
        if self.sfx_state.speedy_playing_by_voice[i] == true then
            self.sfx_state.speedy_playing_by_voice[i] = false
            pcall(msg.post, self.sfx_state.speedy_voice_urls[i], "stop_sound")
        end
    end
end

update_speedy_move_sfx = function(self)
    if not (self and self.sfx_state and self.aliens) then
        if self and self.sfx_state then
            self.sfx_state.speedy_active_count = 0
            stop_speedy_move_sfx(self)
        end
        return
    end
    if not is_directional_move_sfx_allowed(self) then
        self.sfx_state.speedy_active_count = 0
        stop_speedy_move_sfx(self)
        return
    end
    local moving_speedy_count = 0
    for _, alien in ipairs(self.aliens) do
        if alien
            and alien.is_dead ~= true
            and alien.type == ALIEN_TYPE_SPEEDY
            and alien.is_moving == true
            and alien.go_id
        then
            moving_speedy_count = moving_speedy_count + 1
        end
    end
    self.sfx_state.speedy_active_count = moving_speedy_count
    local max_voices = math.max(1, tonumber(SFX_SPEEDY_MOVE_MAX_STACK_VOICES or 4) or 4)
    local target_voices = math.min(max_voices, moving_speedy_count)
    local playing = self.sfx_state.speedy_playing_by_voice or {}
    local urls = self.sfx_state.speedy_voice_urls or {}
    for i = 1, max_voices do
        local should_play = i <= target_voices
        if should_play and playing[i] ~= true then
            playing[i] = true
            pcall(msg.post, urls[i], "play_sound")
        elseif (not should_play) and playing[i] == true then
            playing[i] = false
            pcall(msg.post, urls[i], "stop_sound")
        end
    end
    self.sfx_state.speedy_playing_by_voice = playing
end

local function spawn_exit_test_stash(self)
    if EXIT_TEST_STASH_ENABLED ~= true then
        return
    end
    if not (self.world_grid and self.level_library and self.current_level_index and LOOT_RUNTIME and LOOT_RUNTIME.create_world_item_instance) then
        return
    end
    local selected_level = self.level_library[self.current_level_index]
    if not selected_level then
        return
    end
    local cell5_id = nil
    for _, placement in ipairs(selected_level) do
        if placement and placement.tile == "exit" then
            cell5_id = coords_to_id(placement.x, placement.y)
            break
        end
    end
    if not (cell5_id and self.world_grid[cell5_id] and self.world_grid[cell5_id].tileID ~= hash("empty")) then
        return
    end
    -- for _ = 1, 9 do
    --     LOOT_RUNTIME.create_world_item_instance(self, "power", cell5_id, nil, { test_stash = true })
    -- end
    if LOOT_RUNTIME.refresh_world_item_visuals then
        LOOT_RUNTIME.refresh_world_item_visuals(self)
    end
    print("TEST STASH | Spawned exit cell-5 items (9x power).")
end

function start_solo_game_flow(self)
    self.multiplayer_mode_active = false
    self.tutorial_mode = false
    if self.mp_state then
        self.mp_state.enabled = false
    end
    local selected = self.solo_setup and self.solo_setup.mission_type or self.selected_mission_type or MISSION_TYPE_ESCAPE
    self.selected_mission_type = multiplayer_normalize_mission_type(selected)
    self.controlled_unit_id = "sarge"
    local level_index = select_level_index_for_mission(self, self.selected_mission_type)
    reset_and_load_level(self, level_index)
    reset_derple_feedback_runtime(self)
    apply_aesthetic_mode(self)
    enter_flow_state(self, FLOW_STATE_GAME)
    self.game_won = false
end

local function start_tutorial_game_flow(self)
    self.multiplayer_mode_active = false
    self.tutorial_mode = true
    if self.mp_state then
        self.mp_state.enabled = false
    end
    self.selected_mission_type = MISSION_TYPE_TUTORIAL
    self.controlled_unit_id = "sarge"
    reset_and_load_level(self, 5)
    self.tutorial_mode = true
    self.tutorial_completed = false
    local step1 = TUTORIAL_STEP_DEFS[1]
    local wx, wy = get_tutorial_step_world_center(self, step1)
    if wx and wy then
        self.camera_pos.x = wx
        self.camera_pos.y = wy
        apply_camera_transform(self)
    end
    tutorial_set_current_step(self, 1)
    reset_derple_feedback_runtime(self)
    apply_aesthetic_mode(self)
    enter_flow_state(self, FLOW_STATE_GAME)
    self.game_won = false
end

solo_setup_init_runtime = function(self)
    self.solo_setup = self.solo_setup or {}
    self.solo_setup.mission_type = multiplayer_normalize_mission_type(self.solo_setup.mission_type or MISSION_TYPE_ESCAPE)
end

function start_multiplayer_game_flow(self, session_config)
    self.multiplayer_mode_active = true
    self.tutorial_mode = false
    self.selected_mission_type = multiplayer_normalize_mission_type(session_config and session_config.mission_type or self.selected_mission_type or MISSION_TYPE_ESCAPE)
    if self.mp_state then
        self.mp_state.enabled = true
        self.mp_state.session_id = "local_session_" .. tostring(os.time())
        self.mp_state.mission_type = self.selected_mission_type
        local session_player_count = session_config and session_config.player_count or self.mp_state.player_count or 4
        self.mp_state.player_count = math.max(2, math.min(4, session_player_count))
        if session_config and session_config.seat_assignments then
            self.mp_state.seat_assignments = multiplayer_clone_seat_assignments(session_config.seat_assignments, self.mp_state.player_count)
        elseif not self.mp_state.seat_assignments then
            self.mp_state.seat_assignments = multiplayer_get_default_seat_assignments(self.mp_state.player_count)
        end
        self.mp_state.required_ready_player_ids = multiplayer_get_required_ready_player_ids_for_count(self.mp_state.player_count)
        self.mp_state.workshop_state_sync_accum_s = 0
        self.mp_state.workshop_state_sync_signature = ""
        self.mp_state.factory_state_sync_accum_s = 0
        self.mp_state.factory_state_sync_signature = ""
        self.mp_state.turn_based_snapshot_accum_s = 0
        self.mp_state.turn_based_heartbeat_mismatch_streak = 0
        self.mp_state.turn_based_heartbeat_last_request_turn_id = 0
    end
    multiplayer_reset_ready_gate(self)
    if self.mp_state then
        self.mp_state.debug_active_player_id = self.mp_state.local_player_id or self.mp_state.host_player_id
    end
    local level_index = tonumber(session_config and session_config.level_index or 0) or 0
    if level_index < 1 or not (self.level_library and self.level_library[level_index]) then
        level_index = select_level_index_for_mission(self, self.selected_mission_type)
    end
    reset_and_load_level(self, level_index)
    multiplayer_enforce_controlled_unit(self, true)
    reset_derple_feedback_runtime(self)
    apply_aesthetic_mode(self)
    enter_flow_state(self, FLOW_STATE_GAME)
    self.game_won = false
end

multiplayer_setup_init_runtime = function(self)
    self.mp_setup = self.mp_setup or {}
    self.mp_setup.player_count = self.mp_setup.player_count or 2
    self.mp_setup.mission_type = multiplayer_normalize_mission_type(self.mp_setup.mission_type or MISSION_TYPE_ESCAPE)
    self.mp_setup.selected_unit_id = self.mp_setup.selected_unit_id or "techie"
    self.mp_setup.seat_slots = self.mp_setup.seat_slots or {}
    local defaults = multiplayer_get_default_seat_assignments(self.mp_setup.player_count)
    for _, player_id in ipairs(MP_SETUP_PLAYER_IDS) do
        local slot_count = multiplayer_get_slot_count_for_player(self.mp_setup.player_count, player_id)
        self.mp_setup.seat_slots[player_id] = {}
        for slot_index = 1, slot_count do
            self.mp_setup.seat_slots[player_id][slot_index] = false
        end
    end
    for player_id, units in pairs(defaults) do
        if self.mp_setup.seat_slots[player_id] then
            for slot_index, unit_id in ipairs(units) do
                if self.mp_setup.seat_slots[player_id][slot_index] ~= nil then
                    self.mp_setup.seat_slots[player_id][slot_index] = unit_id
                end
            end
        end
    end
end

multiplayer_setup_set_player_count = function(self, player_count)
    self.mp_setup = self.mp_setup or {}
    local selected_unit_before = self.mp_setup.selected_unit_id
    self.mp_setup.player_count = math.max(2, math.min(4, player_count or 2))
    self.mp_setup.mission_type = multiplayer_normalize_mission_type(self.mp_setup.mission_type or MISSION_TYPE_ESCAPE)
    self.mp_setup.selected_unit_id = selected_unit_before or "techie"
    self.mp_setup.seat_slots = {}
    local defaults = multiplayer_get_default_seat_assignments(self.mp_setup.player_count)
    for _, player_id in ipairs(MP_SETUP_PLAYER_IDS) do
        local slot_count = multiplayer_get_slot_count_for_player(self.mp_setup.player_count, player_id)
        self.mp_setup.seat_slots[player_id] = {}
        for slot_index = 1, slot_count do
            self.mp_setup.seat_slots[player_id][slot_index] = false
        end
    end
    for player_id, units in pairs(defaults) do
        for slot_index, unit_id in ipairs(units) do
            if self.mp_setup.seat_slots[player_id] and self.mp_setup.seat_slots[player_id][slot_index] ~= nil then
                self.mp_setup.seat_slots[player_id][slot_index] = unit_id
            end
        end
    end
end

multiplayer_setup_remove_unit_from_slots = function(self, unit_id)
    if not (self.mp_setup and self.mp_setup.seat_slots) then
        return
    end
    for _, player_id in ipairs(MP_SETUP_PLAYER_IDS) do
        local slots = self.mp_setup.seat_slots[player_id]
        if slots then
            for slot_index = 1, #slots do
                if slots[slot_index] == unit_id then
                    slots[slot_index] = false
                end
            end
        end
    end
end

multiplayer_setup_unit_assigned = function(self, unit_id)
    if not (self.mp_setup and self.mp_setup.seat_slots) then
        return false
    end
    for _, player_id in ipairs(MP_SETUP_PLAYER_IDS) do
        local slots = self.mp_setup.seat_slots[player_id]
        if slots then
            for slot_index = 1, #slots do
                if slots[slot_index] == unit_id then
                    return true
                end
            end
        end
    end
    return false
end

multiplayer_setup_is_valid = function(self)
    if not (self.mp_setup and self.mp_setup.seat_slots) then
        return false
    end
    local used = {}
    local total_assigned = 0
    local assigned_per_player = {}
    local count = self.mp_setup.player_count or 2
    for i = 1, count do
        local player_id = "p" .. tostring(i)
        local slot_count = multiplayer_get_slot_count_for_player(count, player_id)
        local slots = self.mp_setup.seat_slots[player_id] or {}
        local player_assigned = 0
        for slot_index = 1, slot_count do
            local unit_id = slots[slot_index]
            if unit_id and unit_id ~= false then
                if used[unit_id] then
                    return false
                end
                used[unit_id] = true
                total_assigned = total_assigned + 1
                player_assigned = player_assigned + 1
            end
        end
        assigned_per_player[player_id] = player_assigned
    end
    if total_assigned ~= #MP_SETUP_UNIT_IDS then
        return false
    end
    if multiplayer_get_player_for_unit(self.mp_setup.seat_slots, count, "sarge") ~= "p1" then
        return false
    end
    if count == 2 then
        if assigned_per_player.p1 ~= 2 or assigned_per_player.p2 ~= 2 then
            return false
        end
    elseif count == 3 then
        local p1 = assigned_per_player.p1 or 0
        local p2 = assigned_per_player.p2 or 0
        local p3 = assigned_per_player.p3 or 0
        if p1 < 1 or p1 > 2 or p2 < 1 or p2 > 2 or p3 < 1 or p3 > 2 then
            return false
        end
        local two_count = 0
        if p1 == 2 then two_count = two_count + 1 end
        if p2 == 2 then two_count = two_count + 1 end
        if p3 == 2 then two_count = two_count + 1 end
        if two_count ~= 1 then
            return false
        end
    elseif count == 4 then
        if (assigned_per_player.p1 or 0) ~= 1
            or (assigned_per_player.p2 or 0) ~= 1
            or (assigned_per_player.p3 or 0) ~= 1
            or (assigned_per_player.p4 or 0) ~= 1 then
            return false
        end
    end
    return true
end

multiplayer_setup_build_session_config = function(self)
    local count = self.mp_setup and self.mp_setup.player_count or 2
    local mission_type = multiplayer_normalize_mission_type(self.mp_setup and self.mp_setup.mission_type or MISSION_TYPE_ESCAPE)
    local compact = {}
    for i = 1, count do
        local player_id = "p" .. tostring(i)
        compact[player_id] = {}
        local slots = self.mp_setup and self.mp_setup.seat_slots and self.mp_setup.seat_slots[player_id] or {}
        local slot_count = multiplayer_get_slot_count_for_player(count, player_id)
        for slot_index = 1, slot_count do
            local unit_id = slots and slots[slot_index] or nil
            if unit_id and unit_id ~= false then
                table.insert(compact[player_id], unit_id)
            end
        end
    end
    return {
        player_count = count,
        seat_assignments = compact,
        mission_type = mission_type
    }
end

multiplayer_setup_apply_session_config = function(self, session_config)
    if type(session_config) ~= "table" then
        return
    end
    local selected_unit_before = self.mp_setup and self.mp_setup.selected_unit_id or nil
    local player_count = math.max(2, math.min(4, tonumber(session_config.player_count or 2) or 2))
    multiplayer_setup_set_player_count(self, player_count)
    if selected_unit_before and selected_unit_before ~= false then
        self.mp_setup.selected_unit_id = selected_unit_before
    end
    self.mp_setup.mission_type = multiplayer_normalize_mission_type(session_config.mission_type or self.mp_setup.mission_type or MISSION_TYPE_ESCAPE)
    local assignments = multiplayer_clone_seat_assignments(session_config.seat_assignments or {}, player_count)
    for _, player_id in ipairs(MP_SETUP_PLAYER_IDS) do
        local slot_count = multiplayer_get_slot_count_for_player(player_count, player_id)
        self.mp_setup.seat_slots[player_id] = self.mp_setup.seat_slots[player_id] or {}
        for slot_index = 1, slot_count do
            self.mp_setup.seat_slots[player_id][slot_index] = false
        end
        local units = assignments[player_id] or {}
        for slot_index = 1, math.min(slot_count, #units) do
            self.mp_setup.seat_slots[player_id][slot_index] = units[slot_index]
        end
    end
end

multiplayer_setup_push_state = function(self)
    if not (self.mp_state and self.mp_state.enabled) then
        return
    end
    if self.mp_state.local_player_id ~= self.mp_state.host_player_id then
        return
    end
    local config = multiplayer_setup_build_session_config(self)
    -- Primary path: direct host event broadcast keeps setup UI synced even if command handling drops.
    multiplayer_transport_broadcast_event(self, "setup_state_updated", {
        session_config = config
    })
    -- Compatibility path: keep the command route so existing trace/debug flow still exercises it.
    multiplayer_transport_send_command(self, "push_setup_state", {
        session_config = config
    }, self.mp_state.local_player_id)
end

local function stop_outro_slideshow_runtime(self, reason)
    if self.outro_slideshow_state then
        OUTRO_SLIDESHOW.stop(self.outro_slideshow_state, reason or "stopped")
        self.outro_slideshow_state = nil
    end
    if self.outro_slide_layer_nodes then
        for i = 2, #self.outro_slide_layer_nodes do
            local node = self.outro_slide_layer_nodes[i]
            if node then
                pcall(go.delete, node)
            end
        end
    end
    self.outro_slide_layer_nodes = { self.ui and self.ui.flow_outro_slide or nil }
    self.outro_slide_layer_anim_ids = {}
    if self.outro_fx_instances then
        for _, fx_id in ipairs(self.outro_fx_instances) do
            pcall(go.delete, fx_id)
        end
        self.outro_fx_instances = {}
    end
    self.outro_slide_anim_id = nil
end

local function ensure_outro_slide_layer_nodes(self, needed)
    needed = math.max(1, tonumber(needed or 1) or 1)
    self.outro_slide_layer_nodes = self.outro_slide_layer_nodes or { self.ui and self.ui.flow_outro_slide or nil }
    self.outro_slide_layer_anim_ids = self.outro_slide_layer_anim_ids or {}
    while #self.outro_slide_layer_nodes < needed do
        local id = create_outro_marker_sprite(hash("outro_purge_win_spaceship_fadeBlack"), FLOW_UI_PANEL_Z + 0.001)
        table.insert(self.outro_slide_layer_nodes, id)
    end
end

local function start_outro_slideshow_runtime(self)
    stop_outro_slideshow_runtime(self, "restart")
    self.flow_outro_timer = 0
    self.outro_fx_instances = {}
    self.outro_slide_layer_nodes = { self.ui and self.ui.flow_outro_slide or nil }
    self.outro_slide_layer_anim_ids = {}
    local sequence = OUTRO_SEQUENCES.get_sequence(self.end_outro_sequence_id)
    if not sequence then
        print(string.format("OUTRO | no sequence for id=%s, using placeholder timer", tostring(self.end_outro_sequence_id)))
        self.outro_slideshow_state = nil
        return
    end
    local hooks = {
        on_frame = function(pose, state)
            if not (self.ui and self.ui.flow_outro_slide and pose) then
                return
            end
            local layers = pose.layers or {}
            ensure_outro_slide_layer_nodes(self, #layers)
            local shake_x = tonumber(pose.camera_shake_x or 0) or 0
            local shake_y = tonumber(pose.camera_shake_y or 0) or 0
            for i, layer in ipairs(layers) do
                local node = self.outro_slide_layer_nodes and self.outro_slide_layer_nodes[i] or nil
                if node then
                    local anim_name = tostring(layer.anim or "")
                    if anim_name ~= "" and anim_name ~= (self.outro_slide_layer_anim_ids[i] or "") then
                        self.outro_slide_layer_anim_ids[i] = anim_name
                        pcall(msg.post, msg.url(nil, node, "sprite"), "play_animation", { id = hash(anim_name) })
                    end
                    local x = OUTRO_SLIDE_CENTER_X + (tonumber(layer.x or 0) or 0) + shake_x
                    local y = OUTRO_SLIDE_CENTER_Y + (tonumber(layer.y or 0) or 0) + shake_y
                    -- Allow tiny values for comic overlays (e.g. scale 0.002 start points).
                    local scale_x = math.max(0.0001, tonumber(layer.scale_x or layer.scale or 1) or 1)
                    local scale_y = math.max(0.0001, tonumber(layer.scale_y or layer.scale or 1) or 1)
                    local alpha = math.max(0, math.min(1, tonumber(layer.alpha or 1) or 1))
                    local draw_w = tonumber(layer.draw_w or OUTRO_SLIDE_DEFAULT_W) or OUTRO_SLIDE_DEFAULT_W
                    if draw_w <= 0 then draw_w = OUTRO_SLIDE_DEFAULT_W end
                    local draw_h = tonumber(layer.draw_h or OUTRO_SLIDE_DEFAULT_H) or OUTRO_SLIDE_DEFAULT_H
                    if draw_h <= 0 then draw_h = OUTRO_SLIDE_DEFAULT_H end
                    local z = FLOW_UI_PANEL_Z + 0.001 + ((tonumber(layer.z or 0) or 0) * 0.0001)
                    set_ui_square_transform(
                        self,
                        node,
                        x,
                        y,
                        z,
                        vmath.vector4(
                            tonumber(layer.tint_r or 1) or 1,
                            tonumber(layer.tint_g or 1) or 1,
                            tonumber(layer.tint_b or 1) or 1,
                            alpha
                        ),
                        (draw_w * scale_x) * 0.021,
                        (draw_h * scale_y) * 0.021,
                        tonumber(layer.rotation_deg or 0) or 0
                    )
                end
            end
            if self.outro_slide_layer_nodes then
                local hidden = vmath.vector4(0, 0, 0, 0)
                for i = (#layers + 1), #self.outro_slide_layer_nodes do
                    local node = self.outro_slide_layer_nodes[i]
                    if node then
                        set_ui_square_transform(
                            self,
                            node,
                            -9999,
                            -9999,
                            FLOW_UI_PANEL_Z + 0.001,
                            hidden,
                            OUTRO_SLIDE_DEFAULT_W * 0.021,
                            OUTRO_SLIDE_DEFAULT_H * 0.021
                        )
                    end
                end
            end
        end,
        on_complete = function(done_reason, state)
            self.outro_slideshow_state = nil
            self.outro_slide_anim_id = nil
            if (self.game_flow_state or FLOW_STATE_GAME) == FLOW_STATE_OUTRO then
                if tostring(self.end_outro_sequence_id or "") == "title" then
                    enter_flow_state(self, FLOW_STATE_TITLE)
                else
                    enter_score_flow(self)
                end
            end
        end,
        spawn_fx = function(cue, state)
            local factory_path = tostring((cue and cue.factory) or "")
            if factory_path == "" then
                return nil
            end
            local x = OUTRO_SLIDE_CENTER_X + (tonumber(cue.x or cue.offset_x or 0) or 0)
            local y = OUTRO_SLIDE_CENTER_Y + (tonumber(cue.y or cue.offset_y or 0) or 0)
            -- Match slideshow layer z semantics (relative stack), not absolute world z.
            local z_local = tonumber(cue and cue.z or 0) or 0
            local z = FLOW_UI_PANEL_Z + 0.002 + (z_local * 0.0001)
            local wx, wy = screen_to_world(x, y, self.camera_pos, self.camera_zoom)
            local fx_id = factory.create(factory_path, vmath.vector3(wx, wy, z))
            if fx_id then
                if cue.rotation_deg ~= nil then
                    pcall(go.set_rotation, vmath.quat_rotation_z(math.rad(tonumber(cue.rotation_deg) or 0)), fx_id)
                end
                pcall(particlefx.play, msg.url(nil, fx_id, "particlefx"))
                table.insert(self.outro_fx_instances, fx_id)
            end
            return fx_id
        end,
        stop_fx = function(handle, cue, state)
            if handle then
                pcall(go.delete, handle)
            end
        end,
        update_fx = function(handle, cue, fx_pose, state)
            if not handle or not fx_pose then
                return
            end
            local x = OUTRO_SLIDE_CENTER_X + (tonumber(fx_pose.x or 0) or 0)
            local y = OUTRO_SLIDE_CENTER_Y + (tonumber(fx_pose.y or 0) or 0)
            local z_local = tonumber(fx_pose.z or (cue and cue.z) or 0) or 0
            local z = FLOW_UI_PANEL_Z + 0.002 + (z_local * 0.0001)
            local wx, wy = screen_to_world(x, y, self.camera_pos, self.camera_zoom)
            pcall(go.set_position, vmath.vector3(wx, wy, z), handle)
        end,
        play_sfx = function(cue, state)
            print(string.format("OUTRO SFX | cue=%s", tostring(cue and cue.cue or "")))
        end,
        start_music = function(soundtrack, state)
            print(string.format("OUTRO MUSIC START | cue=%s", tostring(soundtrack and soundtrack.cue or "")))
        end,
        stop_music = function(soundtrack, state)
            print(string.format("OUTRO MUSIC STOP | cue=%s", tostring(soundtrack and soundtrack.cue or "")))
        end
    }
    self.outro_slideshow_state = OUTRO_SLIDESHOW.start(sequence, hooks)
    if not self.outro_slideshow_state then
        print(string.format("OUTRO | sequence start failed for id=%s, using placeholder timer", tostring(self.end_outro_sequence_id)))
    end
end

local function stop_level_fx_before_outro(self)
    if not self then
        return
    end
    local function stop_and_delete_fx(go_id)
        if not go_id then
            return
        end
        pcall(particlefx.stop, msg.url(nil, go_id, "particlefx"), { clear = true })
        pcall(go.delete, go_id)
    end
    if self.hazard_fx_objects then
        for _, entry in ipairs(self.hazard_fx_objects) do
            if entry then
                if entry.fire_id then stop_and_delete_fx(entry.fire_id) end
                if entry.gas_id then stop_and_delete_fx(entry.gas_id) end
            end
        end
        self.hazard_fx_objects = {}
    end
    if self.entry_fire_fx_objects then
        for key, fx_id in pairs(self.entry_fire_fx_objects) do
            if fx_id then stop_and_delete_fx(fx_id) end
            self.entry_fire_fx_objects[key] = nil
        end
    end
    if self.exit_green_smoke_fx_objects then
        for key, fx_id in pairs(self.exit_green_smoke_fx_objects) do
            if fx_id then stop_and_delete_fx(fx_id) end
            self.exit_green_smoke_fx_objects[key] = nil
        end
    end
    self.exit_green_smoke_fx_power_state = {}
    if self.wiregap_fx_objects then
        for i, fx_id in ipairs(self.wiregap_fx_objects) do
            if fx_id then stop_and_delete_fx(fx_id) end
            self.wiregap_fx_objects[i] = nil
        end
    end
    if self.power_node_loop_fx then
        for key, fx_id in pairs(self.power_node_loop_fx) do
            if fx_id then stop_and_delete_fx(fx_id) end
            self.power_node_loop_fx[key] = nil
        end
    end
    if self.medbay_underlay_visuals then
        for _, entry in pairs(self.medbay_underlay_visuals) do
            if entry and entry.bubbles_fx_id then
                stop_and_delete_fx(entry.bubbles_fx_id)
                entry.bubbles_fx_id = nil
            end
        end
    end
    if self.backdrop_cloud_fx then
        stop_and_delete_fx(self.backdrop_cloud_fx)
        self.backdrop_cloud_fx = nil
    end
end

local function update_outro_slideshow_runtime(self, dt)
    if (self.game_flow_state or FLOW_STATE_GAME) ~= FLOW_STATE_OUTRO then
        return
    end
    if self.outro_slideshow_state then
        OUTRO_SLIDESHOW.update(self.outro_slideshow_state, dt)
    else
        self.flow_outro_timer = (self.flow_outro_timer or 0) + dt
        if (self.flow_outro_timer or 0) >= 8.0 then
            if tostring(self.end_outro_sequence_id or "") == "title" then
                enter_flow_state(self, FLOW_STATE_TITLE)
            else
                enter_score_flow(self)
            end
        end
    end
end

function enter_mission_outro(self, result, reason)
    self.flow_score_breakdown = compute_placeholder_score_breakdown(self)
    self.flow_outro_timer = 0
    self.flow_submit_done = false
    self.drag_resource = { active = false }
    self.is_panning = false
    self.did_drag = false
    stop_level_fx_before_outro(self)
    local mission_type = multiplayer_normalize_mission_type(get_current_mission_type(self))
    local final_result = tostring(result or (self.game_won and "win" or "lose"))
    if final_result ~= "win" and final_result ~= "lose" then
        final_result = self.game_won and "win" or "lose"
    end
    self.end_result = final_result
    self.end_mission_type = mission_type
    local preview_override = tostring(self.debug_outro_sequence_override or "")
    if preview_override ~= "" then
        self.end_outro_sequence_id = preview_override
    else
        self.end_outro_sequence_id = string.format("%s_%s", mission_type, final_result)
    end
    self.end_reason = tostring(reason or "unknown")
    self.end_session_origin = (self.mp_state and self.mp_state.enabled) and "multiplayer" or "solo"
    enter_flow_state(self, FLOW_STATE_OUTRO)
    start_outro_slideshow_runtime(self)
    print(string.format(
        "FLOW | mission_end -> outro | mission=%s result=%s reason=%s origin=%s sequence=%s",
        tostring(self.end_mission_type),
        tostring(self.end_result),
        tostring(self.end_reason),
        tostring(self.end_session_origin),
        tostring(self.end_outro_sequence_id)
    ))
end

function enter_outro_flow_from_launch(self)
    local mission_type = multiplayer_normalize_mission_type(get_current_mission_type(self))
    if mission_type == MISSION_TYPE_TUTORIAL then
        local preview_override = tostring(self.debug_outro_sequence_override or "")
        if preview_override == "" then
            self.end_outro_sequence_id = "escape_win"
            self.flow_outro_timer = 0
            self.flow_submit_done = false
            self.drag_resource = { active = false }
            self.is_panning = false
            self.did_drag = false
            self.end_result = "win"
            self.end_mission_type = "escape"
            self.end_reason = "launch"
            self.end_session_origin = (self.mp_state and self.mp_state.enabled) and "multiplayer" or "solo"
            enter_flow_state(self, FLOW_STATE_OUTRO)
            start_outro_slideshow_runtime(self)
            print("FLOW | tutorial launch -> forced escape_win outro")
            return
        end
    end
    enter_mission_outro(self, "win", "launch")
end

function enter_score_flow(self)
    stop_outro_slideshow_runtime(self, "score_flow")
    if not self.flow_score_breakdown then
        self.flow_score_breakdown = compute_placeholder_score_breakdown(self)
    end
    enter_flow_state(self, FLOW_STATE_SCORE)
    local s = self.flow_score_breakdown
    print(string.format(
        "SCORE | total=%d survivors=%d seated=%d power=%d objectives=%d dead=%d",
        s.total or 0,
        s.survivors or 0,
        s.seated or 0,
        s.power_units or 0,
        s.objectives or 0,
        s.dead or 0
    ))
end

function update_flow_ui(self, dt)
    if not self.ui then
        return
    end
    self.flow_overlay_phase = (self.flow_overlay_phase or 0) + (dt or 0)
    local state = self.game_flow_state or FLOW_STATE_GAME
    local hidden = vmath.vector4(0, 0, 0, 0)
    if state ~= FLOW_STATE_GAME then
        set_ui_square_transform(self, self.ui.transport_status_dot, -9999, -9999, MP_NET_STATUS_DOT_Z, hidden, MP_NET_STATUS_DOT_W, MP_NET_STATUS_DOT_H)
    end
    if state == FLOW_STATE_GAME then
        set_ui_square_transform(self, self.ui.flow_overlay, -9999, -9999, FLOW_UI_OVERLAY_Z, hidden, SCREEN_WIDTH, SCREEN_HEIGHT)
        set_ui_square_transform(self, self.ui.flow_panel, -9999, -9999, FLOW_UI_PANEL_Z, hidden, 760, 420)
        set_ui_square_transform(self, self.ui.flow_outro_slide, -9999, -9999, FLOW_UI_PANEL_Z + 0.001, hidden, OUTRO_SLIDE_DEFAULT_W * 0.021, OUTRO_SLIDE_DEFAULT_H * 0.021)
        set_ui_square_transform(self, self.ui.flow_outro_ship, -9999, -9999, FLOW_UI_PANEL_Z, hidden, 280, 120)
        set_ui_square_transform(self, self.ui.flow_outro_skip_button, -9999, -9999, FLOW_UI_BUTTON_Z, hidden, 170, 52)
        set_ui_square_transform(self, self.ui.flow_score_submit_button, -9999, -9999, FLOW_UI_BUTTON_Z, hidden, 250, 56)
        set_ui_square_transform(self, self.ui.flow_score_title_button, -9999, -9999, FLOW_UI_BUTTON_Z, hidden, 250, 56)
        set_ui_square_transform(self, self.ui.flow_title_tutorial_button, -9999, -9999, FLOW_UI_BUTTON_Z, hidden, 280, 70)
        set_ui_square_transform(self, self.ui.flow_title_solo_button, -9999, -9999, FLOW_UI_BUTTON_Z, hidden, 280, 70)
        set_ui_square_transform(self, self.ui.flow_title_multiplayer_button, -9999, -9999, FLOW_UI_BUTTON_Z, hidden, 280, 70)
        set_ui_square_transform(self, self.ui.flow_mp_setup_panel, -9999, -9999, MP_SETUP_PANEL_Z, hidden, MP_SETUP_PANEL_W * 0.021, MP_SETUP_PANEL_H * 0.021)
        if self.ui.flow_mp_mission_buttons then
            for _, btn in ipairs(self.ui.flow_mp_mission_buttons) do
                set_ui_square_transform(self, btn, -9999, -9999, MP_SETUP_UI_Z, hidden, MP_SETUP_MISSION_BTN_W * 0.021, MP_SETUP_MISSION_BTN_H * 0.021)
            end
        end
        if self.ui.flow_mp_count_buttons then
            for _, btn in ipairs(self.ui.flow_mp_count_buttons) do
                set_ui_square_transform(self, btn, -9999, -9999, MP_SETUP_UI_Z, hidden, MP_SETUP_COUNT_BTN_W * 0.021, MP_SETUP_COUNT_BTN_H * 0.021)
            end
        end
        set_ui_square_transform(self, self.ui.flow_mp_count_active_ring, -9999, -9999, MP_SETUP_UI_Z, hidden, MP_SETUP_COUNT_ACTIVE_RING_W * 0.021, MP_SETUP_COUNT_ACTIVE_RING_H * 0.021)
        set_ui_square_transform(self, self.ui.flow_mp_back_button, -9999, -9999, MP_SETUP_UI_Z, hidden, MP_SETUP_ACTION_BTN_W * 0.021, MP_SETUP_ACTION_BTN_H * 0.021)
        set_ui_square_transform(self, self.ui.flow_mp_start_button, -9999, -9999, MP_SETUP_UI_Z, hidden, MP_SETUP_ACTION_BTN_W * 0.021, MP_SETUP_ACTION_BTN_H * 0.021)
        set_ui_square_transform(self, self.ui.flow_mp_start_disabled_overlay, -9999, -9999, MP_SETUP_UI_Z + 0.001, hidden, MP_SETUP_ACTION_BTN_W * 0.021, MP_SETUP_ACTION_BTN_H * 0.021)
        set_ui_square_transform(self, self.ui.flow_mp_start_enabled_glow, -9999, -9999, MP_SETUP_UI_Z - 0.001, hidden, MP_SETUP_START_GLOW_W * 0.021, MP_SETUP_START_GLOW_H * 0.021)
        if self.ui.flow_mp_unit_buttons then
            for _, btn in ipairs(self.ui.flow_mp_unit_buttons) do
                set_ui_square_transform(self, btn, -9999, -9999, MP_SETUP_UI_Z, hidden, MP_SETUP_UNIT_POOL_W * 0.021, MP_SETUP_UNIT_POOL_H * 0.021)
            end
        end
        if self.ui.flow_mp_slot_icons then
            for _, slot_icons in pairs(self.ui.flow_mp_slot_icons) do

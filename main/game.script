-- =============================================================================
-- ADJACENT CELL HELPERS
-- =============================================================================
--[[
    Get adjacent cell IDs using simple arithmetic:
    - Right: current_id + 1
    - Left: current_id - 1
    - Up: current_id + GRID_COLS
    - Down: current_id - GRID_COLS

    Edge cells are tracked to prevent stepping out of grid
]]

-- Edge cell lists
local LEFT_EDGE = {}
local RIGHT_EDGE = {}
local TOP_EDGE = {}
local BOTTOM_EDGE = {}

function initialize_edge_lists()
    for y = 1, GRID_ROWS do
        table.insert(LEFT_EDGE, coords_to_id(1, y))
        table.insert(RIGHT_EDGE, coords_to_id(GRID_COLS, y))
    end
    for x = 1, GRID_COLS do
        table.insert(BOTTOM_EDGE, coords_to_id(x, 1))
        table.insert(TOP_EDGE, coords_to_id(x, GRID_ROWS))
    end
end

function is_in_list(value, list) --is in one of the EDGE lists!
    for _, v in ipairs(list) do
        if v == value then
            return true
        end
    end
    return false
end

-- Get adjacent cell ID with boundary checking
function get_adjacent_cell(cell_id, direction)
    local adjacent_id = nil

    if direction == "right" then
        if is_in_list(cell_id, RIGHT_EDGE) then
            return nil  -- Can't go right from right edge
        end
        adjacent_id = cell_id + 1
    elseif direction == "left" then
        if is_in_list(cell_id, LEFT_EDGE) then
            return nil  -- Can't go left from left edge
        end
        adjacent_id = cell_id - 1
    elseif direction == "up" then
        if is_in_list(cell_id, TOP_EDGE) then
            return nil  -- Can't go up from top edge
        end
        adjacent_id = cell_id + GRID_COLS
    elseif direction == "down" then
        if is_in_list(cell_id, BOTTOM_EDGE) then
            return nil  -- Can't go down from bottom edge
        end
        adjacent_id = cell_id - GRID_COLS
    end

    return adjacent_id
end

local function get_step_move_cost(world_grid, from_cell_id, to_cell_id)
    local from_cell = world_grid[from_cell_id]
    local to_cell = world_grid[to_cell_id]
    if not from_cell or not to_cell then
        return math.huge
    end

    local has_obstacle = false
    local scan = { to_cell.object1, to_cell.object2, to_cell.object3 }
    for _, obj in ipairs(scan) do
        if obj and obj.name == hash("obstacle") then
            has_obstacle = true
            break
        end
    end

    local step_cost = 0
    -- Vertical transitions are always a flat ladder cost unless obstacle rule applies.
    if from_cell.xCell == to_cell.xCell and from_cell.yCell ~= to_cell.yCell then
        step_cost = VERTICAL_MOVE_AP_COST
    else
        step_cost = 1
    end
    if has_obstacle then
        -- Simplified rule: any obstacle in destination cell makes the step cost 2 AP.
        step_cost = 2
    end

    return math.min(HUMAN_MAX_ACTION_POINTS, step_cost)
end

local function get_alien_step_move_cost(world_grid, from_cell_id, to_cell_id, alien_type)
    local from_cell = world_grid[from_cell_id]
    local to_cell = world_grid[to_cell_id]
    if not from_cell or not to_cell then
        return math.huge
    end
    if alien_type == ALIEN_TYPE_BLIP then
        return 1
    end

    local has_obstacle = false
    local scan = { to_cell.object1, to_cell.object2, to_cell.object3 }
    for _, obj in ipairs(scan) do
        if obj and obj.name == hash("obstacle") then
            has_obstacle = true
            break
        end
    end
    if has_obstacle then
        return 2
    end

    if from_cell.xCell == to_cell.xCell and from_cell.yCell ~= to_cell.yCell then
        return get_alien_action_cost_value("vertical_move", ALIEN_VERTICAL_MOVE_AP_COST)
    end

    return 1
end

get_obstacle_move_speed_multiplier = function(step_ap_cost)
    if step_ap_cost >= 5 then
        return 0.45
    elseif step_ap_cost == 4 then
        return 0.65
    elseif step_ap_cost == 3 then
        return 0.82
    elseif step_ap_cost == 2 then
        return 0.92
    end
    return 1.0
end

trigger_obstacle_pass_nudge = function(self, cell_id, from_cell_id, nudge_scale)
    if not self or not self.world_grid or not cell_id then
        return
    end
    local cell = self.world_grid[cell_id]
    if not cell then
        return
    end
    local has_obstacle = false
    local obstacle_count = 0
    local scan = { cell.object1, cell.object2, cell.object3 }
    for _, obj in ipairs(scan) do
        if obj and obj.name == hash("obstacle") then
            has_obstacle = true
            local count = obj.stackCount or obj.obstacleCount or 1
            if count < 1 then
                count = 1
            end
            obstacle_count = obstacle_count + count
        end
    end
    if not has_obstacle then
        return
    end
    local nudge_sign = 0
    local move_dx = 0
    if from_cell_id then
        local from_cell = self.world_grid[from_cell_id]
        if from_cell then
            local dx = (cell.xCell or 0) - (from_cell.xCell or 0)
            move_dx = dx
            if dx > 0 then
                nudge_sign = 1
            elseif dx < 0 then
                nudge_sign = -1
            end
        end
    end
    if nudge_sign == 0 then
        local prev = cell.obstacleNudgeDir or 1
        nudge_sign = prev >= 0 and 1 or -1
    end
    local scale = nudge_scale or 1
    if scale < 0 then
        scale = 0
    end
    local max_abs = 15 * math.max(1, scale)
    cell.obstacleNudgeDir = nudge_sign
    cell.obstacleShudderTimer = 0.22
    cell.obstacleNudgeEventClock = 0
    local lag_by_index = {}
    local target_by_index = cell.obstacleNudgeTargetByIndex or {}
    local current_by_index = cell.obstacleNudgeCurrentByIndex or {}
    local obstacle_entries = {}
    local entry_index = 0
    local scan_slots = { cell.object1, cell.object2, cell.object3 }
    for _, obj in ipairs(scan_slots) do
        if obj and obj.name == hash("obstacle") then
            local count = obj.stackCount or obj.obstacleCount or 1
            if count < 1 then
                count = 1
            end
            local base_x = obj.offsetX or 0
            for i = 1, count do
                entry_index = entry_index + 1
                table.insert(obstacle_entries, { x = base_x + ((i - 1) * 16), draw_index = entry_index })
            end
        end
    end
    if #obstacle_entries <= 0 then
        for i = 1, math.max(1, obstacle_count) do
            table.insert(obstacle_entries, { x = i * 16, draw_index = i })
        end
    end
    local reverse_order = move_dx < 0
    table.sort(obstacle_entries, function(a, b)
        if reverse_order then
            return a.x > b.x
        end
        return a.x < b.x
    end)
    for order_idx, entry in ipairs(obstacle_entries) do
        local draw_idx = entry.draw_index or order_idx
        lag_by_index[draw_idx] = (order_idx - 1) * OBSTACLE_SLOT_LAG_SECONDS
        local next_target = (target_by_index[draw_idx] or 0) + (15 * scale * nudge_sign)
        local max_for_slot = max_abs
        if next_target > max_for_slot then
            next_target = max_for_slot
        elseif next_target < -max_for_slot then
            next_target = -max_for_slot
        end
        target_by_index[draw_idx] = next_target
        if current_by_index[draw_idx] == nil then
            current_by_index[draw_idx] = 0
        end
    end
    cell.obstacleNudgeLagByIndex = lag_by_index
    cell.obstacleNudgeTargetByIndex = target_by_index
    cell.obstacleNudgeCurrentByIndex = current_by_index
end

function can_cross_between_cells(world_grid, from_cell_id, to_cell_id)
    local from_cell = world_grid[from_cell_id]
    local to_cell = world_grid[to_cell_id]
    if not from_cell or not to_cell then
        return false
    end

    local dx = to_cell.xCell - from_cell.xCell
    local dy = to_cell.yCell - from_cell.yCell

    if dx == 1 and dy == 0 then
        return from_cell.accessRight
    elseif dx == -1 and dy == 0 then
        return to_cell.accessRight
    elseif dx == 0 and dy == 1 then
        return to_cell.accessDown
    elseif dx == 0 and dy == -1 then
        return from_cell.accessDown
    end

    return false
end

function get_door_object_on_cell(cell)
    if not cell then
        return nil
    end
    local candidates = { cell.object1, cell.object2, cell.object3 }
    for _, obj in ipairs(candidates) do
        if obj and obj.name == hash("door") then
            return obj
        end
    end
    return nil
end

local function is_secure_door_object(door_obj)
    return door_obj and door_obj.isSecureAlienProof == true
end

function is_object_dependency_met_for_door(world_grid, obj)
    if not obj then
        return false
    end
    local dependency_id = obj.dependsOn or 0
    if dependency_id <= 0 then
        return true
    end
    for _, cell in ipairs(world_grid or {}) do
        local scan = { cell.object1, cell.object2, cell.object3 }
        for _, other in ipairs(scan) do
            if other and other.objectId == dependency_id then
                return other.isFixed == true
            end
        end
    end
    return false
end

function is_door_closed_runtime(world_grid, owner_cell, door_obj)
    if not owner_cell or not door_obj then
        return false
    end
    local functional = is_door_functional_runtime(world_grid, owner_cell, door_obj)
    if not functional then
        return false
    end
    return door_obj.isOpen ~= true
end

function is_door_functional_runtime(world_grid, owner_cell, door_obj)
    if not owner_cell or not door_obj then
        return false
    end
    local powered = owner_cell.isPowered == true
    local fixed = door_obj.isFixed == true
    local deps_met = is_object_dependency_met_for_door(world_grid, door_obj)
    return powered and fixed and deps_met
end

function get_edge_door_context(world_grid, from_cell_id, to_cell_id)
    local from_cell = world_grid[from_cell_id]
    local to_cell = world_grid[to_cell_id]
    if not from_cell or not to_cell then
        return nil, nil, false
    end
    local dx = to_cell.xCell - from_cell.xCell
    local dy = to_cell.yCell - from_cell.yCell
    -- Doors currently represent horizontal accessRight edges only.
    if dy ~= 0 then
        return nil, nil, false
    end
    local owner_cell = nil
    if dx == 1 then
        owner_cell = from_cell
    elseif dx == -1 then
        owner_cell = to_cell
    else
        return nil, nil, false
    end
    local door_obj = get_door_object_on_cell(owner_cell)
    if not door_obj then
        return nil, nil, false
    end
    return owner_cell, door_obj, is_door_closed_runtime(world_grid, owner_cell, door_obj)
end

function is_cell_barricaded(world_grid, cell_id)
    if not world_grid or not cell_id then
        return false
    end
    local cell = world_grid[cell_id]
    if not cell or cell.tileID == hash("empty") then
        return false
    end
    if (cell.has_barricade == true) and ((cell.barricade_hp or 0) > 0) then
        return true
    end
    return false
end

remove_one_obstacle_from_cell = function(world_grid, cell_id)
    if not world_grid or not cell_id then
        return false, 0
    end
    local cell = world_grid[cell_id]
    if not cell or cell.tileID == hash("empty") then
        return false, 0
    end
    local hp = cell.barricade_hp or 0
    if (cell.has_barricade ~= true) or hp <= 0 then
        local slots = { cell.object1, cell.object2, cell.object3 }
        local total_obstacles = 0
        local has_stack_barricade = false
        for _, obj in ipairs(slots) do
            if obj and obj.name == hash("obstacle") then
                local count = obj.stackCount or obj.obstacleCount or 1
                if count < 1 then
                    count = 1
                end
                total_obstacles = total_obstacles + count
                if count >= 3 then
                    has_stack_barricade = true
                end
            end
        end
        if not has_stack_barricade then
            return false, 0
        end
        hp = math.max(3, math.min(10, total_obstacles))
        cell.has_barricade = true
        cell.barricade_hp = hp
        cell.barricade_brightness = 1.0
        for _, slot in ipairs(slots) do
            if slot and slot.name == hash("obstacle") then
                slot.name = hash("empty")
                slot.isFixed = false
                slot.isWelded = false
                slot.isOpen = false
                slot.dependsOn = 0
                slot.isDependentOn = {}
                slot.objectId = 0
                slot.offsetX = 0
                slot.offsetY = 0
                slot.fxOffsetX = 0
                slot.fxOffsetY = 0
                slot.fxRotation = 0
                slot.fxFactory = nil
                slot.hitW = 32
                slot.hitH = 32
                slot.requiredComponent = nil
                slot.stackCount = nil
                slot.obstacleCount = nil
            end
        end
    end
    hp = math.max(0, hp - 1)
    cell.barricade_hp = hp
    cell.barricade_brightness = math.max(0.25, math.min(1.0, (cell.barricade_brightness or 1.0) * 0.67))
    if hp <= 0 then
        cell.has_barricade = false
        cell.barricade_hp = nil
        cell.barricade_brightness = nil
        cell.barricade_scale_pulse = nil
        cell.barricade_scale_pulse_timer = nil
        cell.barricade_slot_index = nil
        cell.barricade_anchor_x = nil
        cell.barricade_anchor_y = nil
        cell.obstacleShudderTimer = nil
        cell.obstacleShudderPhase = nil
    end
    return true, hp
end

try_brute_break_adjacent_barricade = function(self, alien)
    if not self or not alien or alien.type ~= ALIEN_TYPE_BRUTE or (not alien.cell_id) then
        return false
    end
    local target_cell_id = alien.cell_id
    if not is_cell_barricaded(self.world_grid, target_cell_id) then
        local search_dirs = { "right", "left", "up", "down" }
        target_cell_id = nil
        for _, dir in ipairs(search_dirs) do
            local adj_id = get_adjacent_cell(alien.cell_id, dir)
            if adj_id and is_cell_barricaded(self.world_grid, adj_id) and can_cross_between_cells(self.world_grid, alien.cell_id, adj_id) then
                local _, _, edge_door_closed = get_edge_door_context(self.world_grid, alien.cell_id, adj_id)
                if edge_door_closed then
                    -- Closed door on the edge blocks barricade attacks; brute should hit the door first.
                    if try_brute_damage_edge_door(self, alien, alien.cell_id, adj_id) then
                        return true
                    end
                else
                    target_cell_id = adj_id
                    break
                end
            end
        end
        if not target_cell_id then
            return false
        end
    end
    self.barricade_damage_cells_this_turn = self.barricade_damage_cells_this_turn or {}
    if alien.go_id then
        local target_cell = self.world_grid and self.world_grid[target_cell_id] or nil
        if target_cell then
            local tx, ty = coords_to_world_pos(target_cell.xCell, target_cell.yCell)
            tx = tx + (target_cell.barricade_anchor_x or 0)
            ty = ty + (target_cell.barricade_anchor_y or 0)
            local apos = go.get_position(alien.go_id)
            local dx = tx - apos.x
            local dy = ty - apos.y
            local len = math.sqrt((dx * dx) + (dy * dy))
            local ux, uy = 0, 0
            if len > 0.001 then
                ux = dx / len
                uy = dy / len
            else
                local sprite_url = msg.url(nil, alien.go_id, "sprite")
                local facing_right = true
                local ok_flip, current_flip = pcall(sprite.get_hflip, sprite_url)
                if ok_flip then
                    facing_right = current_flip == true
                end
                ux = facing_right and 1 or -1
            end
            local lurch_dx = dx * 0.9
            local lurch_dy = dy * 0.9
            local sprite_url = msg.url(nil, alien.go_id, "sprite")
            local shadow_url = msg.url(nil, alien.go_id, "shadow")
            alien.melee_pose_lock_timer = math.max(alien.melee_pose_lock_timer or 0, 0.36)
            local side_anim = (self.aesthetic_mode == AESTHETIC_MODE_BOARDGAME)
                and hash("alien_brute_side_boardgame")
                or hash("alien_brute_side")
            pcall(msg.post, sprite_url, "play_animation", { id = side_anim })
            local facing_right = ux > 0
            pcall(sprite.set_hflip, sprite_url, facing_right)
            pcall(sprite.set_hflip, shadow_url, facing_right)
            print(string.format("DEBUG: Brute #%d sprite-lurch triggered toward barricade cell %d.", alien.id or 0, target_cell_id))
            local base_go_pos = go.get_position(alien.go_id)
            local target_go_pos = vmath.vector3(base_go_pos.x + lurch_dx, base_go_pos.y + lurch_dy, base_go_pos.z)
            pcall(go.cancel_animations, alien.go_id, "position")
            pcall(go.animate, alien.go_id, "position", go.PLAYBACK_ONCE_FORWARD, target_go_pos, go.EASING_OUTSINE, 0.20)
            pcall(go.animate, alien.go_id, "position", go.PLAYBACK_ONCE_FORWARD, base_go_pos, go.EASING_INSINE, 0.28, 0.20)
            timer.delay(0.30, false, function()
                if alien and alien.go_id and (not alien.is_dead) then
                    alien.melee_pose_lock_timer = 0
                    local front_anim = (self.aesthetic_mode == AESTHETIC_MODE_BOARDGAME)
                        and hash("alien_brute_boardgame")
                        or hash("alien_brute")
                    local end_sprite_url = msg.url(nil, alien.go_id, "sprite")
                    local end_shadow_url = msg.url(nil, alien.go_id, "shadow")
                    pcall(msg.post, end_sprite_url, "play_animation", { id = front_anim })
                    pcall(sprite.set_hflip, end_sprite_url, false)
                    pcall(sprite.set_hflip, end_shadow_url, false)
                end
            end)
        end
    end
    if self.barricade_damage_cells_this_turn[target_cell_id] then
        return true
    end
    local removed, remaining = remove_one_obstacle_from_cell(self.world_grid, target_cell_id)
    if not removed then
        return false
    end
    self.barricade_damage_cells_this_turn[target_cell_id] = true
    local target_cell = self.world_grid and self.world_grid[target_cell_id]
    if target_cell then
        target_cell.obstacleShudderTimer = 0.60
        target_cell.obstacleShudderPhase = 0
        local fx_x, fx_y = coords_to_world_pos(target_cell.xCell, target_cell.yCell)
        fx_x = fx_x + (target_cell.barricade_anchor_x or 0)
        fx_y = fx_y + (target_cell.barricade_anchor_y or 0)
        local fx_id = factory.create("/barricade_broken_fx_factory#barricade_broken_fx_factory", vmath.vector3(fx_x, fx_y, 0.62))
        if fx_id then
            pcall(particlefx.play, msg.url(nil, fx_id, "particlefx"))
            timer.delay(0.18, false, function()
                if fx_id then
                    pcall(particlefx.stop, msg.url(nil, fx_id, "particlefx"), { clear = false })
                end
            end)
            timer.delay(1.1, false, function()
                if fx_id then
                    pcall(go.delete, fx_id)
                end
            end)
        end
        if remaining <= 0 then
            target_cell.has_barricade = false
            target_cell.barricade_hp = nil
            target_cell.barricade_brightness = nil
            target_cell.barricade_scale_pulse = nil
            target_cell.barricade_scale_pulse_timer = nil
            target_cell.barricade_slot_index = nil
            target_cell.barricade_anchor_x = nil
            target_cell.barricade_anchor_y = nil
            target_cell.obstacleShudderTimer = nil
            target_cell.obstacleShudderPhase = nil
        end
    end
    if LOOT_RUNTIME and LOOT_RUNTIME.play_barricade_hit_fx then
        LOOT_RUNTIME.play_barricade_hit_fx(self, target_cell_id, remaining <= 0)
    end
    if LOOT_RUNTIME and LOOT_RUNTIME.refresh_fix_markers then
        LOOT_RUNTIME.refresh_fix_markers(self)
    end
    if LOOT_RUNTIME and LOOT_RUNTIME.refresh_world_item_visuals then
        LOOT_RUNTIME.refresh_world_item_visuals(self)
    end
    if remaining > 0 then
        print(string.format("Brute #%d damaged barricade in cell %d (hp=%d).", alien.id or 0, target_cell_id, remaining))
    else
        print(string.format("Brute #%d destroyed barricade in cell %d.", alien.id or 0, target_cell_id))
    end
    return true
end

reset_runtime_object_slot_to_empty = function(slot)
    if not slot then
        return
    end
    slot.name = hash("empty")
    slot.isFixed = false
    slot.isWelded = false
    slot.isOpen = false
    slot.dependsOn = 0
    slot.isDependentOn = {}
    slot.objectId = 0
    slot.offsetX = 0
    slot.offsetY = 0
    slot.fxOffsetX = 0
    slot.fxOffsetY = 0
    slot.fxRotation = 0
    slot.fxFactory = nil
    slot.hitW = 32
    slot.hitH = 32
    slot.requiredComponent = nil
    slot.door_hp = nil
    slot.door_damage_tint = nil
    slot.door_shudder_timer = nil
    slot.door_shudder_phase = nil
end

try_brute_damage_edge_door = function(self, alien, from_cell_id, to_cell_id)
    if not self or not alien then
        return false
    end
    local is_true_brute = alien.type == ALIEN_TYPE_BRUTE
    local is_hidden_brute_blip = alien.type == ALIEN_TYPE_BLIP and alien.hidden_reveal_type == ALIEN_TYPE_BRUTE
    if (not is_true_brute) and (not is_hidden_brute_blip) then
        return false
    end
    local owner_cell, door_obj, door_closed = get_edge_door_context(self.world_grid, from_cell_id, to_cell_id)
    if not owner_cell or not door_obj or not door_closed then
        return false
    end
    if is_secure_door_object(door_obj) then
        return false
    end
    self.door_damage_cells_this_turn = self.door_damage_cells_this_turn or {}
    local damage_key = owner_cell.idNumber or 0
    if alien.go_id and is_true_brute then
        local cell_x, cell_y = coords_to_world_pos(owner_cell.xCell, owner_cell.yCell)
        local tx = cell_x + (door_obj.offsetX or 0)
        local ty = cell_y + (door_obj.offsetY or 0)
        local apos = go.get_position(alien.go_id)
        local dx = tx - apos.x
        local dy = ty - apos.y
        local len = math.sqrt((dx * dx) + (dy * dy))
        local ux, uy = 1, 0
        if len > 0.001 then
            ux = dx / len
            uy = dy / len
        end
        local lurch_dx = dx * 0.9
        local lurch_dy = dy * 0.9
        local sprite_url = msg.url(nil, alien.go_id, "sprite")
        local shadow_url = msg.url(nil, alien.go_id, "shadow")
        alien.melee_pose_lock_timer = math.max(alien.melee_pose_lock_timer or 0, 0.36)
        local side_anim = (self.aesthetic_mode == AESTHETIC_MODE_BOARDGAME)
            and hash("alien_brute_side_boardgame")
            or hash("alien_brute_side")
        pcall(msg.post, sprite_url, "play_animation", { id = side_anim })
        local facing_right = ux > 0
        pcall(sprite.set_hflip, sprite_url, facing_right)
        pcall(sprite.set_hflip, shadow_url, facing_right)
        local base_go_pos = go.get_position(alien.go_id)
        local target_go_pos = vmath.vector3(base_go_pos.x + lurch_dx, base_go_pos.y + lurch_dy, base_go_pos.z)
        pcall(go.cancel_animations, alien.go_id, "position")
        pcall(go.animate, alien.go_id, "position", go.PLAYBACK_ONCE_FORWARD, target_go_pos, go.EASING_OUTSINE, 0.20)
        pcall(go.animate, alien.go_id, "position", go.PLAYBACK_ONCE_FORWARD, base_go_pos, go.EASING_INSINE, 0.28, 0.20)
        timer.delay(0.30, false, function()
            if alien and alien.go_id and (not alien.is_dead) then
                alien.melee_pose_lock_timer = 0
                local front_anim = (self.aesthetic_mode == AESTHETIC_MODE_BOARDGAME)
                    and hash("alien_brute_boardgame")
                    or hash("alien_brute")
                local end_sprite_url = msg.url(nil, alien.go_id, "sprite")
                local end_shadow_url = msg.url(nil, alien.go_id, "shadow")
                pcall(msg.post, end_sprite_url, "play_animation", { id = front_anim })
                pcall(sprite.set_hflip, end_sprite_url, false)
                pcall(sprite.set_hflip, end_shadow_url, false)
            end
        end)
    end
    if self.door_damage_cells_this_turn[damage_key] then
        return true
    end
    self.door_damage_cells_this_turn[damage_key] = true
    local hp = door_obj.door_hp or 3
    hp = math.max(0, hp - 1)
    door_obj.door_hp = hp
    door_obj.door_damage_tint = math.max(0.25, math.min(1.0, hp / 3))
    door_obj.door_shudder_timer = 0.60
    door_obj.door_shudder_phase = 0

    local cell_x, cell_y = coords_to_world_pos(owner_cell.xCell, owner_cell.yCell)
    local fx_x = cell_x + (door_obj.offsetX or 0)
    local fx_y = cell_y + (door_obj.offsetY or 0)
    local fx_id = factory.create("/barricade_broken_fx_factory#barricade_broken_fx_factory", vmath.vector3(fx_x, fx_y, 0.62))
    if fx_id then
        pcall(particlefx.play, msg.url(nil, fx_id, "particlefx"))
        timer.delay(0.18, false, function()
            if fx_id then
                pcall(particlefx.stop, msg.url(nil, fx_id, "particlefx"), { clear = false })
            end
        end)
        timer.delay(1.1, false, function()
            if fx_id then
                pcall(go.delete, fx_id)
            end
        end)
    end

    if hp <= 0 then
        reset_runtime_object_slot_to_empty(door_obj)
    end

    if LOOT_RUNTIME and LOOT_RUNTIME.refresh_fix_markers then
        LOOT_RUNTIME.refresh_fix_markers(self)
    end
    if LOOT_RUNTIME and LOOT_RUNTIME.refresh_door_markers then
        LOOT_RUNTIME.refresh_door_markers(self)
    end

    if hp > 0 then
        print(string.format("Brute #%d damaged door object #%d (hp=%d).", alien.id or 0, door_obj.objectId or 0, hp))
    else
        print(string.format("Brute #%d destroyed door object #%d.", alien.id or 0, door_obj.objectId or 0))
    end
    return true
end

function can_alien_cross_between_cells(world_grid, from_cell_id, to_cell_id, alien_type, hidden_reveal_type)
    if not can_cross_between_cells(world_grid, from_cell_id, to_cell_id) then
        return false
    end
    local from_cell = world_grid and world_grid[from_cell_id] or nil
    local to_cell = world_grid and world_grid[to_cell_id] or nil
    if from_cell and to_cell and from_cell.yCell == to_cell.yCell and from_cell.xCell ~= to_cell.xCell then
        local dir = (to_cell.xCell > from_cell.xCell) and 1 or -1
        local from_anchor = get_barricade_anchor_x_for_cell(from_cell)
        local to_anchor = get_barricade_anchor_x_for_cell(to_cell)
        if is_cell_barricaded(world_grid, from_cell_id) then
            local from_blocks_departure = (from_anchor == 0)
                or (dir == 1 and from_anchor > 0)
                or (dir == -1 and from_anchor < 0)
            if from_blocks_departure then
                return false
            end
        end
        if is_cell_barricaded(world_grid, to_cell_id) then
            local to_blocks_entry = (to_anchor == 0)
                or (dir == 1 and to_anchor < 0)
                or (dir == -1 and to_anchor > 0)
            if to_blocks_entry then
                return false
            end
        end
    end
    if is_cell_barricaded(world_grid, to_cell_id) then
        return alien_type == ALIEN_TYPE_BRUTE
    end
    local _, door_obj, door_closed = get_edge_door_context(world_grid, from_cell_id, to_cell_id)
    if not door_obj or not door_closed then
        return true
    end
    if is_secure_door_object(door_obj) then
        return false
    end
    return alien_type == ALIEN_TYPE_BRUTE
        or (alien_type == ALIEN_TYPE_BLIP and hidden_reveal_type == ALIEN_TYPE_BRUTE)
end

function can_human_cross_between_cells(world_grid, from_cell_id, to_cell_id)
    if not can_cross_between_cells(world_grid, from_cell_id, to_cell_id) then
        return false
    end
    local _, _, door_closed = get_edge_door_context(world_grid, from_cell_id, to_cell_id)
    if door_closed then
        return false
    end
    return true
end

function get_clicked_door_on_light(self, world_x, world_y)
    if not self or not self.world_grid then
        return nil, nil
    end
    local best_obj = nil
    local best_cell = nil
    local best_dist = math.huge
    for _, cell in ipairs(self.world_grid) do
        local door_obj = get_door_object_on_cell(cell)
        if door_obj then
            local cx, cy = coords_to_world_pos(cell.xCell, cell.yCell)
            local dx = cx + (door_obj.offsetX or 0)
            local dy = cy + (door_obj.offsetY or 0)
            local w = door_obj.hitW or 42
            local h = door_obj.hitH or 72
            local half_w = w * 0.5
            local half_h = h * 0.5
            if world_x >= (dx - half_w) and world_x <= (dx + half_w) and world_y >= (dy - half_h) and world_y <= (dy + half_h) then
                -- For testing clarity, accept clicks on the whole door hitbox.
                local ddx = world_x - dx
                local ddy = world_y - dy
                local dist = math.sqrt(ddx * ddx + ddy * ddy)
                if dist < best_dist then
                    best_dist = dist
                    best_obj = door_obj
                    best_cell = cell
                end
            end
        end
    end
    return best_cell, best_obj
end

function can_unit_reach_door_toggle(unit, owner_cell_id)
    if not unit or not unit.cell_id or not owner_cell_id then
        return false
    end
    if unit.cell_id == owner_cell_id then
        return true
    end
    local right_id = get_adjacent_cell(owner_cell_id, "right")
    if right_id and unit.cell_id == right_id then
        return true
    end
    return false
end

get_door_by_object_id = function(world_grid, object_id)
    if not world_grid or not object_id then
        return nil, nil
    end
    for _, cell in ipairs(world_grid) do
        if cell then
            local slots = { cell.object1, cell.object2, cell.object3 }
            for _, obj in ipairs(slots) do
                if obj and obj.name == hash("door") and obj.objectId == object_id then
                    return cell, obj
                end
            end
        end
    end
    return nil, nil
end

get_ap_cost_value = function(action_key, default_cost)
    local value = nil
    if type(AP_COSTS) == "table" then
        value = tonumber(AP_COSTS[action_key])
    end
    if value == nil then
        value = tonumber(default_cost or 1) or 1
    end
    if value < 0 then
        return 0
    end
    return value
end

get_alien_action_cost_value = function(action_key, default_cost)
    local value = nil
    if type(ALIEN_ACTION_COSTS) == "table" then
        value = tonumber(ALIEN_ACTION_COSTS[action_key])
    end
    if value == nil then
        value = tonumber(default_cost or 1) or 1
    end
    if value < 0 then
        return 0
    end
    return value
end

multiplayer_apply_toggle_door_event = function(self, payload)
    if type(payload) ~= "table" then
        return false
    end
    local unit = self.squad_units and self.squad_units[payload.unit_id] or nil
    local object_id = tonumber(payload.object_id)
    local owner_cell, door_obj = get_door_by_object_id(self.world_grid, object_id)
    if (not owner_cell or not door_obj) and payload.owner_cell_id then
        local fallback_cell = self.world_grid and self.world_grid[tonumber(payload.owner_cell_id)] or nil
        if fallback_cell then
            local fallback_door = get_door_object_on_cell(fallback_cell)
            if fallback_door then
                owner_cell = fallback_cell
                door_obj = fallback_door
            end
        end
    end
    if not unit or not owner_cell or not door_obj then
        return false
    end
    local ap_before = tonumber(unit.current_ap or 0) or 0
    local desired_open = (payload.is_open == true)
    door_obj.isOpen = desired_open
    local ap_after = tonumber(payload.ap_after)
    if ap_after ~= nil then
        unit.current_ap = math.max(0, ap_after)
    else
        local ap_cost = tonumber(payload.ap_cost)
        if ap_cost == nil then
            ap_cost = get_ap_cost_value("door_toggle", 1)
        end
        unit.current_ap = math.max(0, ap_before - math.max(0, ap_cost))
    end
    if LOOT_RUNTIME and LOOT_RUNTIME.refresh_door_markers then
        LOOT_RUNTIME.refresh_door_markers(self)
    end
    local spent_ap = math.max(0, ap_before - (tonumber(unit.current_ap or 0) or 0))
    print(string.format("%s %s door object #%d. (AP -%d)", unit.display_name, door_obj.isOpen and "opened" or "closed", door_obj.objectId or 0, spent_ap))
    return true
end

function try_toggle_door_with_selected_human(self, unit, world_x, world_y)
    if not unit or (unit.current_health or 0) <= 0 then
        return false
    end
    local owner_cell, door_obj = get_clicked_door_on_light(self, world_x, world_y)
    if not owner_cell or not door_obj then
        return false
    end
    if not can_unit_reach_door_toggle(unit, owner_cell.idNumber) then
        print("too far away")
        return true
    end
    local ap_cost = get_ap_cost_value("door_toggle", 1)
    if unit.current_ap < ap_cost then
        print("Unable to toggle door: no AP")
        return true
    end
    if not is_door_functional_runtime(self.world_grid, owner_cell, door_obj) then
        print("Door is offline or broken and cannot be toggled.")
        return true
    end
    if self.mp_state and self.mp_state.enabled then
        multiplayer_transport_send_command(self, "toggle_door", {
            turn_id = self.mp_state.turn_id or 1,
            unit_id = unit.id,
            object_id = door_obj.objectId,
            is_open = not (door_obj.isOpen == true)
        }, multiplayer_get_active_player_id_for_commands(self))
        return true
    end
    door_obj.isOpen = not (door_obj.isOpen == true)
    unit.current_ap = unit.current_ap - ap_cost
    if LOOT_RUNTIME and LOOT_RUNTIME.refresh_door_markers then
        LOOT_RUNTIME.refresh_door_markers(self)
    end
    print(string.format("%s %s door object #%d. (AP -%d)", unit.display_name, door_obj.isOpen and "opened" or "closed", door_obj.objectId or 0, ap_cost))
    return true
end

local function get_alien_neighbors(cell_id, world_grid, alien_type, hidden_reveal_type)
    local neighbors = {}
    local directions = { "right", "left", "up", "down" }
    local cfg = ALIEN_TYPE_CONFIG[alien_type]
    local can_traverse_void = cfg and cfg.can_traverse_void

    for _, dir in ipairs(directions) do
        local adj_id = get_adjacent_cell(cell_id, dir)
        if adj_id then
            local adj_cell = world_grid[adj_id]
            local can_enter_void = can_traverse_void == true
            local is_void = adj_cell.tileID == hash("empty")
            if (not is_void or can_enter_void) and can_alien_cross_between_cells(world_grid, cell_id, adj_id, alien_type, hidden_reveal_type) then
                local step_cost = get_alien_step_move_cost(world_grid, cell_id, adj_id, alien_type)
                table.insert(neighbors, { id = adj_id, cost = step_cost })
            end
        end
    end

    return neighbors
end

-- Get all valid adjacent cells (4-directional)
local get_vent_neighbors_for_path
function get_neighbors(cell_id, world_grid, movement_profile, path_context)
    local neighbors = {}
    local directions = {"right", "left", "up", "down"}
    movement_profile = movement_profile or MOVEMENT_PROFILE_HUMAN

    for _, dir in ipairs(directions) do
        local adj_id = get_adjacent_cell(cell_id, dir)
        if adj_id then
            local cell = world_grid[adj_id]
            -- Check if cell is not VOID (part of a valid tile)
            if cell.tileID ~= hash("empty") and can_human_cross_between_cells(world_grid, cell_id, adj_id) then
                table.insert(neighbors, { id = adj_id, cost = get_step_move_cost(world_grid, cell_id, adj_id) })
            end
        end
    end

    -- FUTURE HOOK (not active yet):
    if movement_profile == MOVEMENT_PROFILE_ALIEN_VENT then
        local vent_neighbors = get_vent_neighbors_for_path(cell_id, world_grid, path_context)
        for _, vent_neighbor in ipairs(vent_neighbors) do
            table.insert(neighbors, vent_neighbor)
        end
    end

    return neighbors
end

-- =============================================================================
-- FUTURE: VENT PATHFINDING HOOKS (SCaffold ONLY, NOT ACTIVE YET)
-- =============================================================================
--[[
    Design intent:
    - Humans use normal adjacency edges only.
    - Aliens can use normal edges + optional vent transition edges.
    - Techie can "seal" vents so alien vent graph updates dynamically.
]]

local function object_is_vent(obj)
    return obj and obj.name == hash("vent")
end

local function cell_has_active_vent(cell)
    if not cell then
        return false
    end

    local candidates = { cell.object1, cell.object2, cell.object3 }
    for _, obj in ipairs(candidates) do
        if object_is_vent(obj) then
            if obj.isWelded ~= true and obj.isSealed ~= true then
                return true
            end
        end
    end

    return false
end

local function get_active_vent_cell_ids(world_grid)
    local vent_cells = {}
    for cell_id, cell in ipairs(world_grid) do
        if cell_has_active_vent(cell) then
            table.insert(vent_cells, cell_id)
        end
    end
    return vent_cells
end

local function manhattan_distance_by_id(from_id, to_id)
    local x1, y1 = id_to_coords(from_id)
    local x2, y2 = id_to_coords(to_id)
    return math.abs(x2 - x1) + math.abs(y2 - y1)
end

local function get_nearest_active_vent(from_cell_id, world_grid)
    local vents = get_active_vent_cell_ids(world_grid)
    local nearest_id = nil
    local best_dist = math.huge

    for _, vent_id in ipairs(vents) do
        if vent_id ~= from_cell_id then
            local d = manhattan_distance_by_id(from_cell_id, vent_id)
            if d < best_dist then
                best_dist = d
                nearest_id = vent_id
            end
        end
    end

    return nearest_id
end

get_vent_neighbors_for_path = function(cell_id, world_grid, path_context)
    if not world_grid or not world_grid[cell_id] then
        return {}
    end
    if not cell_has_active_vent(world_grid[cell_id]) then
        return {}
    end
    local target_cell_id = path_context and path_context.target_cell_id or nil
    if not target_cell_id then
        return {}
    end
    local vents = get_active_vent_cell_ids(world_grid)
    local best_vent = nil
    local best_dist = math.huge
    for _, vent_id in ipairs(vents) do
        if vent_id ~= cell_id then
            local d = manhattan_distance_by_id(vent_id, target_cell_id)
            if d < best_dist or (d == best_dist and (best_vent == nil or vent_id < best_vent)) then
                best_dist = d
                best_vent = vent_id
            end
        end
    end
    if best_vent then
        return { { id = best_vent, cost = ALIEN_VENT_TRANSIT_AP_COST } }
    end
    return {}
end

-- =============================================================================
-- AUTHORED CONTENT MODULES
-- =============================================================================
-- Tile and level authored definitions now live in:
--   - `main/tile_defs.lua`
--   - `main/level_defs.lua`

-- =============================================================================
-- BAKING DOWN PROCESS
-- =============================================================================
--[[
    "Bakes down" a level design onto the worldGrid
    - Takes tile placement data and tile library
    - Copies tile data into appropriate worldGrid cells
    - Sets tileID for all 9 cells of each placed tile
]]

function bake_level_to_world_grid(world_grid, level_design, tile_library)
    local function clone_loot_items(items)
        if type(items) ~= "table" then
            return nil
        end
        local out = {}
        for i, item in ipairs(items) do
            out[i] = item
        end
        return out
    end

    local function clone_object(obj)
        local dep_list = {}
        if obj and obj.isDependentOn then
            for i, dep in ipairs(obj.isDependentOn) do
                dep_list[i] = dep
            end
        end
        return {
            name = (obj and obj.name) or hash("empty"),
            isFixed = (obj and obj.isFixed) == true,
            isWelded = (obj and obj.isWelded) == true,
            isOpen = (obj and obj.isOpen) == true,
            isSecureAlienProof = (obj and obj.isSecureAlienProof) == true,
            dependsOn = (obj and obj.dependsOn) or 0,
            isDependentOn = dep_list,
            objectId = (obj and obj.objectId) or 0,
            offsetX = (obj and obj.offsetX) or 0,
            offsetY = (obj and obj.offsetY) or 0,
            fxOffsetX = (obj and obj.fxOffsetX) or 0,
            fxOffsetY = (obj and obj.fxOffsetY) or 0,
            fxRotation = (obj and obj.fxRotation) or 0,
            fxFactory = (obj and obj.fxFactory) or nil,
            hitW = (obj and obj.hitW) or 32,
            hitH = (obj and obj.hitH) or 32,
            requiredComponent = obj and obj.requiredComponent or nil,
            lootItems = clone_loot_items(obj and obj.lootItems)
        }
    end

    -- First, ensure all cells start as "empty" (VOID)
    for i = 1, #world_grid do
        world_grid[i].tileID = hash("empty")
        world_grid[i].tileInstanceId = 0
        world_grid[i].isOutside = false
        world_grid[i].hazard_type = "none"
        world_grid[i].isFireHazard = false
        world_grid[i].isGasHazard = false
        world_grid[i].blipSpawnEnabled = false
        world_grid[i].hasLoot = false
        world_grid[i].lootOffsetX = 0
        world_grid[i].lootOffsetY = 0
        world_grid[i].object1 = { name = hash("empty"), isFixed = false, isWelded = false, isOpen = false, dependsOn = 0, isDependentOn = {}, objectId = 0, offsetX = 0, offsetY = 0, fxOffsetX = 0, fxOffsetY = 0, fxRotation = 0, fxFactory = nil, hitW = 32, hitH = 32, requiredComponent = nil }
        world_grid[i].object2 = { name = hash("empty"), isFixed = false, isWelded = false, isOpen = false, dependsOn = 0, isDependentOn = {}, objectId = 0, offsetX = 0, offsetY = 0, fxOffsetX = 0, fxOffsetY = 0, fxRotation = 0, fxFactory = nil, hitW = 32, hitH = 32, requiredComponent = nil }
        world_grid[i].object3 = { name = hash("empty"), isFixed = false, isWelded = false, isOpen = false, dependsOn = 0, isDependentOn = {}, objectId = 0, offsetX = 0, offsetY = 0, fxOffsetX = 0, fxOffsetY = 0, fxRotation = 0, fxFactory = nil, hitW = 32, hitH = 32, requiredComponent = nil }
    end

    -- Place each tile from the level design
    for placement_index, placement in ipairs(level_design) do
        local center_x = placement.x
        local center_y = placement.y
        local tile_name = placement.tile
        local tile = tile_library[tile_name]

        if not tile then
            print("ERROR: Tile '" .. tile_name .. "' not found in library")
        else
            -- Map the 3x3 tile cells to worldGrid
            -- Tile cell layout: 7 8 9
            --                   4 5 6
            --                   1 2 3
            local tile_cell_index = 1
            for dy = -1, 1 do
                for dx = -1, 1 do
                    local world_x = center_x + dx
                    local world_y = center_y + dy
                    local world_cell_id = coords_to_id(world_x, world_y)

                    if world_cell_id then
                        local tile_cell = tile.cells[tile_cell_index]
                        local world_cell = world_grid[world_cell_id]

                        -- Copy tile data to world cell
                        world_cell.tileID = tile.tileID
                        world_cell.lightValue = tile_cell.lightValue
                        world_cell.moveValue = tile_cell.moveValue
                        world_cell.coverValue = tile_cell.coverValue
                        world_cell.isOutside = tile_cell.isOutside == true
                        world_cell.hazard_type = tostring(tile_cell.hazard_type or tile_cell.hazardType or tile_cell.hazard or "none")
                        world_cell.isFireHazard = tile_cell.isFireHazard == true or tile_cell.has_fire_hazard == true or tile_cell.hasFireHazard == true
                        world_cell.isGasHazard = tile_cell.isGasHazard == true or tile_cell.has_gas_hazard == true or tile_cell.hasGasHazard == true
                        world_cell.accessRight = tile_cell.accessRight
                        world_cell.accessDown = tile_cell.accessDown
                        world_cell.isPowered = tile_cell.isPowered
                        world_cell.tileInstanceId = placement_index
                        world_cell.isOccupied = tile_cell.isOccupied
                        world_cell.hasLoot = tile_cell.hasLoot == true
                        world_cell.lootOffsetX = tile_cell.lootOffsetX or 0
                        world_cell.lootOffsetY = tile_cell.lootOffsetY or 0
                        world_cell.object1 = clone_object(tile_cell.object1)
                        world_cell.object2 = clone_object(tile_cell.object2)
                        world_cell.object3 = clone_object(tile_cell.object3)
                        local spawn_objs = { world_cell.object1, world_cell.object2, world_cell.object3 }
                        world_cell.blipSpawnEnabled = false
                        for _, obj in ipairs(spawn_objs) do
                            if obj and obj.name and (obj.name == hash("blip_spawn") or obj.name == hash("blip")) then
                                world_cell.blipSpawnEnabled = true
                                break
                            end
                        end
                    end

                    tile_cell_index = tile_cell_index + 1
                end
            end
        end
    end

    local next_object_id = 1
    local id_remap_by_tile = {}
    for _, cell in ipairs(world_grid) do
        local tile_instance = cell.tileInstanceId or 0
        id_remap_by_tile[tile_instance] = id_remap_by_tile[tile_instance] or {}
        local tile_remap = id_remap_by_tile[tile_instance]
        local objects = { cell.object1, cell.object2, cell.object3 }
        for _, obj in ipairs(objects) do
            if obj then
                obj.dependsOn = obj.dependsOn or 0
                obj.isDependentOn = obj.isDependentOn or {}
                obj.isWelded = obj.isWelded == true
                obj.isOpen = obj.isOpen == true
                obj.offsetX = obj.offsetX or 0
                obj.offsetY = obj.offsetY or 0
                obj.fxOffsetX = obj.fxOffsetX or 0
                obj.fxOffsetY = obj.fxOffsetY or 0
                obj.fxRotation = obj.fxRotation or 0
                obj.hitW = obj.hitW or 32
                obj.hitH = obj.hitH or 32
                obj.requiredComponent = obj.requiredComponent
                if obj.name and obj.name ~= hash("empty") then
                    local source_id = obj.objectId or 0
                    if source_id > 0 and tile_remap[source_id] then
                        obj.objectId = tile_remap[source_id]
                    else
                        obj.objectId = next_object_id
                        if source_id > 0 then
                            tile_remap[source_id] = next_object_id
                        end
                        next_object_id = next_object_id + 1
                    end
                else
                    obj.objectId = obj.objectId or 0
                end
            end
        end
    end
    for _, cell in ipairs(world_grid) do
        local tile_instance = cell.tileInstanceId or 0
        local tile_remap = id_remap_by_tile[tile_instance] or {}
        local objects = { cell.object1, cell.object2, cell.object3 }
        for _, obj in ipairs(objects) do
            if obj and obj.name and obj.name ~= hash("empty") then
                local dep = obj.dependsOn or 0
                if dep > 0 and tile_remap[dep] then
                    obj.dependsOn = tile_remap[dep]
                end
            end
        end
    end

    return world_grid
end

-- =============================================================================
-- PATHFINDING (A* Algorithm)
-- =============================================================================
--[[
    Finds path from start_cell_id to end_cell_id
    Returns: table of cell IDs representing path, or nil if no path found
    Takes into account: fixed step AP costs, access permissions, VOID cells
]]

function heuristic(from_id, to_id)
    local x1, y1 = id_to_coords(from_id)
    local x2, y2 = id_to_coords(to_id)
    return math.abs(x2 - x1) + math.abs(y2 - y1)  -- Manhattan distance
end

function find_path(world_grid, start_id, end_id, max_action_points, movement_profile, path_context)
    if not world_grid[start_id] or not world_grid[end_id] then
        return nil
    end

    if world_grid[end_id].tileID == hash("empty") then
        return nil  -- Can't path to VOID cell
    end

    movement_profile = movement_profile or MOVEMENT_PROFILE_HUMAN

    local open_set = { start_id }
    local came_from = {}
    local g_score = {}
    local f_score = {}

    -- Initialize scores
    for i = 1, #world_grid do
        g_score[i] = math.huge
        f_score[i] = math.huge
    end
    g_score[start_id] = 0
    f_score[start_id] = heuristic(start_id, end_id)

    while #open_set > 0 do
        -- Find node in open_set with lowest f_score
        local current = open_set[1]
        local current_index = 1
        for i, node_id in ipairs(open_set) do
            if f_score[node_id] < f_score[current] then
                current = node_id
                current_index = i
            end
        end

        if current == end_id then
            -- Reconstruct path
            local path = { current }
            while came_from[current] do
                current = came_from[current]
                table.insert(path, 1, current)
            end

            -- Calculate total cost
            local total_cost = 0
            for i = 2, #path do
                total_cost = total_cost + get_step_move_cost(world_grid, path[i - 1], path[i])
            end

            if max_action_points and total_cost > max_action_points then
                return nil  -- Path too expensive
            end

            return path, total_cost
        end

        -- Remove current from open_set
        table.remove(open_set, current_index)

        -- Check neighbors
        local neighbors = get_neighbors(current, world_grid, movement_profile, path_context)
        for _, neighbor_data in ipairs(neighbors) do
            local neighbor_id = neighbor_data.id
            local move_cost = neighbor_data.cost

            local tentative_g_score = g_score[current] + move_cost

            if tentative_g_score < g_score[neighbor_id] then
                came_from[neighbor_id] = current
                g_score[neighbor_id] = tentative_g_score
                f_score[neighbor_id] = g_score[neighbor_id] + heuristic(neighbor_id, end_id)

                -- Add to open_set if not already there
                local in_open = false
                for _, id in ipairs(open_set) do
                    if id == neighbor_id then
                        in_open = true
                        break
                    end
                end
                if not in_open then
                    table.insert(open_set, neighbor_id)
                end
            end
        end
    end

    return nil  -- No path found
end

local function find_alien_path(world_grid, alien_type, start_id, end_id, max_action_points, hidden_reveal_type)
    if not world_grid[start_id] or not world_grid[end_id] then
        return nil
    end

    local end_is_void = world_grid[end_id].tileID == hash("empty")
    if alien_type ~= ALIEN_TYPE_BLIP and end_is_void then
        return nil
    end

    local open_set = { start_id }
    local came_from = {}
    local g_score = {}
    local f_score = {}

    for i = 1, #world_grid do
        g_score[i] = math.huge
        f_score[i] = math.huge
    end

    g_score[start_id] = 0
    f_score[start_id] = heuristic(start_id, end_id)

    while #open_set > 0 do
        local current = open_set[1]
        local current_index = 1
        for i, node_id in ipairs(open_set) do
            if f_score[node_id] < f_score[current] then
                current = node_id
                current_index = i
            end
        end

        if current == end_id then
            local path = { current }
            while came_from[current] do
                current = came_from[current]
                table.insert(path, 1, current)
            end

            local total_cost = 0
            for i = 2, #path do
                local step_cost = get_alien_step_move_cost(world_grid, path[i - 1], path[i], alien_type)
                total_cost = total_cost + step_cost
            end

            if max_action_points and total_cost > max_action_points then
                return nil
            end

            return path, total_cost
        end

        table.remove(open_set, current_index)

        local neighbors = get_alien_neighbors(current, world_grid, alien_type, hidden_reveal_type)
        for _, neighbor_data in ipairs(neighbors) do
            local neighbor_id = neighbor_data.id
            local move_cost = neighbor_data.cost
            local tentative_g_score = g_score[current] + move_cost

            if tentative_g_score < g_score[neighbor_id] then
                came_from[neighbor_id] = current
                g_score[neighbor_id] = tentative_g_score
                f_score[neighbor_id] = g_score[neighbor_id] + heuristic(neighbor_id, end_id)

                local in_open = false
                for _, id in ipairs(open_set) do
                    if id == neighbor_id then
                        in_open = true
                        break
                    end
                end
                if not in_open then
                    table.insert(open_set, neighbor_id)
                end
            end
        end
    end

    return nil
end

local function pick_weighted_blip_reveal_type()
    local speedy_weight = ALIEN_REVEAL_WEIGHT_SPEEDY
    local cannon_weight = ALIEN_REVEAL_WEIGHT_CANNON
    local spitter_weight = ALIEN_REVEAL_WEIGHT_SPITTER
    local brute_weight = ALIEN_REVEAL_WEIGHT_BRUTE
    if SFX_TEST_FAVOR_SPEEDY_REVEAL == true then
        -- TEMP TEST TWEAK: bias reveals toward speedies for movement SFX validation.
        speedy_weight = math.max(speedy_weight, cannon_weight + spitter_weight + brute_weight)
    end
    local weighted = {
        { type = ALIEN_TYPE_CANNON, w = cannon_weight },
        { type = ALIEN_TYPE_SPEEDY, w = speedy_weight },
        { type = ALIEN_TYPE_SPITTER, w = spitter_weight },
        { type = ALIEN_TYPE_BRUTE, w = brute_weight }
    }

    local total = 0
    for _, item in ipairs(weighted) do
        total = total + item.w
    end

    if total <= 0 then
        return ALIEN_TYPE_CANNON
    end

    local roll = math.random() * total
    local running = 0
    for _, item in ipairs(weighted) do
        running = running + item.w
        if roll <= running then
            return item.type
        end
    end

    return ALIEN_TYPE_CANNON
end

local get_living_alien_targets

local function get_human_cell_ids(self)
    local ids = {}
    for _, target in ipairs(get_living_alien_targets(self)) do
        if target and target.cell_id then
            table.insert(ids, target.cell_id)
        end
    end
    return ids
end

local function get_nearest_human_cell_id(self, from_cell_id)
    local nearest = nil
    local best = math.huge
    for _, human_cell_id in ipairs(get_human_cell_ids(self)) do
        local d = heuristic(from_cell_id, human_cell_id)
        if d < best then
            best = d
            nearest = human_cell_id
        end
    end
    return nearest
end

local function get_nearest_reachable_human_cell_id(self, alien_type, from_cell_id, hidden_reveal_type)
    local human_ids = get_human_cell_ids(self)
    local best_target = nil
    local best_path = nil
    local best_cost = math.huge
    local from_cell = self.world_grid and self.world_grid[from_cell_id]
    local blip_in_void = (alien_type == ALIEN_TYPE_BLIP) and (from_cell and from_cell.tileID == hash("empty"))
    local hidden_brute_blip = alien_type == ALIEN_TYPE_BLIP and hidden_reveal_type == ALIEN_TYPE_BRUTE
    local can_use_vent = alien_type ~= ALIEN_TYPE_BRUTE and (not hidden_brute_blip) and not blip_in_void
    for _, human_cell_id in ipairs(human_ids) do
        local normal_path, normal_cost
        if alien_type == ALIEN_TYPE_BLIP or alien_type == ALIEN_TYPE_BRUTE then
            normal_path, normal_cost = find_alien_path(self.world_grid, alien_type, from_cell_id, human_cell_id, nil, hidden_reveal_type)
        else
            normal_path, normal_cost = find_path(self.world_grid, from_cell_id, human_cell_id, nil, MOVEMENT_PROFILE_HUMAN, nil)
        end
        local chosen_path = normal_path
        local chosen_cost = normal_cost or math.huge
        if can_use_vent then
            local vent_path, vent_cost = find_path(
                self.world_grid,
                from_cell_id,
                human_cell_id,
                nil,
                MOVEMENT_PROFILE_ALIEN_VENT,
                { target_cell_id = human_cell_id }
            )
            if vent_path and vent_cost and (vent_cost < chosen_cost or vent_cost == chosen_cost) then
                chosen_path = vent_path
                chosen_cost = vent_cost
            end
        end
        if chosen_path and chosen_cost then
            if chosen_cost < best_cost
                or (chosen_cost == best_cost and (best_target == nil or human_cell_id < best_target))
            then
                best_target = human_cell_id
                best_path = chosen_path
                best_cost = chosen_cost
            end
        end
    end
    if best_target and best_path then
        return best_target, best_path
    end
    return nil, nil
end

get_blip_fallback_staging_target = function(self, from_cell_id, alien_type, hidden_reveal_type)
    if not self.world_grid or not self.world_grid[from_cell_id] then
        return nil, nil
    end
    local fallback_alien_type = alien_type or ALIEN_TYPE_BLIP
    local human_ids = get_human_cell_ids(self)
    if #human_ids == 0 then
        return nil, nil
    end

    local best_target = nil
    local best_path = nil
    local best_human_dist = math.huge
    local best_path_cost = math.huge

    for candidate_id, candidate_cell in ipairs(self.world_grid) do
        if candidate_id ~= from_cell_id and candidate_cell and candidate_cell.tileID ~= hash("empty") then
            local candidate_path, candidate_cost = find_alien_path(self.world_grid, fallback_alien_type, from_cell_id, candidate_id, nil, hidden_reveal_type)
            if candidate_path and candidate_cost and candidate_cost > 0 then
                local nearest_human_dist = math.huge
                for _, human_id in ipairs(human_ids) do
                    local d = heuristic(candidate_id, human_id)
                    if d < nearest_human_dist then
                        nearest_human_dist = d
                    end
                end

                if nearest_human_dist < best_human_dist
                    or (nearest_human_dist == best_human_dist and candidate_cost < best_path_cost)
                    or (nearest_human_dist == best_human_dist and candidate_cost == best_path_cost and (best_target == nil or candidate_id < best_target))
                then
                    best_target = candidate_id
                    best_path = candidate_path
                    best_human_dist = nearest_human_dist
                    best_path_cost = candidate_cost
                end
            end
        end
    end

    return best_target, best_path
end

get_brute_barricade_staging_target = function(self, from_cell_id)
    if not self or not self.world_grid or not from_cell_id then
        return nil, nil
    end
    local best_target = nil
    local best_path = nil
    local best_cost = math.huge

    for cell_id, cell in ipairs(self.world_grid) do
        if cell and cell.tileID ~= hash("empty") and is_cell_barricaded(self.world_grid, cell_id) then
            local path, cost = find_alien_path(self.world_grid, ALIEN_TYPE_BRUTE, from_cell_id, cell_id, nil)
            if path and cost then
                if cost < best_cost or (cost == best_cost and (best_target == nil or cell_id < best_target)) then
                    best_target = cell_id
                    best_path = path
                    best_cost = cost
                end
            end
        end
    end
    return best_target, best_path
end

get_blip_cell_offset = function(alien)
    if not alien then
        return 0, 0
    end
    if alien.blip_cell_offset_x == nil or alien.blip_cell_offset_y == nil then
        alien.blip_cell_offset_x = math.random(-45, 45)
        alien.blip_cell_offset_y = math.random(-45, 45)
    end
    return alien.blip_cell_offset_x or 0, alien.blip_cell_offset_y or 0
end

local function has_unobstructed_los(world_grid, from_id, to_id)
    local from_cell = world_grid[from_id]
    local to_cell = world_grid[to_id]
    if not from_cell or not to_cell then
        return false
    end

    if from_cell.xCell ~= to_cell.xCell and from_cell.yCell ~= to_cell.yCell then
        return false
    end

    if from_cell.xCell == to_cell.xCell then
        local step = (to_cell.yCell > from_cell.yCell) and 1 or -1
        local current_id = from_id
        while current_id ~= to_id do
            local next_id = current_id + (GRID_COLS * step)
            if not can_human_cross_between_cells(world_grid, current_id, next_id) then
                return false
            end
            current_id = next_id
        end
        return true
    end

    local step = (to_cell.xCell > from_cell.xCell) and 1 or -1
    local current_id = from_id
    while current_id ~= to_id do
        local next_id = current_id + step
        if not can_human_cross_between_cells(world_grid, current_id, next_id) then
            return false
        end
        current_id = next_id
    end
    return true
end

local function has_unobstructed_human_ranged_los(world_grid, from_id, to_id)
    local from_cell = world_grid[from_id]
    local to_cell = world_grid[to_id]
    if not from_cell or not to_cell then
        return false
    end

    if from_cell.xCell ~= to_cell.xCell and from_cell.yCell ~= to_cell.yCell then
        return false
    end

    if from_cell.xCell == to_cell.xCell then
        local step = (to_cell.yCell > from_cell.yCell) and 1 or -1
        local current_id = from_id
        while current_id ~= to_id do
            local next_id = current_id + (GRID_COLS * step)
            if not can_cross_between_cells(world_grid, current_id, next_id) then
                return false
            end
            local _, _, door_closed = get_edge_door_context(world_grid, current_id, next_id)
            if door_closed then
                return false
            end
            -- Barricades do not block human ranged LOS by design.
            current_id = next_id
        end
        return true
    end

    local step = (to_cell.xCell > from_cell.xCell) and 1 or -1
    local current_id = from_id
    while current_id ~= to_id do
        local next_id = current_id + step
        if not can_cross_between_cells(world_grid, current_id, next_id) then
            return false
        end
        local _, _, door_closed = get_edge_door_context(world_grid, current_id, next_id)
        if door_closed then
            return false
        end
        -- Barricades do not block human ranged LOS by design.
        current_id = next_id
    end
    return true
end

compute_manual_ranged_hit_chance = function(self, unit, alien)
    if not (self and self.world_grid and unit and alien) then
        return nil
    end
    local alien_cell = self.world_grid[alien.cell_id]
    if not alien_cell then
        return nil
    end
    local active_light = (alien_cell.isPowered and math.max(0, math.min(3, alien_cell.lightValue or 0))) or 0
    local ranged_model = require("main.config").RANGED_HIT_MODEL
    local base_hit_chance = ranged_model.base_hit_chance + (active_light * ranged_model.per_light_level_bonus)
    local range_cells = manhattan_distance_by_id(unit.cell_id, alien.cell_id)
    local range_penalty = math.max(0, (range_cells - 1) * 10)
    local role = CLASS_ROLE_HOOKS[unit.class_id]
    local class_bonus = (role and role.ranged_hit_bonus) or 0
    return math.max(ranged_model.min_hit_chance, math.min(ranged_model.max_hit_chance, base_hit_chance + class_bonus - range_penalty))
end

local function get_edge_spawn_cell_ids(world_grid)
    local ids = {}
    local fallback_edge_ids = {}
    for cell_id, cell in ipairs(world_grid) do
        if cell and cell.tileID ~= hash("empty") then
            local has_spawn = cell.blipSpawnEnabled == true
            local objs = { cell.object1, cell.object2, cell.object3 }
            for _, obj in ipairs(objs) do
                if obj and obj.name and (obj.name == hash("blip_spawn") or obj.name == hash("blip")) then
                    has_spawn = true
                    break
                end
            end
            if has_spawn then
                table.insert(ids, cell_id)
            end
            if is_in_list(cell_id, LEFT_EDGE)
                or is_in_list(cell_id, RIGHT_EDGE)
                or is_in_list(cell_id, TOP_EDGE)
                or is_in_list(cell_id, BOTTOM_EDGE)
            then
                table.insert(fallback_edge_ids, cell_id)
            end
        end
    end
    if #ids == 0 and #fallback_edge_ids > 0 then
        return fallback_edge_ids
    end
    return ids
end

local function ensure_spitter_bottom_visual(self, alien)
    if not self or not alien or alien.type ~= ALIEN_TYPE_SPITTER or not alien.go_id then
        return
    end
    if self.aesthetic_mode ~= AESTHETIC_MODE_COMPUTER then
        if alien.spitter_bottom_go_id then
            pcall(go.delete, alien.spitter_bottom_go_id)
            alien.spitter_bottom_go_id = nil
        end
        return
    end
    if alien.spitter_bottom_go_id then
        local ok = pcall(go.get_position, alien.spitter_bottom_go_id)
        if ok then
            return
        end
        alien.spitter_bottom_go_id = nil
    end
    local base_pos = go.get_position(alien.go_id)
    local bottom_id = factory.create("/alien_spitter_bottom_factory#alien_spitter_bottom_factory", base_pos)
    if not bottom_id then
        return
    end
    go.set_parent(bottom_id, alien.go_id, false)
    go.set_position(vmath.vector3(0, SPITTER_BOTTOM_OFFSET_Y, SPITTER_BOTTOM_OFFSET_Z), bottom_id)
    sprite.set_hflip(msg.url(nil, bottom_id, "sprite"), alien.spitter_flip == true)
    alien.spitter_bottom_go_id = bottom_id
    alien.spitter_bottom_sway_phase = alien.spitter_bottom_sway_phase or (math.random() * math.pi * 2)
end

local function update_spitter_bottom_sway(alien, dt)
    if not alien or alien.type ~= ALIEN_TYPE_SPITTER or not alien.spitter_bottom_go_id then
        return
    end
    alien.spitter_bottom_sway_phase = (alien.spitter_bottom_sway_phase or 0) + (dt * SPITTER_BOTTOM_SWAY_SPEED * math.pi * 2)
    local sway_angle = math.sin(alien.spitter_bottom_sway_phase) * math.rad(SPITTER_BOTTOM_SWAY_MAX_DEG)
    local trail_base_target = 0
    if alien.is_moving and alien.go_id then
        local pos = go.get_position(alien.go_id)
        local prev_x = alien.spitter_last_x or pos.x
        local dx = pos.x - prev_x
        if dx < -0.1 then
            alien.spitter_bottom_trail_dir = -1
        elseif dx > 0.1 then
            alien.spitter_bottom_trail_dir = 1
        end
        trail_base_target = (alien.spitter_bottom_trail_dir or 0) * math.rad(SPITTER_BOTTOM_TRAIL_MOVE_DEG)
        alien.spitter_last_x = pos.x
    elseif alien.go_id then
        local pos = go.get_position(alien.go_id)
        alien.spitter_last_x = pos.x
        alien.spitter_bottom_trail_dir = nil
    end

    local base_next = trail_base_target
    if not alien.is_moving then
        -- Smoothly blend back to neutral when movement stops.
        local base_current = alien.spitter_bottom_trail_base_angle or 0
        local blend_t = math.min(1, (dt or 0) * SPITTER_BOTTOM_TRAIL_BLEND_SPEED)
        base_next = base_current + ((trail_base_target - base_current) * blend_t)
    end
    alien.spitter_bottom_trail_base_angle = base_next

    local angle = base_next + sway_angle
    pcall(go.set_rotation, vmath.quat_rotation_z(angle), alien.spitter_bottom_go_id)
end

local function ensure_alien_visual(self, alien)
    if alien.go_id then
        return
    end

    local x, y = coords_to_world_pos(self.world_grid[alien.cell_id].xCell, self.world_grid[alien.cell_id].yCell)
    if alien.type == ALIEN_TYPE_BLIP then
        local off_x, off_y = get_blip_cell_offset(alien)
        x = x + off_x
        y = y + off_y
    else
        x = x + (CELL_WIDTH * 0.25)
        local human_count = 0
        if self.squad_units then
            for _, unit in pairs(self.squad_units) do
                if unit.cell_id == alien.cell_id and (unit.current_health or 0) > 0 then
                    human_count = human_count + 1
                end
            end
        end
        if human_count > 0 and self.aliens then
            local on_cell = {}
            for _, scan in ipairs(self.aliens) do
                if (not scan.is_dead) and scan.cell_id == alien.cell_id and scan.type ~= ALIEN_TYPE_BLIP then
                    table.insert(on_cell, scan)
                end
            end
            table.sort(on_cell, function(a, b)
                return (a.id or 0) < (b.id or 0)
            end)
            local idx = 1
            for i, scan in ipairs(on_cell) do
                if scan.id == alien.id then
                    idx = i
                    break
                end
            end
            local lane = { 20, -20, 40, -40, 60, -60 }
            x = x + (lane[idx] or 0)
        end
        x = clamp_world_x_to_cell(self.world_grid[alien.cell_id], x)
    end
    if alien.type == ALIEN_TYPE_SPEEDY then
        y = y + 50
    elseif alien.type == ALIEN_TYPE_SPITTER then
        y = y - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM
    elseif alien.type == ALIEN_TYPE_CANNON then
        y = y - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM - 25
    elseif alien.type == ALIEN_TYPE_BRUTE then
        y = y - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM + 35
    else
        y = y + 0
    end
    local pos = vmath.vector3(x, y, 0.6)
    local visual_kind = "marker"
    if alien.type == ALIEN_TYPE_BLIP then
        alien.go_id = factory.create("/alien_blip_factory#alien_blip_factory", pos)
        alien.uses_blip_sprite = true
        visual_kind = "blip"
    elseif alien.type == ALIEN_TYPE_CANNON then
        alien.go_id = factory.create("/alien_cannon_fodder_factory#alien_cannon_fodder_factory", pos)
        alien.uses_blip_sprite = true
        visual_kind = "cannon"
    elseif alien.type == ALIEN_TYPE_SPITTER then
        alien.go_id = factory.create("/alien_spitter_factory#alien_spitter_factory", pos)
        alien.uses_blip_sprite = true
        visual_kind = "spitter"
    elseif alien.type == ALIEN_TYPE_SPEEDY then
        alien.go_id = factory.create("/alien_speedy_factory#alien_speedy_factory", pos)
        alien.uses_blip_sprite = true
        visual_kind = "speedy"
    elseif alien.type == ALIEN_TYPE_BRUTE then
        alien.go_id = factory.create("/alien_cannon_fodder_factory#alien_cannon_fodder_factory", pos)
        alien.uses_blip_sprite = true
        visual_kind = "brute"
    else
        alien.go_id = factory.create("/ui_factory#ui_factory", pos)
        alien.uses_blip_sprite = false
        visual_kind = "marker"
    end
    alien.visual_kind = visual_kind
    if alien.go_id then
        if alien.uses_blip_sprite then
            if alien.type == ALIEN_TYPE_CANNON or alien.type == ALIEN_TYPE_SPITTER or alien.type == ALIEN_TYPE_SPEEDY or alien.type == ALIEN_TYPE_BRUTE then
                local scale = 0.33333334
                if alien.type == ALIEN_TYPE_CANNON then
                    scale = 0.22 * CANNON_FODDER_SCALE_MULTIPLIER
                elseif alien.type == ALIEN_TYPE_SPITTER then
                    scale = (0.33333334 * 0.75) * SPITTER_SCALE_MULTIPLIER
                elseif alien.type == ALIEN_TYPE_SPEEDY then
                    scale = scale * 0.75
                elseif alien.type == ALIEN_TYPE_BRUTE then
                    scale = (0.22 * 1.5 * 1.25 * 1.2 * 1.1) * ((self.aesthetic_mode == AESTHETIC_MODE_COMPUTER) and 1.2 or 1.0)
                end
                sprite.set_hflip(msg.url(nil, alien.go_id, "sprite"), false)
                sprite.set_hflip(msg.url(nil, alien.go_id, "shadow"), false)
                go.set(msg.url(nil, alien.go_id, "shadow"), "tint", vmath.vector4(1, 1, 1, get_world_shadow_alpha(self)))
                alien.spitter_flip = false
                go.set_scale(vmath.vector3(scale, scale, 1), alien.go_id)
                if alien.type == ALIEN_TYPE_SPITTER then
                    ensure_spitter_bottom_visual(self, alien)
                end
            else
                go.set_scale(vmath.vector3(1, 1, 1), alien.go_id)
            end
        else
            go.set_scale(vmath.vector3(ALIEN_MARKER_SIZE, ALIEN_MARKER_SIZE, 1), alien.go_id)
        end
    end
end

local function refresh_alien_visual(self, alien)
    local wanted_visual_kind = "marker"
    if alien.type == ALIEN_TYPE_BLIP then
        wanted_visual_kind = "blip"
    elseif alien.type == ALIEN_TYPE_CANNON then
        wanted_visual_kind = "cannon"
    elseif alien.type == ALIEN_TYPE_SPITTER then
        wanted_visual_kind = "spitter"
    elseif alien.type == ALIEN_TYPE_SPEEDY then
        wanted_visual_kind = "speedy"
    elseif alien.type == ALIEN_TYPE_BRUTE then
        wanted_visual_kind = "brute"
    end
    if alien.go_id and alien.visual_kind ~= wanted_visual_kind then
        go.delete(alien.go_id)
        alien.go_id = nil
    end
    if not alien.go_id then
        ensure_alien_visual(self, alien)
    end
    if not alien.go_id then
        return
    end
    local alien_anim = get_alien_anim_for_aesthetic(self, alien.type)
    if alien_anim and alien.current_aesthetic_anim ~= alien_anim then
        msg.post(msg.url(nil, alien.go_id, "sprite"), "play_animation", { id = alien_anim })
        alien.current_aesthetic_anim = alien_anim
    elseif not alien_anim then
        alien.current_aesthetic_anim = nil
    end
    if alien.type == ALIEN_TYPE_SPITTER then
        ensure_spitter_bottom_visual(self, alien)
    else
        alien.spitter_bottom_go_id = nil
    end

    local cfg = ALIEN_TYPE_CONFIG[alien.type]
    local x, y = coords_to_world_pos(self.world_grid[alien.cell_id].xCell, self.world_grid[alien.cell_id].yCell)
    if alien.type == ALIEN_TYPE_BLIP then
        local off_x, off_y = get_blip_cell_offset(alien)
        x = x + off_x
        y = y + off_y
    else
        x = x + (CELL_WIDTH * 0.25)
        local human_count = 0
        if self.squad_units then
            for _, unit in pairs(self.squad_units) do
                if unit.cell_id == alien.cell_id and (unit.current_health or 0) > 0 then
                    human_count = human_count + 1
                end
            end
        end
        if human_count > 0 and self.aliens then
            local on_cell = {}
            for _, scan in ipairs(self.aliens) do
                if (not scan.is_dead) and scan.cell_id == alien.cell_id and scan.type ~= ALIEN_TYPE_BLIP then
                    table.insert(on_cell, scan)
                end
            end
            table.sort(on_cell, function(a, b)
                return (a.id or 0) < (b.id or 0)
            end)
            local idx = 1
            for i, scan in ipairs(on_cell) do
                if scan.id == alien.id then
                    idx = i
                    break
                end
            end
            local lane = { 20, -20, 40, -40, 60, -60 }
            x = x + (lane[idx] or 0)
        end
        x = clamp_world_x_to_cell(self.world_grid[alien.cell_id], x)
    end
    if alien.type == ALIEN_TYPE_SPEEDY then
        y = y + 50
    elseif alien.type == ALIEN_TYPE_SPITTER then
        y = y - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM
    elseif alien.type == ALIEN_TYPE_CANNON then
        y = y - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM - 25
    elseif alien.type == ALIEN_TYPE_BRUTE then
        y = y - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM + 5
    else
        y = y + 0
    end
    go.set_position(vmath.vector3(x, y, 0.6), alien.go_id)
    if alien.melee_flash_active then
        local flash_alpha = 1
        if cfg and cfg.marker_tint then
            flash_alpha = cfg.marker_tint.w
        end
        go.set(msg.url(nil, alien.go_id, "sprite"), "tint", vmath.vector4(1, 0.2, 0.2, flash_alpha))
    elseif alien.type == ALIEN_TYPE_BLIP and alien.uses_blip_sprite then
        if alien.hidden_reveal_type == ALIEN_TYPE_BRUTE then
            go.set(msg.url(nil, alien.go_id, "sprite"), "tint", vmath.vector4(1.0, 0.55, 0.15, 1.0))
        else
            go.set(msg.url(nil, alien.go_id, "sprite"), "tint", vmath.vector4(1, 1, 1, 1))
        end
    elseif (not alien.uses_blip_sprite) and cfg and cfg.marker_tint then
        go.set(msg.url(nil, alien.go_id, "sprite"), "tint", cfg.marker_tint)
    end
end

local function spawn_alien(self, alien_type, cell_id)
    local cfg = ALIEN_TYPE_CONFIG[alien_type]
    if not cfg then
        return nil
    end

    self.next_alien_id = (self.next_alien_id or 0) + 1
    local alien = {
        id = self.next_alien_id,
        type = alien_type,
        cell_id = cell_id,
        ap_max = cfg.ap_per_turn,
        hp_max = cfg.hp,
        hp_current = cfg.hp,
        can_traverse_void = cfg.can_traverse_void == true,
        has_ranged = cfg.has_ranged == true,
        ranged_cells = cfg.ranged_cells or 0,
        go_id = nil,
        is_moving = false,
        move_path = nil,
        move_path_index = 0,
        spitter_anim_phase = math.random() * math.pi * 2,
        spitter_flip = false
    }
    if alien_type == ALIEN_TYPE_BLIP then
        alien.hidden_reveal_type = pick_weighted_blip_reveal_type()
    end

    table.insert(self.aliens, alien)
    ensure_alien_visual(self, alien)
    refresh_alien_visual(self, alien)
    print(string.format("Alien spawned: #%d %s at cell %d", alien.id, alien.type, alien.cell_id))
    return alien
end

local function maybe_reveal_blip(self, alien)
    if alien.type ~= ALIEN_TYPE_BLIP then
        return
    end

    -- Blips cannot reveal while standing in VOID cells.
    local current_cell = self.world_grid[alien.cell_id]
    if not current_cell or current_cell.tileID == hash("empty") then
        return
    end

    for _, human_cell_id in ipairs(get_human_cell_ids(self)) do
        if has_unobstructed_los(self.world_grid, alien.cell_id, human_cell_id) then
            local revealed_type = alien.hidden_reveal_type or pick_weighted_blip_reveal_type()
            local cfg = ALIEN_TYPE_CONFIG[revealed_type]
            alien.type = revealed_type
            alien.ap_max = cfg.ap_per_turn
            alien.hp_max = cfg.hp
            alien.hp_current = cfg.hp
            alien.can_traverse_void = cfg.can_traverse_void == true
            alien.has_ranged = cfg.has_ranged == true
            alien.ranged_cells = cfg.ranged_cells or 0
            refresh_alien_visual(self, alien)
            print(string.format("Blip #%d revealed as %s", alien.id, revealed_type))
            return
        end
    end
end

local function get_alien_turn_movement_segment(self, alien, path, max_ap)
    if not path or #path < 2 then
        return nil, 0
    end

    local ap_spent = 0
    local segment = { path[1] }

    for i = 2, #path do
        local from_cell = path[i - 1]
        local to_cell = path[i]
        local step_cost = get_alien_step_move_cost(self.world_grid, from_cell, to_cell, alien and alien.type or nil)

        if ap_spent + step_cost > max_ap then
            break
        end

        ap_spent = ap_spent + step_cost
        table.insert(segment, to_cell)
    end

    if #segment < 2 then
        return nil, 0
    end

    return segment, ap_spent
end

apply_blip_pulse_scale = function(alien, dt)
    if not alien or alien.type ~= ALIEN_TYPE_BLIP or alien.is_dead or not alien.go_id then
        return
    end
    if alien.blip_pulse_phase == nil then
        alien.blip_pulse_phase = math.random() * math.pi * 2
    end
    if alien.blip_pulse_speed == nil then
        alien.blip_pulse_speed = 0.14 + (math.random() * 0.12) -- cycles/sec (slow)
    end
    if alien.blip_pulse_amount == nil then
        alien.blip_pulse_amount = 0.07 + (math.random() * 0.14)
    end
    if alien.blip_pulse_base_scale == nil then
        alien.blip_pulse_base_scale = 0.92 + (math.random() * 0.18)
    end
    local speed_mul = 2
    local scale_mul = 1.25
    if alien.hidden_reveal_type == ALIEN_TYPE_BRUTE then
        scale_mul = scale_mul * 2.0
    end
    alien.blip_pulse_phase = alien.blip_pulse_phase + (dt * alien.blip_pulse_speed * speed_mul * math.pi * 2)
    local wave = math.sin(alien.blip_pulse_phase)
    local s = alien.blip_pulse_base_scale * (1 + (wave * alien.blip_pulse_amount)) * scale_mul
    go.set_scale(vmath.vector3(s, s, 1), alien.go_id)
end

update_spitter_idle_visual = function(self, alien, dt)
    if not alien or alien.type ~= ALIEN_TYPE_SPITTER or not alien.go_id then
        return
    end
    ensure_spitter_bottom_visual(self, alien)
    alien.spitter_idle_phase = (alien.spitter_idle_phase or 0) + (dt * SPITTER_IDLE_PULSE_SPEED * math.pi * 2)
    local pulse = math.sin(alien.spitter_idle_phase)
    local pulse_mul = 1 + (SPITTER_IDLE_PULSE_AMPLITUDE * pulse)
    local base_scale = (0.33333334 * 0.75) * SPITTER_SCALE_MULTIPLIER
    go.set_scale(vmath.vector3(base_scale * pulse_mul, base_scale * pulse_mul, 1), alien.go_id)

    local decoupled_mp_client = (REALTIME_MP_DECOUPLE_MOVEMENT_FROM_HOST == true)
        and self
        and self.mp_state
        and self.mp_state.enabled == true
        and self.mp_state.local_player_id ~= self.mp_state.host_player_id
        and self.realtime_rules_enabled == true
    if decoupled_mp_client then
        -- Avoid fighting host snapshot/interpolation transforms on client.
        alien.spitter_idle_anchor_x = nil
        alien.spitter_idle_anchor_y = nil
        update_spitter_bottom_sway(alien, dt)
        return
    end

    if alien.is_moving then
        alien.spitter_idle_anchor_x = nil
        alien.spitter_idle_anchor_y = nil
        return
    end
    local pos = go.get_position(alien.go_id)
    if not alien.spitter_idle_anchor_x or not alien.spitter_idle_anchor_y then
        alien.spitter_idle_anchor_x = pos.x
        alien.spitter_idle_anchor_y = pos.y
    end
    alien.spitter_bob_phase = (alien.spitter_bob_phase or 0) + (dt * SPITTER_IDLE_BOB_SPEED * math.pi * 2)
    local bob_offset_y = math.sin(alien.spitter_bob_phase) * SPITTER_IDLE_BOB_AMPLITUDE
    go.set_position(vmath.vector3(alien.spitter_idle_anchor_x, alien.spitter_idle_anchor_y + bob_offset_y, pos.z), alien.go_id)
    update_spitter_bottom_sway(alien, dt)
end

local function get_vent_object_on_cell(cell)
    if not cell then
        return nil
    end
    local objs = { cell.object1, cell.object2, cell.object3 }
    for _, obj in ipairs(objs) do
        if object_is_vent(obj) then
            if obj.isWelded ~= true and obj.isSealed ~= true then
                return obj
            end
        end
    end
    return nil
end

local function begin_alien_path_animation(alien, segment_path)
    alien.move_path = segment_path
    alien.move_path_index = 2 -- first is current position
    alien.is_moving = true
end

local function any_alien_is_moving(self)
    if not self.aliens then
        return false
    end
    for _, alien in ipairs(self.aliens) do
        if alien.is_moving then
            return true
        end
    end
    return false
end

local function remove_dead_aliens(self)
    if not self.aliens then
        return
    end
    for i = #self.aliens, 1, -1 do
        if self.aliens[i].is_dead then
            local alien = self.aliens[i]
            clear_counter_shadow_proxy(alien)
            if alien.spitter_bottom_go_id then
                pcall(go.delete, alien.spitter_bottom_go_id)
                alien.spitter_bottom_go_id = nil
            end
            if alien.go_id then
                go.delete(alien.go_id)
                alien.go_id = nil
            end
            table.remove(self.aliens, i)
        end
    end
end

local function spawn_human_reaction_projectile(self, shooter_unit, target_alien, impact_hit, impact_light, impact_chance, impact_roll)
    if not shooter_unit or not shooter_unit.go_path or not target_alien or not target_alien.go_id then
        return
    end

    local from = go.get_position(shooter_unit.go_path)
    local to = go.get_position(target_alien.go_id)
    local projectile_id = factory.create("/ui_factory#ui_factory", vmath.vector3(from.x, from.y, 0.75))
    if not projectile_id then
        return
    end
    play_human_shoot_sfx(self)

    go.set_scale(vmath.vector3(SPITTER_PROJECTILE_SIZE * 0.2, SPITTER_PROJECTILE_SIZE * 0.2, 1), projectile_id)
    msg.post(msg.url(nil, projectile_id, "sprite"), "play_animation", { id = hash("human_projectile_1") })
    go.set(msg.url(nil, projectile_id, "sprite"), "tint", vmath.vector4(1, 1, 1, 1))
    local dir_x = to.x - from.x
    local dir_y = to.y - (from.y + 20)
    if math.abs(dir_x) > 0.01 or math.abs(dir_y) > 0.01 then
        go.set_rotation(vmath.quat_rotation_z(math.atan2(dir_y, dir_x) + math.pi), projectile_id)
    end

    table.insert(self.spitter_projectiles, {
        kind = "human",
        go_id = projectile_id,
        from = vmath.vector3(from.x, from.y + 20, 0.75),
        to = vmath.vector3(to.x, to.y, 0.75),
        t = 0,
        speed = SPITTER_PROJECTILE_SPEED * 1.4,
        target_alien_id = target_alien.id,
        shooter_name = shooter_unit.display_name,
        impact_hit = impact_hit == true,
        impact_light = impact_light or 0,
        impact_chance = impact_chance or 0,
        impact_roll = impact_roll or 0
    })
    if self.mp_state and self.mp_state.enabled and realtime_mp_host_can_simulate(self) then
        multiplayer_transport_broadcast_event(self, "realtime_human_projectile", {
            from_x = from.x,
            from_y = from.y + 20,
            to_x = to.x,
            to_y = to.y
        })
    end
end

local function resolve_human_reaction_fire(self, alien)
    if not self.reactive_combat_enabled then
        return false
    end
    if not alien or alien.is_dead then
        return false
    end

    self.human_reactive_fire_cooldown_by_unit_id = self.human_reactive_fire_cooldown_by_unit_id or {}
    self.human_reactive_pending_delay_by_unit_id = self.human_reactive_pending_delay_by_unit_id or {}

    local reaction_order = { "sarge", "techie", "medic", "gunner" }
    for _, unit_id in ipairs(reaction_order) do
        local unit = self.squad_units and self.squad_units[unit_id]
        local unit_cooldown = self.human_reactive_fire_cooldown_by_unit_id[unit_id]
        local unit_pending_delay = self.human_reactive_pending_delay_by_unit_id[unit_id]
        if unit and unit.cell_id and unit.reactive_fire_enabled ~= false and ((not unit_cooldown) or unit_cooldown <= 0) then
            if self.realtime_rules_enabled == true and unit_pending_delay and unit_pending_delay > 0 then
                goto continue_reactive_unit
            end
            local nearest_dist = math.huge
            local tied_targets = {}
            if self.aliens then
                for _, candidate in ipairs(self.aliens) do
                    if candidate and (not candidate.is_dead) and candidate.cell_id and has_unobstructed_human_ranged_los(self.world_grid, unit.cell_id, candidate.cell_id) then
                        local d = manhattan_distance_by_id(unit.cell_id, candidate.cell_id)
                        local is_vertical_lane = false
                        local vertical_lane_allowed = true
                        local from_cell = self.world_grid[unit.cell_id]
                        local to_cell = self.world_grid[candidate.cell_id]
                        if from_cell and to_cell then
                            is_vertical_lane = (from_cell.xCell == to_cell.xCell) and (from_cell.yCell ~= to_cell.yCell)
                            if is_vertical_lane then
                                local from_center_x = coords_to_world_pos(from_cell.xCell, from_cell.yCell)
                                local to_center_x = coords_to_world_pos(to_cell.xCell, to_cell.yCell)
                                local shooter_pos = unit.go_path and go.get_position(unit.go_path) or nil
                                local target_pos = candidate.go_id and go.get_position(candidate.go_id) or nil
                                local shooter_x = shooter_pos and shooter_pos.x or from_center_x
                                local target_x = target_pos and target_pos.x or to_center_x
                                local right_threshold = CELL_WIDTH * 0.15
                                local shooter_in_right_lane = shooter_x >= (from_center_x + right_threshold)
                                local target_in_right_lane = target_x >= (to_center_x + right_threshold)
                                vertical_lane_allowed = shooter_in_right_lane and target_in_right_lane
                            end
                        end
                        if vertical_lane_allowed then
                            if d < nearest_dist then
                                nearest_dist = d
                                tied_targets = { candidate }
                            elseif d == nearest_dist then
                                table.insert(tied_targets, candidate)
                            end
                        end
                    end
                end
            end
            local chosen_target = nil
            if #tied_targets > 0 then
                chosen_target = tied_targets[math.random(1, #tied_targets)]
            end
            if chosen_target then
                local reactive_shot_ap_cost = get_ap_cost_value("reactive_ranged_shot", 1)
                try_realtime_auto_load_ammo_from_backpack(self, unit)
                if unit.current_ap < reactive_shot_ap_cost and unit.current_ammo <= 0 then
                    print(string.format("%s cannot fire at alien #%d (no AP and no ammo)", unit.display_name, chosen_target.id))
                elseif unit.current_ap < reactive_shot_ap_cost then
                    print(string.format("%s cannot fire at alien #%d (no AP)", unit.display_name, chosen_target.id))
                elseif unit.current_ammo <= 0 then
                    print(string.format("%s cannot fire at alien #%d (no ammo)", unit.display_name, chosen_target.id))
                else
                    if self.realtime_rules_enabled == true then
                        if unit_pending_delay == nil then
                            local jitter_min = math.max(0, tonumber(HUMAN_REACTIVE_REALTIME_STAGGER_MIN_S or 0) or 0)
                            local jitter_max = math.max(jitter_min, tonumber(HUMAN_REACTIVE_REALTIME_STAGGER_MAX_S or jitter_min) or jitter_min)
                            self.human_reactive_pending_delay_by_unit_id[unit_id] = jitter_min + (math.random() * (jitter_max - jitter_min))
                            goto continue_reactive_unit
                        elseif unit_pending_delay > 0 then
                            goto continue_reactive_unit
                        end
                    end
                    self.human_reactive_pending_delay_by_unit_id[unit_id] = nil
                    unit.current_ap = unit.current_ap - reactive_shot_ap_cost
                    unit.current_ammo = unit.current_ammo - 1
                    local target_cell = self.world_grid[chosen_target.cell_id]
                    local active_light = (target_cell and target_cell.isPowered and math.max(0, math.min(3, target_cell.lightValue or 0))) or 0
                    local ranged_model = require("main.config").RANGED_HIT_MODEL
                    local base_hit_chance = ranged_model.base_hit_chance + (active_light * ranged_model.per_light_level_bonus)
                    local range_cells = nearest_dist
                    local range_penalty = math.max(0, (range_cells - 1) * 10)
                    local role = CLASS_ROLE_HOOKS[unit.class_id]
                    local class_bonus = (role and role.ranged_hit_bonus) or 0
                    local hit_chance = math.max(ranged_model.min_hit_chance, math.min(ranged_model.max_hit_chance, base_hit_chance + class_bonus - range_penalty))
                    print(string.format(
                        "RANGED DEBUG | reactive | shooter=%s targetAlien=%d range=%d penalty=%d light=%d classBonus=%d chance=%d",
                        unit.display_name or "unit",
                        chosen_target.id or 0,
                        range_cells or 0,
                        range_penalty or 0,
                        active_light or 0,
                        class_bonus or 0,
                        hit_chance or 0
                    ))
                    local roll = math.random(1, 100)
                    spawn_human_reaction_projectile(self, unit, chosen_target, roll <= hit_chance, active_light, hit_chance, roll)
                    self.human_reactive_fire_cooldown_by_unit_id[unit_id] = HUMAN_REACTIVE_FIRE_INTERVAL_SECONDS
                end
            end
        end
        ::continue_reactive_unit::
    end

    return false
end

local function tick_human_reactive_fire_cooldowns(self, dt)
    self.human_reactive_fire_cooldown_by_unit_id = self.human_reactive_fire_cooldown_by_unit_id or {}
    for unit_id, cooldown in pairs(self.human_reactive_fire_cooldown_by_unit_id) do
        cooldown = cooldown - dt
        if cooldown <= 0 then
            self.human_reactive_fire_cooldown_by_unit_id[unit_id] = nil
        else
            self.human_reactive_fire_cooldown_by_unit_id[unit_id] = cooldown
        end
    end
    self.human_reactive_pending_delay_by_unit_id = self.human_reactive_pending_delay_by_unit_id or {}
    for unit_id, delay_s in pairs(self.human_reactive_pending_delay_by_unit_id) do
        local next_delay = (tonumber(delay_s or 0) or 0) - (tonumber(dt or 0) or 0)
        if next_delay <= 0 then
            self.human_reactive_pending_delay_by_unit_id[unit_id] = 0
        else
            self.human_reactive_pending_delay_by_unit_id[unit_id] = next_delay
        end
    end
end

local function get_living_humans(self)
    local living = {}
    if not self.squad_units then
        return living
    end
    for _, unit in pairs(self.squad_units) do
        if unit.cell_id and unit.current_health and unit.current_health > 0 then
            table.insert(living, unit)
        end
    end
    return living
end

get_living_alien_targets = function(self)
    local living = {}
    if self and self.squad_units then
        for _, unit in pairs(self.squad_units) do
            if unit and unit.cell_id and (unit.current_health or 0) > 0 then
                unit.target_kind = "human"
                table.insert(living, unit)
            end
        end
    end
    if self and self.civilians then
        for _, civilian in ipairs(self.civilians) do
            if civilian and civilian.cell_id and (civilian.current_health or 0) > 0 and civilian.is_dead ~= true then
                civilian.target_kind = "civilian"
                civilian.display_name = civilian.display_name or string.format("Civilian #%d", tonumber(civilian.id or 0) or 0)
                table.insert(living, civilian)
            end
        end
    end
    return living
end

local function has_living_alien_target_on_cell(self, cell_id)
    if not (self and cell_id) then
        return false
    end
    for _, target in ipairs(get_living_alien_targets(self)) do
        if target and target.cell_id == cell_id then
            return true
        end
    end
    return false
end

get_barricade_anchor_x_for_cell = function(cell)
    if not cell then
        return 0
    end
    if cell.barricade_anchor_x ~= nil then
        return cell.barricade_anchor_x
    end
    local slot_index = cell.barricade_slot_index or 2
    if slot_index == 1 then
        return -70
    elseif slot_index == 3 then
        return 70
    end
    return 0
end

spitter_shot_blocked_by_barricade = function(self, alien, target)
    if not self or not self.world_grid or not alien or not target then
        return false
    end
    local from_id = alien.cell_id
    local to_id = target.cell_id
    if not from_id or not to_id or from_id == to_id then
        return false
    end
    local from_cell = self.world_grid[from_id]
    local to_cell = self.world_grid[to_id]
    if not from_cell or not to_cell then
        return false
    end

    -- Rule 1: any barricade in an intermediate cell blocks the shot.
    if from_cell.xCell == to_cell.xCell then
        local step = (to_cell.yCell > from_cell.yCell) and 1 or -1
        for y = from_cell.yCell + step, to_cell.yCell - step, step do
            local mid_id = coords_to_id(from_cell.xCell, y)
            if mid_id and is_cell_barricaded(self.world_grid, mid_id) then
                return true, "intermediate_barricade"
            end
        end
    elseif from_cell.yCell == to_cell.yCell then
        local step = (to_cell.xCell > from_cell.xCell) and 1 or -1
        for x = from_cell.xCell + step, to_cell.xCell - step, step do
            local mid_id = coords_to_id(x, from_cell.yCell)
            if mid_id and is_cell_barricaded(self.world_grid, mid_id) then
                return true, "intermediate_barricade"
            end
        end
    end

    -- Rules 2-5: same-cell barricade can block cross-cell horizontal shooting by side.
    if is_cell_barricaded(self.world_grid, from_id) and from_cell.xCell ~= to_cell.xCell then
        local from_center_x = coords_to_world_pos(from_cell.xCell, from_cell.yCell)
        local shooter_pos = alien.go_id and go.get_position(alien.go_id) or nil
        local shooter_x = shooter_pos and shooter_pos.x or from_center_x
        local barricade_x = from_center_x + get_barricade_anchor_x_for_cell(from_cell)

        local shooter_side = (shooter_x >= barricade_x) and 1 or -1
        local target_dir = (to_cell.xCell > from_cell.xCell) and 1 or -1
        if shooter_side ~= target_dir then
            return true, "same_cell_side_block"
        end
    end

    -- Rule 6: barricade in target cell can shield by target-side against horizontal shots.
    if is_cell_barricaded(self.world_grid, to_id) and from_cell.xCell ~= to_cell.xCell then
        local to_center_x = coords_to_world_pos(to_cell.xCell, to_cell.yCell)
        local target_go_id = target.go_path or (self.civilian_visuals and target.id and self.civilian_visuals[target.id]) or nil
        local target_pos = target_go_id and go.get_position(target_go_id) or nil
        local target_x = target_pos and target_pos.x or to_center_x
        local barricade_x = to_center_x + get_barricade_anchor_x_for_cell(to_cell)
        local target_side = (target_x >= barricade_x) and 1 or -1
        local shot_dir = (to_cell.xCell > from_cell.xCell) and 1 or -1
        if target_side == shot_dir then
            return true, "target_cell_side_block"
        end
    end

    return false
end

local function choose_spitter_target(self, alien)
    local candidates = {}
    local range_cells = alien.ranged_cells or SPITTER_MAX_RANGE_CELLS
    for _, target in ipairs(get_living_alien_targets(self)) do
        local dist = heuristic(alien.cell_id, target.cell_id)
        if dist <= range_cells and has_unobstructed_los(self.world_grid, alien.cell_id, target.cell_id) then
            local vertical_lane_allowed = true
            local from_cell = self.world_grid and self.world_grid[alien.cell_id] or nil
            local to_cell = self.world_grid and self.world_grid[target.cell_id] or nil
            if from_cell and to_cell then
                local is_vertical_lane = (from_cell.xCell == to_cell.xCell) and (from_cell.yCell ~= to_cell.yCell)
                if is_vertical_lane then
                    local from_center_x = coords_to_world_pos(from_cell.xCell, from_cell.yCell)
                    local to_center_x = coords_to_world_pos(to_cell.xCell, to_cell.yCell)
                    local shooter_pos = alien.go_id and go.get_position(alien.go_id) or nil
                    local target_go_id = target.go_path or (self.civilian_visuals and target.id and self.civilian_visuals[target.id]) or nil
                    local target_pos = target_go_id and go.get_position(target_go_id) or nil
                    local shooter_x = shooter_pos and shooter_pos.x or from_center_x
                    local target_x = target_pos and target_pos.x or to_center_x
                    local right_threshold = CELL_WIDTH * 0.15
                    local shooter_in_right_lane = shooter_x >= (from_center_x + right_threshold)
                    local target_in_right_lane = target_x >= (to_center_x + right_threshold)
                    vertical_lane_allowed = shooter_in_right_lane and target_in_right_lane
                end
            end
            local blocked_by_barricade = spitter_shot_blocked_by_barricade(self, alien, target)
            if vertical_lane_allowed and (not blocked_by_barricade) then
                table.insert(candidates, { unit = target, dist = dist, hp = target.current_health })
            end
        end
    end

    if #candidates == 0 then
        return nil
    end

    local nearest_dist = math.huge
    for _, candidate in ipairs(candidates) do
        if candidate.dist < nearest_dist then
            nearest_dist = candidate.dist
        end
    end

    local nearest = {}
    for _, candidate in ipairs(candidates) do
        if candidate.dist == nearest_dist then
            table.insert(nearest, candidate)
        end
    end

    local lowest_hp = math.huge
    for _, candidate in ipairs(nearest) do
        if candidate.hp < lowest_hp then
            lowest_hp = candidate.hp
        end
    end

    local best = {}
    for _, candidate in ipairs(nearest) do
        if candidate.hp == lowest_hp then
            table.insert(best, candidate)
        end
    end

    if #best == 1 then
        return best[1].unit
    end
    return best[math.random(1, #best)].unit
end

local function spawn_spitter_projectile(self, alien, target_human)
    local target_go_id = target_human and (target_human.go_path or (self.civilian_visuals and target_human.id and self.civilian_visuals[target_human.id])) or nil
    if not alien.go_id or not target_go_id then
        return
    end

    local from = go.get_position(alien.go_id)
    local to = go.get_position(target_go_id)
    local projectile_id = factory.create("/ui_factory#ui_factory", vmath.vector3(from.x, from.y, 0.75))
    if not projectile_id then
        return
    end

    go.set_scale(vmath.vector3(SPITTER_PROJECTILE_SIZE * 0.2, SPITTER_PROJECTILE_SIZE * 0.2, 1), projectile_id)
    msg.post(msg.url(nil, projectile_id, "sprite"), "play_animation", { id = hash("alien_projectile_1") })
    go.set(msg.url(nil, projectile_id, "sprite"), "tint", vmath.vector4(1, 1, 1, 1))
    local dir_x = to.x - from.x
    local dir_y = (to.y + 20) - from.y
    if math.abs(dir_x) > 0.01 or math.abs(dir_y) > 0.01 then
        go.set_rotation(vmath.quat_rotation_z(math.atan2(dir_y, dir_x) + math.pi), projectile_id)
    end

    table.insert(self.spitter_projectiles, {
        kind = "alien",
        go_id = projectile_id,
        from = vmath.vector3(from.x, from.y, 0.75),
        to = vmath.vector3(to.x, to.y + 20, 0.75),
        t = 0
    })
    if self.mp_state and self.mp_state.enabled and realtime_mp_host_can_simulate(self) then
        multiplayer_transport_broadcast_event(self, "realtime_spitter_projectile", {
            from_x = from.x,
            from_y = from.y,
            to_x = to.x,
            to_y = to.y + 20
        })
    end
end

local function begin_spitter_attack_phase(self)
    self.pending_spitter_attack_phase = true
    self.spitter_attack_started = false
    self.spitter_attack_timer = 0
end

local function start_spitter_attack_queue(self)
    self.spitter_attack_queue = {}
    if not self.aliens then
        return
    end

    for _, alien in ipairs(self.aliens) do
        if (not alien.is_dead) and alien.type == ALIEN_TYPE_SPITTER and (alien.turn_ap_remaining or 0) >= SPITTER_SHOT_AP_COST then
            table.insert(self.spitter_attack_queue, {
                alien_id = alien.id
            })
        end
    end
end

local function update_spitter_projectiles(self, dt)
    if not self.spitter_projectiles then
        return
    end

    for i = #self.spitter_projectiles, 1, -1 do
        local p = self.spitter_projectiles[i]
        if not p.go_id then
            table.remove(self.spitter_projectiles, i)
        else
            local dx = p.to.x - p.from.x
            local dy = p.to.y - p.from.y
            local dist = math.sqrt(dx * dx + dy * dy)
            local travel_time = math.max(0.05, dist / (p.speed or SPITTER_PROJECTILE_SPEED))
            p.t = math.min(1, p.t + (dt / travel_time))
            local px = p.from.x + (dx * p.t)
            local py = p.from.y + (dy * p.t)
            go.set_position(vmath.vector3(px, py, 0.75), p.go_id)
            if p.t >= 1 then
                if p.kind == "human" then
                    local target = nil
                    if self.aliens and p.target_alien_id then
                        for _, a in ipairs(self.aliens) do
                            if a.id == p.target_alien_id then
                                target = a
                                break
                            end
                        end
                    end
                    if target and (not target.is_dead) and p.impact_hit then
                        if MELEE_RUNTIME and MELEE_RUNTIME.spawn_alien_blood_splatter_fx then
                            MELEE_RUNTIME.spawn_alien_blood_splatter_fx(self, target)
                        end
                        target.hp_current = math.max(0, (target.hp_current or target.hp_max or 1) - 1)
                        if target.type == ALIEN_TYPE_BRUTE and target.hp_current > 0 then
                            play_brute_damage_sfx(self)
                            target.brute_damage_flash_timer = 0.24
                            multiplayer_emit_combat_fx_event(self, {
                                fx_type = "brute_damage_flash",
                                alien_id = target.id,
                                duration_s = 0.24
                            })
                        end
                        if target.hp_current <= 0 then
                            if target.type == ALIEN_TYPE_BRUTE and target.go_id then
                                local bpos = go.get_position(target.go_id)
                                if bpos and LOOT_RUNTIME and LOOT_RUNTIME.spawn_impact_ring_at_world then
                                    LOOT_RUNTIME.spawn_impact_ring_at_world(self, bpos.x, bpos.y, vmath.vector4(1.0, 0.55, 0.2, 1), 0.7)
                                end
                            end
                            print(string.format(
                                "%s fired at alien #%d and HIT (alien eliminated) [light=%d chance=%d%% roll=%d]",
                                p.shooter_name or "Human", target.id, p.impact_light or 0, p.impact_chance or 0, p.impact_roll or 0
                            ))
                            target.is_dead = true
                            target.is_moving = false
                            target.move_path = nil
                            target.move_path_index = 0
                            play_alien_death_sfx(self, target.type)
                            score_record_alien_kill(self, target.type)
                            remove_dead_aliens(self)
                        else
                            print(string.format(
                                "%s fired at alien #%d and HIT (HP now %d) [light=%d chance=%d%% roll=%d]",
                                p.shooter_name or "Human", target.id, target.hp_current, p.impact_light or 0, p.impact_chance or 0, p.impact_roll or 0
                            ))
                        end
                    elseif target and (not target.is_dead) then
                        print(string.format(
                            "%s fired at alien #%d and MISSED [light=%d chance=%d%% roll=%d]",
                            p.shooter_name or "Human", target.id, p.impact_light or 0, p.impact_chance or 0, p.impact_roll or 0
                        ))
                    end
                end
                go.delete(p.go_id)
                table.remove(self.spitter_projectiles, i)
            end
        end
    end
end

function get_target_world_pos_for_turret(self, target)
    if not target then
        return nil
    end
    if target.kind == "human" then
        local unit = self.squad_units and self.squad_units[target.id]
        if unit and unit.go_path and (unit.current_health or 0) > 0 then
            return go.get_position(unit.go_path)
        end
    elseif target.kind == "alien" then
        if self.aliens then
            for _, alien in ipairs(self.aliens) do
                if alien.id == target.id and (not alien.is_dead) and alien.go_id then
                    return go.get_position(alien.go_id)
                end
            end
        end
    end
    local cell = self.world_grid and self.world_grid[target.cell_id]
    if not cell then
        return nil
    end
    local x, y = coords_to_world_pos(cell.xCell, cell.yCell)
    return vmath.vector3(x, y, 0.75)
end

function turret_dependency_met(world_grid, turret_obj)
    local dep = turret_obj and (turret_obj.dependsOn or 0) or 0
    if dep <= 0 then
        return true
    end
    for _, cell in ipairs(world_grid or {}) do
        local scan = { cell.object1, cell.object2, cell.object3 }
        for _, obj in ipairs(scan) do
            if obj and obj.objectId == dep then
                return obj.isFixed == true
            end
        end
    end
    return false
end

function collect_reactive_turret_targets(self)
    self.turret_last_human_cell_by_id = self.turret_last_human_cell_by_id or {}
    self.turret_last_alien_cell_by_id = self.turret_last_alien_cell_by_id or {}
    local targets = {}

    if self.squad_units then
        for unit_id, unit in pairs(self.squad_units) do
            if unit and unit.cell_id and (unit.current_health or 0) > 0 then
                local prev = self.turret_last_human_cell_by_id[unit_id]
                self.turret_last_human_cell_by_id[unit_id] = unit.cell_id
                -- Turrets should never target humans.
            end
        end
    end

    if self.aliens then
        for _, alien in ipairs(self.aliens) do
            if alien and (not alien.is_dead) and alien.cell_id then
                local key = tostring(alien.id)
                local prev = self.turret_last_alien_cell_by_id[key]
                self.turret_last_alien_cell_by_id[key] = alien.cell_id
                table.insert(targets, {
                    kind = "alien",
                    id = alien.id,
                    prev_cell_id = prev,
                    cell_id = alien.cell_id,
                    hp = alien.hp_current or 1,
                    moved_recently = (prev and prev ~= alien.cell_id) or false
                })
            end
        end
    end

    return targets
end

function choose_turret_target(self, turret_cell_id, candidates, turret_pos_x, turret_center_x)
    local valid = {}
    for _, target in ipairs(candidates or {}) do
        local is_alien = target and target.kind == "alien"
        local has_current_los = is_alien and target.cell_id and has_unobstructed_los(self.world_grid, turret_cell_id, target.cell_id)
        if target and has_current_los then
            local lane_valid = true
            local target_cell = self.world_grid and self.world_grid[target.cell_id]
            if target_cell then
                local turret_cell = self.world_grid and self.world_grid[turret_cell_id]
                if turret_cell and turret_cell.xCell == target_cell.xCell and turret_cell.yCell ~= target_cell.yCell then
                    local target_pos = get_target_world_pos_for_turret(self, target)
                    if target_pos then
                        local target_center_x = select(1, coords_to_world_pos(target_cell.xCell, target_cell.yCell))
                        local right_threshold = CELL_WIDTH * 0.15
                        local turret_in_right_lane = turret_pos_x >= (turret_center_x + right_threshold)
                        local target_in_right_lane = target_pos.x >= (target_center_x + right_threshold)
                        lane_valid = turret_in_right_lane and target_in_right_lane
                    end
                end
            end
            if lane_valid then
                local dist = manhattan_distance_by_id(turret_cell_id, target.cell_id)
            table.insert(valid, {
                target = target,
                dist = dist,
                moved_priority = target.moved_recently and 0 or 1,
                stable_id = tostring(target.id)
            })
            end
        end
    end
    table.sort(valid, function(a, b)
        if a.dist ~= b.dist then
            return a.dist < b.dist
        end
        if a.moved_priority ~= b.moved_priority then
            return a.moved_priority < b.moved_priority
        end
        return a.stable_id < b.stable_id
    end)
    if #valid > 0 then
        return valid[1].target
    end
    return nil
end

function spawn_turret_projectile_burst(self, from_pos, to_pos, resolve_shot_id)
    if not from_pos or not to_pos then
        return
    end
    self.turret_projectiles = self.turret_projectiles or {}
    local dx = to_pos.x - from_pos.x
    local dy = to_pos.y - from_pos.y
    local len = math.max(0.001, math.sqrt(dx * dx + dy * dy))
    local nx = -dy / len
    local ny = dx / len
    local spread = { -5, -3, -1, 1, 3, 5 }
    for i = 1, TURRET_BURST_PROJECTILE_COUNT do
        local offset = (spread[i] or 0) * (TURRET_BURST_SPREAD_PIXELS * 0.2)
        local sx = from_pos.x + (nx * offset)
        local sy = from_pos.y + (ny * offset)
        local tx = to_pos.x + (nx * offset)
        local ty = to_pos.y + (ny * offset)
        local projectile_id = factory.create("/ui_factory#ui_factory", vmath.vector3(sx, sy, 0.76))
        if projectile_id then
            go.set_scale(vmath.vector3(SPITTER_PROJECTILE_SIZE * 0.16, SPITTER_PROJECTILE_SIZE * 0.16, 1), projectile_id)
            msg.post(msg.url(nil, projectile_id, "sprite"), "play_animation", { id = hash("human_projectile_1") })
            go.set(msg.url(nil, projectile_id, "sprite"), "tint", vmath.vector4(1, 1, 1, 1))
            local dir_x = tx - sx
            local dir_y = ty - sy
            if math.abs(dir_x) > 0.001 or math.abs(dir_y) > 0.001 then
                go.set_rotation(vmath.quat_rotation_z(math.atan2(dir_y, dir_x) + math.pi), projectile_id)
            end
            table.insert(self.turret_projectiles, {
                go_id = projectile_id,
                from = vmath.vector3(sx, sy, 0.76),
                to = vmath.vector3(tx, ty, 0.76),
                t = 0,
                delay = (i - 1) * TURRET_BURST_PROJECTILE_DELAY,
                resolve_shot_id = (i == TURRET_BURST_PROJECTILE_COUNT) and resolve_shot_id or nil
            })
            if self.mp_state and self.mp_state.enabled and realtime_mp_host_can_simulate(self) then
                multiplayer_transport_broadcast_event(self, "realtime_turret_projectile", {
                    from_x = sx,
                    from_y = sy,
                    to_x = tx,
                    to_y = ty,
                    delay = (i - 1) * TURRET_BURST_PROJECTILE_DELAY
                })
            end
        end
    end
end

local handle_human_death_loot_drop

local function resolve_turret_pending_shot(self, shot_id)
    if not self.turret_pending_shots or not shot_id then
        return
    end
    local shot = self.turret_pending_shots[shot_id]
    if not shot or shot.resolved then
        return
    end
    shot.resolved = true
    if shot.hit then
        if shot.target_kind == "human" then
            local unit = self.squad_units and self.squad_units[shot.target_id]
            if unit and (unit.current_health or 0) > 0 then
                unit.current_health = math.max(0, (unit.current_health or 0) - 1)
                if MELEE_RUNTIME and MELEE_RUNTIME.spawn_human_blood_splatter_fx then
                    MELEE_RUNTIME.spawn_human_blood_splatter_fx(self, unit)
                end
                if unit.current_health <= 0 then
                    handle_human_death_loot_drop(self, unit, "turret_reactive")
                end
                print(string.format(
                    "Turret #%d HIT %s (HP now %d) [light=%d chance=%d%% roll=%d]",
                    shot.turret_object_id or 0, unit.display_name, unit.current_health, shot.impact_light or 0, shot.impact_chance or 0, shot.impact_roll or 0
                ))
            end
        else
            local target_alien = nil
            if self.aliens then
                for _, alien in ipairs(self.aliens) do
                    if alien.id == shot.target_id then
                        target_alien = alien
                        break
                    end
                end
            end
            if target_alien and (not target_alien.is_dead) then
                target_alien.hp_current = math.max(0, (target_alien.hp_current or 1) - 1)
                if target_alien.type == ALIEN_TYPE_BRUTE and target_alien.hp_current > 0 then
                    play_brute_damage_sfx(self)
                    target_alien.brute_damage_flash_timer = 0.24
                    multiplayer_emit_combat_fx_event(self, {
                        fx_type = "brute_damage_flash",
                        alien_id = target_alien.id,
                        duration_s = 0.24
                    })
                end
                if target_alien.hp_current <= 0 then
                    if target_alien.type == ALIEN_TYPE_BRUTE and target_alien.go_id then
                        local bpos = go.get_position(target_alien.go_id)
                        if bpos and LOOT_RUNTIME and LOOT_RUNTIME.spawn_impact_ring_at_world then
                            LOOT_RUNTIME.spawn_impact_ring_at_world(self, bpos.x, bpos.y, vmath.vector4(1.0, 0.55, 0.2, 1), 0.7)
                        end
                    end
                    target_alien.is_dead = true
                    target_alien.is_moving = false
                    target_alien.move_path = nil
                    target_alien.move_path_index = 0
                    play_alien_death_sfx(self, target_alien.type)
                    score_record_alien_kill(self, target_alien.type)
                    if MELEE_RUNTIME and MELEE_RUNTIME.spawn_alien_blood_splatter_fx then
                        MELEE_RUNTIME.spawn_alien_blood_splatter_fx(self, target_alien)
                    end
                    remove_dead_aliens(self)
                end
                print(string.format(
                    "Turret #%d HIT alien #%d (HP now %d) [light=%d chance=%d%% roll=%d]",
                    shot.turret_object_id or 0, target_alien.id, target_alien.hp_current or 0, shot.impact_light or 0, shot.impact_chance or 0, shot.impact_roll or 0
                ))
            end
        end
    else
        print(string.format(
            "Turret #%d MISSED %s [light=%d chance=%d%% roll=%d]",
            shot.turret_object_id or 0, tostring(shot.target_id), shot.impact_light or 0, shot.impact_chance or 0, shot.impact_roll or 0
        ))
    end
    self.turret_pending_shots[shot_id] = nil
end

function update_turret_projectiles(self, dt)
    if not self.turret_projectiles then
        return
    end
    for i = #self.turret_projectiles, 1, -1 do
        local p = self.turret_projectiles[i]
        if not p.go_id then
            if p.resolve_shot_id then
                resolve_turret_pending_shot(self, p.resolve_shot_id)
            end
            table.remove(self.turret_projectiles, i)
        else
            p.delay = (p.delay or 0) - dt
            if p.delay > 0 then
                go.set_position(vmath.vector3(-9999, -9999, 0.76), p.go_id)
            else
                local dx = p.to.x - p.from.x
                local dy = p.to.y - p.from.y
                local dist = math.sqrt(dx * dx + dy * dy)
                local travel_time = math.max(0.05, dist / TURRET_PROJECTILE_SPEED)
                p.t = math.min(1, p.t + (dt / travel_time))
                local px = p.from.x + (dx * p.t)
                local py = p.from.y + (dy * p.t)
                go.set_position(vmath.vector3(px, py, 0.76), p.go_id)
                if p.t >= 1 then
                    go.delete(p.go_id)
                    if p.resolve_shot_id then
                        resolve_turret_pending_shot(self, p.resolve_shot_id)
                    end
                    table.remove(self.turret_projectiles, i)
                end
            end
        end
    end
end

handle_human_death_loot_drop = function(self, unit, source_tag)
    if not (self and unit and unit.id and self.squad_units and self.squad_units[unit.id] == unit) then
        return
    end
    if unit.death_drop_done == true then
        return
    end
    local death_cell_id = tonumber(unit.cell_id or 0) or 0
    if death_cell_id <= 0 or not (self.world_grid and self.world_grid[death_cell_id]) then
        print(string.format(
            "DEATH DROP | skipped | unit=%s reason=no_cell source=%s",
            tostring(unit.display_name or unit.id),
            tostring(source_tag or "unknown")
        ))
        unit.death_drop_done = true
        unit.backpack_items = {}
        unit.backpack_used = 0
        unit.carrying_corpse_id = nil
        return
    end
    if not (LOOT_RUNTIME and LOOT_RUNTIME.create_world_item_instance and LOOT_RUNTIME.refresh_world_item_visuals) then
        return
    end
    local dropped = 0
    local corpse_dropped = false
    local backpack_items = unit.backpack_items or {}
    for _, item_type in ipairs(backpack_items) do
        if item_type == "corpse" then
            if (not corpse_dropped) and unit.carrying_corpse_id then
                LOOT_RUNTIME.create_world_item_instance(self, "corpse", death_cell_id, unit.id, {
                    corpse_unit_id = unit.carrying_corpse_id,
                    dropped_from_death = true
                })
                dropped = dropped + 1
                corpse_dropped = true
            end
        else
            LOOT_RUNTIME.create_world_item_instance(self, item_type, death_cell_id, unit.id, {
                dropped_from_death = true
            })
            dropped = dropped + 1
        end
    end
    unit.backpack_items = {}
    unit.backpack_used = 0
    unit.carrying_corpse_id = nil
    unit.death_drop_done = true
    if dropped > 0 then
        LOOT_RUNTIME.refresh_world_item_visuals(self)
    end
    print(string.format(
        "DEATH DROP | unit=%s cell=%d dropped=%d source=%s",
        tostring(unit.display_name or unit.id),
        death_cell_id,
        dropped,
        tostring(source_tag or "unknown")
    ))
end

function process_turret_reactive_fire(self, dt)
    self.turret_fire_cooldown_by_object_id = self.turret_fire_cooldown_by_object_id or {}
    self.turret_fired_this_alien_turn_by_object_id = self.turret_fired_this_alien_turn_by_object_id or {}
    for object_id, cooldown in pairs(self.turret_fire_cooldown_by_object_id) do
        cooldown = cooldown - dt
        if cooldown <= 0 then
            self.turret_fire_cooldown_by_object_id[object_id] = nil
        else
            self.turret_fire_cooldown_by_object_id[object_id] = cooldown
        end
    end

    local turret_targets = collect_reactive_turret_targets(self)
    if #turret_targets == 0 or not self.world_grid then
        return
    end

    for turret_cell_id, cell in ipairs(self.world_grid) do
        if cell and cell.tileID ~= hash("empty") and cell.isPowered then
            local objects = { cell.object1, cell.object2, cell.object3 }
            for _, turret_obj in ipairs(objects) do
                if turret_obj
                    and turret_obj.name == hash("gun_turret")
                    and turret_obj.isFixed == true
                    and (turret_obj.turretArmingTurns or 0) <= 0
                    and turret_dependency_met(self.world_grid, turret_obj)
                then
                    local turret_object_id = turret_obj.objectId or turret_cell_id
                    if (not self.turret_fire_cooldown_by_object_id[turret_object_id])
                        and (not self.turret_fired_this_alien_turn_by_object_id[turret_object_id])
                    then
                        local tx, ty = coords_to_world_pos(cell.xCell, cell.yCell)
                        local turret_pos = vmath.vector3(tx + (turret_obj.offsetX or 0), ty + (turret_obj.offsetY or 0), 0.76)
                        local target = choose_turret_target(self, turret_cell_id, turret_targets, turret_pos.x, tx)
                        if target then
                            local target_pos = get_target_world_pos_for_turret(self, target)
                            if target_pos then
                                self.turret_pending_shots = self.turret_pending_shots or {}
                                self.next_turret_shot_id = (self.next_turret_shot_id or 0) + 1
                                local shot_id = self.next_turret_shot_id
                                play_turret_gun_sfx(self)
                                spawn_turret_projectile_burst(self, turret_pos, target_pos, shot_id)
                                local gun_markers = self.turret_gun_objects or {}
                                local gun_go = gun_markers[turret_cell_id]
                                if gun_go then
                                    local gx = target_pos.x - turret_pos.x
                                    local gy = target_pos.y - turret_pos.y
                                    if math.abs(gx) > 0.001 or math.abs(gy) > 0.001 then
                                        local fire_rot = math.atan2(gy, gx)
                                        local ok_rot = pcall(go.set_rotation, vmath.quat_rotation_z(fire_rot), gun_go)
                                        if ok_rot then
                                            pcall(go.cancel_animations, gun_go, "euler.z")
                                            local return_delay = (TURRET_BURST_PROJECTILE_COUNT - 1) * TURRET_BURST_PROJECTILE_DELAY
                                            pcall(go.animate, gun_go, "euler.z", go.PLAYBACK_ONCE_FORWARD, 0, go.EASING_INOUTSINE, 0.35, return_delay)
                                        else
                                            -- Turret marker may have been rebuilt this frame; skip rotation safely.
                                            gun_markers[turret_cell_id] = nil
                                        end
                                    end
                                end

                                local target_cell = self.world_grid[target.cell_id]
                                local active_light = (target_cell and target_cell.isPowered and math.max(0, math.min(3, target_cell.lightValue or 0))) or 0
                                local ranged_model = require("main.config").RANGED_HIT_MODEL
                                local hit_chance = math.max(
                                    ranged_model.min_hit_chance,
                                    math.min(
                                        ranged_model.max_hit_chance,
                                        ranged_model.base_hit_chance
                                            + (active_light * ranged_model.per_light_level_bonus)
                                            + ((CLASS_ROLE_HOOKS[UNIT_CLASS_GUNNER] and CLASS_ROLE_HOOKS[UNIT_CLASS_GUNNER].ranged_hit_bonus) or 0)
                                    )
                                )
                                local roll = math.random(1, 100)
                                self.turret_pending_shots[shot_id] = {
                                    target_kind = target.kind,
                                    target_id = target.id,
                                    target_cell_id = target.cell_id,
                                    turret_object_id = turret_object_id,
                                    impact_light = active_light,
                                    impact_chance = hit_chance,
                                    impact_roll = roll,
                                    hit = roll <= hit_chance,
                                    resolved = false
                                }

                                self.turret_fire_cooldown_by_object_id[turret_object_id] = TURRET_REACTIVE_FIRE_INTERVAL_SECONDS
                                self.turret_fired_this_alien_turn_by_object_id[turret_object_id] = true
                            end
                        end
                    end
                end
            end
        end
    end
end

local function tick_turret_arming_timers(self)
    if not self.world_grid then
        return
    end
    for _, cell in ipairs(self.world_grid) do
        local objs = { cell.object1, cell.object2, cell.object3 }
        for _, obj in ipairs(objs) do
            if obj and obj.name == hash("gun_turret") then
                local turns_left = obj.turretArmingTurns or 0
                if turns_left > 0 then
                    obj.turretArmingTurns = turns_left - 1
                    if obj.turretArmingTurns <= 0 then
                        obj.turretArmingTurns = 0
                        print(string.format("Turret #%d is now active.", obj.objectId or 0))
                    else
                        print(string.format("Turret #%d arming: %d turn(s) remaining.", obj.objectId or 0, obj.turretArmingTurns))
                    end
                end
            end
        end
    end
end

local function find_alien_by_id(self, alien_id)
    if not self.aliens then
        return nil
    end
    for _, alien in ipairs(self.aliens) do
        if alien.id == alien_id then
            return alien
        end
    end
    return nil
end

local function record_alien_turn_ap_spend(self, alien_id, field_key, amount)
    if not self.alien_turn_ap_debug or alien_id == nil then
        return
    end
    local row = self.alien_turn_ap_debug[alien_id]
    if not row then
        return
    end
    local delta = tonumber(amount or 0) or 0
    if delta <= 0 then
        return
    end
    row[field_key] = (tonumber(row[field_key] or 0) or 0) + delta
end

local function flush_alien_turn_ap_debug(self)
    if not self.alien_turn_ap_debug or self.alien_turn_ap_debug_flushed then
        return
    end
    for _, alien in ipairs(self.aliens or {}) do
        local row = self.alien_turn_ap_debug[alien.id]
        if row then
            row.end_ap = tonumber(alien.turn_ap_remaining or 0) or 0
            print(string.format(
                "ALIEN AP TRACE | id=%d type=%s start=%d move=%d ranged=%d melee=%d end=%d",
                alien.id,
                tostring(alien.type),
                tonumber(row.start_ap or 0) or 0,
                tonumber(row.move_spent or 0) or 0,
                tonumber(row.ranged_spent or 0) or 0,
                tonumber(row.melee_spent or 0) or 0,
                tonumber(row.end_ap or 0) or 0
            ))
        end
    end
    self.alien_turn_ap_debug_flushed = true
end

local function update_spitter_attack_phase(self, dt)
    if not self.pending_spitter_attack_phase then
        return
    end
    if self.pending_melee_attack_phase then
        return
    end
    if self.alien_turn_waiting_for_advance then
        return
    end

    if not self.spitter_attack_started then
        if any_alien_is_moving(self) then
            return
        end
        self.spitter_attack_started = true
        start_spitter_attack_queue(self)
        if #self.spitter_attack_queue == 0 then
            self.pending_spitter_attack_phase = false
            return
        end
    end

    self.spitter_attack_timer = self.spitter_attack_timer - dt
    if self.spitter_attack_timer > 0 then
        return
    end

    if #self.spitter_attack_queue == 0 then
        self.pending_spitter_attack_phase = false
        return
    end

    local attacker = table.remove(self.spitter_attack_queue, 1)
    if not attacker then
        return
    end

    local spitter = find_alien_by_id(self, attacker.alien_id)
    if not spitter or spitter.is_dead or (spitter.turn_ap_remaining or 0) < SPITTER_SHOT_AP_COST then
        return
    end

    local target = choose_spitter_target(self, spitter)
    if not target then
        print(string.format("Spitter #%d cannot fire (no valid target in LOS/range)", spitter.id))
        return
    end
    local blocked_by_barricade, block_reason = spitter_shot_blocked_by_barricade(self, spitter, target)
    if blocked_by_barricade then
        print(string.format(
            "Spitter #%d blocked by barricade (reason=%s) shooterCell=%d targetCell=%d",
            spitter.id, tostring(block_reason), spitter.cell_id or 0, target.cell_id or 0
        ))
        return
    end

    local spitter_cell = self.world_grid and self.world_grid[spitter.cell_id] or nil
    local target_cell_for_lane = self.world_grid and self.world_grid[target.cell_id] or nil
    if spitter_cell and target_cell_for_lane then
        local is_vertical_lane = (spitter_cell.xCell == target_cell_for_lane.xCell) and (spitter_cell.yCell ~= target_cell_for_lane.yCell)
        if is_vertical_lane then
            local spitter_center_x = coords_to_world_pos(spitter_cell.xCell, spitter_cell.yCell)
            local target_center_x = coords_to_world_pos(target_cell_for_lane.xCell, target_cell_for_lane.yCell)
            local spitter_pos_for_lane = spitter.go_id and go.get_position(spitter.go_id) or nil
            local target_go_id_for_lane = target.go_path or (self.civilian_visuals and target.id and self.civilian_visuals[target.id]) or nil
            local target_pos_for_lane = target_go_id_for_lane and go.get_position(target_go_id_for_lane) or nil
            local spitter_x = spitter_pos_for_lane and spitter_pos_for_lane.x or spitter_center_x
            local target_x = target_pos_for_lane and target_pos_for_lane.x or target_center_x
            local right_threshold = CELL_WIDTH * 0.15
            local spitter_in_right_lane = spitter_x >= (spitter_center_x + right_threshold)
            local target_in_right_lane = target_x >= (target_center_x + right_threshold)
            if (not spitter_in_right_lane) or (not target_in_right_lane) then
                print(string.format("Spitter #%d blocked: vertical shot requires right-lane alignment.", spitter.id))
                return
            end
        end
    end

    local target_go_id = target.go_path or (self.civilian_visuals and target.id and self.civilian_visuals[target.id]) or nil
    if spitter.go_id and target_go_id then
        local spitter_pos = go.get_position(spitter.go_id)
        local target_pos = go.get_position(target_go_id)
        local dx = target_pos.x - spitter_pos.x
        if math.abs(dx) > 2 then
            spitter.spitter_flip = dx > 0
            sprite.set_hflip(msg.url(nil, spitter.go_id, "sprite"), spitter.spitter_flip)
            sprite.set_hflip(msg.url(nil, spitter.go_id, "shadow"), spitter.spitter_flip)
            if spitter.spitter_bottom_go_id then
                sprite.set_hflip(msg.url(nil, spitter.spitter_bottom_go_id, "sprite"), spitter.spitter_flip)
            end
        end
    end

    spitter.turn_ap_remaining = math.max(0, (spitter.turn_ap_remaining or 0) - SPITTER_SHOT_AP_COST)
    spawn_spitter_projectile(self, spitter, target)
    record_alien_turn_ap_spend(self, spitter.id, "ranged_spent", SPITTER_SHOT_AP_COST)

    local target_cell = self.world_grid and self.world_grid[target.cell_id] or nil
    local active_light = (target_cell and target_cell.isPowered and math.max(0, math.min(3, target_cell.lightValue or 0))) or 0
    local ranged_model = require("main.config").RANGED_HIT_MODEL
    local armor_reduction = (target.target_kind ~= "civilian") and get_human_armor_hit_reduction(target) or 0
    local hit_chance = math.max(
        ranged_model.min_hit_chance,
        math.min(ranged_model.max_hit_chance, (ranged_model.base_hit_chance + (active_light * ranged_model.per_light_level_bonus)) - armor_reduction)
    )
    local roll = math.random(1, 100)
    if roll <= hit_chance then
        target.current_health = math.max(0, target.current_health - 1)
        if MELEE_RUNTIME and MELEE_RUNTIME.spawn_human_blood_splatter_fx then
            MELEE_RUNTIME.spawn_human_blood_splatter_fx(self, target)
        end
        print(string.format(
            "Spitter #%d fired at %s and HIT (HP now %d) [light=%d chance=%d%% roll=%d armor=%d]",
            spitter.id, target.display_name, target.current_health, active_light, hit_chance, roll, armor_reduction
        ))
        if target.current_health <= 0 then
            if target.target_kind == "civilian" then
                target.is_dead = true
                target.current_ap = 0
                target.is_awake = false
                target.is_moving = false
                target.move_path = nil
                target.move_path_index = 0
            else
                handle_human_death_loot_drop(self, target, "spitter_ranged")
            end
            print(target.display_name .. " is dead")
        end
    else
        print(string.format(
            "Spitter #%d fired at %s and MISSED [light=%d chance=%d%% roll=%d armor=%d]",
            spitter.id, target.display_name, active_light, hit_chance, roll, armor_reduction
        ))
    end

    if (spitter.turn_ap_remaining or 0) >= SPITTER_SHOT_AP_COST then
        table.insert(self.spitter_attack_queue, attacker)
    end
    self.spitter_attack_timer = SPITTER_SHOT_INTERVAL_SECONDS
end

apply_brute_alpha_pulse = function(self, alien, dt)
    if (not alien) or alien.is_dead or alien.type ~= ALIEN_TYPE_BRUTE or (not alien.go_id) or alien.melee_flash_active then
        return
    end
    local sprite_url = msg.url(nil, alien.go_id, "sprite")
    if self.aesthetic_mode == AESTHETIC_MODE_COMPUTER then
        if alien.alpha_pulse_speed == nil then
            alien.alpha_pulse_speed = 0.275 + (math.random() * 0.625)
        end
        if alien.emissive_phase == nil then
            alien.emissive_phase = math.random() * math.pi * 2
        end
        alien.emissive_phase = (alien.emissive_phase or 0) + (dt * math.pi * 2 * (alien.alpha_pulse_speed or 1))
        local glow = (math.sin(alien.emissive_phase) * 0.5) + 0.5
        local flash_timer = alien.brute_damage_flash_timer or 0
        if flash_timer > 0 then
            flash_timer = math.max(0, flash_timer - dt)
            alien.brute_damage_flash_timer = flash_timer
            pcall(go.set, sprite_url, "tint", vmath.vector4(1.0, 0.9, 0.3, 1.0))
            return
        end
        if alien.is_moving then
            -- Pulse moving brute alpha 0..1 in computer aesthetic.
            pcall(go.set, sprite_url, "tint", vmath.vector4(1, 1, 1, glow))
            return
        end
        local alpha = math.pow(glow, 3.8)
        pcall(go.set, sprite_url, "tint", vmath.vector4(0, 0, 0, alpha))
    else
        pcall(go.set, sprite_url, "tint", vmath.vector4(1, 1, 1, 1))
    end
end

local get_cell_hazard_flags

local function update_alien_movement(self, dt)
    if not self.aliens then
        update_speedy_move_sfx(self)
        return
    end

    for _, alien in ipairs(self.aliens) do
        if (alien.type == ALIEN_TYPE_SPEEDY or alien.type == ALIEN_TYPE_CANNON) and alien.go_id and (not alien.is_moving) then
            go.set_rotation(vmath.quat_rotation_z(0), alien.go_id)
        end
        apply_blip_pulse_scale(alien, dt)
        update_spitter_idle_visual(self, alien, dt)
        if (not alien.is_dead) and alien.is_moving and alien.move_path and alien.go_id then
            local target_cell_id = alien.move_path[alien.move_path_index]
            if not target_cell_id then
                if alien.melee_shuffle_target_x and alien.melee_shuffle_target_y then
                    local pos = go.get_position(alien.go_id)
                    local sdx = alien.melee_shuffle_target_x - pos.x
                    local sdy = alien.melee_shuffle_target_y - pos.y
                    local sdist = math.sqrt(sdx * sdx + sdy * sdy)
                    local alien_move_speed = ALIEN_MOVE_SPEED
                    if alien.type == ALIEN_TYPE_CANNON then
                        alien_move_speed = ALIEN_MOVE_SPEED * CANNON_FODDER_MOVE_SPEED_MULTIPLIER
                    elseif alien.type == ALIEN_TYPE_SPITTER then
                        alien_move_speed = ALIEN_MOVE_SPEED * SPITTER_MOVE_SPEED_MULTIPLIER
                    elseif alien.type == ALIEN_TYPE_BRUTE then
                        alien_move_speed = ALIEN_MOVE_SPEED * 0.5
                    elseif alien.type == ALIEN_TYPE_BLIP then
                        if self.realtime_rules_enabled == true and not (self.mp_state and self.mp_state.enabled) then
                            alien_move_speed = ALIEN_MOVE_SPEED * (tonumber(self.realtime_blip_move_speed_multiplier or 0.35) or 0.35)
                        else
                            alien_move_speed = ALIEN_MOVE_SPEED * 0.35
                        end
                    end
                    if self.realtime_rules_enabled == true and not (self.mp_state and self.mp_state.enabled) then
                        alien_move_speed = alien_move_speed * (tonumber(self.realtime_alien_move_speed_multiplier or 1.0) or 1.0)
                    end
                    local sstep = alien_move_speed * dt
                    local profile = get_aesthetic_profile(self)
                    local move_z = 0.6
                    if profile and profile.counter_token_move_enabled == true and alien.type ~= ALIEN_TYPE_BLIP then
                        move_z = profile.counter_alien_move_z or 0.72
                    end
                    if alien.type == ALIEN_TYPE_CANNON or alien.type == ALIEN_TYPE_SPITTER or alien.type == ALIEN_TYPE_SPEEDY or alien.type == ALIEN_TYPE_BRUTE then
                        local anim_speed_mul = 1
                        if alien.type == ALIEN_TYPE_CANNON then
                            anim_speed_mul = CANNON_FODDER_MOVE_PULSE_SPEED_MULTIPLIER
                        elseif alien.type == ALIEN_TYPE_BRUTE then
                            anim_speed_mul = 0.3
                        end
                        alien.spitter_anim_phase = (alien.spitter_anim_phase or 0) + (dt * HUMAN_PINGPONG_SPEED * anim_speed_mul * math.pi * 2)
                        local ping = math.sin(alien.spitter_anim_phase)
                        local base_scale = 0.33333334
                        if alien.type == ALIEN_TYPE_CANNON then
                            base_scale = 0.22 * CANNON_FODDER_SCALE_MULTIPLIER
                        elseif alien.type == ALIEN_TYPE_SPITTER then
                            base_scale = (0.33333334 * 0.75) * SPITTER_SCALE_MULTIPLIER
                        elseif alien.type == ALIEN_TYPE_SPEEDY then
                            base_scale = base_scale * 0.75
                        elseif alien.type == ALIEN_TYPE_BRUTE then
                            base_scale = (0.22 * 1.5 * 1.25 * 1.2 * 1.1) * ((self.aesthetic_mode == AESTHETIC_MODE_COMPUTER) and 1.2 or 1.0)
                        end
                        local sx = base_scale
                        local sy = base_scale
                        if alien.type == ALIEN_TYPE_SPITTER then
                            local spitter_pulse = math.sin(alien.spitter_idle_phase or 0)
                            local spitter_mul = 1 + (SPITTER_IDLE_PULSE_AMPLITUDE * spitter_pulse)
                            sx = base_scale * spitter_mul
                            sy = base_scale * spitter_mul
                        elseif alien.type == ALIEN_TYPE_CANNON then
                            local squeeze = (ping + 1) * 0.5
                            sx = base_scale * (1 - (CANNON_FODDER_MOVE_SQUEEZE_X * squeeze))
                            sy = base_scale * (1 + (CANNON_FODDER_MOVE_STRETCH_Y * squeeze))
                        elseif profile and profile.counter_token_move_enabled == true and alien.type ~= ALIEN_TYPE_BLIP then
                            if not alien.counter_move_total_dist or alien.counter_move_total_dist <= 0 then
                                alien.counter_move_total_dist = math.max(sdist, 1)
                            end
                            local progress = 1 - math.max(0, math.min(1, sdist / alien.counter_move_total_dist))
                            local lift = math.sin(progress * math.pi)
                            local move_arc = 4 * progress * (1 - progress)
                            local wobble = math.sin((alien.spitter_anim_phase or 0) * 2.0 + ((sdx < 0) and 1.4 or 0))
                            local lift_scale = profile.counter_lift_scale or 0.16
                            local wobble_scale = profile.counter_wobble_scale or 0.04
                            sx = base_scale * (1 + (lift * lift_scale) + (wobble * wobble_scale))
                            sy = base_scale * (1 + (lift * lift_scale) - (wobble * wobble_scale * 0.6))
                            alien.counter_shadow_offset = get_counter_shadow_offset(profile, move_arc)
                        elseif math.abs(sdx) >= math.abs(sdy) then
                            alien.counter_shadow_offset = nil
                            sx = base_scale * (1 + (HUMAN_PINGPONG_AMPLITUDE * 1.8) * ping)
                        else
                            alien.counter_shadow_offset = nil
                            sy = base_scale * (1 + (HUMAN_PINGPONG_AMPLITUDE * 1.8) * ping)
                        end
                        if alien.type == ALIEN_TYPE_BRUTE and self.aesthetic_mode == AESTHETIC_MODE_COMPUTER then
                            local subtle = 0.05
                            local pulse = math.sin((alien.spitter_anim_phase or 0) * 0.5)
                            sx = base_scale * (1 + (subtle * pulse))
                            sy = base_scale * (1 - (subtle * pulse * 0.6))
                            local rock = math.sin((alien.spitter_anim_phase or 0) * 0.25)
                            pcall(go.set_rotation, vmath.quat_rotation_z(math.rad(5 * rock)), alien.go_id)
                        end
                        if alien.type == ALIEN_TYPE_BRUTE then
                            -- Keep brute width constant in transit (no x squash/stretch).
                            if self.aesthetic_mode ~= AESTHETIC_MODE_COMPUTER then
                                sx = base_scale
                            end
                        end
                        go.set_scale(vmath.vector3(sx, sy, 1), alien.go_id)
                    end
                    if sdist <= sstep then
                        go.set_position(vmath.vector3(alien.melee_shuffle_target_x, alien.melee_shuffle_target_y, 0.6), alien.go_id)
                        alien.melee_shuffle_target_x = nil
                        alien.melee_shuffle_target_y = nil
                        alien.counter_shadow_offset = nil
                        alien.counter_move_total_dist = nil
                        alien.is_moving = false
                        alien.move_path = nil
                        alien.move_path_index = 0
                        if alien.type == ALIEN_TYPE_SPEEDY or alien.type == ALIEN_TYPE_CANNON then
                            go.set_rotation(vmath.quat_rotation_z(0), alien.go_id)
                        end
                    else
                        local nsx = pos.x + (sdx / sdist) * sstep
                        local nsy = pos.y + (sdy / sdist) * sstep
                        go.set_position(vmath.vector3(nsx, nsy, move_z), alien.go_id)
                    end
                else
                    alien.counter_shadow_offset = nil
                    alien.counter_move_total_dist = nil
                    alien.is_moving = false
                    alien.move_path = nil
                    alien.move_path_index = 0
                    if alien.type == ALIEN_TYPE_SPEEDY or alien.type == ALIEN_TYPE_CANNON then
                        go.set_rotation(vmath.quat_rotation_z(0), alien.go_id)
                    end
                end
            else
                local target_cell = self.world_grid[target_cell_id]
                local from_cell_before_step = alien.cell_id
                local from_cell = self.world_grid[from_cell_before_step]
                local to_cell = self.world_grid[target_cell_id]
                if to_cell and is_cell_barricaded(self.world_grid, target_cell_id) and alien.type ~= ALIEN_TYPE_BRUTE then
                    alien.counter_shadow_offset = nil
                    alien.counter_move_total_dist = nil
                    alien.is_moving = false
                    alien.move_path = nil
                    alien.move_path_index = 0
                    alien.turn_ap_remaining = 0
                    print(string.format("Alien #%d (%s) blocked by barricade at cell %d.", alien.id or 0, alien.type or "?", target_cell_id))
                else
                local brute_door_blocked = false
                if alien.type == ALIEN_TYPE_BRUTE
                    or (alien.type == ALIEN_TYPE_BLIP and alien.hidden_reveal_type == ALIEN_TYPE_BRUTE)
                then
                    local _, door_obj, door_closed = get_edge_door_context(self.world_grid, from_cell_before_step, target_cell_id)
                    if door_obj and door_closed and is_secure_door_object(door_obj) then
                        brute_door_blocked = true
                        alien.counter_shadow_offset = nil
                        alien.counter_move_total_dist = nil
                        alien.is_moving = false
                        alien.move_path = nil
                        alien.move_path_index = 0
                        alien.turn_ap_remaining = 0
                    elseif door_obj and door_closed and try_brute_damage_edge_door(self, alien, from_cell_before_step, target_cell_id) then
                        brute_door_blocked = true
                        alien.counter_shadow_offset = nil
                        alien.counter_move_total_dist = nil
                        alien.is_moving = false
                        alien.move_path = nil
                        alien.move_path_index = 0
                        alien.turn_ap_remaining = 0
                    end
                end
                if not brute_door_blocked then
                local from_vent = get_vent_object_on_cell(from_cell)
                local to_vent = get_vent_object_on_cell(to_cell)
                local is_vent_jump = (alien.type ~= ALIEN_TYPE_BRUTE) and from_vent and to_vent and from_cell_before_step ~= target_cell_id
                local tx, ty = coords_to_world_pos(target_cell.xCell, target_cell.yCell)
                if alien.type == ALIEN_TYPE_BLIP then
                    if alien.blip_step_for_index ~= alien.move_path_index then
                        alien.blip_step_for_index = alien.move_path_index
                        alien.blip_step_offset_x = math.random(-45, 45)
                        alien.blip_step_offset_y = math.random(-45, 45)
                    end
                    tx = tx + (alien.blip_step_offset_x or 0)
                    ty = ty + (alien.blip_step_offset_y or 0)
                else
                    tx = tx + (CELL_WIDTH * 0.25)
                    local human_count = 0
                    if self.squad_units then
                        for _, unit in pairs(self.squad_units) do
                            if unit.cell_id == target_cell_id and (unit.current_health or 0) > 0 then
                                human_count = human_count + 1
                            end
                        end
                    end
                    if human_count > 0 and self.aliens then
                        local on_cell = {}
                        for _, scan in ipairs(self.aliens) do
                            if (not scan.is_dead)
                                and scan.type ~= ALIEN_TYPE_BLIP
                                and (scan.cell_id == target_cell_id or scan.id == alien.id)
                            then
                                table.insert(on_cell, scan)
                            end
                        end
                        table.sort(on_cell, function(a, b)
                            return (a.id or 0) < (b.id or 0)
                        end)
                        local idx = 1
                        for i, scan in ipairs(on_cell) do
                            if scan.id == alien.id then
                                idx = i
                                break
                            end
                        end
                        local lane = { 20, -20, 40, -40, 60, -60 }
                        tx = tx + (lane[idx] or 0)
                    end
                    tx = clamp_world_x_to_cell(target_cell, tx)
                end
                if alien.type == ALIEN_TYPE_SPEEDY then
                    ty = ty + 50
                elseif alien.type == ALIEN_TYPE_SPITTER then
                    ty = ty - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM
                elseif alien.type == ALIEN_TYPE_CANNON then
                    ty = ty - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM - 25
                elseif alien.type == ALIEN_TYPE_BRUTE then
                    ty = ty - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM + 35
                else
                    ty = ty + 0
                end

                local pos = go.get_position(alien.go_id)
                local dx = tx - pos.x
                local dy = ty - pos.y
                local dist = math.sqrt(dx * dx + dy * dy)
                local alien_move_speed = ALIEN_MOVE_SPEED
                if alien.type == ALIEN_TYPE_CANNON then
                    alien_move_speed = ALIEN_MOVE_SPEED * CANNON_FODDER_MOVE_SPEED_MULTIPLIER
                elseif alien.type == ALIEN_TYPE_SPITTER then
                    alien_move_speed = ALIEN_MOVE_SPEED * SPITTER_MOVE_SPEED_MULTIPLIER
                elseif alien.type == ALIEN_TYPE_BRUTE then
                    alien_move_speed = ALIEN_MOVE_SPEED * 0.5
                elseif alien.type == ALIEN_TYPE_BLIP then
                    if self.realtime_rules_enabled == true and not (self.mp_state and self.mp_state.enabled) then
                        alien_move_speed = ALIEN_MOVE_SPEED * (tonumber(self.realtime_blip_move_speed_multiplier or 0.35) or 0.35)
                    else
                        alien_move_speed = ALIEN_MOVE_SPEED * 0.35
                    end
                end
                if self.realtime_rules_enabled == true and not (self.mp_state and self.mp_state.enabled) then
                    alien_move_speed = alien_move_speed * (tonumber(self.realtime_alien_move_speed_multiplier or 1.0) or 1.0)
                end
                local step = alien_move_speed * dt
                local profile = get_aesthetic_profile(self)
                local move_z = 0.6
                if profile and profile.counter_token_move_enabled == true and alien.type ~= ALIEN_TYPE_BLIP then
                    move_z = profile.counter_alien_move_z or 0.72
                end
                if is_vent_jump then
                    alien.counter_shadow_offset = nil
                end
                if (not is_vent_jump) and (alien.type == ALIEN_TYPE_CANNON or alien.type == ALIEN_TYPE_SPITTER or alien.type == ALIEN_TYPE_SPEEDY or alien.type == ALIEN_TYPE_BRUTE) then
                    local anim_speed_mul = 1
                    if alien.type == ALIEN_TYPE_CANNON then
                        anim_speed_mul = CANNON_FODDER_MOVE_PULSE_SPEED_MULTIPLIER
                    elseif alien.type == ALIEN_TYPE_BRUTE then
                        anim_speed_mul = 0.3
                    end
                    alien.spitter_anim_phase = (alien.spitter_anim_phase or 0) + (dt * HUMAN_PINGPONG_SPEED * anim_speed_mul * math.pi * 2)
                    local ping = math.sin(alien.spitter_anim_phase)
                    local base_scale = 0.33333334
                    if alien.type == ALIEN_TYPE_CANNON then
                        base_scale = 0.22 * CANNON_FODDER_SCALE_MULTIPLIER
                    elseif alien.type == ALIEN_TYPE_SPITTER then
                        base_scale = (0.33333334 * 0.75) * SPITTER_SCALE_MULTIPLIER
                    elseif alien.type == ALIEN_TYPE_SPEEDY then
                        base_scale = base_scale * 0.75
                    elseif alien.type == ALIEN_TYPE_BRUTE then
                        base_scale = (0.22 * 1.5 * 1.25 * 1.2 * 1.1) * ((self.aesthetic_mode == AESTHETIC_MODE_COMPUTER) and 1.2 or 1.0)
                    end
                    local sx = base_scale
                    local sy = base_scale
                    if alien.type == ALIEN_TYPE_SPITTER then
                        local spitter_pulse = math.sin(alien.spitter_idle_phase or 0)
                        local spitter_mul = 1 + (SPITTER_IDLE_PULSE_AMPLITUDE * spitter_pulse)
                        sx = base_scale * spitter_mul
                        sy = base_scale * spitter_mul
                    elseif alien.type == ALIEN_TYPE_CANNON then
                        local squeeze = (ping + 1) * 0.5
                        sx = base_scale * (1 - (CANNON_FODDER_MOVE_SQUEEZE_X * squeeze))
                        sy = base_scale * (1 + (CANNON_FODDER_MOVE_STRETCH_Y * squeeze))
                    elseif profile and profile.counter_token_move_enabled == true and alien.type ~= ALIEN_TYPE_BLIP then
                        if not alien.counter_move_total_dist or alien.counter_move_total_dist <= 0 then
                            alien.counter_move_total_dist = math.max(dist, 1)
                        end
                        local progress = 1 - math.max(0, math.min(1, dist / alien.counter_move_total_dist))
                        local lift = math.sin(progress * math.pi)
                        local move_arc = 4 * progress * (1 - progress)
                        local wobble = math.sin((alien.spitter_anim_phase or 0) * 2.0 + ((dx < 0) and 1.4 or 0))
                        local lift_scale = profile.counter_lift_scale or 0.16
                        local wobble_scale = profile.counter_wobble_scale or 0.04
                        sx = base_scale * (1 + (lift * lift_scale) + (wobble * wobble_scale))
                        sy = base_scale * (1 + (lift * lift_scale) - (wobble * wobble_scale * 0.6))
                        alien.counter_shadow_offset = get_counter_shadow_offset(profile, move_arc)
                    elseif math.abs(dx) >= math.abs(dy) then
                        alien.counter_shadow_offset = nil
                        sx = base_scale * (1 + (HUMAN_PINGPONG_AMPLITUDE * 1.8) * ping)
                    else
                        alien.counter_shadow_offset = nil
                        sy = base_scale * (1 + (HUMAN_PINGPONG_AMPLITUDE * 1.8) * ping)
                    end
                    if alien.type == ALIEN_TYPE_BRUTE and self.aesthetic_mode == AESTHETIC_MODE_COMPUTER then
                        local subtle = 0.05
                        local pulse = math.sin((alien.spitter_anim_phase or 0) * 0.5)
                        sx = base_scale * (1 + (subtle * pulse))
                        sy = base_scale * (1 - (subtle * pulse * 0.6))
                        local rock = math.sin((alien.spitter_anim_phase or 0) * 0.25)
                        pcall(go.set_rotation, vmath.quat_rotation_z(math.rad(5 * rock)), alien.go_id)
                    end
                    if alien.type == ALIEN_TYPE_BRUTE then
                        -- Keep brute width constant in transit (no x squash/stretch).
                        if self.aesthetic_mode ~= AESTHETIC_MODE_COMPUTER then
                            sx = base_scale
                        end
                    end
                    go.set_scale(vmath.vector3(sx, sy, 1), alien.go_id)
                end
                if (not is_vent_jump) and (alien.type == ALIEN_TYPE_SPEEDY or alien.type == ALIEN_TYPE_CANNON) then
                    if math.abs(dy) > math.abs(dx) and math.abs(dy) > 0.1 then
                        if dy > 0 then
                            go.set_rotation(vmath.quat_rotation_z(math.rad(-90)), alien.go_id)
                        else
                            go.set_rotation(vmath.quat_rotation_z(math.rad(90)), alien.go_id)
                        end
                    else
                        go.set_rotation(vmath.quat_rotation_z(0), alien.go_id)
                    end
                end
                if (not is_vent_jump) and alien.type == ALIEN_TYPE_BRUTE then
                    local sprite_url = msg.url(nil, alien.go_id, "sprite")
                    local shadow_url = msg.url(nil, alien.go_id, "shadow")
                    if math.abs(dx) >= math.abs(dy) and math.abs(dx) > 0.1 then
                        local side_anim = (self.aesthetic_mode == AESTHETIC_MODE_BOARDGAME)
                            and hash("alien_brute_side_boardgame")
                            or hash("alien_brute_side")
                        if alien.current_aesthetic_anim ~= side_anim then
                            pcall(msg.post, sprite_url, "play_animation", { id = side_anim })
                            alien.current_aesthetic_anim = side_anim
                        end
                        local facing_right = dx > 0
                        sprite.set_hflip(sprite_url, facing_right)
                        sprite.set_hflip(shadow_url, facing_right)
                    else
                        local front_anim = get_alien_anim_for_aesthetic(self, alien.type)
                        if front_anim and alien.current_aesthetic_anim ~= front_anim then
                            pcall(msg.post, sprite_url, "play_animation", { id = front_anim })
                            alien.current_aesthetic_anim = front_anim
                        end
                        sprite.set_hflip(sprite_url, false)
                        sprite.set_hflip(shadow_url, false)
                    end
                end
                if (not is_vent_jump) and (alien.type == ALIEN_TYPE_CANNON or alien.type == ALIEN_TYPE_SPITTER or alien.type == ALIEN_TYPE_SPEEDY) then
                    if math.abs(dx) > 0.1 then
                        -- Requirement: flip sprite while moving right; unflipped while moving left.
                        alien.spitter_flip = dx > 0
                        sprite.set_hflip(msg.url(nil, alien.go_id, "sprite"), alien.spitter_flip)
                        sprite.set_hflip(msg.url(nil, alien.go_id, "shadow"), alien.spitter_flip)
                    end
                end

                if is_vent_jump or dist <= step then
                    if is_vent_jump then
                        local cx, cy = coords_to_world_pos(to_cell.xCell, to_cell.yCell)
                        local vx = cx + (to_vent.offsetX or 0)
                        local vy = cy + (to_vent.offsetY or 0)
                        go.set_position(vmath.vector3(vx, vy, 0.6), alien.go_id)
                    else
                        go.set_position(vmath.vector3(tx, ty, 0.6), alien.go_id)
                    end
                    alien.cell_id = target_cell_id
                    if alien.type == ALIEN_TYPE_BLIP then
                        trigger_unit_tile_bump_sfx(self, "blip")
                    else
                        trigger_unit_tile_bump_sfx(self, "alien")
                    end
                    local continue_after_step = true
                    local step_has_fire = get_cell_hazard_flags(to_cell)
                    if step_has_fire then
                        local fire_step_damage = math.max(0, tonumber(HAZARD_DAMAGE.fire_per_turn or 1) or 1)
                        if fire_step_damage > 0 then
                            alien.hp_current = math.max(0, (alien.hp_current or 0) - fire_step_damage)
                            print(string.format(
                                "ALIEN HAZARD | #%d (%s) took %d fire damage on cell %d (HP=%d)",
                                alien.id or 0,
                                alien.type or "?",
                                fire_step_damage,
                                target_cell_id or 0,
                                alien.hp_current or 0
                            ))
                            if (alien.hp_current or 0) <= 0 then
                                alien.is_dead = true
                                alien.turn_ap_remaining = 0
                                alien.counter_shadow_offset = nil
                                alien.counter_move_total_dist = nil
                                alien.is_moving = false
                                alien.move_path = nil
                                alien.move_path_index = 0
                                if alien.type == ALIEN_TYPE_SPEEDY or alien.type == ALIEN_TYPE_CANNON then
                                    go.set_rotation(vmath.quat_rotation_z(0), alien.go_id)
                                end
                                continue_after_step = false
                            end
                        end
                    end
                    if continue_after_step then
                        if alien.type == ALIEN_TYPE_SPEEDY or alien.type == ALIEN_TYPE_CANNON then
                            go.set_rotation(vmath.quat_rotation_z(0), alien.go_id)
                        end
                        if alien.type ~= ALIEN_TYPE_SPEEDY then
                            local obstacle_nudge_scale = 1
                            if alien.type == ALIEN_TYPE_BRUTE then
                                obstacle_nudge_scale = 2
                            end
                            trigger_obstacle_pass_nudge(self, target_cell_id, from_cell_before_step, obstacle_nudge_scale)
                        end
                        if alien.type == ALIEN_TYPE_BLIP then
                            alien.blip_cell_offset_x = alien.blip_step_offset_x or alien.blip_cell_offset_x
                            alien.blip_cell_offset_y = alien.blip_step_offset_y or alien.blip_cell_offset_y
                            alien.blip_step_for_index = nil
                            alien.blip_step_offset_x = nil
                            alien.blip_step_offset_y = nil
                        end
                        alien.counter_move_total_dist = nil
                        if is_vent_jump then
                            local cx, cy = coords_to_world_pos(to_cell.xCell, to_cell.yCell)
                            local vx = cx + (to_vent.offsetX or 0)
                            local vy = cy + (to_vent.offsetY or 0)
                            go.set_position(vmath.vector3(vx, vy, 0.6), alien.go_id)
                        end
                        if alien.type == ALIEN_TYPE_BRUTE and is_cell_barricaded(self.world_grid, target_cell_id) then
                            alien.turn_ap_remaining = 0
                            alien.counter_shadow_offset = nil
                            alien.counter_move_total_dist = nil
                            alien.is_moving = false
                            alien.move_path = nil
                            alien.move_path_index = 0
                            print(string.format("Brute #%d entered barricade cell %d and braces to attack.", alien.id or 0, target_cell_id))
                        else
                            alien.move_path_index = alien.move_path_index + 1
                        end
                        maybe_reveal_blip(self, alien)
                        local killed = resolve_human_reaction_fire(self, alien)
                        if not killed then
                            if alien.move_path and alien.move_path_index > #alien.move_path then
                                local weakest_human = nil
                                for _, unit in ipairs(get_living_alien_targets(self)) do
                                    if unit and unit.cell_id == alien.cell_id and unit.go_path then
                                        if (not weakest_human)
                                            or ((unit.current_health or 0) < (weakest_human.current_health or 0))
                                            or (((unit.current_health or 0) == (weakest_human.current_health or 0)) and tostring(unit.id) < tostring(weakest_human.id))
                                        then
                                            weakest_human = unit
                                        end
                                    end
                                end
                                if weakest_human and weakest_human.go_path then
                                    local hpos = go.get_position(weakest_human.go_path)
                                    local apos = go.get_position(alien.go_id)
                                    local desired_x = hpos.x + 38
                                    if apos.x < hpos.x then
                                        desired_x = hpos.x - 38
                                    end
                                    desired_x = clamp_world_x_to_cell(self.world_grid[alien.cell_id], desired_x)
                                    local _, ty_adj = coords_to_world_pos(self.world_grid[alien.cell_id].xCell, self.world_grid[alien.cell_id].yCell)
                                    if alien.type == ALIEN_TYPE_SPEEDY then
                                        ty_adj = ty_adj + 50
                                    elseif alien.type == ALIEN_TYPE_SPITTER then
                                        ty_adj = ty_adj - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM
                                    elseif alien.type == ALIEN_TYPE_CANNON then
                                        ty_adj = ty_adj - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM - 25
                                    end
                                    local occupied = {}
                                    if self.aliens then
                                        for _, other in ipairs(self.aliens) do
                                            if other.id ~= alien.id and (not other.is_dead) and other.cell_id == alien.cell_id and other.go_id then
                                                local op = go.get_position(other.go_id)
                                                table.insert(occupied, op.x)
                                            end
                                        end
                                    end
                                    local final_x = desired_x
                                    for hop = 0, 4 do
                                        local cand_a = clamp_world_x_to_cell(self.world_grid[alien.cell_id], desired_x + (hop * 24))
                                        local cand_b = clamp_world_x_to_cell(self.world_grid[alien.cell_id], desired_x - (hop * 24))
                                        local cand = cand_a
                                        if hop % 2 == 1 then
                                            cand = cand_b
                                        end
                                        local ok = true
                                        for i = 1, #occupied do
                                            if math.abs(cand - occupied[i]) < 18 then
                                                ok = false
                                                break
                                            end
                                        end
                                        if ok then
                                            final_x = cand
                                            break
                                        end
                                    end
                                    if math.abs(final_x - apos.x) > 1 then
                                        alien.melee_shuffle_target_x = final_x
                                        alien.melee_shuffle_target_y = ty_adj
                                    else
                                        alien.counter_shadow_offset = nil
                                        alien.counter_move_total_dist = nil
                                        alien.is_moving = false
                                        alien.move_path = nil
                                        alien.move_path_index = 0
                                        if alien.type == ALIEN_TYPE_SPEEDY or alien.type == ALIEN_TYPE_CANNON then
                                            go.set_rotation(vmath.quat_rotation_z(0), alien.go_id)
                                        end
                                    end
                                else
                                    alien.counter_shadow_offset = nil
                                    alien.counter_move_total_dist = nil
                                    alien.is_moving = false
                                    alien.move_path = nil
                                    alien.move_path_index = 0
                                    if alien.type == ALIEN_TYPE_SPEEDY or alien.type == ALIEN_TYPE_CANNON then
                                        go.set_rotation(vmath.quat_rotation_z(0), alien.go_id)
                                    end
                                end
                            end
                        end
                    end
                else
                    local nx = pos.x + (dx / dist) * step
                    local ny = pos.y + (dy / dist) * step
                    go.set_position(vmath.vector3(nx, ny, move_z), alien.go_id)
                end
                end
                end
            end
        end
    end

    remove_dead_aliens(self)
    update_speedy_move_sfx(self)
end

local any_civilian_is_moving
local tutorial_rules_locked
local get_current_mission_type

local function process_alien_turn(self)
    if tutorial_rules_locked and tutorial_rules_locked(self) then
        return
    end
    self.aliens = self.aliens or {}

    if any_alien_is_moving(self) or self.pending_spitter_attack_phase or self.pending_melee_attack_phase or any_civilian_is_moving(self) then
        return
    end

    if self.alien_turn_waiting_for_advance then
        return
    end

    if not self.alien_turn_active then
        if not (self.realtime_rules_enabled == true and not (self.mp_state and self.mp_state.enabled)) then
            -- Temporary turn rule: spawn one new blip every new turn.
            local edge_cells = get_edge_spawn_cell_ids(self.world_grid)
            if #edge_cells > 0 then
                local idx = math.random(1, #edge_cells)
                spawn_alien(self, ALIEN_TYPE_BLIP, edge_cells[idx])
                print("Turn event: spawned 1 new blip")
            else
                print("Turn event: no eligible unpowered blip spawn cells.")
            end
        end
        self.alien_turn_active = true
        self.alien_turn_waiting_for_advance = false
        self.barricade_damage_cells_this_turn = {}
        self.door_damage_cells_this_turn = {}
        self.turret_fired_this_alien_turn_by_object_id = {}
        self.alien_turn_ap_debug = {}
        self.alien_turn_ap_debug_flushed = false
        print("=== Alien Turn Start ===")
        for _, alien in ipairs(self.aliens) do
            if not alien.is_dead then
                local cfg = ALIEN_TYPE_CONFIG[alien.type]
                local ap_budget = cfg and cfg.ap_per_turn or 1
                -- TEMPORARY: disable one-turn brute barricade pause for now.
                -- Kept commented so this behavior can be restored later if desired.
                -- if (alien.barricade_pause_turns or 0) > 0 then
                --     alien.barricade_pause_turns = math.max(0, (alien.barricade_pause_turns or 0) - 1)
                --     ap_budget = 0
                -- elseif try_brute_break_adjacent_barricade(self, alien) then
                if try_brute_break_adjacent_barricade(self, alien) then
                    ap_budget = 0
                end
                alien.turn_ap_remaining = ap_budget
                self.alien_turn_ap_debug[alien.id] = {
                    start_ap = ap_budget,
                    move_spent = 0,
                    ranged_spent = 0,
                    melee_spent = 0,
                    end_ap = ap_budget
                }
            end
        end
    end

    local any_step = false
    local any_melee_ready_without_move = false
    local any_spitter_ready_to_fire = false
    local step_mode = self.alien_turn_manual_pause
    for _, alien in ipairs(self.aliens) do
        if (not alien.is_dead) and (alien.turn_ap_remaining or 0) > 0 then
            local ap_budget = alien.turn_ap_remaining or 0
            local shares_cell_with_living_human = has_living_alien_target_on_cell(self, alien.cell_id)
            local spitter_holding_for_shot = false
            if alien.type == ALIEN_TYPE_SPITTER and ap_budget >= SPITTER_SHOT_AP_COST then
                local immediate_shot_target = choose_spitter_target(self, alien)
                if immediate_shot_target then
                    spitter_holding_for_shot = true
                    any_spitter_ready_to_fire = true
                    alien.turn_ap_remaining = ap_budget
                    print(string.format(
                        "Alien #%d (%s) holding position to prioritize ranged attack",
                        alien.id, alien.type
                    ))
                end
            end

            if not spitter_holding_for_shot then
                local target_cell_id, path = get_nearest_reachable_human_cell_id(self, alien.type, alien.cell_id, alien.hidden_reveal_type)
                local used_fallback_staging = false
                if not target_cell_id and alien.type ~= ALIEN_TYPE_BRUTE then
                    target_cell_id, path = get_blip_fallback_staging_target(self, alien.cell_id, alien.type, alien.hidden_reveal_type)
                    used_fallback_staging = target_cell_id ~= nil
                end
                if not target_cell_id and alien.type == ALIEN_TYPE_BRUTE then
                    target_cell_id, path = get_brute_barricade_staging_target(self, alien.cell_id)
                    used_fallback_staging = target_cell_id ~= nil
                end
                if target_cell_id then
                    local step_budget = ap_budget
                    if step_mode then
                        step_budget = 1
                    end
                    local segment_path, spent = get_alien_turn_movement_segment(self, alien, path, step_budget)
                    spent = spent or 0
                    if spent <= 0 then
                        -- If already engaged in melee range, preserve AP for melee phase.
                        if shares_cell_with_living_human then
                            alien.turn_ap_remaining = ap_budget
                        else
                            alien.turn_ap_remaining = 0
                        end
                    else
                        alien.turn_ap_remaining = math.max(0, ap_budget - spent)
                        record_alien_turn_ap_spend(self, alien.id, "move_spent", spent)
                        any_step = true
                    end
                    if segment_path then
                        begin_alien_path_animation(alien, segment_path)
                    end
                    print(string.format(
                        "Alien #%d (%s) target=%d moved=%s spent=%d rem=%d%s",
                        alien.id, alien.type, target_cell_id, tostring(segment_path ~= nil), spent, alien.turn_ap_remaining or 0,
                        used_fallback_staging and " [fallback-staging]" or ""
                    ))
                else
                    -- No path found: still allow melee when already sharing a cell with a valid target.
                    if shares_cell_with_living_human then
                        alien.turn_ap_remaining = ap_budget
                    else
                        alien.turn_ap_remaining = 0
                    end
                    print(string.format("Alien #%d (%s) has no reachable target", alien.id, alien.type))
                end
            end
            if (alien.turn_ap_remaining or 0) > 0 and shares_cell_with_living_human then
                any_melee_ready_without_move = true
            end
        end
    end

    if any_step or any_melee_ready_without_move or any_spitter_ready_to_fire then
        MELEE_RUNTIME.begin_phase(self)
        begin_spitter_attack_phase(self)
        if step_mode and self.alien_turn_manual_pause then
            self.alien_turn_waiting_for_advance = true
        end
        if not step_mode then
            self.alien_turn_active = false
        end
        return
    end

    self.alien_turn_active = false
    self.alien_turn_waiting_for_advance = false
    self.alien_turn_manual_pause = false
    print("=== Alien Turn End ===")
end

local function spawn_initial_blips(self, count)
    if tutorial_rules_locked and tutorial_rules_locked(self) then
        return
    end
    local edge_cells = get_edge_spawn_cell_ids(self.world_grid)
    if #edge_cells == 0 then
        return
    end

    local used = {}
    for i = 1, math.min(count, #edge_cells) do
        local idx = math.random(1, #edge_cells)
        while used[idx] do
            idx = math.random(1, #edge_cells)
        end
        used[idx] = true
        spawn_alien(self, ALIEN_TYPE_BLIP, edge_cells[idx])
    end
end

local function update_ladder_tints(self)
    if not (self and self.world_grid and self.ladder_markers) then
        return
    end
    for source_cell_id, marker_id in pairs(self.ladder_markers) do
        local source_cell = self.world_grid[source_cell_id]
        if marker_id and source_cell and source_cell.tileID ~= hash("empty") then
            local tint = (source_cell.isPowered == true) and LADDER_TINT_ON or LADDER_TINT_OFF
            go.set(msg.url(nil, marker_id, "sprite"), "tint", tint)
        end
    end
end

local function is_valid_ladder_cell(cell)
    return cell
        and cell.tileID ~= hash("empty")
        and (cell.isOutside ~= true)
        and ((tonumber(cell.moveValue) or 0) > 0)
end

local function can_spawn_ladder_between(world_grid, source_cell_id, below_cell_id)
    if not (world_grid and source_cell_id and below_cell_id) then
        return false
    end
    local source = world_grid[source_cell_id]
    local below = world_grid[below_cell_id]
    if not (is_valid_ladder_cell(source) and is_valid_ladder_cell(below)) then
        return false
    end
    if source.accessDown ~= true then
        return false
    end
    -- Final baked-topology rule: this vertical edge must actually be traversable in
    -- the baked world, otherwise it is an invalid ladder placement.
    if not can_cross_between_cells(world_grid, source_cell_id, below_cell_id) then
        return false
    end
    return true
end

get_current_mission_type = function(self)
    local selected = self.selected_mission_type or (self.mp_state and self.mp_state.mission_type)
    if selected then
        return multiplayer_normalize_mission_type(selected)
    end
    local level_def = self.level_library and self.level_library[self.current_level_index or 1] or nil
    return get_level_mission_type(level_def)
end

local function is_rescue_entry_tile_name(tile_name)
    local name = tostring(tile_name or "")
    return name == RESCUE_ENTRY_TILE_NAME or name == RESCUE_ENTRY_TILE_NAME_ALT
end

local function get_rescue_entry_victory_cell_ids(self, local_cell_override)
    local out = {}
    local level = self and self.level_library and self.level_library[self.current_level_index or 1] or nil
    if type(level) ~= "table" then
        return out
    end
    for _, placement in ipairs(level) do
        if placement and is_rescue_entry_tile_name(placement.tile) then
            local local_idx = tonumber(local_cell_override or RESCUE_ENTRY_VICTORY_LOCAL_CELL or 4) or 4
            local local_x = (local_idx - 1) % 3
            local local_y = math.floor((local_idx - 1) / 3)
            local cell_x = (placement.x or 0) - 1 + local_x
            local cell_y = (placement.y or 0) - 1 + local_y
            local cell_id = coords_to_id(cell_x, cell_y)
            if cell_id and self.world_grid and self.world_grid[cell_id] and self.world_grid[cell_id].tileID ~= hash("empty") then
                out[#out + 1] = cell_id
            end
        end
    end
    return out
end

local function is_cell_in_any_rescue_entry_tile(self, cell_id)
    local level = self and self.level_library and self.level_library[self.current_level_index or 1] or nil
    if type(level) ~= "table" then
        return false
    end
    local cid = tonumber(cell_id or 0) or 0
    if cid <= 0 then
        return false
    end
    for _, placement in ipairs(level) do
        if placement and is_rescue_entry_tile_name(placement.tile) then
            for dy = -1, 1 do
                for dx = -1, 1 do
                    local check_id = coords_to_id((placement.x or 0) + dx, (placement.y or 0) + dy)
                    if check_id == cid then
                        return true
                    end
                end
            end
        end
    end
    return false
end

local function get_world_cell_ids_for_tile_local_cells(self, tile_name, local_cells)
    local out = {}
    local level = self and self.level_library and self.level_library[self.current_level_index or 1] or nil
    if type(level) ~= "table" or type(local_cells) ~= "table" then
        return out
    end
    for _, placement in ipairs(level) do
        if placement and tostring(placement.tile or "") == tostring(tile_name or "") then
            for _, local_idx in ipairs(local_cells) do
                local idx = tonumber(local_idx or 0) or 0
                if idx >= 1 and idx <= 9 then
                    local local_x = (idx - 1) % 3
                    local local_y = math.floor((idx - 1) / 3)
                    local cell_x = (placement.x or 0) - 1 + local_x
                    local cell_y = (placement.y or 0) - 1 + local_y
                    local cell_id = coords_to_id(cell_x, cell_y)
                    if cell_id and self.world_grid and self.world_grid[cell_id] and self.world_grid[cell_id].tileID ~= hash("empty") then
                        out[#out + 1] = cell_id
                    end
                end
            end
        end
    end
    return out
end

local function tutorial_world_to_screen(self, world_x, world_y)
    local zoom = tonumber(self and self.camera_zoom or 1) or 1
    if zoom <= 0 then
        zoom = 1
    end
    local camera_pos = (self and self.camera_pos) or vmath.vector3(0, 0, 0)
    local screen_x = ((world_x - camera_pos.x) * zoom) + (SCREEN_WIDTH * 0.5)
    local screen_y = ((world_y - camera_pos.y) * zoom) + (SCREEN_HEIGHT * 0.5)
    return screen_x, screen_y
end

local function get_tutorial_step_world_center(self, step_def)
    if not (self and step_def and self.level_library and self.current_level_index and self.world_grid) then
        return nil, nil
    end
    local level = self.level_library[self.current_level_index]
    if type(level) ~= "table" then
        return nil, nil
    end
    local target_tile = tostring(step_def.tile or "")
    local local_idx = tonumber(step_def.cell or 0) or 0
    if target_tile == "" or local_idx < 1 or local_idx > 9 then
        return nil, nil
    end
    for _, placement in ipairs(level) do
        local placement_tile = tostring(placement and placement.tile or "")
        local tile_matches = placement_tile == target_tile
            or (target_tile == "escape" and placement_tile == "exit")
        if tile_matches then
            local local_x = (local_idx - 1) % 3
            local local_y = math.floor((local_idx - 1) / 3)
            local cell_x = (placement.x or 0) - 1 + local_x
            local cell_y = (placement.y or 0) - 1 + local_y
            local world_cell_id = coords_to_id(cell_x, cell_y)
            local world_cell = world_cell_id and self.world_grid[world_cell_id] or nil
            if world_cell and world_cell.tileID ~= hash("empty") then
                local wx, wy = coords_to_world_pos(world_cell.xCell, world_cell.yCell)
                return wx, wy
            end
        end
    end
    return nil, nil
end

local function get_tutorial_step_screen_center(self, step_def)
    local wx, wy = get_tutorial_step_world_center(self, step_def)
    if not (wx and wy) then
        return SCREEN_WIDTH * 0.5, SCREEN_HEIGHT * 0.5
    end
    return tutorial_world_to_screen(self, wx, wy)
end

local function tutorial_set_current_step(self, step_index)
    if not self then
        return
    end
    local idx = tonumber(step_index or 1) or 1
    if idx < 1 then
        idx = 1
    end
    local step_def = TUTORIAL_STEP_DEFS[idx]
    if not step_def then
        self.tutorial_step_index = nil
        self.tutorial_overlay_active = false
        self.tutorial_anchor_world_x = nil
        self.tutorial_anchor_world_y = nil
        return
    end
    self.tutorial_step_index = idx
    self.tutorial_overlay_active = true
    local wx, wy = get_tutorial_step_world_center(self, step_def)
    self.tutorial_anchor_world_x = wx
    self.tutorial_anchor_world_y = wy
    if wx and wy then
        self.camera_pos.x = wx
        self.camera_pos.y = wy
        go.set_position(self.camera_pos, "/camera")
        go.set("/camera#camera", "orthographic_zoom", self.camera_zoom)
    end
    local sx, sy = get_tutorial_step_screen_center(self, step_def)
    self.tutorial_panel_screen_x = sx
    self.tutorial_panel_screen_y = sy
    if self.ui and self.ui.tutorial_panel and step_def.anim then
        msg.post(msg.url(nil, self.ui.tutorial_panel, "sprite"), "play_animation", { id = step_def.anim })
    end
end

local function tutorial_try_advance_from_click(self, screen_x, screen_y)
    if not (self and self.tutorial_mode == true and self.tutorial_overlay_active == true and self.tutorial_panel_screen_x and self.tutorial_panel_screen_y) then
        return false
    end
    local zoom = tonumber(self.camera_zoom or 1) or 1
    if zoom <= 0 then
        zoom = 1
    end
    local panel_w_screen = TUTORIAL_PANEL_W * TUTORIAL_PANEL_DRAW_SCALE * zoom
    local panel_h_screen = TUTORIAL_PANEL_H * TUTORIAL_PANEL_DRAW_SCALE * zoom
    local hotspot_size_screen = math.max(48, TUTORIAL_NEXT_HOTSPOT_SIZE * TUTORIAL_PANEL_DRAW_SCALE * zoom)
    local half_w = panel_w_screen * 0.5
    local half_h = panel_h_screen * 0.5
    local hotspot_center_x = self.tutorial_panel_screen_x + half_w - (hotspot_size_screen * 0.5)
    local hotspot_center_y = self.tutorial_panel_screen_y - half_h + (hotspot_size_screen * 0.5)
    if not is_point_in_screen_rect(screen_x, screen_y, self.tutorial_panel_screen_x, self.tutorial_panel_screen_y, panel_w_screen, panel_h_screen) then
        return false
    end
    if is_point_in_screen_rect(screen_x, screen_y, hotspot_center_x, hotspot_center_y, hotspot_size_screen, hotspot_size_screen) then
        local next_idx = (tonumber(self.tutorial_step_index or 1) or 1) + 1
        if next_idx > #TUTORIAL_STEP_DEFS then
            self.tutorial_overlay_active = false
            self.tutorial_step_index = nil
            self.tutorial_anchor_world_x = nil
            self.tutorial_anchor_world_y = nil
            self.tutorial_completed = true
        else
            tutorial_set_current_step(self, next_idx)
        end
        return true
    end
    return true
end

tutorial_rules_locked = function(self)
    return self and self.tutorial_mode == true and self.tutorial_completed ~= true
end

local function build_cell_lookup(cell_ids)
    local out = {}
    for _, cell_id in ipairs(cell_ids or {}) do
        out[tonumber(cell_id or 0) or 0] = true
    end
    return out
end

local function dna_is_active_mission(self)
    return tostring(get_current_mission_type(self) or "") == MISSION_TYPE_DNA_SAMPLE
end

local function has_alive_brute_on_any_cell(self, lookup)
    for _, alien in ipairs(self.aliens or {}) do
        if alien
            and alien.type == ALIEN_TYPE_BRUTE
            and (alien.hp_current or 0) > 0
            and lookup[tonumber(alien.cell_id or 0) or 0] == true
        then
            return true
        end
    end
    return false
end

local function refresh_dna_marker_runtime(self)
    if LOOT_RUNTIME and LOOT_RUNTIME.refresh_dna_mission_markers then
        LOOT_RUNTIME.refresh_dna_mission_markers(self)
    end
end

local function has_world_item_type(self, item_type)
    for _, item in ipairs(self.world_item_instances or {}) do
        if item and item.item_type == item_type then
            return true
        end
    end
    return false
end

local function try_spawn_dna_sample_item(self)
    if not dna_is_active_mission(self) then
        return false
    end
    if self.dna_sample_spawned == true or self.dna_sample_returned == true then
        return false
    end
    if has_world_item_type(self, DNA_SAMPLE_ITEM_TYPE) then
        self.dna_sample_spawned = true
        return false
    end
    local sample_cells = get_world_cell_ids_for_tile_local_cells(self, DNA_LAB_TILE_NAME, { DNA_BAR_LOCAL_CELL })
    local sample_cell_id = tonumber(sample_cells and sample_cells[1] or 0) or 0
    if sample_cell_id <= 0 then
        return false
    end
    if not (LOOT_RUNTIME and LOOT_RUNTIME.create_world_item_instance and LOOT_RUNTIME.refresh_world_item_visuals) then
        return false
    end
    LOOT_RUNTIME.create_world_item_instance(self, DNA_SAMPLE_ITEM_TYPE, sample_cell_id, nil, {
        dna_sample = true,
        slot_order = 1,
        impact_ring_on_spawn = true
    })
    self.dna_sample_spawned = true
    LOOT_RUNTIME.refresh_world_item_visuals(self)
    print(string.format("DNA SAMPLE | spawned at cell %d", sample_cell_id))
    return true
end

local function tick_dna_progress_for_new_human_turn(self)
    if not dna_is_active_mission(self) then
        self.dna_analysis_progress = 0
        self.dna_analysis_complete = false
        self.dna_sample_spawned = false
        self.dna_sample_returned = false
        refresh_dna_marker_runtime(self)
        return
    end
    self.dna_analysis_progress = math.max(0, tonumber(self.dna_analysis_progress or 0) or 0)
    if self.dna_analysis_complete == true then
        self.dna_analysis_progress = DNA_PROGRESS_TARGET
        if self.dna_sample_spawned ~= true and self.dna_sample_returned ~= true then
            try_spawn_dna_sample_item(self)
        end
        refresh_dna_marker_runtime(self)
        return
    end
    local brute_target_cells = get_world_cell_ids_for_tile_local_cells(self, DNA_LAB_TILE_NAME, DNA_BRUTE_LOCAL_CELLS)
    local has_brute = has_alive_brute_on_any_cell(self, build_cell_lookup(brute_target_cells))
    if has_brute then
        self.dna_analysis_progress = math.min(DNA_PROGRESS_TARGET, self.dna_analysis_progress + 1)
        if self.dna_analysis_progress >= DNA_PROGRESS_TARGET then
            self.dna_analysis_complete = true
            self.dna_analysis_progress = DNA_PROGRESS_TARGET
            try_spawn_dna_sample_item(self)
        end
    else
        self.dna_analysis_progress = 0
    end
    refresh_dna_marker_runtime(self)
end

local function get_dna_mission_status(self)
    local carriers_ready = 0
    local victory_lookup = build_cell_lookup(get_rescue_entry_victory_cell_ids(self, DNA_RESCUE_RETURN_LOCAL_CELL))
    if next(victory_lookup) ~= nil then
        for _, unit in pairs(self.squad_units or {}) do
            if unit
                and (unit.current_health or 0) > 0
                and unit.in_shuttle ~= true
                and victory_lookup[tonumber(unit.cell_id or 0) or 0] == true
            then
                for _, item in ipairs(unit.backpack_items or {}) do
                    if item == DNA_SAMPLE_ITEM_TYPE then
                        carriers_ready = carriers_ready + 1
                        break
                    end
                end
            end
        end
    end
    return {
        progress = math.max(0, math.min(DNA_PROGRESS_TARGET, tonumber(self.dna_analysis_progress or 0) or 0)),
        complete = self.dna_analysis_complete == true,
        return_ready = carriers_ready > 0,
        carriers_ready = carriers_ready,
        sample_spawned = self.dna_sample_spawned == true,
        sample_returned = self.dna_sample_returned == true
    }
end

local function purge_is_active_mission(self)
    return tostring(get_current_mission_type(self) or "") == MISSION_TYPE_PURGE
end

local function get_wall_clock_ms()
    if socket and socket.gettime then
        return math.floor((socket.gettime() * 1000) + 0.5)
    end
    return (os.time() or 0) * 1000
end

local function get_alive_human_count_on_lookup(self, lookup)
    local count = 0
    for _, unit in pairs(self.squad_units or {}) do
        if unit
            and (unit.current_health or 0) > 0
            and unit.in_shuttle ~= true
            and lookup[tonumber(unit.cell_id or 0) or 0] == true
        then
            count = count + 1
        end
    end
    return count
end

local function purge_has_bomb_on_portal_target(self)
    local target_cells = get_world_cell_ids_for_tile_local_cells(self, PURGE_BOMB_TILE_NAME, { PURGE_BOMB_LOCAL_CELL })
    local lookup = build_cell_lookup(target_cells)
    if next(lookup) == nil then
        return false
    end
    for _, item in ipairs(self.world_item_instances or {}) do
        if item
            and item.item_type == PURGE_BOMB_ITEM_TYPE
            and lookup[tonumber(item.cell_id or 0) or 0] == true
        then
            return true
        end
    end
    return false
end

local function purge_is_extract_ready(self)
    local cell_ids = get_rescue_entry_victory_cell_ids(self, PURGE_RESCUE_RETURN_LOCAL_CELL)
    local lookup = build_cell_lookup(cell_ids)
    if next(lookup) == nil then
        return false
    end
    return get_alive_human_count_on_lookup(self, lookup) > 0
end

local function get_purge_mission_status(self)
    local now_ms = get_wall_clock_ms()
    local started = self.purge_timer_started == true and tonumber(self.purge_deadline_epoch_ms or 0) > 0
    local remaining_ms = 0
    if started then
        remaining_ms = math.max(0, (tonumber(self.purge_deadline_epoch_ms or 0) or 0) - now_ms)
    end
    return {
        bomb_planted = self.purge_bomb_planted == true,
        timer_started = started,
        launch_pressed = self.purge_launch_pressed == true,
        extract_ready = purge_is_extract_ready(self),
        remaining_ms = remaining_ms,
        remaining_s = math.ceil(remaining_ms / 1000),
        expired = self.purge_time_expired == true
    }
end

local function mark_purge_launch_pressed(self)
    if not purge_is_active_mission(self) then
        return false
    end
    if self.purge_launch_pressed == true then
        return true
    end
    self.purge_launch_pressed = true
    print("PURGE | launch button armed.")
    return true
end

local function update_purge_runtime(self)
    if not purge_is_active_mission(self) then
        self.purge_bomb_planted = false
        self.purge_timer_started = false
        self.purge_launch_pressed = false
        self.purge_time_expired = false
        self.purge_result_locked = false
        self.purge_deadline_epoch_ms = 0
        return
    end

    local now_ms = get_wall_clock_ms()
    local host_authority = true
    if self.mp_state and self.mp_state.enabled then
        host_authority = self.mp_state.local_player_id == self.mp_state.host_player_id
    end
    local planted = purge_has_bomb_on_portal_target(self)
    if planted then
        self.purge_bomb_planted = true
    end
    if host_authority and planted and self.purge_timer_started ~= true then
        self.purge_timer_started = true
        self.purge_deadline_epoch_ms = now_ms + (PURGE_COUNTDOWN_SECONDS * 1000)
        self.purge_time_expired = false
        self.purge_result_locked = false
        print("PURGE | bomb planted, countdown started (300s).")
    end

    if self.purge_timer_started ~= true or self.purge_result_locked == true or not host_authority then
        return
    end

    local deadline_ms = tonumber(self.purge_deadline_epoch_ms or 0) or 0
    if deadline_ms <= 0 or now_ms < deadline_ms then
        return
    end

    self.purge_time_expired = true
    self.purge_result_locked = true
    local extract_ready = purge_is_extract_ready(self)
    local launch_ready = self.purge_launch_pressed == true
    local state = ensure_score_state(self)
    SCORE_RUNTIME.record_mission_failed(state)
    self.game_won = false
    print(string.format(
        "PURGE | FAILURE at timeout. launch=%s extract=%s",
        launch_ready and "yes" or "no",
        extract_ready and "yes" or "no"
    ))
    enter_mission_outro(self, "lose", "purge_timeout")
end

local function update_all_humans_dead_loss(self)
    if (self.game_flow_state or FLOW_STATE_GAME) ~= FLOW_STATE_GAME then
        return
    end
    if not self.squad_units then
        return
    end
    local any_living_human = false
    for _, unit in pairs(self.squad_units) do
        if unit and (tonumber(unit.current_health or 0) or 0) > 0 then
            any_living_human = true
            break
        end
    end
    if any_living_human then
        return
    end
    local state = ensure_score_state(self)
    SCORE_RUNTIME.record_mission_failed(state)
    self.game_won = false
    print("MISSION | FAILURE all humans are dead.")
    enter_mission_outro(self, "lose", "all_humans_dead")
end

local function get_nearest_reachable_rescue_victory_path_for_civilian(self, civilian)
    if not (self and civilian and civilian.cell_id) then
        return nil
    end
    local best_path = nil
    local best_cost = math.huge
    local best_target = math.huge
    for _, target_cell_id in ipairs(get_rescue_entry_victory_cell_ids(self)) do
        if target_cell_id ~= civilian.cell_id then
            local path, total_cost = find_path(
                self.world_grid,
                civilian.cell_id,
                target_cell_id,
                nil,
                MOVEMENT_PROFILE_HUMAN,
                nil
            )
            if path and #path >= 2 then
                local cost = tonumber(total_cost or 0) or 0
                if cost < best_cost or (cost == best_cost and target_cell_id < best_target) then
                    best_path = path
                    best_cost = cost
                    best_target = target_cell_id
                end
            end
        end
    end
    return best_path
end

local set_civilian_scale
local get_civilian_world_pos_in_cell

local function clear_civilian_visuals(self)
    self.civilian_visuals = self.civilian_visuals or {}
    self.civilian_shadow_visuals = self.civilian_shadow_visuals or {}
    self.civilian_hp_bar_bg_visuals = self.civilian_hp_bar_bg_visuals or {}
    self.civilian_hp_bar_fill_visuals = self.civilian_hp_bar_fill_visuals or {}
    for civilian_id, go_id in pairs(self.civilian_visuals) do
        if go_id then
            pcall(go.delete, go_id)
        end
        self.civilian_visuals[civilian_id] = nil
    end
    for civilian_id, go_id in pairs(self.civilian_shadow_visuals) do
        if go_id then
            pcall(go.delete, go_id)
        end
        self.civilian_shadow_visuals[civilian_id] = nil
    end
    for civilian_id, go_id in pairs(self.civilian_hp_bar_bg_visuals) do
        if go_id then
            pcall(go.delete, go_id)
        end
        self.civilian_hp_bar_bg_visuals[civilian_id] = nil
    end
    for civilian_id, go_id in pairs(self.civilian_hp_bar_fill_visuals) do
        if go_id then
            pcall(go.delete, go_id)
        end
        self.civilian_hp_bar_fill_visuals[civilian_id] = nil
    end
end

local function refresh_civilian_visuals(self)
    self.civilian_visuals = self.civilian_visuals or {}
    self.civilian_shadow_visuals = self.civilian_shadow_visuals or {}
    self.civilian_hp_bar_bg_visuals = self.civilian_hp_bar_bg_visuals or {}
    self.civilian_hp_bar_fill_visuals = self.civilian_hp_bar_fill_visuals or {}
    local seen = {}
    local shadow_alpha = get_world_shadow_alpha(self)
    local profile = get_aesthetic_profile(self)
    local counter_move_enabled = profile and profile.counter_token_move_enabled == true
    local base_shadow_pos = vmath.vector3(30, -30, -0.01)
    local shadow_anim, shadow_tint = get_counter_shadow_anim_for_human(self, nil)
    local effective_shadow_tint = shadow_tint or vmath.vector4(1, 1, 1, 0.5)
    effective_shadow_tint = vmath.vector4(effective_shadow_tint.x, effective_shadow_tint.y, effective_shadow_tint.z, shadow_alpha)
    for _, civilian in ipairs(self.civilians or {}) do
        if civilian and civilian.id and civilian.cell_id and self.world_grid and self.world_grid[civilian.cell_id] then
            local cell = self.world_grid[civilian.cell_id]
            local desired_civilian_anim = (civilian.is_dead == true) and CIVILIAN_DEAD_SPRITE_ANIM or CIVILIAN_SPRITE_ANIM
            local x, y = get_civilian_world_pos_in_cell(self, civilian, civilian.cell_id, civilian.entry_slot_index)
            if not (x and y) then
                local cx, cy = coords_to_world_pos(cell.xCell, cell.yCell)
                x = cx
                y = cy - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM
            end
            local go_id = self.civilian_visuals[civilian.id]
            if not go_id then
                go_id = factory.create("/tile_factory#tile_factory", vmath.vector3(x, y, CIVILIAN_VISUAL_Z))
                if go_id then
                    self.civilian_visuals[civilian.id] = go_id
                    pcall(msg.post, msg.url(nil, go_id, "sprite"), "play_animation", { id = desired_civilian_anim })
                    civilian.current_anim_id = desired_civilian_anim
                    pcall(go.set_scale, vmath.vector3(CIVILIAN_VISUAL_SCALE, CIVILIAN_VISUAL_SCALE, 1), go_id)
                end
            end
            if go_id then
                if civilian.current_anim_id ~= desired_civilian_anim then
                    pcall(msg.post, msg.url(nil, go_id, "sprite"), "play_animation", { id = desired_civilian_anim })
                    civilian.current_anim_id = desired_civilian_anim
                end
                civilian.go_path = go_id
                civilian.display_name = civilian.display_name or string.format("Civilian #%d", tonumber(civilian.id or 0) or 0)
                local render_x = x
                local render_y = y
                if civilian.is_moving ~= true then
                    pcall(go.set_position, vmath.vector3(x, y, CIVILIAN_VISUAL_Z), go_id)
                else
                    local pos = go.get_position(go_id)
                    render_x = pos.x
                    render_y = pos.y
                end
                if civilian.is_moving ~= true then
                    pcall(go.set_scale, vmath.vector3(CIVILIAN_VISUAL_SCALE, CIVILIAN_VISUAL_SCALE, 1), go_id)
                end
                if civilian.is_dead ~= true then
                    local civilian_tint = civilian.hazard_flash_active == true
                        and (civilian.hazard_flash_tint or vmath.vector4(1.0, 0.78, 0.25, 1))
                        or vmath.vector4(1, 1, 1, 1)
                    pcall(go.set, msg.url(nil, go_id, "sprite"), "tint", civilian_tint)
                else
                    pcall(go.set, msg.url(nil, go_id, "sprite"), "tint", vmath.vector4(1, 1, 1, 1))
                end
                local shadow_id = self.civilian_shadow_visuals[civilian.id]
                if not shadow_id then
                    shadow_id = factory.create("/human_shadow_proxy_factory#human_shadow_proxy_factory", vmath.vector3(x, y, CIVILIAN_VISUAL_Z - 0.01))
                    if shadow_id then
                        self.civilian_shadow_visuals[civilian.id] = shadow_id
                        if shadow_anim then
                            pcall(msg.post, msg.url(nil, shadow_id, "sprite"), "play_animation", { id = shadow_anim })
                        end
                        pcall(go.set_scale, vmath.vector3(0.75, 0.75, 1), shadow_id)
                    end
                end
                if shadow_id then
                    local shadow_pos = base_shadow_pos
                    if counter_move_enabled then
                        shadow_pos = civilian.shadow_motion_offset or get_counter_shadow_offset(profile, 0)
                    end
                    pcall(go.set_position, vmath.vector3(render_x + shadow_pos.x, render_y + shadow_pos.y, CIVILIAN_VISUAL_Z - 0.01), shadow_id)
                    pcall(go.set, msg.url(nil, shadow_id, "sprite"), "tint", effective_shadow_tint)
                end
                local hp_bg_id = self.civilian_hp_bar_bg_visuals[civilian.id]
                local hp_fill_id = self.civilian_hp_bar_fill_visuals[civilian.id]
                local hp_max = math.max(0, tonumber(civilian.max_health or CIVILIAN_MAX_HEALTH) or CIVILIAN_MAX_HEALTH)
                local hp_now = math.max(0, tonumber(civilian.current_health or hp_max) or hp_max)
                local show_hp_bar = civilian.is_dead ~= true and hp_max > 0
                if show_hp_bar then
                    local hp_ratio = math.max(0, math.min(1, hp_now / hp_max))
                    local unit_pos = go.get_position(go_id)
                    local hp_bar_x = unit_pos.x
                    local hp_bar_y = unit_pos.y + CIVILIAN_HP_BAR_OFFSET_Y
                    local bar_left = hp_bar_x - (CIVILIAN_HP_BAR_FULL_W * 0.5)
                    if not hp_bg_id then
                        hp_bg_id = factory.create("/tile_factory#tile_factory", vmath.vector3(hp_bar_x, hp_bar_y, CIVILIAN_VISUAL_Z + 0.2))
                        if hp_bg_id then
                            self.civilian_hp_bar_bg_visuals[civilian.id] = hp_bg_id
                            pcall(msg.post, msg.url(nil, hp_bg_id, "sprite"), "play_animation", { id = CIVILIAN_HP_BAR_BG_ANIM })
                            pcall(go.set_scale, vmath.vector3(CIVILIAN_HP_BAR_SCALE_X, CIVILIAN_HP_BAR_SCALE_Y, 1), hp_bg_id)
                            pcall(go.set, msg.url(nil, hp_bg_id, "sprite"), "tint", vmath.vector4(1, 1, 1, 1))
                        end
                    elseif hp_bg_id then
                        pcall(go.set_position, vmath.vector3(hp_bar_x, hp_bar_y, CIVILIAN_VISUAL_Z + 0.2), hp_bg_id)
                    end
                    if hp_ratio > 0 then
                        local fill_scale_x = CIVILIAN_HP_BAR_SCALE_X * hp_ratio
                        local fill_full_w = CIVILIAN_HP_BAR_ART_W * fill_scale_x
                        local fill_x = bar_left + (fill_full_w * 0.5)
                        local fill_color = vmath.vector4(0.28, 1.0, 0.38, 1.0)
                        if hp_ratio <= 0.3 then
                            fill_color = vmath.vector4(1.0, 0.36, 0.3, 1.0)
                        elseif hp_ratio <= 0.6 then
                            fill_color = vmath.vector4(1.0, 0.9, 0.3, 1.0)
                        end
                        if not hp_fill_id then
                            hp_fill_id = factory.create("/tile_factory#tile_factory", vmath.vector3(fill_x, hp_bar_y, CIVILIAN_VISUAL_Z + 0.2001))
                            if hp_fill_id then
                                self.civilian_hp_bar_fill_visuals[civilian.id] = hp_fill_id
                                pcall(msg.post, msg.url(nil, hp_fill_id, "sprite"), "play_animation", { id = CIVILIAN_HP_BAR_FILL_ANIM })
                                pcall(go.set, msg.url(nil, hp_fill_id, "sprite"), "tint", fill_color)
                            end
                        end
                        if hp_fill_id then
                            pcall(go.set_position, vmath.vector3(fill_x, hp_bar_y, CIVILIAN_VISUAL_Z + 0.2001), hp_fill_id)
                            pcall(go.set_scale, vmath.vector3(fill_scale_x, CIVILIAN_HP_BAR_SCALE_Y, 1), hp_fill_id)
                            pcall(go.set, msg.url(nil, hp_fill_id, "sprite"), "tint", fill_color)
                        end
                    elseif hp_fill_id then
                        pcall(go.delete, hp_fill_id)
                        self.civilian_hp_bar_fill_visuals[civilian.id] = nil
                    end
                else
                    if hp_bg_id then
                        pcall(go.delete, hp_bg_id)
                        self.civilian_hp_bar_bg_visuals[civilian.id] = nil
                    end
                    if hp_fill_id then
                        pcall(go.delete, hp_fill_id)
                        self.civilian_hp_bar_fill_visuals[civilian.id] = nil
                    end
                end
                seen[civilian.id] = true
            end
        end
    end
    for civilian_id, go_id in pairs(self.civilian_visuals) do
        if not seen[civilian_id] then
            if go_id then
                pcall(go.delete, go_id)
            end
            self.civilian_visuals[civilian_id] = nil
        end
    end
    for civilian_id, go_id in pairs(self.civilian_shadow_visuals) do
        if not seen[civilian_id] then
            if go_id then
                pcall(go.delete, go_id)
            end
            self.civilian_shadow_visuals[civilian_id] = nil
        end
    end
    for civilian_id, go_id in pairs(self.civilian_hp_bar_bg_visuals) do
        if not seen[civilian_id] then
            if go_id then
                pcall(go.delete, go_id)
            end
            self.civilian_hp_bar_bg_visuals[civilian_id] = nil
        end
    end
    for civilian_id, go_id in pairs(self.civilian_hp_bar_fill_visuals) do
        if not seen[civilian_id] then
            if go_id then
                pcall(go.delete, go_id)
            end
            self.civilian_hp_bar_fill_visuals[civilian_id] = nil
        end
    end
end

any_civilian_is_moving = function(self)
    for _, civilian in ipairs(self.civilians or {}) do
        if civilian and civilian.is_dead ~= true and civilian.is_moving == true then
            return true
        end
    end
    return false
end

local function get_civilian_slot_key(civilian)
    return "civilian_" .. tostring((civilian and civilian.id) or 0)
end

local function ensure_civilian_cell_slot_assignment(self, civilian, cell_id, preferred_slot)
    if not (self and civilian and cell_id) then
        return 1
    end
    self.cell_slot_assignments = self.cell_slot_assignments or {}
    self.cell_slot_assignments[cell_id] = self.cell_slot_assignments[cell_id] or {}
    local assignment = self.cell_slot_assignments[cell_id]
    local slot_key = get_civilian_slot_key(civilian)
    local existing = assignment[slot_key]
    if existing and existing >= 1 and existing <= #CELL_SLOT_OFFSETS_X then
        return existing
    end
    local used = {}
    for _, slot_index in pairs(assignment) do
        used[slot_index] = true
    end
    local selected = nil
    if preferred_slot and preferred_slot >= 1 and preferred_slot <= #CELL_SLOT_OFFSETS_X and not used[preferred_slot] then
        selected = preferred_slot
    end
    if not selected then
        for i = 1, #CELL_SLOT_OFFSETS_X do
            if not used[i] then
                selected = i
                break
            end
        end
    end
    selected = selected or 1
    assignment[slot_key] = selected
    return selected
end

local function clear_civilian_cell_slot_assignment(self, civilian, cell_id)
    if not (self and civilian and cell_id and self.cell_slot_assignments and self.cell_slot_assignments[cell_id]) then
        return
    end
    self.cell_slot_assignments[cell_id][get_civilian_slot_key(civilian)] = nil
end

get_civilian_world_pos_in_cell = function(self, civilian, cell_id, preferred_slot)
    if not (self and self.world_grid and cell_id and self.world_grid[cell_id]) then
        return nil, nil, 1
    end
    local cell = self.world_grid[cell_id]
    local base_x, base_y = coords_to_world_pos(cell.xCell, cell.yCell)
    base_y = base_y - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM
    local slot_index = ensure_civilian_cell_slot_assignment(self, civilian, cell_id, preferred_slot)
    local slot_offset = CELL_SLOT_OFFSETS_X[slot_index] or 0
    local x = base_x + (slot_offset * HUMAN_STACK_SPACING_X)
    x = clamp_world_x_to_cell(cell, x)
    return x, base_y, slot_index
end

local function spawn_civilians_for_current_mission(self)
    self.civilians = {}
    self.next_civilian_id = 0
    if get_current_mission_type(self) ~= MISSION_TYPE_RESCUE then
        return
    end
    if not self.world_grid then
        return
    end
    for _, cell in ipairs(self.world_grid) do
        if cell and cell.tileID ~= hash("empty") then
            local slots = { cell.object1, cell.object2, cell.object3 }
            for _, obj in ipairs(slots) do
                if obj and obj.name == CIVILIAN_OBJECT_NAME then
                    self.next_civilian_id = (self.next_civilian_id or 0) + 1
                    table.insert(self.civilians, {
                        id = self.next_civilian_id,
                        display_name = string.format("Civilian #%d", tonumber(self.next_civilian_id or 0) or 0),
                        cell_id = cell.idNumber,
                        is_awake = false,
                        is_dead = false,
                        is_rescued = false,
                        max_ap = CIVILIAN_MAX_ACTION_POINTS,
                        current_ap = CIVILIAN_MAX_ACTION_POINTS,
                        max_health = CIVILIAN_MAX_HEALTH,
                        current_health = CIVILIAN_MAX_HEALTH,
                        spawn_object_id = tonumber(obj.objectId or 0) or 0,
                        anim_phase = 0,
                        shadow_motion_offset = nil,
                        vertical_prep_done_for_index = nil,
                        entry_slot_for_index = nil,
                        entry_slot_index = nil,
                        micro_target_x = nil,
                        micro_target_y = nil,
                        micro_move_kind = nil
                    })
                    local civilian_ref = self.civilians[#self.civilians]
                    ensure_civilian_cell_slot_assignment(self, civilian_ref, cell.idNumber, nil)
                    obj.name = hash("empty")
                    obj.objectId = 0
                end
            end
        end
    end
    print(string.format("CIVILIANS | spawned=%d | mission=%s", #(self.civilians or {}), tostring(get_current_mission_type(self))))
end

local function get_nearest_living_human_for_civilian(self, civilian)
    local best_unit = nil
    local best_dist = math.huge
    for _, unit in ipairs(get_living_humans(self)) do
        if unit and unit.cell_id and civilian and civilian.cell_id then
            local dist = heuristic(civilian.cell_id, unit.cell_id)
            if dist < best_dist then
                best_dist = dist
                best_unit = unit
            elseif dist == best_dist and best_unit and tostring(unit.id) < tostring(best_unit.id) then
                best_unit = unit
            end
        end
    end
    return best_unit
end

local function get_nearest_reachable_human_path_for_civilian(self, civilian)
    if not (self and civilian and civilian.cell_id) then
        return nil, nil
    end
    local best_unit = nil
    local best_path = nil
    local best_cost = math.huge
    local best_dist = math.huge
    for _, unit in ipairs(get_living_humans(self)) do
        if unit and unit.cell_id and unit.cell_id ~= civilian.cell_id then
            local path, total_cost = find_path(
                self.world_grid,
                civilian.cell_id,
                unit.cell_id,
                nil,
                MOVEMENT_PROFILE_HUMAN,
                nil
            )
            if path and #path >= 2 then
                local cost = tonumber(total_cost or 0) or 0
                local dist = heuristic(civilian.cell_id, unit.cell_id)
                if cost < best_cost
                    or (cost == best_cost and dist < best_dist)
                    or (cost == best_cost and dist == best_dist and best_unit and tostring(unit.id) < tostring(best_unit.id))
                then
                    best_unit = unit
                    best_path = path
                    best_cost = cost
                    best_dist = dist
                end
            end
        end
    end
    return best_unit, best_path
end

local function get_follow_target_path_for_civilian(self, civilian)
    if not (self and civilian and civilian.cell_id) then
        return nil, nil
    end
    if civilian.follow_human_id and self.squad_units then
        local preferred = self.squad_units[civilian.follow_human_id]
        if preferred and (preferred.current_health or 0) > 0 and preferred.cell_id and preferred.cell_id ~= civilian.cell_id then
            local path = find_path(
                self.world_grid,
                civilian.cell_id,
                preferred.cell_id,
                nil,
                MOVEMENT_PROFILE_HUMAN,
                nil
            )
            if path and #path >= 2 then
                return preferred, path
            end
        end
    end
    return get_nearest_reachable_human_path_for_civilian(self, civilian)
end

local function get_civilian_turn_movement_segment(self, path, max_ap)
    if not path or #path < 2 then
        return nil, 0
    end
    local ap_spent = 0
    local segment = { path[1] }
    for i = 2, #path do
        local from_cell = path[i - 1]
        local to_cell = path[i]
        local step_cost = get_step_move_cost(self.world_grid, from_cell, to_cell)
        if ap_spent + step_cost > max_ap then
            break
        end
        ap_spent = ap_spent + step_cost
        table.insert(segment, to_cell)
    end
    if #segment < 2 then
        return nil, 0
    end
    return segment, ap_spent
end

local function process_civilian_turn(self)
    if get_current_mission_type(self) ~= MISSION_TYPE_RESCUE then
        return
    end
    if not (self.civilians and self.world_grid) then
        return
    end
    local moved_count = 0
    local woke_count = 0
    for _, civilian in ipairs(self.civilians) do
        if civilian and civilian.is_dead ~= true then
            civilian.max_ap = tonumber(civilian.max_ap or CIVILIAN_MAX_ACTION_POINTS) or CIVILIAN_MAX_ACTION_POINTS
            civilian.current_ap = civilian.max_ap
            civilian.max_health = tonumber(civilian.max_health or CIVILIAN_MAX_HEALTH) or CIVILIAN_MAX_HEALTH
            civilian.current_health = tonumber(civilian.current_health or civilian.max_health) or civilian.max_health
            if civilian.current_health <= 0 then
                civilian.current_ap = 0
                civilian.is_dead = true
            else
                if civilian.is_awake ~= true then
                    for _, unit in ipairs(get_living_humans(self)) do
                        if unit and unit.cell_id and civilian.cell_id and unit.cell_id == civilian.cell_id then
                            civilian.is_awake = true
                            civilian.follow_human_id = unit.id
                            woke_count = woke_count + 1
                            break
                        end
                    end
                end
                if civilian.is_awake == true and civilian.cell_id then
                    local remaining_ap = tonumber(civilian.current_ap or 0) or 0
                    local nearest = nil
                    local path = nil
                    if get_current_mission_type(self) == MISSION_TYPE_RESCUE and is_cell_in_any_rescue_entry_tile(self, civilian.cell_id) then
                        path = get_nearest_reachable_rescue_victory_path_for_civilian(self, civilian)
                    else
                        nearest, path = get_follow_target_path_for_civilian(self, civilian)
                    end
                    if path and remaining_ap > 0 then
                        local segment_path, spent = get_civilian_turn_movement_segment(self, path, remaining_ap)
                        if segment_path then
                            civilian.is_moving = true
                            civilian.move_path = segment_path
                            civilian.move_path_index = 2
                            civilian.vertical_prep_done_for_index = nil
                            civilian.entry_slot_for_index = nil
                            civilian.micro_target_x = nil
                            civilian.micro_target_y = nil
                            civilian.micro_move_kind = nil
                            moved_count = moved_count + math.max(0, (#segment_path - 1))
                            remaining_ap = math.max(0, remaining_ap - (spent or 0))
                        end
                    elseif civilian.is_awake == true then
                        print(string.format(
                            "CIVILIANS | no_reachable_path | id=%d cell=%d",
                            tonumber(civilian.id or 0) or 0,
                            tonumber(civilian.cell_id or 0) or 0
                        ))
                    end
                    civilian.current_ap = math.max(0, remaining_ap)
                end
            end
        end
    end
    refresh_civilian_visuals(self)
    if moved_count > 0 or woke_count > 0 then
        print(string.format(
            "CIVILIANS | turn_update | woke=%d moved_steps=%d",
            tonumber(woke_count or 0) or 0,
            tonumber(moved_count or 0) or 0
        ))
    end
end

local function update_civilian_movement(self, dt)
    if not self or not self.world_grid then
        return
    end
    local move_speed = HUMAN_MOVE_SPEED * 0.9
    local profile = get_aesthetic_profile(self)
    local counter_move_enabled = profile and profile.counter_token_move_enabled == true
    local right_lane_slot = #CELL_SLOT_OFFSETS_X
    local right_lane_offset = (CELL_SLOT_OFFSETS_X[right_lane_slot] or 0) * HUMAN_STACK_SPACING_X
    for _, civilian in ipairs(self.civilians or {}) do
        if civilian and civilian.is_dead ~= true and civilian.is_moving and civilian.move_path then
            local civilian_sfx_key = "civ_" .. tostring(civilian.id or 0)
            local function stop_civilian_motion()
                update_vertical_move_sfx_for_actor(self, civilian_sfx_key, false)
                update_horizontal_move_sfx_for_actor(self, civilian_sfx_key, false)
                civilian.is_moving = false
                civilian.move_path = nil
                civilian.move_path_index = 0
                civilian.vertical_prep_done_for_index = nil
                civilian.entry_slot_for_index = nil
                civilian.entry_slot_index = nil
                civilian.micro_target_x = nil
                civilian.micro_target_y = nil
                civilian.micro_move_kind = nil
                civilian.shadow_motion_offset = nil
                civilian.counter_move_total_dist = nil
                set_civilian_scale(self, civilian, CIVILIAN_VISUAL_SCALE, CIVILIAN_VISUAL_SCALE)
            end

            local go_id = self.civilian_visuals and self.civilian_visuals[civilian.id] or nil
            local handled_micro_motion = false
            if civilian.micro_target_x and civilian.micro_target_y and go_id then
                local pos = go.get_position(go_id)
                local dx = civilian.micro_target_x - pos.x
                local dy = civilian.micro_target_y - pos.y
                local is_vertical_now = math.abs(dy) > math.abs(dx) and math.abs(dy) > 0.01
                local is_horizontal_now = math.abs(dx) >= math.abs(dy) and math.abs(dx) > 0.01
                update_vertical_move_sfx_for_actor(self, civilian_sfx_key, is_vertical_now)
                update_horizontal_move_sfx_for_actor(self, civilian_sfx_key, is_horizontal_now)
                local dist = math.sqrt((dx * dx) + (dy * dy))
                local step = move_speed * (dt or 0)
                civilian.anim_phase = (civilian.anim_phase or 0) + ((dt or 0) * HUMAN_PINGPONG_SPEED * math.pi * 2)
                local ping = math.sin(civilian.anim_phase)
                local scale_x = CIVILIAN_VISUAL_SCALE
                local scale_y = CIVILIAN_VISUAL_SCALE
                if counter_move_enabled then
                    if not civilian.counter_move_total_dist or civilian.counter_move_total_dist <= 0 then
                        civilian.counter_move_total_dist = math.max(dist, 1)
                    end
                    local progress = 1 - math.max(0, math.min(1, dist / civilian.counter_move_total_dist))
                    local lift = math.sin(progress * math.pi)
                    local move_arc = 4 * progress * (1 - progress)
                    local wobble = math.sin((civilian.anim_phase or 0) * 2.0 + ((dx < 0) and 1.4 or 0))
                    local lift_scale = profile.counter_lift_scale or 0.16
                    local wobble_scale = profile.counter_wobble_scale or 0.04
                    scale_x = CIVILIAN_VISUAL_SCALE * (1 + (lift * lift_scale) + (wobble * wobble_scale))
                    scale_y = CIVILIAN_VISUAL_SCALE * (1 + (lift * lift_scale) - (wobble * wobble_scale * 0.6))
                    civilian.shadow_motion_offset = get_counter_shadow_offset(profile, move_arc)
                else
                    civilian.shadow_motion_offset = nil
                    if math.abs(dx) >= math.abs(dy) then
                        scale_x = CIVILIAN_VISUAL_SCALE * (1 + HUMAN_PINGPONG_AMPLITUDE * ping)
                    else
                        scale_y = CIVILIAN_VISUAL_SCALE * (1 + HUMAN_PINGPONG_AMPLITUDE * ping)
                    end
                end
                set_civilian_scale(self, civilian, scale_x, scale_y)
                if dist <= step or dist <= 0.001 then
                    pcall(go.set_position, vmath.vector3(civilian.micro_target_x, civilian.micro_target_y, CIVILIAN_VISUAL_Z), go_id)
                    civilian.micro_target_x = nil
                    civilian.micro_target_y = nil
                    civilian.micro_move_kind = nil
                    civilian.counter_move_total_dist = nil
                    set_civilian_scale(self, civilian, CIVILIAN_VISUAL_SCALE, CIVILIAN_VISUAL_SCALE)
                else
                    local nx = pos.x + ((dx / dist) * step)
                    local ny = pos.y + ((dy / dist) * step)
                    pcall(go.set_position, vmath.vector3(nx, ny, CIVILIAN_VISUAL_Z), go_id)
                end
                handled_micro_motion = true
            end

            if not handled_micro_motion then
                local target_cell_id = civilian.move_path[civilian.move_path_index]
                if not target_cell_id then
                    stop_civilian_motion()
                else
                    local cell = self.world_grid[target_cell_id]
                    if not (go_id and cell) then
                        update_vertical_move_sfx_for_actor(self, civilian_sfx_key, false)
                        update_horizontal_move_sfx_for_actor(self, civilian_sfx_key, false)
                        if civilian.cell_id and civilian.cell_id ~= target_cell_id then
                            clear_civilian_cell_slot_assignment(self, civilian, civilian.cell_id)
                        end
                        civilian.cell_id = target_cell_id or civilian.cell_id
                        ensure_civilian_cell_slot_assignment(self, civilian, civilian.cell_id, civilian.entry_slot_index)
                        trigger_unit_tile_bump_sfx(self, "civ")
                        civilian.move_path_index = (civilian.move_path_index or 0) + 1
                    else
                        local target_x, target_y, target_slot = get_civilian_world_pos_in_cell(self, civilian, target_cell_id, civilian.entry_slot_index)
                        local from_x, from_y = id_to_coords(civilian.cell_id)
                        local to_x, to_y = id_to_coords(target_cell_id)
                        local is_vertical_step = (from_x == to_x) and (from_y ~= to_y)
                        local is_prep_vertical_stage = false
                        if civilian.entry_slot_for_index ~= civilian.move_path_index then
                            civilian.entry_slot_index = target_slot
                            civilian.entry_slot_for_index = civilian.move_path_index
                        end
                        if (not counter_move_enabled) and is_vertical_step and civilian.vertical_prep_done_for_index ~= civilian.move_path_index then
                            local current_cell = self.world_grid[civilian.cell_id]
                            if current_cell then
                                local prep_x, prep_y = coords_to_world_pos(current_cell.xCell, current_cell.yCell)
                                prep_y = prep_y - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM
                                target_x = clamp_world_x_to_cell(current_cell, prep_x + right_lane_offset)
                                target_y = prep_y
                                is_prep_vertical_stage = true
                            end
                        elseif (not counter_move_enabled) and is_vertical_step then
                            local cx, cy = coords_to_world_pos(cell.xCell, cell.yCell)
                            target_x = clamp_world_x_to_cell(cell, cx + right_lane_offset)
                            target_y = cy - (CELL_HEIGHT * 0.5) + HUMAN_FLOOR_OFFSET_FROM_CELL_BOTTOM
                        end
                        local pos = go.get_position(go_id)
                        local dx = target_x - pos.x
                        local dy = target_y - pos.y
                        local is_horizontal_step = not is_vertical_step
                        update_vertical_move_sfx_for_actor(self, civilian_sfx_key, is_vertical_step)
                        update_horizontal_move_sfx_for_actor(self, civilian_sfx_key, is_horizontal_step)
                        local dist = math.sqrt((dx * dx) + (dy * dy))
                        local step = move_speed * (dt or 0)
                        civilian.anim_phase = (civilian.anim_phase or 0) + ((dt or 0) * HUMAN_PINGPONG_SPEED * math.pi * 2)
                        local ping = math.sin(civilian.anim_phase)
                        local scale_x = CIVILIAN_VISUAL_SCALE
                        local scale_y = CIVILIAN_VISUAL_SCALE
                        if counter_move_enabled then
                            if not civilian.counter_move_total_dist or civilian.counter_move_total_dist <= 0 then
                                civilian.counter_move_total_dist = math.max(dist, 1)
                            end
                            local progress = 1 - math.max(0, math.min(1, dist / civilian.counter_move_total_dist))
                            local lift = math.sin(progress * math.pi)
                            local move_arc = 4 * progress * (1 - progress)
                            local wobble = math.sin((civilian.anim_phase or 0) * 2.0 + ((dx < 0) and 1.4 or 0))
                            local lift_scale = profile.counter_lift_scale or 0.16
                            local wobble_scale = profile.counter_wobble_scale or 0.04
                            scale_x = CIVILIAN_VISUAL_SCALE * (1 + (lift * lift_scale) + (wobble * wobble_scale))
                            scale_y = CIVILIAN_VISUAL_SCALE * (1 + (lift * lift_scale) - (wobble * wobble_scale * 0.6))
                            civilian.shadow_motion_offset = get_counter_shadow_offset(profile, move_arc)
                        else
                            civilian.shadow_motion_offset = nil
                            if math.abs(dx) >= math.abs(dy) then
                                scale_x = CIVILIAN_VISUAL_SCALE * (1 + HUMAN_PINGPONG_AMPLITUDE * ping)
                            else
                                scale_y = CIVILIAN_VISUAL_SCALE * (1 + HUMAN_PINGPONG_AMPLITUDE * ping)
                            end
                    end
                        set_civilian_scale(self, civilian, scale_x, scale_y)
                        if dist <= step or dist <= 0.001 then
                            pcall(go.set_position, vmath.vector3(target_x, target_y, CIVILIAN_VISUAL_Z), go_id)
                            if is_prep_vertical_stage then
                                civilian.vertical_prep_done_for_index = civilian.move_path_index
                                civilian.counter_move_total_dist = nil
                            else
                                local old_cell_id = civilian.cell_id
                                if old_cell_id and old_cell_id ~= target_cell_id then
                                    clear_civilian_cell_slot_assignment(self, civilian, old_cell_id)
                                end
                                civilian.cell_id = target_cell_id
                                ensure_civilian_cell_slot_assignment(self, civilian, target_cell_id, civilian.entry_slot_index)
                                trigger_unit_tile_bump_sfx(self, "civ")
                                if (not counter_move_enabled) and is_vertical_step then
                                    local settle_x, settle_y = get_civilian_world_pos_in_cell(self, civilian, target_cell_id, civilian.entry_slot_index)
                                    if settle_x and settle_y and (math.abs(settle_x - target_x) > 0.5 or math.abs(settle_y - target_y) > 0.5) then
                                        civilian.micro_target_x = settle_x
                                        civilian.micro_target_y = settle_y
                                        civilian.micro_move_kind = "settle_after_vertical"
                                    end
                                end
                                civilian.move_path_index = (civilian.move_path_index or 0) + 1
                                civilian.counter_move_total_dist = nil
                            end
                        else
                            local nx = pos.x + ((dx / dist) * step)
                            local ny = pos.y + ((dy / dist) * step)
                            pcall(go.set_position, vmath.vector3(nx, ny, CIVILIAN_VISUAL_Z), go_id)
                        end
                    end
                    if civilian.move_path and civilian.move_path_index > #civilian.move_path and (not civilian.micro_target_x) then
                        stop_civilian_motion()
                    end
                end
            end
        end
    end
end

function can_any_human_reactively_attack(self)
    if not self.squad_units or not self.aliens then
        return false
    end
    for _, unit in pairs(self.squad_units) do
        if (unit.current_health or 0) > 0 and unit.cell_id and unit.reactive_fire_enabled ~= false then
            local melee_ap_cost = get_ap_cost_value("melee_attack", 1)
            local reactive_shot_ap_cost = get_ap_cost_value("reactive_ranged_shot", 1)
            local can_melee = unit.current_ap >= melee_ap_cost
            local can_ranged = unit.current_ap >= reactive_shot_ap_cost and unit.current_ammo > 0
            if can_melee or can_ranged then
                for _, alien in ipairs(self.aliens) do
                    if (not alien.is_dead) and alien.cell_id then
                        if can_melee and alien.cell_id == unit.cell_id then
                            return true
                        end
                        if can_ranged and has_unobstructed_human_ranged_los(self.world_grid, unit.cell_id, alien.cell_id) then
                            return true
                        end
                    end
                end
            end
        end
    end
    return false
end

function reset_derple_feedback_runtime(self)
    self.derple_feedback_low_hp_state = {}
    self.derple_feedback_spot_state = {}
    self.derple_feedback_los_scan_timer = 0
end

function update_derple_feedback_triggers(self, dt)
    if not (LOOT_RUNTIME and LOOT_RUNTIME.emit_derple_feedback) then
        return
    end
    if not self.squad_units then
        return
    end
    self.derple_feedback_low_hp_state = self.derple_feedback_low_hp_state or {}
    self.derple_feedback_spot_state = self.derple_feedback_spot_state or {}
    self.derple_feedback_los_scan_timer = (self.derple_feedback_los_scan_timer or 0) - (dt or 0)

    for unit_id, unit in pairs(self.squad_units) do
        local alive = unit and (unit.current_health or 0) > 0 and unit.cell_id and unit.in_shuttle ~= true
        if alive then
            local hp_threshold = math.max(1, math.floor((unit.max_health or 1) * DERPLE_FEEDBACK_LOW_HP_RATIO))
            local is_low_hp = (unit.current_health or 0) <= hp_threshold
            local was_low_hp = self.derple_feedback_low_hp_state[unit_id] == true
            if is_low_hp and (not was_low_hp) then
                LOOT_RUNTIME.emit_derple_feedback(self, unit_id, "LOW_HP")
            end
            self.derple_feedback_low_hp_state[unit_id] = is_low_hp
        else
            self.derple_feedback_low_hp_state[unit_id] = false
        end
    end

    if self.derple_feedback_los_scan_timer > 0 then
        return
    end
    self.derple_feedback_los_scan_timer = DERPLE_FEEDBACK_LOS_SCAN_INTERVAL
    for unit_id, unit in pairs(self.squad_units) do
        local alive = unit and (unit.current_health or 0) > 0 and unit.cell_id and unit.in_shuttle ~= true
        if alive then
            local has_spot_los = false
            if self.aliens then
                for _, alien in ipairs(self.aliens) do
                    if alien and (not alien.is_dead) and alien.cell_id and has_unobstructed_los(self.world_grid, unit.cell_id, alien.cell_id) then
                        has_spot_los = true
                        break
                    end
                end
            end
            local had_spot_los = self.derple_feedback_spot_state[unit_id] == true
            if has_spot_los and (not had_spot_los) then
                local emitted = LOOT_RUNTIME.emit_derple_feedback(self, unit_id, "SPOT_ALIEN")
                if emitted == true then
                    play_human_alien_alert_sfx(self, unit)
                end
            end
            self.derple_feedback_spot_state[unit_id] = has_spot_los
        else
            self.derple_feedback_spot_state[unit_id] = false
        end
    end
end

-- =============================================================================
-- VISUAL CELL FACTORY
-- =============================================================================
--[[
    Creates visual representation of cells using factory
    Debug sprites show access permissions (walls/floors)
]]

function create_cell_visuals(world_grid, factory_url)
    local cell_objects = {}

    for cell_id, cell in ipairs(world_grid) do
        local x_pos, y_pos = coords_to_world_pos(cell.xCell, cell.yCell)

        -- Determine which debug sprite to use based on access booleans
        local sprite_name = "cell_open"
        if not cell.accessRight and not cell.accessDown then
            sprite_name = "cell_right_down_wall"
        elseif not cell.accessRight then
            sprite_name = "cell_right_wall"
        elseif not cell.accessDown then
            sprite_name = "cell_down_wall"
        end

        -- If cell is VOID, use different sprite
        if cell.tileID == hash("empty") then
            sprite_name = "cell_void"
        end

        -- Create cell game object via factory
        local pos = vmath.vector3(x_pos, y_pos, 0)
        local cell_go = factory.create(factory_url, pos)

        -- Store reference
        cell_objects[cell_id] = {
            go_id = cell_go,
            sprite_name = sprite_name
        }

        -- Set sprite (would need to send message to sprite component)
        -- msg.post(msg.url(nil, cell_go, "sprite"), "play_animation", {id = hash(sprite_name)})
    end

    return cell_objects
end

-- =============================================================================
-- INPUT HANDLING
-- =============================================================================
--[[
    Handles touch/click input to select cells
    Converts screen coordinates to world grid coordinates
]]

function screen_to_world(action_x, action_y, camera_pos, zoom)
    -- Adjust for camera position and zoom
    local world_x = (action_x - SCREEN_WIDTH / 2) / zoom + camera_pos.x
    local world_y = (action_y - SCREEN_HEIGHT / 2) / zoom + camera_pos.y
    return world_x, world_y
end

get_fixed_viewport_rect = function()
    local ok_size, win_w, win_h = pcall(window.get_size)
    if not ok_size or not win_w or not win_h or win_w <= 0 or win_h <= 0 then
        return 0, 0, SCREEN_WIDTH, SCREEN_HEIGHT, 1
    end
    local scale = math.min(1, win_w / SCREEN_WIDTH, win_h / SCREEN_HEIGHT)
    if scale <= 0 then
        return 0, 0, SCREEN_WIDTH, SCREEN_HEIGHT, 1
    end
    local view_w = SCREEN_WIDTH * scale
    local view_h = SCREEN_HEIGHT * scale
    local view_x = (win_w - view_w) * 0.5
    local view_y = (win_h - view_h) * 0.5
    return view_x, view_y, view_w, view_h, scale
end

map_window_input_to_logical = function(x, y, screen_x, screen_y)
    if not x or not y then
        return nil, nil, false
    end
    if not IS_HTML5 then
        return x, y, true
    end

    -- Most HTML5 builds provide canvas-local action.x/y.
    if x >= 0 and x <= SCREEN_WIDTH and y >= 0 and y <= SCREEN_HEIGHT then
        return x, y, true
    end

    -- Fallback: treat x/y as window-space and map into fixed 1280x720 letterbox.
    local ok_size, win_w, win_h = pcall(window.get_size)
    if not ok_size or not win_w or not win_h or win_w <= 0 or win_h <= 0 then
        return nil, nil, false
    end

    local scale = math.min(win_w / SCREEN_WIDTH, win_h / SCREEN_HEIGHT)
    if not scale or scale <= 0 then
        return nil, nil, false
    end

    local view_w = SCREEN_WIDTH * scale
    local view_h = SCREEN_HEIGHT * scale
    local view_x = (win_w - view_w) * 0.5
    local view_y = (win_h - view_h) * 0.5

    local inside =
        x >= view_x and x <= (view_x + view_w) and
        y >= view_y and y <= (view_y + view_h)
    if not inside then
        return nil, nil, false
    end

    local logical_x = (x - view_x) / scale
    local logical_y = (y - view_y) / scale
    return logical_x, logical_y, true
end

enforce_fixed_window_size = function(self, dt, force_now)
    local ok_get, win_w, win_h = pcall(window.get_size)
    if not ok_get or not win_w or not win_h then
        return
    end
    if window.set_fullscreen then
        pcall(window.set_fullscreen, false)
    end
    if force_now == true then
        pcall(window.set_size, SCREEN_WIDTH, SCREEN_HEIGHT)
        if window.set_resizable then
            pcall(window.set_resizable, false)
        end
        if window.set_size_limits then
            pcall(window.set_size_limits, SCREEN_WIDTH, SCREEN_HEIGHT, SCREEN_WIDTH, SCREEN_HEIGHT)
        end
        self.window_lock_timer = 0
        return
    end
    local needs_resize = math.abs(win_w - SCREEN_WIDTH) > 1 or math.abs(win_h - SCREEN_HEIGHT) > 1
    if not needs_resize then
        return
    end
    self.window_lock_timer = (self.window_lock_timer or 0) - (dt or 0)
    if (self.window_lock_timer or 0) <= 0 then
        pcall(window.set_size, SCREEN_WIDTH, SCREEN_HEIGHT)
        self.window_lock_timer = 0.35
    end
end

function handle_cell_click(action, camera_pos, zoom)
    local world_x, world_y = screen_to_world(action.x, action.y, camera_pos, zoom)
    local x_cell, y_cell = world_pos_to_coords(world_x, world_y)
    local cell_id = coords_to_id(x_cell, y_cell)

    if cell_id then
        print(string.format("Clicked Cell ID: %d at (%d, %d) - World: (%.1f, %.1f)",
            cell_id, x_cell, y_cell, world_x, world_y))
        return cell_id
    end

    return nil
end

local function reset_cell_tint(cell_id)
    local go_id = cell_objects[cell_id]
    if go_id then
        msg.post(msg.url(nil, go_id, "cell_sprite1"), "set_tint", { tint = COLOR_DEFAULT })
    end
end

local function apply_cell_tint(cell_id, tint_color)
    local go_id = cell_objects[cell_id]
    if go_id then
        msg.post(msg.url(nil, go_id, "cell_sprite1"), "set_tint", { tint = tint_color })
    end
end

local function clear_path_visuals(self)
    if self.path_highlight_cells then
        for _, cell_id in ipairs(self.path_highlight_cells) do
            reset_cell_tint(cell_id)
        end
    end
    self.path_highlight_cells = {}
end

local function print_path_debug(path, total_cost)
    local ids = {}
    for i, cell_id in ipairs(path) do
        ids[i] = tostring(cell_id)
    end
    print("Path found:")
    print("  Steps: " .. #path)
    print("  Cost: " .. total_cost)
    print("  Route: " .. table.concat(ids, " -> "))
end

local function highlight_path(self, path)
    clear_path_visuals(self)
    self.path_highlight_cells = {}

    for _, cell_id in ipairs(path) do
        apply_cell_tint(cell_id, COLOR_PATH)
        table.insert(self.path_highlight_cells, cell_id)
    end

    if #path >= 1 then
        apply_cell_tint(path[1], COLOR_START)
    end
    if #path >= 2 then
        apply_cell_tint(path[#path], COLOR_END)
    end
end

local function clamp(value, min_value, max_value)
    if value < min_value then
        return min_value
    end
    if value > max_value then
        return max_value
    end
    return value
end

local function get_camera_clamped_pos(camera_pos, zoom)
    local world_w = CELL_WIDTH * GRID_COLS
    local world_h = CELL_HEIGHT * GRID_ROWS
    local half_view_w = (SCREEN_WIDTH * 0.5) / zoom
    local half_view_h = (SCREEN_HEIGHT * 0.5) / zoom

    local min_x = half_view_w - CAMERA_EDGE_PADDING_X
    local max_x = world_w - half_view_w + CAMERA_EDGE_PADDING_X
    local min_y = half_view_h - CAMERA_EDGE_PADDING_Y
    local max_y = world_h - half_view_h + CAMERA_EDGE_PADDING_Y

    local clamped_x = camera_pos.x
    local clamped_y = camera_pos.y

    if min_x > max_x then
        clamped_x = world_w * 0.5
    else
        clamped_x = clamp(camera_pos.x, min_x, max_x)
    end

    if min_y > max_y then
        clamped_y = world_h * 0.5
    else
        clamped_y = clamp(camera_pos.y, min_y, max_y)
    end

    return vmath.vector3(clamped_x, clamped_y, camera_pos.z)
end

local function apply_camera_transform(self)
    self.camera_pos = get_camera_clamped_pos(self.camera_pos, self.camera_zoom)
    go.set_position(self.camera_pos, "/camera")
    go.set("/camera#camera", "orthographic_zoom", self.camera_zoom)
end

local function zoom_camera_at_screen_point(self, target_zoom, screen_x, screen_y)
    local old_zoom = self.camera_zoom
    if target_zoom == old_zoom then
        return
    end

    -- Keep the world point under cursor fixed during zoom.
    local world_x, world_y = screen_to_world(screen_x, screen_y, self.camera_pos, old_zoom)
    self.camera_zoom = target_zoom
    self.camera_pos.x = world_x - ((screen_x - SCREEN_WIDTH * 0.5) / self.camera_zoom)
    self.camera_pos.y = world_y - ((screen_y - SCREEN_HEIGHT * 0.5) / self.camera_zoom)
    apply_camera_transform(self)
end

request_zoom_to = function(self, target_zoom, focus_x, focus_y)
    local clamped = clamp(target_zoom, self.camera_min_zoom, self.camera_max_zoom)
    self.zoom_target = clamped
    self.zoom_focus_x = focus_x or (SCREEN_WIDTH * 0.5)
    self.zoom_focus_y = focus_y or (SCREEN_HEIGHT * 0.5)
end

request_zoom_delta = function(self, delta, focus_x, focus_y)
    local base = self.zoom_target or self.camera_zoom
    request_zoom_to(self, base + delta, focus_x, focus_y)
end

update_smooth_zoom = function(self, dt)
    local target = self.zoom_target
    if not target then
        return
    end
    local diff = target - self.camera_zoom
    if math.abs(diff) < 0.001 then
        self.camera_zoom = target
        apply_camera_transform(self)
        self.zoom_target = nil
        return
    end
    local speed = self.zoom_smooth_speed or 10
    local alpha = 1 - math.exp(-speed * dt)
    local next_zoom = self.camera_zoom + (diff * alpha)
    zoom_camera_at_screen_point(self, next_zoom, self.zoom_focus_x or (SCREEN_WIDTH * 0.5), self.zoom_focus_y or (SCREEN_HEIGHT * 0.5))
end

local function is_walkable_cell(world_grid, cell_id)
    local cell = world_grid[cell_id]
    return cell and cell.tileID ~= hash("empty")
end

local function create_empty_equipment()
    return {
        top = nil,
        center = nil,
        left = nil,
        right = nil,
        bottom = nil
    }
end

local function unit_has_equipped_buff_kind(unit, buff_kind)
    if not unit or type(unit.equipment) ~= "table" then
        return false
    end
    for _, slot_name in ipairs(BUFF_SLOT_ORDER) do
        local item_type = unit.equipment[slot_name]
        local buff_def = item_type and BUFFS_BY_ITEM_TYPE[item_type] or nil
        if buff_def and buff_def.buff_kind == buff_kind then
            return true
        end
    end
    return false
end

local function get_human_ap_refresh_cap(unit)
    local base_ap = tonumber(unit and unit.max_ap or HUMAN_MAX_ACTION_POINTS) or HUMAN_MAX_ACTION_POINTS
    if unit_has_equipped_buff_kind(unit, "speed_stim") then
        return math.max(base_ap, SPEED_STIM_REFRESH_AP)
    end
    return base_ap
end

get_human_new_turn_ap_refresh = function(unit)
    local cap = get_human_ap_refresh_cap(unit)
    return math.max(cap, tonumber(TEMP_HUMAN_NEW_TURN_AP_REFRESH or cap) or cap)
end

try_realtime_auto_load_ammo_from_backpack = function(self, unit)
    if REALTIME_AUTO_AMMO_LOAD_FROM_BACKPACK ~= true then
        return false
    end
    if not (self and unit and self.realtime_rules_enabled == true) then
        return false
    end
    if (tonumber(unit.current_ammo or 0) or 0) > 0 then
        return false
    end
    local max_ammo = tonumber(unit.max_ammo or 0) or 0
    if max_ammo <= 0 then
        return false
    end
    local backpack = unit.backpack_items
    if type(backpack) ~= "table" then
        return false
    end
    for i, item_type in ipairs(backpack) do
        if item_type == "ammo" then
            table.remove(backpack, i)
            unit.backpack_used = #backpack
            unit.current_ammo = math.min(max_ammo, (tonumber(unit.current_ammo or 0) or 0) + 10)
            return true
        end
    end
    return false
end

local function get_human_armor_hit_reduction(unit)
    if not unit or type(unit.equipment) ~= "table" then
        return 0
    end
    for _, slot_name in ipairs(BUFF_SLOT_ORDER) do
        local item_type = unit.equipment[slot_name]
        local buff_def = item_type and BUFFS_BY_ITEM_TYPE[item_type] or nil
        if buff_def and buff_def.buff_kind == "armor" then
            return math.max(0, BUFF_ARMOR_HIT_REDUCTION)
        end
    end
    return 0
end

local function get_nightvision_reveal_context(self, dt_step)
    local selected_unit = nil
    if self and self.squad_units and self.controlled_unit_id then
        selected_unit = self.squad_units[self.controlled_unit_id]
    end
    local target_tile_id = 0
    local target_unit_id = nil
    local can_reveal = false
    if selected_unit
        and (selected_unit.current_health or 0) > 0
        and selected_unit.cell_id
        and unit_has_equipped_buff_kind(selected_unit, "nightvision_goggles")
    then
        local cell = self.world_grid and self.world_grid[selected_unit.cell_id] or nil
        if cell and cell.isPowered ~= true then
            target_tile_id = tonumber(cell.tileInstanceId or 0) or 0
            if target_tile_id > 0 then
                target_unit_id = tostring(selected_unit.id or "")
                can_reveal = true
            end
        end
    end

    if self.nightvision_reveal_unit_id ~= target_unit_id
        or (tonumber(self.nightvision_reveal_tile_id or 0) or 0) ~= target_tile_id
    then
        self.nightvision_reveal_unit_id = target_unit_id
        self.nightvision_reveal_tile_id = target_tile_id
        self.nightvision_reveal_hold_timer = 0
        self.nightvision_reveal_alpha = 0
    end

    local alpha = tonumber(self.nightvision_reveal_alpha or 0) or 0
    if can_reveal and dt_step and dt_step > 0 then
        local hold = tonumber(self.nightvision_reveal_hold_timer or 0) or 0
        if hold < NIGHTVISION_REVEAL_DELAY_S then
            hold = math.min(NIGHTVISION_REVEAL_DELAY_S, hold + dt_step)
            self.nightvision_reveal_hold_timer = hold
            alpha = 0
        else
            local fade_s = math.max(0.001, NIGHTVISION_REVEAL_FADE_S)
            alpha = math.min(1, alpha + (dt_step / fade_s))
        end
    elseif not can_reveal then
        self.nightvision_reveal_hold_timer = 0
        alpha = 0
    end
    self.nightvision_reveal_alpha = alpha
    local hold_now = tonumber(self.nightvision_reveal_hold_timer or 0) or 0
    local reveal_active = can_reveal and hold_now >= NIGHTVISION_REVEAL_DELAY_S
    return reveal_active, target_tile_id, alpha
end

get_cell_hazard_flags = function(cell)
    if not cell then
        return false, false, false
    end
    local fire = false
    local gas = false
    local outside = false
    local t = cell.hazard_type or cell.hazardType or cell.hazard
    if type(t) == "string" then
        local hazard = string.lower(t or "")
        if hazard ~= "" and hazard ~= "none" then
            local tokens = {}
            for token in string.gmatch(hazard, "[^_%-%s]+") do
                tokens[token] = true
            end
            fire = tokens.fire == true
            gas = (tokens.gas == true) or (tokens.poison == true)
            outside = (tokens.outside == true) or (tokens.o2 == true)
        end
    end
    fire = fire or cell.isFireHazard == true or cell.has_fire_hazard == true or cell.hasFireHazard == true
    gas = gas or cell.isGasHazard == true or cell.has_gas_hazard == true or cell.hasGasHazard == true
    outside = outside or cell.isOutsideHazard == true or cell.has_outside_hazard == true or cell.hasOutsideHazard == true
    -- Transitional fallback for pre-hazard-tag data only.
    -- Once all authored maps use hazard_type/flags, this can be removed.
    if outside ~= true and t == nil then
        outside = cell.isOutside == true
    end
    return fire, gas, outside
end

local function apply_start_of_turn_environment_damage(self)
    if not self or not self.squad_units or not self.world_grid then
        return
    end
    local outside_damage = math.max(0, tonumber(HAZARD_DAMAGE.outside_per_turn or 2) or 2)
    local fire_damage = math.max(0, tonumber(HAZARD_DAMAGE.fire_per_turn or 1) or 1)
    local gas_damage = math.max(0, tonumber(HAZARD_DAMAGE.gas_per_turn or 1) or 1)
    for _, unit in pairs(self.squad_units) do
        if unit and (unit.current_health or 0) > 0 and unit.cell_id then
            local cell = self.world_grid[unit.cell_id]
            local has_oxygen_mask = unit_has_equipped_buff_kind(unit, "oxygen_mask")
            local has_hazmat = unit_has_equipped_buff_kind(unit, "hazmat_suit")
            local damage = 0
            local has_fire, has_gas, has_outside = get_cell_hazard_flags(cell)
            if has_outside and not has_oxygen_mask then
                damage = damage + outside_damage
            end
            if has_fire and not has_hazmat then
                damage = damage + fire_damage
            end
            if has_gas and not has_hazmat then
                damage = damage + gas_damage
            end
            if damage > 0 then
                unit.current_health = math.max(0, (unit.current_health or 0) - damage)
                local hazard_feedback_event_type = nil
                if has_fire and not has_hazmat then
                    hazard_feedback_event_type = "WARNING_HAZARD_FIRE_HP"
                elseif has_gas and not has_hazmat then
                    hazard_feedback_event_type = "WARNING_HAZARD_GAS_HP"
                elseif has_outside and not has_oxygen_mask then
                    hazard_feedback_event_type = "WARNING_HAZARD_O2_HP"
                end
                if hazard_feedback_event_type and LOOT_RUNTIME and LOOT_RUNTIME.emit_derple_feedback and unit.id then
                    LOOT_RUNTIME.emit_derple_feedback(self, unit.id, hazard_feedback_event_type)
                end
                local hazard_flash_tint = vmath.vector4(1.0, 0.78, 0.25, 1)
                if has_gas and (not has_hazmat) and not (has_fire and (not has_hazmat)) then
                    hazard_flash_tint = vmath.vector4(0.58, 1.0, 0.66, 1)
                elseif has_outside and not has_oxygen_mask and not has_fire and not has_gas then
                    hazard_flash_tint = vmath.vector4(0.62, 0.82, 1.0, 1)
                end
                unit.hazard_flash_tint = hazard_flash_tint
                unit.hazard_flash_active = true
                unit.hazard_flash_token = (unit.hazard_flash_token or 0) + 1
                local flash_token = unit.hazard_flash_token
                multiplayer_emit_combat_fx_event(self, {
                    fx_type = "hazard_flash",
                    target_kind = "human",
                    target_id = unit.id,
                    tint_r = hazard_flash_tint.x,
                    tint_g = hazard_flash_tint.y,
                    tint_b = hazard_flash_tint.z,
                    duration_s = 0.75
                })
                timer.delay(0.75, false, function()
                    if unit and unit.hazard_flash_token == flash_token then
                        unit.hazard_flash_active = false
                    end
                end)
                print(string.format(
                    "TURN HAZARD | %s took %d damage (HP=%d) [outside=%s fire=%s gas=%s mask=%s hazmat=%s]",
                    unit.display_name or tostring(unit.id),
                    damage,
                    unit.current_health or 0,
                    has_outside and "y" or "n",
                    has_fire and "y" or "n",
                    has_gas and "y" or "n",
                    has_oxygen_mask and "y" or "n",
                    has_hazmat and "y" or "n"
                ))
                if unit.current_health <= 0 then
                    handle_human_death_loot_drop(self, unit, "environment_hazard")
                end
            end
        end
    end
    for _, civilian in ipairs(self.civilians or {}) do
        if civilian and civilian.is_dead ~= true and (civilian.current_health or 0) > 0 and civilian.cell_id then
            local cell = self.world_grid[civilian.cell_id]
            local damage = 0
            local has_fire, has_gas, has_outside = get_cell_hazard_flags(cell)
            if has_outside then
                damage = damage + outside_damage
            end
            if has_fire then
                damage = damage + fire_damage
            end
            if has_gas then
                damage = damage + gas_damage
            end
            if damage > 0 then
                civilian.current_health = math.max(0, (civilian.current_health or 0) - damage)
                civilian.hazard_flash_tint = has_fire and vmath.vector4(1.0, 0.78, 0.25, 1)
                    or (has_gas and vmath.vector4(0.58, 1.0, 0.66, 1) or vmath.vector4(0.62, 0.82, 1.0, 1))
                civilian.hazard_flash_active = true
                civilian.hazard_flash_token = (civilian.hazard_flash_token or 0) + 1
                local civilian_flash_token = civilian.hazard_flash_token
                multiplayer_emit_combat_fx_event(self, {
                    fx_type = "hazard_flash",
                    target_kind = "civilian",
                    target_id = civilian.id,
                    tint_r = civilian.hazard_flash_tint.x,
                    tint_g = civilian.hazard_flash_tint.y,
                    tint_b = civilian.hazard_flash_tint.z,
                    duration_s = 0.75
                })
                timer.delay(0.75, false, function()
                    if civilian and civilian.hazard_flash_token == civilian_flash_token then
                        civilian.hazard_flash_active = false
                    end
                end)
                print(string.format(
                    "TURN HAZARD | %s took %d damage (HP=%d) [outside=%s fire=%s gas=%s]",
                    civilian.display_name or ("Civilian #" .. tostring(civilian.id or 0)),
                    damage,
                    civilian.current_health or 0,
                    has_outside and "y" or "n",
                    has_fire and "y" or "n",
                    has_gas and "y" or "n"
                ))
                if civilian.current_health <= 0 then
                    civilian.is_dead = true
                    civilian.is_awake = false
                    print(string.format("%s died from environment hazard", civilian.display_name or ("Civilian #" .. tostring(civilian.id or 0))))
                end
            end
        end
    end
end


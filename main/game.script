    local unit_id = payload.unit_id
    local cell_id = tonumber(payload.cell_id)
    local world_x = tonumber(payload.world_x)
    local world_y = tonumber(payload.world_y)
    if not (unit_id and cell_id) then
        return false
    end
    self.mp_state.applying_remote_event = true
    local ok = LOOT_RUNTIME.try_pickup_obstacle_by_ids(self, unit_id, cell_id, world_x, world_y) == true
    self.mp_state.applying_remote_event = false
    return ok
end


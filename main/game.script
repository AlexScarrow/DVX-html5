local function try_manual_human_shot(self, unit, clicked_cell_id, world_x, world_y)
    if not unit or not unit.is_selected then
        return false
    end
    if not (unit and (unit.current_health or 0) > 0) then
        print("Unable to fire: selected unit is dead.")
        return true
    end

    local alien = get_clicked_alien_in_cell(self, clicked_cell_id, world_x, world_y)
    if not alien then
        return false
    end
    if self.realtime_rules_enabled == true or unit.cell_id == alien.cell_id then
        clear_ranged_hit_preview(self)
        if self.mp_state and self.mp_state.enabled then
            multiplayer_transport_send_command(self, "manual_shot", {
                turn_id = self.mp_state.turn_id or 1,
                unit_id = unit.id,
                alien_id = alien.id
            }, multiplayer_get_active_player_id_for_commands(self))
            return true
        end
        return multiplayer_attempt_manual_shot_on_target(self, unit, alien)
    end
    local same_pending_target = (self.pending_manual_shot_alien_id == alien.id)
        and (self.pending_manual_shot_unit_id == unit.id)
        and (self.ranged_hit_preview_fading_out ~= true)
        and ((self.ranged_hit_preview_fade_alpha or 0) > 0)
    if same_pending_target then
        clear_ranged_hit_preview(self)
        if self.mp_state and self.mp_state.enabled then
            multiplayer_transport_send_command(self, "manual_shot", {
                turn_id = self.mp_state.turn_id or 1,
                unit_id = unit.id,
                alien_id = alien.id
            }, multiplayer_get_active_player_id_for_commands(self))
            return true
        end
        return multiplayer_attempt_manual_shot_on_target(self, unit, alien)
    end
    local alien_cell = self.world_grid and self.world_grid[alien.cell_id] or nil
    if not alien_cell or alien_cell.tileID == hash("empty") then
        print("Unable to fire: target is in VOID.")
        dismiss_ranged_hit_preview(self)
        return true
    end
    if not has_unobstructed_human_ranged_los(self.world_grid, unit.cell_id, alien.cell_id) then
        print("Unable to fire: no line of sight.")
        dismiss_ranged_hit_preview(self)
        return true
    end
    local shooter_cell = self.world_grid and self.world_grid[unit.cell_id] or nil
    local target_cell = self.world_grid and self.world_grid[alien.cell_id] or nil
    if shooter_cell and target_cell then
        local is_vertical_lane = (shooter_cell.xCell == target_cell.xCell) and (shooter_cell.yCell ~= target_cell.yCell)
        if is_vertical_lane then
            local shooter_center_x = coords_to_world_pos(shooter_cell.xCell, shooter_cell.yCell)
            local target_center_x = coords_to_world_pos(target_cell.xCell, target_cell.yCell)
            local shooter_pos = unit.go_path and go.get_position(unit.go_path) or nil
            local target_pos = alien.go_id and go.get_position(alien.go_id) or nil
            local shooter_x = shooter_pos and shooter_pos.x or shooter_center_x
            local target_x = target_pos and target_pos.x or target_center_x
            local right_threshold = CELL_WIDTH * 0.15
            local shooter_in_right_lane = shooter_x >= (shooter_center_x + right_threshold)
            local target_in_right_lane = target_x >= (target_center_x + right_threshold)
            if (not shooter_in_right_lane) or (not target_in_right_lane) then
                print("Unable to fire: vertical shot requires both shooter and target in right lane.")
                dismiss_ranged_hit_preview(self)
                return true
            end
        end
    end
    local shot_ap_cost = get_ap_cost_value("manual_ranged_shot", 1)
    if unit.current_ap < shot_ap_cost or unit.current_ammo <= 0 then
        print("unable to fire no ammo/ap")
        dismiss_ranged_hit_preview(self)
        return true
    end
    local hit_chance = compute_manual_ranged_hit_chance(self, unit, alien)
    if not hit_chance then
        dismiss_ranged_hit_preview(self)
        return true
    end
    show_ranged_hit_preview(self, unit, alien, hit_chance)
    return true
end

local function handle_human_click_flow(self, clicked_cell_id, world_x, world_y)
    local unit = get_controlled_unit(self)
    if not unit or not unit.cell_id then
        return false
    end

    local clicked_unit = get_clicked_unit_in_cell(self, clicked_cell_id, world_x, world_y)
    if clicked_unit then
        clear_ranged_hit_preview(self)
        if not multiplayer_can_control_unit(self, clicked_unit.id) then
            print(string.format(
                "MP CONTROL | blocked | acting_as=%s unit=%s",
                tostring(multiplayer_get_active_player_id_for_commands(self)),
                tostring(clicked_unit.id)
            ))
            return true
        end
        if not (clicked_unit and (clicked_unit.current_health or 0) > 0) then
            print(clicked_unit.display_name .. " is dead.")
            return true
        end
        if clicked_unit.is_moving then
            print(clicked_unit.display_name .. " is already moving.")
            return true
        end
        if self.controlled_unit_id == clicked_unit.id and clicked_unit.is_selected then
            if self.cell_slot_assignments and self.cell_slot_assignments[clicked_cell_id] then
                local assignment = self.cell_slot_assignments[clicked_cell_id]
                local current_slot = assignment[clicked_unit.id] or 1
                local used = {}
                for unit_id, slot_index in pairs(assignment) do
                    if unit_id ~= clicked_unit.id then
                        used[slot_index] = true
                    end
                end
                local next_slot = current_slot
                for step = 1, #CELL_SLOT_OFFSETS_X do
                    local candidate = ((current_slot + step - 1) % #CELL_SLOT_OFFSETS_X) + 1
                    if not used[candidate] then
                        next_slot = candidate
                        break
                    end
                end
                assignment[clicked_unit.id] = next_slot
                local target_x, target_y = get_unit_world_pos_in_cell(self, clicked_unit, clicked_cell_id)
                local current_pos = go.get_position(clicked_unit.go_path)
                local dx = target_x - current_pos.x
                local dy = target_y - current_pos.y
                local distance = math.sqrt(dx * dx + dy * dy)
                local move_duration = math.max(0.06, distance / HUMAN_MOVE_SPEED)
                go.cancel_animations(clicked_unit.go_path, "position")
                go.animate(
                    clicked_unit.go_path,
                    "position",
                    go.PLAYBACK_ONCE_FORWARD,
                    vmath.vector3(target_x, target_y, 0.5),
                    go.EASING_INOUTSINE,
                    move_duration
                )
                print(clicked_unit.display_name .. " shifted position within cell.")
            end
        else
            self.controlled_unit_id = clicked_unit.id
            deselect_all_units(self)
            clicked_unit.is_selected = true
            play_human_confirm_select_sfx(self, clicked_unit)
            print(clicked_unit.display_name .. " selected. Click destination cell.")
        end
        self.ui_close_on_next_non_unit_click = false
        self.awaiting_slot_shuffle_click = false
        update_human_visual_state(self)
        self.selected_start_cell = nil
        update_human_ap_debug_label(self)
        return true
    end

    unit = get_controlled_unit(self)
    if unit and not multiplayer_can_control_unit(self, unit.id) then
        multiplayer_enforce_controlled_unit(self, true)
        unit = get_controlled_unit(self)
    end
    if not (unit and (unit.current_health or 0) > 0) then
        clear_ranged_hit_preview(self)
        if unit.is_selected then
            unit.is_selected = false
            update_human_visual_state(self)
        end
        print(unit.display_name .. " is dead and cannot act.")
        return true
    end

    if unit.is_selected then
        if try_toggle_door_with_selected_human(self, unit, world_x, world_y) then
            self.ui_close_on_next_non_unit_click = false
            update_human_visual_state(self)
            update_human_ap_debug_label(self)
            return true
        end
        if try_manual_human_shot(self, unit, clicked_cell_id, world_x, world_y) then
            self.ui_close_on_next_non_unit_click = false
            return true
        end
        if self.pending_manual_shot_alien_id and (self.ranged_hit_preview_fade_alpha or 0) > 0 then
            dismiss_ranged_hit_preview(self)
            self.ui_close_on_next_non_unit_click = false
            return true
        end
        if self.alien_turn_active and self.realtime_rules_enabled ~= true then
            print("Alien turn paused: select humans and fire, or press advance.")
            return true
        end

        if clicked_cell_id == unit.cell_id then
            if self.cell_slot_assignments and self.cell_slot_assignments[clicked_cell_id] then
                local assignment = self.cell_slot_assignments[clicked_cell_id]
                local current_slot = assignment[unit.id] or 1
                local used = {}
                for unit_id, slot_index in pairs(assignment) do
                    if unit_id ~= unit.id then
                        used[slot_index] = true
                    end
                end
                local base_x, _ = get_human_world_pos_for_cell(self.world_grid[clicked_cell_id])
                local best_slot = current_slot
                local best_dist = math.huge
                for i = 1, #CELL_SLOT_OFFSETS_X do
                    if i == current_slot or not used[i] then
                        local slot_x = base_x + ((CELL_SLOT_OFFSETS_X[i] or 0) * HUMAN_STACK_SPACING_X)
                        local dist = math.abs(world_x - slot_x)
                        if dist < best_dist then
                            best_dist = dist
                            best_slot = i
                        end
                    end
                end
                assignment[unit.id] = best_slot
                local target_x, target_y = get_unit_world_pos_in_cell(self, unit, clicked_cell_id)
                local current_pos = go.get_position(unit.go_path)
                local dx = target_x - current_pos.x
                local dy = target_y - current_pos.y
                local distance = math.sqrt(dx * dx + dy * dy)
                local move_duration = math.max(0.06, distance / HUMAN_MOVE_SPEED)
                go.cancel_animations(unit.go_path, "position")
                go.animate(
                    unit.go_path,
                    "position",
                    go.PLAYBACK_ONCE_FORWARD,
                    vmath.vector3(target_x, target_y, 0.5),
                    go.EASING_INOUTSINE,
                    move_duration
                )
                print(unit.display_name .. " repositioned within cell (0 AP).")
            end
            self.ui_close_on_next_non_unit_click = false
            update_human_visual_state(self)
            update_human_ap_debug_label(self)
            return true
        end

        if unit.is_moving then
            print(unit.display_name .. " is already moving.")
            return true
        end
        if unit.current_ap <= 0 then
            print(unit.display_name .. " has no AP. Click next turn to refresh.")
            update_human_visual_state(self)
            return true
        end

        if not is_walkable_cell(self.world_grid, clicked_cell_id) then
            print("Destination is VOID. Choose a valid destination.")
            update_human_visual_state(self)
            return true
        end

        local path, total_cost = find_path(self.world_grid, unit.cell_id, clicked_cell_id, nil, MOVEMENT_PROFILE_HUMAN, nil)
        if path then
            local destination_slot_index = nil
            local destination_slot_requested = nil
            local destination_cell = self.world_grid and self.world_grid[clicked_cell_id] or nil
            if destination_cell then
                local base_x, _ = get_human_world_pos_for_cell(destination_cell)
                local assignment = self.cell_slot_assignments and self.cell_slot_assignments[clicked_cell_id] or nil
                local used = {}
                if assignment then
                    for unit_id, slot_index in pairs(assignment) do
                        if unit_id ~= unit.id then
                            used[slot_index] = true
                        end
                    end
                end
                local best_slot = 1
                local best_dist = math.huge
                for i = 1, #CELL_SLOT_OFFSETS_X do
                    local slot_x = base_x + ((CELL_SLOT_OFFSETS_X[i] or 0) * HUMAN_STACK_SPACING_X)
                    local dist = math.abs(world_x - slot_x)
                    if dist < best_dist then
                        best_dist = dist
                        best_slot = i
                    end
                end
                destination_slot_requested = best_slot
                if not used[best_slot] then
                    destination_slot_index = best_slot
                else
                    local desired_offset = CELL_SLOT_OFFSETS_X[best_slot] or 0
                    for i = 1, #CELL_SLOT_OFFSETS_X do
                        if not used[i] then
                            local dist = math.abs((CELL_SLOT_OFFSETS_X[i] or 0) - desired_offset)
                            if destination_slot_index == nil
                                or dist < math.abs((CELL_SLOT_OFFSETS_X[destination_slot_index] or 0) - desired_offset)
                            then
                                destination_slot_index = i
                            end
                        end
                    end
                end
            end
            print(unit.display_name .. " route selected:")
            if destination_slot_requested then
                print(string.format(
                    "%s destination slot click on cell %d -> requested slot %d, resolved slot %d",
                    unit.display_name,
                    clicked_cell_id,
                    destination_slot_requested,
                    destination_slot_index or destination_slot_requested
                ))
            end
            print_path_debug(path, total_cost)
            highlight_path(self, path)
            if self.mp_state and self.mp_state.enabled then
                local active_player_id = multiplayer_get_active_player_id_for_commands(self)
                local is_non_host_client = (self.mp_state.local_player_id ~= self.mp_state.host_player_id)
                if is_non_host_client then
                    -- Responsiveness improvement: apply local prediction immediately for client-owned moves.
                    -- Host remains authoritative and turn_state snapshots will reconcile any mismatch.
                    begin_human_path_move(self, path, clicked_cell_id, destination_slot_index or destination_slot_requested)
                    print(string.format("MP PREDICT | move_unit local_apply | unit=%s", tostring(unit.id)))
                end
                multiplayer_transport_send_command(self, "move_unit", {
                    turn_id = self.mp_state.turn_id or 1,
                    unit_id = unit.id,
                    destination_cell_id = clicked_cell_id,
                    destination_slot_index = destination_slot_index or destination_slot_requested
                }, active_player_id)
            else
                begin_human_path_move(self, path, clicked_cell_id, destination_slot_index or destination_slot_requested)
            end
        else
            print("No path found for " .. unit.display_name .. " to cell: " .. clicked_cell_id)
        end

        self.ui_close_on_next_non_unit_click = false
        update_human_visual_state(self)
        return true
    end

    return false
end

function process_cell_selection(self, clicked_cell_id)
    local cell = self.world_grid[clicked_cell_id]
    if cell.tileID == hash("empty") then
        print("Clicked VOID cell. Select a valid cell.")
        return
    end

    if not self.selected_start_cell then
        clear_path_visuals(self)
        self.selected_start_cell = clicked_cell_id
        apply_cell_tint(clicked_cell_id, COLOR_START)
        table.insert(self.path_highlight_cells, clicked_cell_id)
        print("Start cell selected: " .. clicked_cell_id .. ". Click destination cell.")
    else
        local start_id = self.selected_start_cell
        local end_id = clicked_cell_id

        if start_id == end_id then
            clear_path_visuals(self)
            self.selected_start_cell = nil
            print("Selection canceled (same start/destination cell).")
            return
        end

        local path, total_cost = find_path(self.world_grid, start_id, end_id, nil)
        if path then
            print_path_debug(path, total_cost)
            highlight_path(self, path)
        else
            clear_path_visuals(self)
            apply_cell_tint(start_id, COLOR_START)
            table.insert(self.path_highlight_cells, start_id)
            apply_cell_tint(end_id, COLOR_END)
            table.insert(self.path_highlight_cells, end_id)
            print("No valid path from " .. start_id .. " to " .. end_id)
        end

        self.selected_start_cell = nil
    end
end


    -- =============================================================================
    -- VISUAL RENDERING
    -- =============================================================================

    function spawn_visuals(self)
        print("Creating visual representation...")
        local spawned_count = 0
        if self.ladder_markers then
            for key, ladder_id in pairs(self.ladder_markers) do
                if ladder_id then
                    pcall(go.delete, ladder_id)
                end
                self.ladder_markers[key] = nil
            end
        end
        cell_objects = {}
        tile_objects = {}
        self.tile_light_layers = {}
        self.tile_light_power_state = {}
        self.tile_light_flicker_state = {}
        self.tile_light_anim_ids = {}
        self.tile_light_is_workshop = {}
        self.tile_light_is_lab = {}
        self.tile_alpha_layers = {}
        self.tile_room_shadows = {}
        self.exterior_detail_objects = {}
        self.entry_fire_fx_objects = {}
        self.exit_green_smoke_fx_objects = {}
        self.exit_green_smoke_fx_power_state = {}
        self.ladder_markers = {}
        self.tile_base_objects = {}
        self.tile_alpha_power_state = {}
        self.tile_off_proximity_mul_state = {}
        loot_objects = {}
        machine_objects = {}
        self.turret_tripod_objects = {}
        self.turret_gun_objects = {}
        self.power_node_objects = {}
        self.vent_objects = {}
        self.light_value_objects = {}

        -- Spawn tile sprites slightly above cell debug layer (50% opacity).
        local selected_level = self.level_library[self.current_level_index or 1]
        for placement_index, placement in ipairs(selected_level) do
            local center_x, center_y = coords_to_world_pos(placement.x, placement.y)
            local pos = vmath.vector3(center_x, center_y, 0.02)

            local tile_def = self.tile_library and self.tile_library[placement.tile] or nil
            local visual_tile_name = (tile_def and tile_def.visualTile) or placement.tile
            if tile_def then
                if self.aesthetic_mode == AESTHETIC_MODE_BOARDGAME and tile_def.visualTileBoardgame then
                    visual_tile_name = tile_def.visualTileBoardgame
                elseif self.aesthetic_mode == AESTHETIC_MODE_COMPUTER and tile_def.visualTileComputer then
                    visual_tile_name = tile_def.visualTileComputer
                end
            end
            local id = factory.create("/tile_factory#tile_factory", pos, nil, {}, vmath.vector3(visual_scale, visual_scale, 1))
            if id then
                local anim = "tile_" .. visual_tile_name
                msg.post(msg.url(nil, id, "sprite"), "play_animation", { id = hash(anim) })
                go.set(msg.url(nil, id, "sprite"), "tint", vmath.vector4(1, 1, 1, TILE_OPACITY))
                table.insert(tile_objects, id)
                self.tile_base_objects[placement_index] = id
            else
                print("Tile factory create failed for: " .. placement.tile)
            end

            local tile_shadow_id = factory.create(
                "/shadow_box_factory#shadow_box_factory",
                vmath.vector3(center_x + 12, center_y - 12, 0.005),
                nil,
                {},
                vmath.vector3(1, 1, 1)
            )
            if tile_shadow_id then
                go.set(msg.url(nil, tile_shadow_id, "sprite"), "tint", vmath.vector4(0, 0, 0, 0))
                self.tile_room_shadows[placement_index] = tile_shadow_id
            end

            if placement.tile == "entry" then
                local fire_cell_id = coords_to_id(placement.x, placement.y - 1)
                if fire_cell_id and self.world_grid and self.world_grid[fire_cell_id] and self.world_grid[fire_cell_id].tileID ~= hash("empty") then
                    local fire_x, fire_y = coords_to_world_pos(placement.x, placement.y - 1)
                    local fire_fx_id = factory.create(
                        "/crash_spaceship_fire_fx_factory#crash_spaceship_fire_fx_factory",
                        vmath.vector3(fire_x + ENTRY_FIRE_OFFSET_X, fire_y + ENTRY_FIRE_OFFSET_Y, ENTRY_FIRE_Z)
                    )
                    if fire_fx_id then
                        self.entry_fire_fx_objects[placement_index] = fire_fx_id
                        go.set_rotation(vmath.quat_rotation_z(math.rad(ENTRY_FIRE_ROTATION_DEG)), fire_fx_id)
                        pcall(particlefx.play, msg.url(nil, fire_fx_id, "particlefx"))
                    end
                end
            end
            if placement.tile == "exit" then
                local smoke_cell_id = coords_to_id(placement.x + 1, placement.y - 1) -- exit tile cell 3
                if smoke_cell_id and self.world_grid and self.world_grid[smoke_cell_id] and self.world_grid[smoke_cell_id].tileID ~= hash("empty") then
                    local smoke_x, smoke_y = coords_to_world_pos(placement.x + 1, placement.y - 1)
                    local smoke_fx_id = factory.create(
                        "/escape_pod_green_smoke_fx_factory#escape_pod_green_smoke_fx_factory",
                        vmath.vector3(
                            smoke_x + EXIT_GREEN_SMOKE_CELL3_BOTTOM_OFFSET_X,
                            smoke_y + EXIT_GREEN_SMOKE_CELL3_BOTTOM_OFFSET_Y,
                            EXIT_GREEN_SMOKE_Z
                        )
                    )
                    if smoke_fx_id then
                        self.exit_green_smoke_fx_objects[placement_index] = smoke_fx_id
                        self.exit_green_smoke_fx_power_state[placement_index] = false
                        pcall(particlefx.stop, msg.url(nil, smoke_fx_id, "particlefx"), { clear = true })
                    end
                end
            end

            if placement.tile ~= "entry" and (not is_rescue_entry_tile_name(placement.tile)) then
                -- Exterior details are only for truly exposed silhouettes:
                -- roof: no overlapping tile anywhere above; left wall: no overlapping tile anywhere to the left.
                local has_tile_above = false
                local has_tile_left = false
                local p_left = placement.x - 1
                local p_right = placement.x + 1
                local p_bottom = placement.y - 1
                local p_top = placement.y + 1
                for _, scan in ipairs(selected_level) do
                    if scan ~= placement then
                        local s_left = scan.x - 1
                        local s_right = scan.x + 1
                        local s_bottom = scan.y - 1
                        local s_top = scan.y + 1
                        local overlaps_x = not (s_right < p_left or s_left > p_right)
                        local overlaps_y = not (s_top < p_bottom or s_bottom > p_top)
                        if (not has_tile_above) and overlaps_x and scan.y > placement.y then
                            has_tile_above = true
                        end
                        if (not has_tile_left) and overlaps_y and scan.x < placement.x then
                            has_tile_left = true
                        end
                        if has_tile_above and has_tile_left then
                            break
                        end
                    end
                end
                if not has_tile_above then
                    local roof_id = factory.create(
                        "/tile_factory#tile_factory",
                        vmath.vector3(center_x, center_y + (CELL_HEIGHT * 3), 0.02),
                        nil,
                        {},
                        vmath.vector3(visual_scale, visual_scale, 1)
                    )
                    if roof_id then
                        msg.post(msg.url(nil, roof_id, "sprite"), "play_animation", { id = hash("exterior_roof1") })
                        go.set(msg.url(nil, roof_id, "sprite"), "tint", vmath.vector4(1, 1, 1, 1))
                        table.insert(tile_objects, roof_id)
                        table.insert(self.exterior_detail_objects, roof_id)
                    end
                end
                if not has_tile_left then
                    local left_wall_id = factory.create(
                        "/tile_factory#tile_factory",
                        vmath.vector3(center_x - (CELL_WIDTH * 3), center_y, 0.02),
                        nil,
                        {},
                        vmath.vector3(visual_scale, visual_scale, 1)
                    )
                    if left_wall_id then
                        msg.post(msg.url(nil, left_wall_id, "sprite"), "play_animation", { id = hash("exterior_leftWall1") })
                        go.set(msg.url(nil, left_wall_id, "sprite"), "tint", vmath.vector4(1, 1, 1, 1))
                        table.insert(tile_objects, left_wall_id)
                        table.insert(self.exterior_detail_objects, left_wall_id)
                    end
                end
            end

            local power_light_off_anim = tile_def and tile_def.powerLightOffAnim or nil
            local power_light_on_anim = tile_def and tile_def.powerLightOnAnim or nil
            if power_light_off_anim and power_light_on_anim then
                local light_id = factory.create("/tile_factory#tile_factory", vmath.vector3(center_x, center_y, 0.3), nil, {}, vmath.vector3(visual_scale, visual_scale, 1))
                if light_id then
                    msg.post(msg.url(nil, light_id, "sprite"), "play_animation", { id = hash(power_light_off_anim) })
                    self.tile_light_layers[placement_index] = light_id
                    self.tile_light_power_state[placement_index] = false
                    self.tile_light_flicker_state[placement_index] = nil
                    self.tile_light_is_workshop[placement_index] = (placement.tile == "workshop")
                    self.tile_light_is_lab[placement_index] = (placement.tile == "lab")
                    self.tile_light_anim_ids[placement_index] = {
                        on = hash(power_light_on_anim),
                        off = hash(power_light_off_anim)
                    }
                end
            end

            -- Shared foreground alpha layer for depth, rendered above units/objects.
            local alpha_id = factory.create("/tile_factory#tile_factory", vmath.vector3(center_x, center_y, 0.7), nil, {}, vmath.vector3(visual_scale, visual_scale, 1))
            if alpha_id then
                msg.post(
                    msg.url(nil, alpha_id, "sprite"),
                    "play_animation",
                    { id = get_tile_alpha_overlay_anim_id(tile_def, self.aesthetic_mode) }
                )
                local always_visible = tile_def and tile_def.alphaOverlayAlwaysVisible == true
                go.set(msg.url(nil, alpha_id, "sprite"), "tint", vmath.vector4(1, 1, 1, always_visible and 1 or 0))
                self.tile_alpha_layers[placement_index] = alpha_id
                self.tile_alpha_power_state[placement_index] = always_visible and true or false
            end
        end
        for _, cell in ipairs(self.world_grid) do
            if is_valid_ladder_cell(cell) then
                local below_cell_id = get_adjacent_cell(cell.idNumber, "down")
                local below_cell = below_cell_id and self.world_grid and self.world_grid[below_cell_id] or nil
                if below_cell and can_spawn_ladder_between(self.world_grid, cell.idNumber, below_cell_id) then
                    local bx, by = coords_to_world_pos(below_cell.xCell, below_cell.yCell)
                    local ladder_id = factory.create("/loot_marker_factory#loot_marker_factory", vmath.vector3(bx + LADDER_OFFSET_X, by + LADDER_OFFSET_Y, LADDER_Z))
                    if ladder_id then
                        msg.post(msg.url(nil, ladder_id, "sprite"), "play_animation", { id = hash("ladder") })
                        local initial_tint = (cell.isPowered == true) and LADDER_TINT_ON or LADDER_TINT_OFF
                        go.set(msg.url(nil, ladder_id, "sprite"), "tint", initial_tint)
                        self.ladder_markers[cell.idNumber] = ladder_id
                    end
                end
            end
        end
        update_ladder_tints(self)
        print("Spawned " .. #tile_objects .. " tiles")

        -- Spawn cell sprites (debug grid under semi-transparent tiles)
        for _, cell in ipairs(self.world_grid) do
            print("making visual cell")
            if cell.tileID ~= hash("empty") then  -- Only spawn cells that are part of tiles
            --if true then  -- spawn ALL CELLS!
                local x, y = coords_to_world_pos(cell.xCell, cell.yCell)
                local pos = vmath.vector3(x, y, 0)

                -- Determine animation
                local animation = "cell_open"
                if not cell.accessRight and not cell.accessDown then
                    animation = "cell_right_down_wall"
                elseif not cell.accessRight then
                    animation = "cell_right_wall"
                elseif not cell.accessDown then
                    animation = "cell_down_wall"
                end
               
                local id = factory.create("/cell_factory#cell_factory", pos, nil, {}, vmath.vector3(visual_scale, visual_scale, 1))
                if id then
                    msg.post(msg.url(nil, id, "cell_sprite1"), "set_animation", {animation = hash(animation)})
                    msg.post(msg.url(nil, id, "cell_sprite1"), "set_tint", { tint = vmath.vector4(1, 1, 1, 0) })
                    cell_objects[cell.idNumber] = id
                    spawned_count = spawned_count + 1
                end

                
--                 local id = factory.create("/cell_factory#cell_factory", pos, nil, {}, vmath.vector3(visual_scale, visual_scale, 1))
--                 if id then
--                     print("alex",id)
--                     msg.post(msg.url(nil, id, "cell_sprite"), "set_animation", {animation = hash(animation)})
--                    
-- 
--                     cell_objects[cell.idNumber] = id
--                 end
            end
        end

        print("Spawned " .. spawned_count .. " cells")
        LOOT_RUNTIME.refresh_loot_markers(self)
        if LOOT_RUNTIME.refresh_hazard_fx then
            LOOT_RUNTIME.refresh_hazard_fx(self)
        end
        LOOT_RUNTIME.refresh_machine_markers(self)
        LOOT_RUNTIME.refresh_turret_markers(self)
        LOOT_RUNTIME.refresh_fix_markers(self)
        LOOT_RUNTIME.refresh_power_node_markers(self)
        LOOT_RUNTIME.refresh_door_markers(self)
        LOOT_RUNTIME.refresh_wiregap_markers(self)
        LOOT_RUNTIME.refresh_vent_markers(self)
        LOOT_RUNTIME.refresh_light_value_markers(self)
        if LOOT_RUNTIME.refresh_factory_underlay_visuals then
            LOOT_RUNTIME.refresh_factory_underlay_visuals(self)
        end
        if LOOT_RUNTIME.refresh_workshop_underlay_visuals then
            LOOT_RUNTIME.refresh_workshop_underlay_visuals(self)
        end
    end--of spawn visuals fn

local function update_exit_green_smoke_fx(self)
    if not (self.exit_green_smoke_fx_objects and self.world_grid) then
        return
    end
    self.exit_green_smoke_fx_power_state = self.exit_green_smoke_fx_power_state or {}
    for tile_instance_id, fx_id in pairs(self.exit_green_smoke_fx_objects) do
        if fx_id then
            local tile_powered = false
            for _, cell in ipairs(self.world_grid) do
                if cell.tileInstanceId == tile_instance_id and cell.isPowered == true then
                    tile_powered = true
                    break
                end
            end
            local was_powered = self.exit_green_smoke_fx_power_state[tile_instance_id]
            if was_powered == nil or was_powered ~= tile_powered then
                if tile_powered then
                    pcall(particlefx.play, msg.url(nil, fx_id, "particlefx"))
                else
                    pcall(particlefx.stop, msg.url(nil, fx_id, "particlefx"), { clear = true })
                end
                self.exit_green_smoke_fx_power_state[tile_instance_id] = tile_powered
            end
        end
    end
end






-- =============================================================================
-- INIT FUNCTION
-- =============================================================================

function init(self)
    print("=== DERPLES VS XENOS - Initializing ===")
    print("Chat GPT is here")

   

    -- Initialize edge lists for boundary checking
    initialize_edge_lists()

    -- Create the worldGrid (15x15 = 225 cells)
    self.world_grid = create_world_grid()
    print("WorldGrid created: " .. #self.world_grid .. " cells")

    -- Create tile library
    self.tile_library = require("main.tile_defs").create_tile_library(COMPONENT_UI)
    print("Tile library created")

    -- Create level designs
    self.level_library = require("main.level_defs").create_level_library()
    print("Level library created")

    -- Select a random level (for now, just use level 1)
    self.current_level_index = 1
    local selected_level = self.level_library[self.current_level_index]
    print("Selected level 1 for baking")

    -- Bake the level onto the worldGrid
    self.world_grid = bake_level_to_world_grid(self.world_grid, selected_level, self.tile_library)
    print("Level baked down to worldGrid")

    -- Camera setup
    self.camera_pos = vmath.vector3(CELL_WIDTH * GRID_COLS / 2, CELL_HEIGHT * GRID_ROWS / 2, 1000)
    self.camera_zoom = 1.0
    self.camera_min_zoom = 0.25--0.5
    self.camera_max_zoom = 1.5--1.0
    self.drag_threshold_px = 12
    self.is_panning = false
    self.did_drag = false
    self.drag_start_screen_x = 0
    self.drag_start_screen_y = 0
    self.drag_start_camera_pos = self.camera_pos
    self.last_pan_screen_x = 0
    self.last_pan_screen_y = 0
    self.pan_velocity_x = 0
    self.pan_velocity_y = 0
    self.pan_inertia_damping = 1--8
    self.pan_inertia_min_speed = 3

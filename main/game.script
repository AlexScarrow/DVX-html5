    self.ui.flow_mp_back_button = create_ui_marker_sprite(hash("mp_btn_back"), MP_SETUP_UI_Z)
    self.ui.flow_mp_start_button = create_ui_marker_sprite(hash("mp_btn_start"), MP_SETUP_UI_Z)
    self.ui.flow_mp_start_disabled_overlay = create_ui_marker_sprite(hash("mp_btn_start_disabled_overlay"), MP_SETUP_UI_Z + 0.001)
    self.ui.flow_mp_start_enabled_glow = create_ui_marker_sprite(hash("mp_btn_start_enabled_glow"), MP_SETUP_UI_Z - 0.001)
    for i, unit_id in ipairs(MP_SETUP_UNIT_IDS) do
        self.ui.flow_mp_unit_buttons[i] = create_ui_marker_sprite(multiplayer_get_unit_anim_id(unit_id), MP_SETUP_UI_Z)
    end
    for _, player_id in ipairs(MP_SETUP_PLAYER_IDS) do
        self.ui.flow_mp_slot_icons[player_id] = {}
        for slot_index = 1, 2 do
            self.ui.flow_mp_slot_icons[player_id][slot_index] = create_ui_marker_sprite(multiplayer_get_unit_anim_id("sarge"), MP_SETUP_UI_Z + 0.002)
        end
    end
    for i = 1, 4 do
        self.ui.flow_score_rows[i] = create_ui_square(0, 0, FLOW_UI_PANEL_Z, vmath.vector4(0, 0, 0, 0), 300, 28)
    end

    print(string.format(
        "UI panel pixels: panel=%dx%d, portrait=%dx%d, footer=%dx%d, pip=%dx%d (max %d), backpack slots=%d (%dx%d each, %dx%d grid)",
        UI_PANEL_W, UI_PANEL_H, UI_PORTRAIT_W, UI_PORTRAIT_H, UI_FOOTER_W, UI_FOOTER_H,
        UI_BAR_PIP_SIZE, UI_BAR_PIP_SIZE, UI_MAX_PIPS, UI_BACKPACK_COLS * UI_BACKPACK_ROWS,
        UI_BACKPACK_SLOT_SIZE, UI_BACKPACK_SLOT_SIZE, UI_BACKPACK_COLS, UI_BACKPACK_ROWS
    ))
end


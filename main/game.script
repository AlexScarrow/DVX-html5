local function get_controlled_unit(self)
    if not self.squad_units or not self.controlled_unit_id then
        return nil
    end
    return self.squad_units[self.controlled_unit_id]
end

local function get_unit_by_id(self, unit_id)
    if not self.squad_units or not unit_id then
        return nil
    end
    return self.squad_units[unit_id]
end

local function get_unit_on_cell(self, cell_id)
    if not self.squad_units then
        return nil
    end
    for _, unit in pairs(self.squad_units) do
        if unit.cell_id == cell_id then
            return unit
        end
    end
    return nil
end

local function get_units_on_cell(self, cell_id)
    local units = {}
    if not self.squad_units then
        return units
    end
    for _, unit in pairs(self.squad_units) do
        if unit.cell_id == cell_id then
            table.insert(units, unit)
        end
    end
    return units
end

local function get_spawn_order_unit_id_list()
    return { "sarge", "techie", "medic", "gunner" }
end

local function sort_units_by_spawn_order(units)
    local order = { sarge = 1, techie = 2, medic = 3, gunner = 4 }
    table.sort(units, function(a, b)
        return (order[a.id] or 99) < (order[b.id] or 99)
    end)
end

local function ensure_cell_slot_assignment(self, unit, cell_id)
    if not unit or not cell_id then
        return 1
    end

    self.cell_slot_assignments = self.cell_slot_assignments or {}
    self.cell_slot_assignments[cell_id] = self.cell_slot_assignments[cell_id] or {}
    local assignment = self.cell_slot_assignments[cell_id]

    if assignment[unit.id] then
        return assignment[unit.id]
    end

    local used = {}
    for _, slot_index in pairs(assignment) do
        used[slot_index] = true
    end

    local selected_slot = 1
    for i = 1, #CELL_SLOT_OFFSETS_X do
        if not used[i] then
            selected_slot = i
            break
        end
    end

    assignment[unit.id] = selected_slot
    return selected_slot
end

local function clear_cell_slot_assignment(self, unit, cell_id)
    if not unit or not cell_id or not self.cell_slot_assignments then
        return
    end
    local assignment = self.cell_slot_assignments[cell_id]
    if assignment then
        assignment[unit.id] = nil
    end
end

local function cell_has_any_unit_except(self, cell_id, except_unit_id)
    if not self.squad_units then
        return false
    end
    for _, unit in pairs(self.squad_units) do
        if unit.id ~= except_unit_id and unit.cell_id == cell_id then
            return true
        end
    end
    return false
end

local function deselect_all_units(self)
    if not self.squad_units then
        return
    end
    for _, unit in pairs(self.squad_units) do
        unit.is_selected = false
    end
end

local function any_unit_is_moving(self)
    if not self.squad_units then
        return false
    end
    for _, unit in pairs(self.squad_units) do
        if unit.is_moving then
            return true
        end
    end
    return false
end

local function unit_has_role(unit, role_key)
    if not unit then
        return false
    end
    local role = CLASS_ROLE_HOOKS[unit.class_id]
    return role and role[role_key] == true
end

local function get_unit_base_tint(unit)
    if not unit then
        return vmath.vector4(1, 1, 1, 1)
    end
    if unit.class_id == UNIT_CLASS_SARGE then
        return HUMAN_TINT_SARGE
    elseif unit.class_id == UNIT_CLASS_TECHIE then
        return HUMAN_TINT_TECHIE
    elseif unit.class_id == UNIT_CLASS_MEDIC then
        return HUMAN_TINT_MEDIC
    elseif unit.class_id == UNIT_CLASS_GUNNER then
        return HUMAN_TINT_GUNNER
    end
    return vmath.vector4(1, 1, 1, 1)
end

local function get_selected_tint(base_tint)
    return vmath.vector4(
        math.min(base_tint.x + 0.2, 1),
        math.min(base_tint.y + 0.2, 1),
        math.min(base_tint.z + 0.2, 1),
        1
    )
end

-- FUTURE GAMEPLAY HOOKS (role-gated actions)
local function can_donate_ap(unit)
    return unit_has_role(unit, "can_donate_ap")
end

local function can_fix(unit)
    return unit_has_role(unit, "can_fix")
end

local function can_heal(unit)
    return unit_has_role(unit, "can_heal")
end

local function has_heavy_weapon(unit)
    return unit_has_role(unit, "heavy_weapon")
end

local function get_unit_ranged_hit_bonus(unit)
    if not unit then
        return 0
    end
    local role = CLASS_ROLE_HOOKS[unit.class_id]
    return (role and role.ranged_hit_bonus) or 0
end

local function print_squad_debug_overview(self)
    if not self.squad_units then
        return
    end

    print("=== SQUAD DEBUG (UI placeholder in console) ===")
    for _, unit in pairs(self.squad_units) do
        print(string.format(
            "  %s class=%s AP=%d/%d roles{donate=%s fix=%s heal=%s heavy=%s}",
            unit.display_name,
            unit.class_id,
            unit.current_ap,
            unit.max_ap,
            tostring(unit_has_role(unit, "can_donate_ap")),
            tostring(unit_has_role(unit, "can_fix")),
            tostring(unit_has_role(unit, "can_heal")),
            tostring(unit_has_role(unit, "heavy_weapon"))
        ))
    end
end

local function find_first_walkable_cell(world_grid)
    for cell_id, cell in ipairs(world_grid) do
        if cell.tileID ~= hash("empty") then
            return cell_id
        end
    end
    return nil
end

local function set_unit_scale(unit, scale_x, scale_y)
    if unit and unit.go_path then
        local ok = pcall(go.set_scale, vmath.vector3(scale_x, scale_y, 1), unit.go_path)
        if not ok then
            unit.go_path = nil
            unit.sprite_path = nil
        end
    end
end

local function set_unit_rotation_degrees(unit, degrees)
    if unit and unit.go_path then
        local ok = pcall(go.set_rotation, vmath.quat_rotation_z(math.rad(degrees or 0)), unit.go_path)
        if not ok then
            unit.go_path = nil
            unit.sprite_path = nil
        end
    end
end

set_civilian_scale = function(self, civilian, scale_x, scale_y)
    if not (self and civilian and civilian.id and self.civilian_visuals) then
        return
    end
    local go_id = self.civilian_visuals[civilian.id]
    if go_id then
        pcall(go.set_scale, vmath.vector3(scale_x, scale_y, 1), go_id)
    end
end

get_counter_shadow_offset = function(profile, move_arc)
    local base_x = (profile and profile.counter_shadow_base_offset_x) or 0
    local base_y = (profile and profile.counter_shadow_base_offset_y) or 0
    local extra_x = (profile and profile.counter_shadow_lift_extra_x) or 108
    local extra_y = (profile and profile.counter_shadow_lift_extra_y) or -104
    local arc = move_arc or 0
    return vmath.vector3(
        30 + base_x + (extra_x * arc),
        -30 + base_y + (extra_y * arc),
        -0.01
    )
end

get_counter_shadow_anim_for_alien = function(alien_type)
    if alien_type == ALIEN_TYPE_CANNON then
        return hash("alien_cannonFodder_shadow")
    elseif alien_type == ALIEN_TYPE_BRUTE then
        return hash("alien_brute_shadow")
    elseif alien_type == ALIEN_TYPE_SPITTER then
        return hash("alien_spitter_shadow")
    elseif alien_type == ALIEN_TYPE_SPEEDY then
        return hash("alien_speedy_shadow")
    end
    return nil
end

get_alien_anim_for_aesthetic = function(self, alien_type)
    if not self then
        return nil
    end
    if self.aesthetic_mode == AESTHETIC_MODE_BOARDGAME then
        if alien_type == ALIEN_TYPE_CANNON then
            return hash("alien_cannonFodder_boardgame")
        elseif alien_type == ALIEN_TYPE_BRUTE then
            return hash("alien_brute_boardgame")
        elseif alien_type == ALIEN_TYPE_SPITTER then
            return hash("alien_spitter_boardgame")
        elseif alien_type == ALIEN_TYPE_SPEEDY then
            return hash("alien_speedy_boardgame")
        end
    end
    if alien_type == ALIEN_TYPE_CANNON then
        return hash("alien_cannonFodder")
    elseif alien_type == ALIEN_TYPE_BRUTE then
        return hash("alien_brute")
    elseif alien_type == ALIEN_TYPE_SPITTER then
        return hash("alien_spitter")
    elseif alien_type == ALIEN_TYPE_SPEEDY then
        return hash("alien_speedy")
    end
    return nil
end

get_counter_shadow_anim_for_human = function(self, unit)
    if not unit then
        return hash("human_dropShadow"), vmath.vector4(1, 1, 1, 0.5)
    end
    if self and self.aesthetic_mode == AESTHETIC_MODE_BOARDGAME then
        return hash("human_proxyShadow_boardgame"), vmath.vector4(1, 1, 1, 0.5)
    end
    return hash("human_dropShadow"), vmath.vector4(1, 1, 1, 0.5)
end

ensure_counter_shadow_proxy = function(entity, anim_hash, tint, factory_path)
    if not anim_hash then
        return nil
    end
    if entity.shadow_proxy_id then
        return entity.shadow_proxy_id
    end
    local proxy_factory = factory_path or "/tile_factory#tile_factory"
    local proxy_id = factory.create(proxy_factory, vmath.vector3(0, 0, 0.49))
    if proxy_id then
        msg.post(msg.url(nil, proxy_id, "sprite"), "play_animation", { id = anim_hash })
        go.set_scale(vmath.vector3(0.75, 0.75, 1), proxy_id)
        go.set(msg.url(nil, proxy_id, "sprite"), "tint", tint or vmath.vector4(1, 1, 1, 0.5))
        entity.shadow_proxy_id = proxy_id
    end
    return proxy_id
end

clear_counter_shadow_proxy = function(entity)
    if entity and entity.shadow_proxy_id then
        go.delete(entity.shadow_proxy_id)
        entity.shadow_proxy_id = nil
    end
    if entity then
        entity.shadow_proxy_pending_clear = false
        entity.shadow_proxy_clear_token = nil
    end
end

schedule_counter_shadow_proxy_clear = function(entity, delay_s)
    if not entity or not entity.shadow_proxy_id then
        return
    end
    if entity.shadow_proxy_pending_clear then
        return
    end
    entity.shadow_proxy_pending_clear = true
    entity.shadow_proxy_clear_token = (entity.shadow_proxy_clear_token or 0) + 1
    local token = entity.shadow_proxy_clear_token
    timer.delay(delay_s or 0.08, false, function()
        if entity
            and entity.shadow_proxy_pending_clear
            and entity.shadow_proxy_id
            and entity.shadow_proxy_clear_token == token then
            clear_counter_shadow_proxy(entity)
        end
    end)
end

local function update_human_visual_state(self)
    if not self.squad_units then
        return
    end

    local shadow_alpha = get_world_shadow_alpha(self)
    local profile = get_aesthetic_profile(self)
    local counter_move_enabled = profile and profile.counter_token_move_enabled == true
    local shadow_origin = vmath.vector3(30, -30, -0.01)
    for _, unit in pairs(self.squad_units) do
        if unit.sprite_path then
            local function safe_set_tint(color)
                local ok = pcall(go.set, unit.sprite_path, "tint", color)
                if not ok then
                    unit.go_path = nil
                    unit.sprite_path = nil
                end
            end
            local flash_timer = unit.hit_flash_timer or 0
            if not (unit and (unit.current_health or 0) > 0) then
                local dead_anim = get_human_anim_for_aesthetic(self, unit)
                if dead_anim then
                    pcall(msg.post, unit.sprite_path, "play_animation", { id = dead_anim })
                end
                safe_set_tint(vmath.vector4(1, 1, 1, 1))
            elseif flash_timer > 0 then
                local flash_band = math.floor(flash_timer * 24) % 2
                if flash_band == 0 then
                    safe_set_tint(vmath.vector4(1, 0.15, 0.15, 1))
                else
                    safe_set_tint(vmath.vector4(0.65, 0.05, 0.05, 1))
                end
            elseif unit.hazard_flash_active == true then
                safe_set_tint(unit.hazard_flash_tint or vmath.vector4(1.0, 0.78, 0.25, 1))
            elseif unit.current_ap <= 0 then
                safe_set_tint(HUMAN_TINT_NO_AP)
            else
                local base_tint = get_unit_base_tint(unit)
                if unit.is_selected then
                    safe_set_tint(get_selected_tint(base_tint))
                else
                    safe_set_tint(base_tint)
                end
            end
        end
        if unit.shadow_path then
            local ok = pcall(go.set, unit.shadow_path, "tint", vmath.vector4(1, 1, 1, shadow_alpha))
            if not ok then
                unit.shadow_path = nil
            else
                local shadow_pos = shadow_origin
                if counter_move_enabled then
                    shadow_pos = unit.shadow_motion_offset or get_counter_shadow_offset(profile, 0)
                end
                local use_proxy_shadow = counter_move_enabled and (unit.is_moving or unit.shadow_proxy_pending_clear) and unit.go_path ~= nil
                if use_proxy_shadow then
                    local proxy_anim, proxy_tint = get_counter_shadow_anim_for_human(self, unit)
                    local proxy_id = ensure_counter_shadow_proxy(unit, proxy_anim, proxy_tint, "/human_shadow_proxy_factory#human_shadow_proxy_factory")
                    if proxy_id and unit.go_path then
                        local pos = go.get_position(unit.go_path)
                        go.set_position(vmath.vector3(pos.x + shadow_pos.x, pos.y + shadow_pos.y, pos.z - 0.01), proxy_id)
                    end
                    pcall(go.set, unit.shadow_path, "tint", vmath.vector4(1, 1, 1, 0))
                    if counter_move_enabled and (not unit.is_moving) and unit.shadow_proxy_id then
                        schedule_counter_shadow_proxy_clear(unit, 0.08)
                    end
                else
                    clear_counter_shadow_proxy(unit)
                    pcall(go.set, unit.shadow_path, "position", shadow_pos)
                end
            end
        end
    end
end

local function update_selected_unit_pulse(self, dt)
    if not self.squad_units then
        return
    end

    for _, unit in pairs(self.squad_units) do
        if unit.go_path and not unit.is_moving then
            local receive_timer = unit.receive_pulse_timer or 0
            if receive_timer > 0 then
                receive_timer = math.max(0, receive_timer - dt)
                unit.receive_pulse_timer = receive_timer
                local progress = 1 - (receive_timer / 0.24)
                local pulse = 1 + (0.26 * math.sin(progress * math.pi))
                set_unit_scale(unit, HUMAN_VISUAL_SCALE * pulse, HUMAN_VISUAL_SCALE * pulse)
            elseif unit.is_selected and unit.current_ap > 0 then
                unit.select_pulse_phase = (unit.select_pulse_phase or 0) + (dt * UNIT_SELECTED_PULSE_SPEED * math.pi * 2)
                local pulse = 1 + UNIT_SELECTED_PULSE_AMPLITUDE * math.sin(unit.select_pulse_phase)
                set_unit_scale(unit, HUMAN_VISUAL_SCALE * pulse, HUMAN_VISUAL_SCALE * pulse)
            else
                unit.select_pulse_phase = 0
                set_unit_scale(unit, HUMAN_VISUAL_SCALE, HUMAN_VISUAL_SCALE)
            end
        end
    end
end

